+void CbfProfileInputController::ExecuteEditAction(
+    TabId tab_id,
+    mojom::CbfEditAction action) {
+  ExecuteEditActionForWebContents(context_->tab_manager().GetWebContents(tab_id),
+                                  action);
+}
+
+void CbfProfileInputController::ExecuteEditActionForWebContents(
+    content::WebContents* web_contents,
+    mojom::CbfEditAction action) {
+  if (!web_contents) {
+    return;
+  }
+
+  switch (action) {
+    case mojom::CbfEditAction::kUndo:
+      web_contents->Undo();
+      return;
+    case mojom::CbfEditAction::kRedo:
+      web_contents->Redo();
+      return;
+    case mojom::CbfEditAction::kCut:
+      web_contents->Cut();
+      return;
+    case mojom::CbfEditAction::kCopy:
+      web_contents->Copy();
+      return;
+    case mojom::CbfEditAction::kPaste:
+      web_contents->Paste();
+      return;
+    case mojom::CbfEditAction::kSelectAll:
+      web_contents->SelectAll();
+      return;
+  }
+}
