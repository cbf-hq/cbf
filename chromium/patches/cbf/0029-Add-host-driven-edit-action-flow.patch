+bool CbfBridgeClient::ExecuteEditAction(uint64_t tab_id, uint8_t action) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  const auto mojom_action = ToMojomEditAction(action);
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id,
+             cbf::mojom::CbfEditAction action) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->ExecuteEditAction(tab_id, action);
+          },
+          impl, tab_id, mojom_action));
+  return true;
+}
+
+bool CbfBridgeClient::ExecuteExtensionPopupEditAction(uint64_t popup_id,
+                                                      uint8_t action) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  const auto mojom_action = ToMojomEditAction(action);
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t popup_id,
+             cbf::mojom::CbfEditAction action) {
+            auto it = impl->popup_profiles.find(popup_id);
+            if (it == impl->popup_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->ExecuteExtensionPopupEditAction(
+                popup_id, action);
+          },
+          impl, popup_id, mojom_action));
+  return true;
+}
