+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       BrowserServiceListsCanonicalProfilesWithDefaultFlag) {
+  CbfBrowserService browser_service{std::string()};
+
+  std::vector<mojom::CbfProfileInfoPtr> profiles;
+  base::RunLoop run_loop;
+  browser_service.GetProfiles(base::BindOnce(
+      [](std::vector<mojom::CbfProfileInfoPtr>* out_profiles,
+         base::RunLoop* run_loop,
+         std::vector<mojom::CbfProfileInfoPtr> in_profiles) {
+        *out_profiles = std::move(in_profiles);
+        run_loop->Quit();
+      },
+      &profiles, &run_loop));
+  run_loop.Run();
+
+  ASSERT_FALSE(profiles.empty());
+
+  size_t default_count = 0;
+  for (const auto& profile : profiles) {
+    ASSERT_TRUE(profile);
+    EXPECT_FALSE(profile->profile_id.empty());
+    if (profile->is_default) {
+      default_count++;
+      EXPECT_EQ(profile->profile_id, CanonicalProfileId());
+    }
+  }
+
+  EXPECT_EQ(default_count, 1u);
+}
