@@ -48,6 +48,14 @@ BASE_EXPORT void ClearAmIBundledCache();
 // Returns true if this process is marked as a "Background only process".
 BASE_EXPORT bool IsBackgroundOnlyProcess();
 
+// Returns true if `exec_path` points to a helper executable nested under a
+// framework bundle's `Helpers/*.app/Contents/MacOS/` directory.
+BASE_EXPORT bool IsHelperApplicationExecutablePath(const FilePath& exec_path);
+
+// Returns true if the current executable is running from a helper app nested
+// under a framework bundle's `Helpers` directory.
+BASE_EXPORT bool IsHelperApplication();
+
 // Returns the path to a resource within the framework bundle.
 BASE_EXPORT FilePath PathForFrameworkBundleResource(const char* resource_name);
 
diff --git a/base/apple/foundation_util.mm b/base/apple/foundation_util.mm
index 2c5fd953795d0..e00b749b5100d 100644
--- a/base/apple/foundation_util.mm
+++ b/base/apple/foundation_util.mm
@@ -23,6 +23,7 @@
 #include "base/no_destructor.h"
 #include "base/numerics/checked_math.h"
 #include "base/numerics/safe_conversions.h"
+#include "base/path_service.h"
 #include "base/strings/string_util.h"
 #include "base/strings/sys_string_conversions.h"
 #include "build/branding_buildflags.h"
@@ -105,6 +106,45 @@ bool IsBackgroundOnlyProcess() {
   }
 }
 
+bool IsHelperApplicationExecutablePath(const FilePath& exec_path) {
+#if BUILDFLAG(IS_IOS)
+  return false;
+#else
+  if (exec_path.empty()) {
+    return false;
+  }
+
+  const FilePath macos_dir = exec_path.DirName();
+  if (macos_dir.BaseName().value() != "MacOS") {
+    return false;
+  }
+
+  const FilePath contents_dir = macos_dir.DirName();
+  if (contents_dir.BaseName().value() != "Contents") {
+    return false;
+  }
+
+  const FilePath helper_app_dir = contents_dir.DirName();
+  if (helper_app_dir.Extension() != ".app") {
+    return false;
+  }
+
+  return helper_app_dir.DirName().BaseName().value() == "Helpers";
+#endif
+}
+
+bool IsHelperApplication() {
+#if BUILDFLAG(IS_IOS)
+  return false;
+#else
+  FilePath exec_path;
+  if (!PathService::Get(base::FILE_EXE, &exec_path)) {
+    return false;
+  }
+  return IsHelperApplicationExecutablePath(exec_path);
+#endif
+}
+
 FilePath PathForFrameworkBundleResource(const char* resource_name) {
   NSBundle* bundle = apple::FrameworkBundle();
   NSURL* resource_url = [bundle URLForResource:@(resource_name)
diff --git a/base/apple/foundation_util_unittest.mm b/base/apple/foundation_util_unittest.mm
index e6d641b05edab..acebf6ddf9e2d 100644
--- a/base/apple/foundation_util_unittest.mm
+++ b/base/apple/foundation_util_unittest.mm
@@ -22,6 +22,25 @@
 
 namespace base::apple {
 
+TEST(FoundationUtilTest, IsHelperApplicationExecutablePath) {
+  EXPECT_TRUE(IsHelperApplicationExecutablePath(FilePath(
+      "/tmp/Chromium.app/Contents/Frameworks/Chromium Framework.framework/"
+      "Versions/1.2.3.4/Helpers/Chromium Helper.app/Contents/MacOS/"
+      "Chromium Helper")));
+  EXPECT_TRUE(IsHelperApplicationExecutablePath(
+      FilePath("/tmp/Content Shell.app/Contents/Frameworks/"
+               "Content Shell Framework.framework/Versions/C/Helpers/"
+               "Content Shell Helper.app/Contents/MacOS/"
+               "Content Shell Helper")));
+
+  EXPECT_FALSE(IsHelperApplicationExecutablePath(
+      FilePath("/tmp/Chromium.app/Contents/MacOS/Chromium")));
+  EXPECT_FALSE(IsHelperApplicationExecutablePath(
+      FilePath("/tmp/Chromium.app/Contents/Frameworks/"
+               "Chromium Framework.framework/Versions/1.2.3.4/Chromium")));
+  EXPECT_FALSE(IsHelperApplicationExecutablePath(FilePath()));
+}
