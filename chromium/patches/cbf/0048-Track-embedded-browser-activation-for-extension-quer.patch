+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SetTabFocusTransfersActivationBetweenEmbeddedBrowsers) {
+  const TabId first_tab_id = CreatePage();
+  const TabId second_tab_id = CreatePage();
+  ASSERT_NE(first_tab_id, kInvalidTabId);
+  ASSERT_NE(second_tab_id, kInvalidTabId);
+
+  Browser* first_browser = GetHostBrowserForTab(first_tab_id);
+  Browser* second_browser = GetHostBrowserForTab(second_tab_id);
+  ASSERT_NE(first_browser, nullptr);
+  ASSERT_NE(second_browser, nullptr);
+  ASSERT_NE(first_browser->window(), nullptr);
+  ASSERT_NE(second_browser->window(), nullptr);
+
+  profile_service_->SetTabFocus(first_tab_id, true);
+  profile_service_->SetTabFocus(second_tab_id, true);
+
+  EXPECT_FALSE(first_browser->window()->IsActive());
+  EXPECT_FALSE(first_browser->IsActive());
+  EXPECT_TRUE(second_browser->window()->IsActive());
+  EXPECT_TRUE(second_browser->IsActive());
+  EXPECT_EQ(GetLastActiveBrowserWindowInterfaceWithAnyProfile(),
+            static_cast<BrowserWindowInterface*>(second_browser));
+}
