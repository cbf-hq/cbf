+    if (is_active_) {
+      return;
+    }
+
+    // Embedded CBF tabs do not own an OS browser window; activation is driven
+    // by host-app focus and mirrored into Chromium's browser activation state.
+    is_active_ = true;
+    if (browser_) {
+      browser_->DidBecomeActive();
+    }
