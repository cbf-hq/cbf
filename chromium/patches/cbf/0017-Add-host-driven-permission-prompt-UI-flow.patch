+void CbfBridgeClientImpl::Observer::OnPromptUiRequested(
+    uint64_t tab_id,
+    cbf::mojom::CbfPromptUiRequestPtr request) {
+  if (!request) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventPromptUiRequested;
+  event.profile_id = profile_id_;
+  event.tab_id = tab_id;
+  event.request_id = request->request_id;
+  event.prompt_ui_kind = static_cast<uint8_t>(request->kind);
+  event.prompt_ui_permission = static_cast<uint8_t>(request->permission);
+  event.prompt_ui_permission_key = request->permission_key;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
+void CbfBridgeClientImpl::Observer::OnPromptUiResolved(
+    uint64_t tab_id,
+    cbf::mojom::CbfPromptUiResolutionPtr resolution) {
+  if (!resolution) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventPromptUiResolved;
+  event.profile_id = profile_id_;
+  event.tab_id = tab_id;
+  event.request_id = resolution->request_id;
+  event.prompt_ui_kind = static_cast<uint8_t>(resolution->kind);
+  event.prompt_ui_permission = static_cast<uint8_t>(resolution->permission);
+  event.prompt_ui_result = static_cast<uint8_t>(resolution->result);
+  event.prompt_ui_permission_key = resolution->permission_key;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
