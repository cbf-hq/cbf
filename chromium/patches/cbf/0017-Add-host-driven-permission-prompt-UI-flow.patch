+void CbfProfileService::NotifyPromptUiRequested(
+    uint64_t tab_id,
+    uint64_t request_id,
+    mojom::CbfPromptUiKind kind,
+    mojom::CbfPromptUiPermissionType permission,
+    const std::string& permission_key) {
+  if (!observer_) {
+    return;
+  }
+  auto request = mojom::CbfPromptUiRequest::New();
+  request->request_id = request_id;
+  request->kind = kind;
+  request->permission = permission;
+  request->permission_key = permission_key;
+  observer_->OnPromptUiRequested(tab_id, std::move(request));
+}
+
+void CbfProfileService::NotifyPromptUiResolved(
+    uint64_t tab_id,
+    uint64_t request_id,
+    mojom::CbfPromptUiKind kind,
+    mojom::CbfPromptUiPermissionType permission,
+    const std::string& permission_key,
+    mojom::CbfPromptUiResolutionResult result) {
+  if (!observer_) {
+    return;
+  }
+  auto resolution = mojom::CbfPromptUiResolution::New();
+  resolution->request_id = request_id;
+  resolution->kind = kind;
+  resolution->permission = permission;
+  resolution->permission_key = permission_key;
+  resolution->result = result;
+  observer_->OnPromptUiResolved(tab_id, std::move(resolution));
+}
+
+void CbfProfileService::ResolvePendingPermissionPromptsForTab(
+    TabId tab_id,
+    mojom::CbfPromptUiResolutionResult result) {
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  for (auto it = pending_permission_prompts_.begin();
+       it != pending_permission_prompts_.end();) {
+    if (it->second.tab_id != tab_id) {
+      ++it;
+      continue;
+    }
+    const uint64_t request_id = it->first;
+    const mojom::CbfPromptUiPermissionType permission = it->second.permission;
+    const std::string permission_key = it->second.permission_key;
+    const auto delegate = it->second.delegate;
+    it = pending_permission_prompts_.erase(it);
+    if (delegate) {
+      PromptOptions prompt_options = std::monostate();
+      if (result == mojom::CbfPromptUiResolutionResult::kAllowed) {
+        delegate->Accept(prompt_options);
+      } else {
+        delegate->Deny(prompt_options);
+      }
+    }
+    NotifyPromptUiResolved(tab_id, request_id,
+                           mojom::CbfPromptUiKind::kPermissionPrompt,
+                           permission, permission_key, result);
+  }
+}
+
+void CbfProfileService::ResolvePendingPermissionPromptsForShutdown(
+    mojom::CbfPromptUiResolutionResult result) {
+  for (auto it = pending_permission_prompts_.begin();
+       it != pending_permission_prompts_.end();) {
+    const uint64_t request_id = it->first;
+    const TabId tab_id = it->second.tab_id;
+    const mojom::CbfPromptUiPermissionType permission = it->second.permission;
+    const std::string permission_key = it->second.permission_key;
+    const auto delegate = it->second.delegate;
+    it = pending_permission_prompts_.erase(it);
+    if (delegate) {
+      PromptOptions prompt_options = std::monostate();
+      if (result == mojom::CbfPromptUiResolutionResult::kAllowed) {
+        delegate->Accept(prompt_options);
+      } else {
+        delegate->Deny(prompt_options);
+      }
+    }
+    NotifyPromptUiResolved(tab_id, request_id,
+                           mojom::CbfPromptUiKind::kPermissionPrompt,
+                           permission, permission_key, result);
+  }
+}
