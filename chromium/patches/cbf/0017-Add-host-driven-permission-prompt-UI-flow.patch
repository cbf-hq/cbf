index 0000000000000..010790d3ad8cb
--- /dev/null
+++ b/chrome/browser/cbf/cbf_permission_prompt.cc
@@ -0,0 +1,159 @@
+#include "chrome/browser/cbf/cbf_permission_prompt.h"
+
+#include <variant>
+
+#include "build/build_config.h"
+#include "build/buildflag.h"
+#include "chrome/browser/cbf/cbf_browser_service.h"
+#include "chrome/browser/cbf/cbf_profile_service.h"
+#include "chrome/browser/cbf/cbf_service.h"
+#include "chrome/browser/profiles/profile.h"
+#include "components/permissions/permission_request.h"
+#include "components/permissions/request_type.h"
+#include "components/permissions/resolvers/permission_prompt_options.h"
+#include "content/public/browser/web_contents.h"
+
+namespace cbf {
+namespace {
+
+CbfProfileService* ResolveProfileService(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+
+  CbfService* cbf_service = CbfService::GetForProcess();
+  if (!cbf_service || !cbf_service->browser_service()) {
+    return nullptr;
+  }
+
+  auto* profile =
+      Profile::FromBrowserContext(web_contents->GetBrowserContext());
+  if (!profile) {
+    return nullptr;
+  }
+
+  return cbf_service->browser_service()->GetProfileServiceForProfile(profile);
+}
+
+}  // namespace
+
+CbfPermissionPrompt::CbfPermissionPrompt(content::WebContents* web_contents,
+                                         Delegate* delegate)
+    : web_contents_(web_contents), delegate_(delegate) {
+  if (!web_contents_ || !delegate_) {
+    return;
+  }
+
+  CbfProfileService* profile_service = ResolveProfileService(web_contents_);
+  if (profile_service &&
+      profile_service->RequestPermissionPromptForWebContents(
+          web_contents_, ResolvePermissionType(delegate_),
+          ResolvePermissionKey(delegate_),
+          delegate_->GetWeakPtr())) {
+    return;
+  }
+
+  PromptOptions prompt_options = std::monostate();
+  delegate_->Deny(prompt_options);
+}
+
+CbfPermissionPrompt::~CbfPermissionPrompt() = default;
+
+// static
+std::unique_ptr<permissions::PermissionPrompt> CbfPermissionPrompt::Create(
+    content::WebContents* web_contents,
+    permissions::PermissionPrompt::Delegate* delegate) {
+  return std::make_unique<CbfPermissionPrompt>(web_contents, delegate);
+}
+
+bool CbfPermissionPrompt::UpdateAnchor() {
+  return true;
+}
+
+permissions::PermissionPrompt::TabSwitchingBehavior
+CbfPermissionPrompt::GetTabSwitchingBehavior() {
+  return TabSwitchingBehavior::kKeepPromptAlive;
+}
+
+permissions::PermissionPromptDisposition
+CbfPermissionPrompt::GetPromptDisposition() const {
+  return permissions::PermissionPromptDisposition::CUSTOM_MODAL_DIALOG;
+}
+
+bool CbfPermissionPrompt::IsAskPrompt() const {
+  return true;
+}
+
+std::optional<gfx::Rect> CbfPermissionPrompt::GetViewBoundsInScreen() const {
+  return std::nullopt;
+}
+
+bool CbfPermissionPrompt::ShouldFinalizeRequestAfterDecided() const {
+  return true;
+}
+
+std::vector<permissions::ElementAnchoredBubbleVariant>
+CbfPermissionPrompt::GetPromptVariants() const {
+  return {};
+}
+
+std::optional<permissions::feature_params::PermissionElementPromptPosition>
+CbfPermissionPrompt::GetPromptPosition() const {
+  return std::nullopt;
+}
+
+// static
+mojom::CbfPromptUiPermissionType CbfPermissionPrompt::ResolvePermissionType(
+    Delegate* delegate) {
+  if (!delegate) {
+    return mojom::CbfPromptUiPermissionType::kUnknown;
+  }
+
+  const auto& requests = delegate->Requests();
+  for (const auto& request : requests) {
+    if (!request) {
+      continue;
+    }
+    switch (request->request_type()) {
+      case permissions::RequestType::kGeolocation:
+        return mojom::CbfPromptUiPermissionType::kGeolocation;
+      case permissions::RequestType::kNotifications:
+        return mojom::CbfPromptUiPermissionType::kNotifications;
+      case permissions::RequestType::kMicStream:
+        return mojom::CbfPromptUiPermissionType::kAudioCapture;
+      case permissions::RequestType::kCameraStream:
+#if !BUILDFLAG(IS_ANDROID) && !BUILDFLAG(IS_IOS)
+      case permissions::RequestType::kCameraPanTiltZoom:
+#endif
+        return mojom::CbfPromptUiPermissionType::kVideoCapture;
+      default:
+        break;
+    }
+  }
+
+  return mojom::CbfPromptUiPermissionType::kUnknown;
+}
+
+// static
+std::string CbfPermissionPrompt::ResolvePermissionKey(Delegate* delegate) {
+  if (!delegate) {
+    return std::string();
+  }
+
+  const auto& requests = delegate->Requests();
+  for (const auto& request : requests) {
+    if (!request) {
+      continue;
+    }
+    const char* key =
+        permissions::PermissionKeyForRequestType(request->request_type());
+    if (!key || key[0] == '\0') {
+      continue;
+    }
+    return key;
+  }
+
+  return std::string();
+}
+
+}  // namespace cbf
