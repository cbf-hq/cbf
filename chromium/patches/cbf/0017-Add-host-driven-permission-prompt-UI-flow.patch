+bool CbfBridgeClient::RespondPromptUi(uint64_t tab_id,
+                                      uint64_t request_id,
+                                      uint8_t prompt_ui_kind,
+                                      bool allow) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id, uint64_t request_id,
+             uint8_t prompt_ui_kind, bool allow) {
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            auto response = cbf::mojom::CbfPromptUiResponse::New();
+            switch (prompt_ui_kind) {
+              case kCbfPromptUiKindPermissionPrompt:
+                response->kind = cbf::mojom::CbfPromptUiKind::kPermissionPrompt;
+                break;
+              case kCbfPromptUiKindUnknown:
+              default:
+                response->kind = cbf::mojom::CbfPromptUiKind::kUnknown;
+                break;
+            }
+            response->allow = allow;
+            remote_it->second.remote->RespondPromptUi(
+                tab_id, request_id, std::move(response));
+          },
+          impl, tab_id, request_id, prompt_ui_kind, allow));
+  return true;
+}
