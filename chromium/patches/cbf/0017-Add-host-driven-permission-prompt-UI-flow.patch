+bool CbfProfileService::RequestPermissionPromptForWebContents(
+    content::WebContents* web_contents,
+    mojom::CbfPromptUiPermissionType permission,
+    const std::string& permission_key,
+    base::WeakPtr<permissions::PermissionPrompt::Delegate> delegate) {
+  if (!web_contents || !delegate || !observer_) {
+    return false;
+  }
+  const TabId tab_id = tab_manager_.GetTabIdForWebContents(web_contents);
+  if (tab_id == kInvalidTabId) {
+    return false;
+  }
+  ResolvePendingPermissionPromptsForTab(
+      tab_id, mojom::CbfPromptUiResolutionResult::kAborted);
+
+  const uint64_t request_id = next_prompt_ui_request_id_++;
+  auto pending = PendingPermissionPrompt();
+  pending.tab_id = tab_id;
+  pending.permission = permission;
+  pending.permission_key = permission_key;
+  pending.delegate = std::move(delegate);
+  pending_permission_prompts_[request_id] = std::move(pending);
+
+  NotifyPromptUiRequested(tab_id, request_id,
+                          mojom::CbfPromptUiKind::kPermissionPrompt,
+                          permission, permission_key);
+  return true;
+}
