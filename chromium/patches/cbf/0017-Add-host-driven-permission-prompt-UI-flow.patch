+void CbfProfileService::RespondPromptUi(uint64_t tab_id,
+                                        uint64_t request_id,
+                                        mojom::CbfPromptUiResponsePtr response) {
+  if (!response) {
+    return;
+  }
+  if (response->kind != mojom::CbfPromptUiKind::kPermissionPrompt) {
+    return;
+  }
+
+  auto it = pending_permission_prompts_.find(request_id);
+  if (it == pending_permission_prompts_.end()) {
+    return;
+  }
+  if (it->second.tab_id != tab_id) {
+    DCHECK(false);
+    return;
+  }
+
+  PendingPermissionPrompt pending = std::move(it->second);
+  pending_permission_prompts_.erase(it);
+
+  mojom::CbfPromptUiResolutionResult result =
+      mojom::CbfPromptUiResolutionResult::kAborted;
+  if (pending.delegate) {
+    PromptOptions prompt_options = std::monostate();
+    if (response->allow) {
+      pending.delegate->Accept(prompt_options);
+      result = mojom::CbfPromptUiResolutionResult::kAllowed;
+    } else {
+      pending.delegate->Deny(prompt_options);
+      result = mojom::CbfPromptUiResolutionResult::kDenied;
+    }
+  }
+
+  NotifyPromptUiResolved(tab_id, request_id,
+                         mojom::CbfPromptUiKind::kPermissionPrompt,
+                         pending.permission, pending.permission_key, result);
+}
