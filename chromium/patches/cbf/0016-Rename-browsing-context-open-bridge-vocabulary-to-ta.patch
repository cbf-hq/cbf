+
+TEST_F(CbfBrowserServiceTest, MismatchedConfirmShutdownIsSafeNoOp) {
+  CbfBrowserService service("expected-token");
+
+  service.ConfirmShutdown(/*request_id=*/999u, /*proceed=*/true);
+
+  EXPECT_FALSE(service.IsShutdownRequested());
+}
+
+TEST_F(CbfBrowserServiceTest, RepeatedRequestShutdownAfterProceedingIsSafe) {
+  CbfBrowserService service("expected-token");
+
+  service.RequestShutdown(/*request_id=*/1u);
+  service.RequestShutdown(/*request_id=*/2u);
+
+  EXPECT_FALSE(service.IsShutdownRequested());
+}
+
