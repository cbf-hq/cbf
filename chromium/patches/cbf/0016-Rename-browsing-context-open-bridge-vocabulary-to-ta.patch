+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       HistoryContainsVisitedUrlFromCbfManagedTab) {
+  embedded_test_server()->RegisterRequestHandler(base::BindRepeating(
+      [](const net::test_server::HttpRequest& request)
+          -> std::unique_ptr<net::test_server::HttpResponse> {
+        if (request.relative_url != "/cbf-history-regression") {
+          return nullptr;
+        }
+        auto response =
+            std::make_unique<net::test_server::BasicHttpResponse>();
+        response->set_code(net::HTTP_OK);
+        response->set_content_type("text/html");
+        response->set_content(
+            "<!doctype html><title>cbf-history-regression-marker</title>"
+            "<body>cbf-history-regression-marker</body>");
+        return response;
+      }));
+  ASSERT_TRUE(embedded_test_server()->Start());
+
+  const GURL visited_url = embedded_test_server()->GetURL(
+      "/cbf-history-regression");
+  const TabId visited_tab_id = CreatePage(visited_url.spec());
+  ASSERT_NE(visited_tab_id, kInvalidTabId);
+  WaitForLoad(visited_tab_id);
+
+  const TabId history_tab_id = CreatePage("chrome://history");
+  ASSERT_NE(history_tab_id, kInvalidTabId);
+  WaitForLoad(history_tab_id);
+
+  history::HistoryService* history_service = HistoryServiceFactory::GetForProfile(
+      browser()->profile(), ServiceAccessType::EXPLICIT_ACCESS);
+  ASSERT_NE(history_service, nullptr);
+
+  history::QueryURLResult query_result;
+  base::RunLoop run_loop;
+  base::CancelableTaskTracker tracker;
+  history_service->QueryURL(
+      visited_url,
+      base::BindOnce(
+          [](history::QueryURLResult* out_result, base::RunLoop* run_loop,
+             history::QueryURLResult result) {
+            *out_result = std::move(result);
+            run_loop->Quit();
+          },
+          &query_result, &run_loop),
+      &tracker);
+  run_loop.Run();
+
+  EXPECT_TRUE(query_result.success);
+}
