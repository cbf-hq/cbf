+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       HistorySwitchBetweenRootAndGroupedDoesNotCrash) {
+  const TabId tab_id = CreatePage("chrome://history");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  EXPECT_EQ(true, content::EvalJs(web_contents, R"(
+    (async () => {
+      const waitFrame = () =>
+          new Promise(resolve => requestAnimationFrame(() => resolve()));
+      const appExists = () => !!document.querySelector('history-app');
+
+      window.history.pushState({}, '', '/grouped');
+      window.dispatchEvent(new PopStateEvent('popstate'));
+      await waitFrame();
+      if (!appExists() || !window.location.pathname.endsWith('/grouped')) {
+        return false;
+      }
+
+      window.history.pushState({}, '', '/');
+      window.dispatchEvent(new PopStateEvent('popstate'));
+      await waitFrame();
+      return appExists() && window.location.pathname === '/';
+    })();
+  )"));
+}
