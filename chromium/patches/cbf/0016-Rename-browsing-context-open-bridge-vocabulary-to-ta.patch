-    cbf::mojom::CbfBrowsingContextOpenRequestPtr request) {
+void CbfBridgeClientImpl::Observer::OnTabOpenRequested(
+    cbf::mojom::CbfTabOpenRequestPtr request) {
   if (!request) {
     return;
   }
   CbfBridgeEventData event;
