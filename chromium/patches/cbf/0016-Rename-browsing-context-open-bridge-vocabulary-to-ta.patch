+void CbfBridgeClientImpl::Observer::OnTabOpenResolved(
+    cbf::mojom::CbfTabOpenResultPtr result) {
   if (!result) {
     return;
   }
   CbfBridgeEventData event;
-  event.kind = kEventBrowsingContextOpenResolved;
+  event.kind = kEventTabOpenResolved;
   event.request_id = result->request_id;
   event.profile_id = profile_id_;
-  event.browsing_context_open_result = static_cast<uint8_t>(result->result);
+  event.tab_open_result = static_cast<uint8_t>(result->result);
   if (result->target_tab_id.has_value()) {
     event.has_target_tab_id = true;
     event.target_tab_id = result->target_tab_id.value();
   }
-  impl_->browsing_context_open_request_profiles.erase(result->request_id);
+  impl_->tab_open_request_profiles.erase(result->request_id);
   std::lock_guard<std::mutex> lock(impl_->events_mutex);
   impl_->events.push(std::move(event));
 }
