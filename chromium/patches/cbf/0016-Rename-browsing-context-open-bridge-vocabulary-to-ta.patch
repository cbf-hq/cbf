     event.has_source_tab_id = true;
     event.source_tab_id = request->source_tab_id.value();
   }
-  impl_->browsing_context_open_request_profiles[request->request_id] = profile_id_;
+  impl_->tab_open_request_profiles[request->request_id] = profile_id_;
   std::lock_guard<std::mutex> lock(impl_->events_mutex);
   impl_->events.push(std::move(event));
