+  service.NotifyBeforeUnloadDialogRequested(/*tab_id=*/42u);
+  service.NotifyBeforeUnloadFired(/*tab_id=*/42u, /*proceed=*/false);
+  service.NotifyBeforeUnloadFired(/*tab_id=*/42u, /*proceed=*/true);
+
+  EXPECT_FALSE(service.IsShutdownRequested());
