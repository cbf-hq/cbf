+void CbfProfileService::ListExtensions(const std::string& profile_id,
+                                       ListExtensionsCallback callback) {
+  std::vector<mojom::CbfExtensionInfoPtr> result;
+  if (!profile_) {
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  extensions::ExtensionRegistry* registry =
+      extensions::ExtensionRegistry::Get(profile_.get());
+  if (!registry) {
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  auto append_set = [&result](const extensions::ExtensionSet& set, bool enabled) {
+    for (const auto& extension : set) {
+      if (!extension) {
+        continue;
+      }
+      auto info = mojom::CbfExtensionInfo::New();
+      info->id = extension->id();
+      info->name = extension->name();
+      info->version = extension->version().GetString();
+      info->enabled = enabled;
+      info->permission_names = BuildPermissionNames(extension.get());
+      result.push_back(std::move(info));
+    }
+  };
+  append_set(registry->enabled_extensions(), true);
+  append_set(registry->disabled_extensions(), false);
+
+  if (observer_) {
+    observer_->OnExtensionsListed(profile_id, mojo::Clone(result));
+  }
+  std::move(callback).Run(std::move(result));
+}
+
+void CbfProfileService::RequestExtensionInstallPrompt(
+    uint64_t tab_id,
+    uint64_t request_id,
+    const std::string& extension_id,
+    mojom::CbfExtensionInstallPromptMode mode) {
+  content::WebContents* web_contents = tab_manager_.GetWebContents(tab_id);
+  if (!web_contents || !profile_) {
+    return;
+  }
+  extensions::ExtensionRegistry* registry =
+      extensions::ExtensionRegistry::Get(profile_.get());
+  if (!registry) {
+    if (observer_) {
+      observer_->OnExtensionRuntimeWarning(
+          tab_id, "extension_registry_unavailable");
+    }
+    return;
+  }
+  const extensions::Extension* extension =
+      registry->GetInstalledExtension(extension_id);
+  if (!extension) {
+    if (observer_) {
+      observer_->OnExtensionRuntimeWarning(tab_id,
+                                           "extension_not_found");
+    }
+    return;
+  }
+
+  auto pending = PendingExtensionInstallPrompt();
+  pending.tab_id = tab_id;
+  pending.extension_id = extension_id;
+
+  if (mode == mojom::CbfExtensionInstallPromptMode::kHostMediated) {
+    pending.host_callback = base::BindOnce(
+        [](base::WeakPtr<CbfProfileService> self, uint64_t prompt_request_id,
+           bool proceed) {
+          if (!self) {
+            return;
+          }
+          self->ResolveExtensionInstallPrompt(
+              prompt_request_id,
+              proceed ? mojom::CbfExtensionInstallPromptResult::kAccepted
+                      : mojom::CbfExtensionInstallPromptResult::kUserCanceled,
+              std::string());
+        },
+        weak_factory_.GetWeakPtr(), request_id);
+    pending_extension_prompts_[request_id] = std::move(pending);
+    if (observer_) {
+      observer_->OnExtensionInstallPromptRequested(
+          tab_id, request_id, extension_id, extension->name(),
+          BuildPermissionNames(extension));
+    }
+    return;
+  }
+
+  pending.prompt = std::make_unique<ExtensionInstallPrompt>(web_contents);
+  pending.prompt->ConfirmInstall(
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileService> self, uint64_t prompt_request_id,
+             extensions::ExtensionInstallPromptClient::DoneCallbackPayload
+                 payload) {
+            if (!self) {
+              return;
+            }
+            self->ResolveExtensionInstallPrompt(
+                prompt_request_id, ToCbfInstallPromptResult(payload.result),
+                payload.justification);
+          },
+          weak_factory_.GetWeakPtr(), request_id),
+      extension);
+  pending_extension_prompts_[request_id] = std::move(pending);
+}
+
+void CbfProfileService::RespondExtensionInstallPrompt(uint64_t tab_id,
+                                                      uint64_t request_id,
+                                                      bool proceed) {
+  auto it = pending_extension_prompts_.find(request_id);
+  if (it == pending_extension_prompts_.end()) {
+    return;
+  }
+  if (it->second.tab_id != tab_id) {
+    return;
+  }
+  if (!it->second.host_callback) {
+    return;
+  }
+  std::move(it->second.host_callback).Run(proceed);
+}
