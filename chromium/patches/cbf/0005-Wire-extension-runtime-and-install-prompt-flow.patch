+bool CbfBridgeClient::ListExtensions(const std::string& profile_id,
+                                     CbfExtensionInfoList* out_list) {
+  if (!impl_ || !out_list) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner || !impl_->browser_remote.is_bound()) {
+    return false;
+  }
+
+  base::WaitableEvent done(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  bool success = false;
+  std::vector<cbf::mojom::CbfExtensionInfoPtr> extensions;
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, std::string profile_id,
+             std::vector<cbf::mojom::CbfExtensionInfoPtr>* out_extensions,
+             bool* success, base::WaitableEvent* done) {
+            if (!impl->browser_remote.is_bound()) {
+              done->Signal();
+              return;
+            }
+            auto& connection = impl->profile_connections[profile_id];
+            if (!connection.remote.is_bound()) {
+              mojo::PendingRemote<cbf::mojom::CbfProfileService>
+                  profile_remote;
+              mojo::PendingReceiver<cbf::mojom::CbfProfileService> receiver =
+                  profile_remote.InitWithNewPipeAndPassReceiver();
+              impl->browser_remote->BindProfileService(profile_id,
+                                                       std::move(receiver));
+              connection.remote.Bind(std::move(profile_remote));
+              connection.observer = std::make_unique<
+                  CbfBridgeClientImpl::Observer>(impl, profile_id);
+              mojo::PendingRemote<cbf::mojom::CbfProfileObserver>
+                  observer_remote;
+              connection.observer_receiver = std::make_unique<
+                  mojo::Receiver<cbf::mojom::CbfProfileObserver>>(
+                  connection.observer.get(),
+                  observer_remote.InitWithNewPipeAndPassReceiver());
+              connection.remote->SetObserver(std::move(observer_remote));
+            }
+            connection.remote->ListExtensions(
+                profile_id, base::BindOnce(
+                                [](std::vector<cbf::mojom::CbfExtensionInfoPtr>*
+                                       out_extensions,
+                                   bool* success, base::WaitableEvent* done,
+                                   std::vector<cbf::mojom::CbfExtensionInfoPtr>
+                                       extensions) {
+                                  *out_extensions = std::move(extensions);
+                                  *success = true;
+                                  done->Signal();
+                                },
+                                out_extensions, success, done));
+          },
+          impl_.get(), profile_id, &extensions, &success, &done));
+  done.Wait();
+  if (!success) {
+    return false;
+  }
+
+  out_list->len = static_cast<uint32_t>(extensions.size());
+  out_list->items =
+      extensions.empty() ? nullptr : new CbfExtensionInfo[extensions.size()];
+  auto out_extensions =
+      UNSAFE_BUFFERS(base::span(out_list->items, out_list->len));
+  size_t index = 0;
+  for (auto& entry : out_extensions) {
+    const auto& extension = extensions[index++];
+    entry.id = CopyCString(extension->id);
+    entry.name = CopyCString(extension->name);
+    entry.version = CopyCString(extension->version);
+    entry.enabled = extension->enabled;
+    entry.permission_names.len =
+        static_cast<uint32_t>(extension->permission_names.size());
+    entry.permission_names.items = extension->permission_names.empty()
+                                       ? nullptr
+                                       : new char*[extension->permission_names.size()];
+    auto out_permissions = UNSAFE_BUFFERS(
