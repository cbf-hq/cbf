+void CbfProfileService::ResolveExtensionInstallPrompt(
+    uint64_t request_id,
+    mojom::CbfExtensionInstallPromptResult result,
+    const std::string& detail) {
+  auto it = pending_extension_prompts_.find(request_id);
+  if (it == pending_extension_prompts_.end()) {
+    return;
+  }
+  const TabId tab_id = it->second.tab_id;
+  const std::string extension_id = it->second.extension_id;
+  pending_extension_prompts_.erase(it);
+  if (!observer_) {
+    return;
+  }
+  observer_->OnExtensionInstallPromptResolved(tab_id, request_id,
+                                              extension_id, result, detail);
+}
