+std::vector<std::string> BuildPermissionNames(const extensions::Extension* extension) {
+  std::vector<std::string> names;
+  if (!extension || !extension->permissions_data()) {
+    return names;
+  }
+  const auto messages = extension->permissions_data()->GetPermissionMessages();
+  names.reserve(messages.size());
+  for (const auto& message : messages) {
+    names.push_back(base::UTF16ToUTF8(message.message()));
+  }
+  return names;
+}
+
+mojom::CbfExtensionInstallPromptResult ToCbfInstallPromptResult(
+    extensions::ExtensionInstallPromptClient::Result result) {
+  switch (result) {
+    case extensions::ExtensionInstallPromptClient::Result::ACCEPTED:
+      return mojom::CbfExtensionInstallPromptResult::kAccepted;
+    case extensions::ExtensionInstallPromptClient::Result::
+        ACCEPTED_WITH_WITHHELD_PERMISSIONS:
+      return mojom::CbfExtensionInstallPromptResult::
+          kAcceptedWithWithheldPermissions;
+    case extensions::ExtensionInstallPromptClient::Result::USER_CANCELED:
+      return mojom::CbfExtensionInstallPromptResult::kUserCanceled;
+    case extensions::ExtensionInstallPromptClient::Result::ABORTED:
+      return mojom::CbfExtensionInstallPromptResult::kAborted;
+  }
+}
