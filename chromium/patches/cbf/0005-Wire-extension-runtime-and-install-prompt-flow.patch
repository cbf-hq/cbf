+void FreeExtensionInfoList(CbfExtensionInfoList list) {
+  if (!list.items || list.len == 0) {
+    return;
+  }
+  auto items = UNSAFE_BUFFERS(base::span(list.items, list.len));
+  for (auto& item : items) {
+    delete[] item.id;
+    delete[] item.name;
+    delete[] item.version;
+    FreeStringList(item.permission_names);
+    item.permission_names.items = nullptr;
+    item.permission_names.len = 0;
+  }
+  delete[] list.items;
+}
