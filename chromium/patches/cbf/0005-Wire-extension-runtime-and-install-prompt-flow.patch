+void CbfBridgeClientImpl::Observer::OnExtensionsListed(
+    const std::string& profile_id,
+    std::vector<cbf::mojom::CbfExtensionInfoPtr> extensions) {
+  CbfBridgeEventData event;
+  event.kind = kEventExtensionsListed;
+  event.profile_id = profile_id;
+  event.extensions = std::move(extensions);
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
+void CbfBridgeClientImpl::Observer::OnExtensionInstallPromptRequested(
+    uint64_t tab_id,
+    uint64_t request_id,
+    const std::string& extension_id,
+    const std::string& extension_name,
+    const std::vector<std::string>& permission_names) {
+  CbfBridgeEventData event;
+  event.kind = kEventExtensionInstallPromptRequested;
+  event.profile_id = profile_id_;
+  event.tab_id = tab_id;
+  event.request_id = request_id;
+  event.extension_id = extension_id;
+  event.extension_name = extension_name;
+  event.permission_names = permission_names;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
+void CbfBridgeClientImpl::Observer::OnExtensionInstallPromptResolved(
+    uint64_t tab_id,
+    uint64_t request_id,
+    const std::string& extension_id,
+    cbf::mojom::CbfExtensionInstallPromptResult result,
+    const std::string& detail) {
+  CbfBridgeEventData event;
+  event.kind = kEventExtensionInstallPromptResolved;
+  event.profile_id = profile_id_;
+  event.tab_id = tab_id;
+  event.request_id = request_id;
+  event.extension_id = extension_id;
+  event.extension_install_prompt_result = static_cast<uint8_t>(result);
+  event.extension_install_prompt_detail = detail;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
+void CbfBridgeClientImpl::Observer::OnExtensionRuntimeWarning(
+    uint64_t tab_id,
+    const std::string& detail) {
+  CbfBridgeEventData event;
+  event.kind = kEventExtensionRuntimeWarning;
+  event.profile_id = profile_id_;
+  event.tab_id = tab_id;
+  event.extension_runtime_warning = detail;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
 CbfBridgeClientImpl::ProfileConnection::ProfileConnection() = default;
 CbfBridgeClientImpl::ProfileConnection::~ProfileConnection() = default;
 
