+CbfExtensionInfoList ToCbfExtensionInfoList(
+    const std::vector<cbf::mojom::CbfExtensionInfoPtr>& values) {
+  CbfExtensionInfoList out = {};
+  if (values.empty()) {
+    return out;
+  }
+  CbfExtensionInfo* out_items = new CbfExtensionInfo[values.size()];
+  auto out_span = UNSAFE_BUFFERS(base::span(out_items, values.size()));
+  for (size_t i = 0; i < out_span.size(); ++i) {
+    out_span[i] = {};
+    if (!values[i]) {
+      continue;
+    }
+    out_span[i].id = CopyCString(values[i]->id);
+    out_span[i].name = CopyCString(values[i]->name);
+    out_span[i].version = CopyCString(values[i]->version);
+    out_span[i].enabled = values[i]->enabled;
+    out_span[i].permission_names = ToCbfStringList(values[i]->permission_names);
+  }
+  out.items = out_items;
+  out.len = static_cast<uint32_t>(values.size());
+  return out;
