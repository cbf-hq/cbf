+void AttachExtensionRuntimeHelpers(content::WebContents* web_contents,
+                                   ::Profile* profile) {
+  (void)profile;
+#if BUILDFLAG(ENABLE_EXTENSIONS_CORE)
+  if (extensions::GetViewType(web_contents) ==
+      extensions::mojom::ViewType::kInvalid) {
+    extensions::SetViewType(web_contents,
+                            extensions::mojom::ViewType::kTabContents);
+  }
+  extensions::NavigationExtensionEnabler::CreateForWebContents(web_contents);
+  extensions::WebNavigationTabObserver::CreateForWebContents(web_contents);
+  extensions::TabHelper::CreateForWebContents(web_contents);
+#endif
+}
+
+void AttachPrintingPdfHelpers(content::WebContents* web_contents,
+                              ::Profile* profile) {
+  (void)web_contents;
+  (void)profile;
+}
+
+void AttachAutofillHelpers(content::WebContents* web_contents,
+                           ::Profile* profile) {
+  (void)web_contents;
+  (void)profile;
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(CbfWebContentsBootstrapMarker);
+
+}  // namespace
+
+void BootstrapCbfWebContents(content::WebContents* web_contents,
+                             ::Profile* profile) {
+  if (!web_contents) {
+    return;
+  }
+  if (CbfWebContentsBootstrapMarker::FromWebContents(web_contents)) {
+    return;
+  }
+
+  CbfWebContentsBootstrapMarker::CreateForWebContents(web_contents);
+
+  AttachExtensionRuntimeHelpers(web_contents, profile);
+  AttachPrintingPdfHelpers(web_contents, profile);
+  AttachAutofillHelpers(web_contents, profile);
+}
+
+bool HasCbfWebContentsBootstrapForTesting(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return false;
+  }
+  return CbfWebContentsBootstrapMarker::FromWebContents(web_contents) !=
+         nullptr;
+}
+
+}  // namespace cbf
