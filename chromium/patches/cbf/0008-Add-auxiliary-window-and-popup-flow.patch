+void CbfProfileService::TryAttachPrintPreviewDialog(TabId tab_id,
+                                                    int attempts_remaining) {
+  if (attempts_remaining < 0) {
+    return;
+  }
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  for (const auto& entry : print_preview_window_to_web_page_) {
+    if (entry.second == tab_id) {
+      return;
+    }
+  }
+
+  content::WebContents* initiator = tab_manager_.GetWebContents(tab_id);
+  if (!initiator) {
+    return;
+  }
+
+  auto* dialog_controller = printing::PrintPreviewDialogController::GetInstance();
+  if (!dialog_controller) {
+    return;
+  }
+  content::WebContents* preview_dialog =
+      dialog_controller->GetPrintPreviewForContents(initiator);
+  if (preview_dialog) {
+    RegisterPrintPreviewDialog(tab_id, preview_dialog);
+    return;
+  }
+
+  if (attempts_remaining == 0) {
+    return;
+  }
+
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&CbfProfileService::TryAttachPrintPreviewDialog,
+                     weak_factory_.GetWeakPtr(), tab_id,
+                     attempts_remaining - 1),
+      base::Milliseconds(50));
+}
+
+void CbfProfileService::RegisterPrintPreviewDialog(
+    TabId tab_id,
+    content::WebContents* preview_dialog) {
+  if (!preview_dialog) {
+    return;
+  }
+  auto existing_it = print_preview_dialog_to_window_.find(preview_dialog);
+  if (existing_it != print_preview_dialog_to_window_.end()) {
+    return;
+  }
+
+  const uint64_t window_id = next_auxiliary_window_id_++;
+  print_preview_window_to_dialog_[window_id] = preview_dialog;
+  print_preview_dialog_to_window_[preview_dialog] = window_id;
+  print_preview_window_to_web_page_[window_id] = tab_id;
+  print_preview_web_contents_collection_.StartObserving(preview_dialog);
+  NotifyAuxiliaryWindowOpened(tab_id, window_id,
+                              mojom::CbfAuxiliaryWindowKind::kPrintPreviewDialog,
+                              "Print Preview", true);
+}
+
+void CbfProfileService::ResolvePrintPreviewWindowClosed(
+    uint64_t window_id,
+    mojom::CbfAuxiliaryWindowCloseReason reason) {
+  auto web_page_it = print_preview_window_to_web_page_.find(window_id);
+  if (web_page_it == print_preview_window_to_web_page_.end()) {
+    return;
+  }
+  const TabId tab_id = web_page_it->second;
+
+  auto dialog_it = print_preview_window_to_dialog_.find(window_id);
+  if (dialog_it != print_preview_window_to_dialog_.end()) {
+    content::WebContents* dialog = dialog_it->second;
+    if (dialog) {
+      print_preview_web_contents_collection_.StopObserving(dialog);
+      print_preview_dialog_to_window_.erase(dialog);
+    }
+    print_preview_window_to_dialog_.erase(dialog_it);
+  }
+  print_preview_window_to_web_page_.erase(web_page_it);
+  host_forced_print_preview_windows_.erase(window_id);
+
+  NotifyAuxiliaryWindowClosed(
+      tab_id, window_id, mojom::CbfAuxiliaryWindowKind::kPrintPreviewDialog,
+      reason);
+}
+
+void CbfProfileService::OnWidgetClosing(views::Widget* widget) {
+  auto it = auxiliary_widget_to_window_id_.find(widget);
+  if (it == auxiliary_widget_to_window_id_.end()) {
+    return;
+  }
+  auxiliary_widget_to_window_id_.erase(it);
+}
+
+void CbfProfileService::WebContentsDestroyed(content::WebContents* web_contents) {
+  auto it = print_preview_dialog_to_window_.find(web_contents);
+  if (it == print_preview_dialog_to_window_.end()) {
+    return;
+  }
+  const uint64_t window_id = it->second;
+  const auto reason = host_forced_print_preview_windows_.contains(window_id)
+                          ? mojom::CbfAuxiliaryWindowCloseReason::kHostForced
+                          : mojom::CbfAuxiliaryWindowCloseReason::kUnknown;
+  ResolvePrintPreviewWindowClosed(window_id, reason);
+}
+
+void CbfProfileService::RenderProcessGone(content::WebContents* web_contents,
+                                          base::TerminationStatus status) {
+  (void)status;
+  WebContentsDestroyed(web_contents);
 }
 
