+extensions::ExtensionInstallPromptClient::Result ToExtensionInstallResult(
+    mojom::CbfExtensionInstallPromptResult result) {
+  switch (result) {
+    case mojom::CbfExtensionInstallPromptResult::kAccepted:
+      return extensions::ExtensionInstallPromptClient::Result::ACCEPTED;
+    case mojom::CbfExtensionInstallPromptResult::
+        kAcceptedWithWithheldPermissions:
+      return extensions::ExtensionInstallPromptClient::Result::
+          ACCEPTED_WITH_WITHHELD_PERMISSIONS;
+    case mojom::CbfExtensionInstallPromptResult::kUserCanceled:
+      return extensions::ExtensionInstallPromptClient::Result::USER_CANCELED;
+    case mojom::CbfExtensionInstallPromptResult::kAborted:
+      return extensions::ExtensionInstallPromptClient::Result::ABORTED;
+  }
