+bool CbfProfileService::OpenDefaultAuxiliaryWindowImpl(uint64_t request_id) {
+  auto it = pending_extension_prompts_.find(request_id);
+  if (it == pending_extension_prompts_.end()) {
+    return false;
+  }
+  auto& pending = it->second;
+  content::WebContents* web_contents = tab_manager_.GetWebContents(pending.tab_id);
+  if (!web_contents || !pending.extension.get()) {
+    ResolveExtensionInstallPrompt(
+        request_id, mojom::CbfExtensionInstallPromptResult::kAborted, "missing_web_contents");
+    return false;
+  }
+  if (pending.prompt) {
+    return true;
+  }
+  pending.auxiliary_window_id = next_auxiliary_window_id_++;
+  const uint64_t tab_id = pending.tab_id;
+  const uint64_t auxiliary_window_id = pending.auxiliary_window_id;
+  pending.prompt = std::make_unique<ExtensionInstallPrompt>(web_contents);
+  std::optional<SkBitmap> icon = pending.icon;
+  pending.prompt->ShowDialog(
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileService> self, uint64_t prompt_request_id,
+             extensions::ExtensionInstallPromptClient::DoneCallbackPayload payload) {
+            if (!self) {
+              return;
+            }
+            self->ResolveExtensionInstallPrompt(
+                prompt_request_id, ToCbfInstallPromptResult(payload.result),
+                payload.justification);
+          },
+          weak_factory_.GetWeakPtr(), request_id),
+      pending.extension.get(), icon ? &(*icon) : nullptr,
+      base::BindRepeating(
+          [](base::WeakPtr<CbfProfileService> self, uint64_t tab_id,
+             uint64_t auxiliary_window_id, std::string extension_name,
+             std::unique_ptr<ExtensionInstallPromptShowParams> show_params,
+             ExtensionInstallPrompt::DoneCallback done_callback,
+             std::unique_ptr<ExtensionInstallPrompt::Prompt> prompt) {
+            if (!self) {
+              std::move(done_callback).Run(
+                  extensions::ExtensionInstallPromptClient::DoneCallbackPayload(
+                      extensions::ExtensionInstallPromptClient::Result::ABORTED));
+              return;
+            }
+            self->NotifyAuxiliaryWindowOpened(
+                tab_id, auxiliary_window_id,
+                mojom::CbfAuxiliaryWindowKind::kExtensionInstallPrompt,
+                extension_name, true);
+            ExtensionInstallPrompt::GetDefaultShowDialogCallback().Run(
+                std::move(show_params), std::move(done_callback), std::move(prompt));
+          },
+          weak_factory_.GetWeakPtr(), tab_id, auxiliary_window_id, pending.extension_name));
+  auxiliary_window_to_prompt_request_[auxiliary_window_id] = request_id;
+  return true;
+}
+
+bool CbfProfileService::RespondAuxiliaryWindowImpl(
+    uint64_t request_id,
+    mojom::CbfAuxiliaryWindowResponsePtr response) {
+  if (!response) {
+    return false;
+  }
+  if (response->kind != mojom::CbfAuxiliaryWindowKind::kExtensionInstallPrompt) {
+    return false;
+  }
+  ResolveExtensionInstallPrompt(
+      request_id,
+      response->proceed ? mojom::CbfExtensionInstallPromptResult::kAccepted
+                        : mojom::CbfExtensionInstallPromptResult::kUserCanceled,
+      std::string());
+  return true;
+}
+
