+  auto request = mojom::CbfAuxiliaryWindowRequest::New();
+  request->request_id = request_id;
+  request->kind = kind;
+  request->extension_id = extension_id;
+  request->extension_name = extension_name;
+  request->permission_names = permission_names;
+  observer_->OnAuxiliaryWindowOpenRequested(tab_id, std::move(request));
+}
