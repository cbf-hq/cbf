+void CbfProfileService::PrintPreview(uint64_t tab_id) {
+  content::WebContents* web_contents = tab_manager_.GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  bool print_preview_disabled = false;
+#if BUILDFLAG(IS_MAC)
+  // WebContents-modal preview on macOS requires a parent NSWindow for kChild
+  // modal widgets. CBF pages can run without one, so fall back safely.
+  views::Widget* top_level_widget =
+      views::Widget::GetTopLevelWidgetForNativeView(web_contents->GetNativeView());
+  if (!top_level_widget || !top_level_widget->GetNativeWindow()) {
+    print_preview_disabled = true;
+  }
+#endif
+
+  const bool started = printing::StartPrint(
+      web_contents,
+#if BUILDFLAG(IS_CHROMEOS)
+      /*print_renderer=*/mojo::NullAssociatedRemote(),
+#endif
+      /*print_preview_disabled=*/print_preview_disabled,
+      /*has_selection=*/false);
+  if (!started) {
+    return;
+  }
+
+  if (print_preview_disabled) {
+    return;
+  }
+
+  TryAttachPrintPreviewDialog(tab_id, /*attempts_remaining=*/10);
+}
