diff --git a/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc b/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
index ee8f470bd34f3..7135cca04c0e6 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
+++ b/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
@@ -96,6 +96,7 @@ void CbfBridgeClientImpl::Observer::OnSurfaceHandleUpdated(
 
 void CbfBridgeClientImpl::Observer::OnWebPageCreated(uint64_t web_page_id,
                                                     uint64_t request_id) {
+  impl_->web_page_profiles.emplace(web_page_id, profile_id_);
   CbfBridgeEventData event;
   event.kind = kEventWebPageCreated;
   event.web_page_id = web_page_id;
@@ -105,7 +106,24 @@ void CbfBridgeClientImpl::Observer::OnWebPageCreated(uint64_t web_page_id,
   impl_->events.push(std::move(event));
 }
 
+void CbfBridgeClientImpl::Observer::OnDevToolsOpened(
+    uint64_t web_page_id,
+    uint64_t devtools_web_page_id) {
+  LOG(INFO) << "[CBF][Bridge] OnDevToolsOpened inspected_id=" << web_page_id
+            << " devtools_id=" << devtools_web_page_id
+            << " profile_id=" << profile_id_;
+  impl_->web_page_profiles.emplace(devtools_web_page_id, profile_id_);
+  CbfBridgeEventData event;
+  event.kind = kEventDevToolsOpened;
+  event.web_page_id = devtools_web_page_id;
+  event.inspected_web_page_id = web_page_id;
+  event.profile_id = profile_id_;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
 void CbfBridgeClientImpl::Observer::OnWebPageClosed(uint64_t web_page_id) {
+  impl_->web_page_profiles.erase(web_page_id);
   CbfBridgeEventData event;
   event.kind = kEventWebPageClosed;
   event.web_page_id = web_page_id;
