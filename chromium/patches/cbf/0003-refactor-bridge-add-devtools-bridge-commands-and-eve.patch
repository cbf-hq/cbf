+++ b/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
@@ -96,6 +96,7 @@ void CbfBridgeClientImpl::Observer::OnSurfaceHandleUpdated(
 
 void CbfBridgeClientImpl::Observer::OnWebPageCreated(uint64_t tab_id,
                                                     uint64_t request_id) {
+  impl_->web_page_profiles.emplace(tab_id, profile_id_);
   CbfBridgeEventData event;
   event.kind = kEventWebPageCreated;
   event.tab_id = tab_id;
@@ -105,7 +106,24 @@ void CbfBridgeClientImpl::Observer::OnWebPageCreated(uint64_t tab_id,
   impl_->events.push(std::move(event));
 }
 
+void CbfBridgeClientImpl::Observer::OnDevToolsOpened(
+    uint64_t tab_id,
+    uint64_t devtools_tab_id) {
+  LOG(INFO) << "[CBF][Bridge] OnDevToolsOpened inspected_id=" << tab_id
+            << " devtools_id=" << devtools_tab_id
+            << " profile_id=" << profile_id_;
+  impl_->web_page_profiles.emplace(devtools_tab_id, profile_id_);
+  CbfBridgeEventData event;
+  event.kind = kEventDevToolsOpened;
+  event.tab_id = devtools_tab_id;
+  event.inspected_tab_id = tab_id;
+  event.profile_id = profile_id_;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
 void CbfBridgeClientImpl::Observer::OnWebPageClosed(uint64_t tab_id) {
+  impl_->web_page_profiles.erase(tab_id);
   CbfBridgeEventData event;
   event.kind = kEventWebPageClosed;
   event.tab_id = tab_id;
