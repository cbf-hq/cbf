diff --git a/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc b/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc
index a2c4fa5255304..04e6a3ac6038d 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc
+++ b/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc
@@ -316,6 +316,61 @@ bool CbfBridgeClient::Reload(uint64_t web_page_id, bool ignore_cache) {
   return true;
 }
 
+bool CbfBridgeClient::OpenDevTools(uint64_t web_page_id) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t web_page_id) {
+            auto it = impl->web_page_profiles.find(web_page_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->OpenDevTools(web_page_id);
+          },
+          impl, web_page_id));
+  return true;
+}
+
+bool CbfBridgeClient::InspectElement(uint64_t web_page_id, int32_t x, int32_t y) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t web_page_id, int32_t x,
+             int32_t y) {
+            auto it = impl->web_page_profiles.find(web_page_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->InspectElement(web_page_id, x, y);
+          },
+          impl, web_page_id, x, y));
+  return true;
+}
+
 bool CbfBridgeClient::GetWebPageDomHtml(uint64_t web_page_id, uint64_t request_id) {
   if (!impl_) {
     return false;
@@ -449,3 +504,25 @@ extern "C" bool cbf_bridge_client_get_web_page_dom_html(
   return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
       ->GetWebPageDomHtml(web_page_id, request_id);
 }
+
+extern "C" bool cbf_bridge_client_open_dev_tools(
+    CbfBridgeClientHandle* client,
+    uint64_t web_page_id) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->OpenDevTools(web_page_id);
+}
+
+extern "C" bool cbf_bridge_client_inspect_element(
+    CbfBridgeClientHandle* client,
+    uint64_t web_page_id,
+    int32_t x,
+    int32_t y) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->InspectElement(web_page_id, x, y);
+}
