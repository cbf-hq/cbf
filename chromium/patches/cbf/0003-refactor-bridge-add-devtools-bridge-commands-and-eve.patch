   uint8_t beforeunload_reason;
   uint8_t cursor_type;
@@ -506,6 +508,12 @@ bool cbf_bridge_client_go_forward(CbfBridgeClientHandle* client,
 bool cbf_bridge_client_reload(CbfBridgeClientHandle* client,
                                uint64_t web_page_id,
                                bool ignore_cache);
+bool cbf_bridge_client_open_dev_tools(CbfBridgeClientHandle* client,
