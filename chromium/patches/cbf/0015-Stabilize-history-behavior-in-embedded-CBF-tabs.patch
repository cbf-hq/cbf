+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       HistoryPageHidesSyncedTabsUiInCbfTabs) {
+  const TabId tab_id = CreatePage("chrome://history");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  EXPECT_EQ(true, content::EvalJs(web_contents, R"(
+    (async () => {
+      await customElements.whenDefined('history-app');
+      await customElements.whenDefined('history-side-bar');
+      await new Promise(resolve => requestAnimationFrame(resolve));
+
+      const app = document.querySelector('history-app');
+      if (!app) {
+        return false;
+      }
+
+      const sideBar = app?.shadowRoot?.querySelector('#contentSideBar');
+      if (!sideBar) {
+        return false;
+      }
+
+      return !sideBar?.shadowRoot?.querySelector('#syncedTabs');
+    })();
+  )"));
+}
