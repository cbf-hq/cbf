index da2dd78c8556d..76d8f2d5c92ac 100644
--- a/chrome/browser/cbf/cbf_embedded_browser_window.cc
+++ b/chrome/browser/cbf/cbf_embedded_browser_window.cc
@@ -19,6 +19,7 @@
 #include "chrome/browser/ui/browser_list_observer.h"
 #include "chrome/browser/ui/browser_window.h"
 #include "chrome/browser/ui/browser_window/public/browser_window_features.h"
+#include "chrome/browser/ui/webui/webui_embedding_context.h"
 #include "chrome/browser/ui/dialogs/browser_dialogs.h"
 #include "chrome/browser/ui/find_bar/find_bar.h"
 #include "chrome/browser/ui/location_bar/location_bar.h"
@@ -476,8 +477,27 @@ Browser* CreateCbfEmbeddedBrowser(Profile* profile, bool for_devtools) {
   Browser::CreateParams params =
       for_devtools ? Browser::CreateParams::CreateForDevTools(profile)
                    : Browser::CreateParams(profile, /*user_gesture=*/false);
+  params.omit_from_session_restore = true;
+  params.should_trigger_session_restore = false;
+  params.trusted_source = true;
   params.window = new CbfEmbeddedBrowserWindow();
   return Browser::Create(params);
 }
 
+bool IsCbfEmbeddedBrowser(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return false;
+  }
+
+  BrowserWindowInterface* browser_window_interface =
+      webui::GetBrowserWindowInterface(web_contents);
+  if (!browser_window_interface) {
+    return false;
+  }
+
+  Browser* browser = browser_window_interface->GetBrowserForMigrationOnly();
+  return browser && browser->omit_from_session_restore() &&
+         browser->window() && browser->window()->AsBrowserView() == nullptr;
+}
+
 }  // namespace cbf
