 CbfProfileService::~CbfProfileService() {
   profile_observation_.Reset();
+  const std::vector<TabId> tab_ids = GetAllTabIds();
+  for (const TabId tab_id : tab_ids) {
+    if (tab_id == kInvalidTabId) {
+      continue;
+    }
+    context_menu_controller_->OnWebPageClosed(tab_id);
+    input_controller_->OnWebPageClosed(tab_id);
+    ime_controller_->OnWebPageClosed(tab_id);
+    drag_controller_->OnWebPageClosed(tab_id);
+    devtools_controller_->OnWebPageClosed(tab_id);
+  }
   CloseAllWebPages();
 }
 
