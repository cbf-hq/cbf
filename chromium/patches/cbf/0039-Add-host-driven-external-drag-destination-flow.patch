+bool CbfBridgeClient::SendExternalDragEnter(const CbfExternalDragEnter* event) {
+  if (!event || !impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  auto mojom_event = cbf::mojom::CbfExternalDragEnter::New();
+  mojom_event->tab_id = event->tab_id;
+  mojom_event->data = ConvertCbfDragDataToMojom(event->data);
+  mojom_event->allowed_operations = event->allowed_operations;
+  mojom_event->modifiers = event->modifiers;
+  mojom_event->position_in_widget_x = event->position_in_widget_x;
+  mojom_event->position_in_widget_y = event->position_in_widget_y;
+  mojom_event->position_in_screen_x = event->position_in_screen_x;
+  mojom_event->position_in_screen_y = event->position_in_screen_y;
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl,
+             cbf::mojom::CbfExternalDragEnterPtr event) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(event->tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->SendExternalDragEnter(std::move(event));
+          },
+          impl, std::move(mojom_event)));
+  return true;
+}
