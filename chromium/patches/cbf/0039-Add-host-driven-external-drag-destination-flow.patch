+void CbfProfileDragController::SendExternalDragUpdate(
+    mojom::CbfExternalDragUpdatePtr event) {
+  if (!event || !external_drag_state_ ||
+      external_drag_state_->tab_id != event->tab_id) {
+    return;
+  }
+
+  content::WebContentsImpl* web_contents =
+      AsWebContentsImpl(context_->tab_manager().GetWebContents(event->tab_id));
+  if (!web_contents || !web_contents->GetRenderWidgetHostView()) {
+    ResetExternalDragState();
+    return;
+  }
+
+  const gfx::PointF client_point(event->position_in_widget_x,
+                                 event->position_in_widget_y);
+  const gfx::PointF screen_point(event->position_in_screen_x,
+                                 event->position_in_screen_y);
+  const blink::DragOperationsMask allowed_ops =
+      static_cast<blink::DragOperationsMask>(event->allowed_operations);
+  const int modifiers = static_cast<int>(event->modifiers);
+  const uint64_t generation = external_drag_state_->generation;
+  const uint64_t sequence = ++external_drag_state_->update_sequence;
+
+  web_contents->PreHandleDragUpdate(external_drag_state_->drop_data_unfiltered,
+                                    client_point);
+
+  web_contents->GetRenderWidgetHostAtPointAsynchronously(
+      static_cast<content::RenderWidgetHostViewBase*>(
+          web_contents->GetRenderWidgetHostView()),
+      client_point,
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileDragController> self, uint64_t generation,
+             uint64_t sequence, gfx::PointF client_point,
+             gfx::PointF screen_point, blink::DragOperationsMask allowed_ops,
+             int modifiers,
+             base::WeakPtr<content::RenderWidgetHostViewBase> target_view,
+             std::optional<gfx::PointF> transformed_point) {
+            if (!self || !transformed_point.has_value() ||
+                !self->external_drag_state_ ||
+                self->external_drag_state_->generation != generation ||
+                self->external_drag_state_->update_sequence != sequence) {
+              return;
+            }
+
+            content::WebContentsImpl* web_contents = AsWebContentsImpl(
+                self->context_->tab_manager().GetWebContents(
+                    self->external_drag_state_->tab_id));
+            if (!web_contents || !target_view) {
+              self->ResetExternalDragState();
+              return;
+            }
+
+            auto* rwh = target_view->GetRenderWidgetHost();
+            auto* target_rwh = content::RenderWidgetHostImpl::From(rwh);
+            if (!target_rwh) {
+              self->ResetExternalDragState();
+              return;
+            }
+
+            if (self->external_drag_state_->current_target_rwh &&
+                self->external_drag_state_->current_target_rwh.get() !=
+                    target_rwh) {
+              self->external_drag_state_->current_target_rwh->DragTargetDragLeave(
+                  gfx::PointF(), gfx::PointF());
+              self->external_drag_state_->drop_data_filtered.reset();
+            }
+
+            if (!self->external_drag_state_->current_target_rwh ||
+                self->external_drag_state_->current_target_rwh.get() !=
+                    target_rwh ||
+                !self->external_drag_state_->drop_data_filtered) {
+              auto filtered = std::make_unique<content::DropData>(
+                  self->external_drag_state_->drop_data_unfiltered);
+              target_rwh->FilterDropData(filtered.get());
+              if (auto* delegate = web_contents->GetDelegate();
+                  delegate &&
+                  !delegate->CanDragEnter(web_contents, *filtered,
+                                          allowed_ops)) {
+                self->NotifyExternalDragOperationChanged(
+                    self->external_drag_state_->tab_id,
+                    ui::mojom::DragOperation::kNone);
+                self->external_drag_state_->last_operation =
+                    ui::mojom::DragOperation::kNone;
+                self->external_drag_state_->drop_data_filtered.reset();
+                self->external_drag_state_->current_target_rwh.reset();
+                return;
+              }
+
+              self->external_drag_state_->drop_data_filtered =
+                  std::move(filtered);
+              self->external_drag_state_->current_target_rwh =
+                  target_rwh->GetWeakPtr();
+              target_rwh->DragTargetDragEnter(
+                  *self->external_drag_state_->drop_data_filtered,
+                  *transformed_point, screen_point, allowed_ops, modifiers,
+                  base::BindOnce(
+                      &CbfProfileDragController::OnExternalDragOperationResolved,
+                      self, generation, self->external_drag_state_->tab_id));
+            }
+
+            target_rwh->DragTargetDragOver(
+                *transformed_point, screen_point, allowed_ops, modifiers,
+                base::BindOnce(
+                    &CbfProfileDragController::OnExternalDragOperationResolved,
+                    self, generation, self->external_drag_state_->tab_id));
+          },
+          weak_factory_.GetWeakPtr(), generation, sequence, client_point,
+          screen_point, allowed_ops, modifiers));
+}
