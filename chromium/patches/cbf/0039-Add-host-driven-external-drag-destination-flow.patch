+cbf::mojom::CbfDragDataPtr ConvertCbfDragDataToMojom(const CbfDragData& data) {
+  auto mojom_data = cbf::mojom::CbfDragData::New();
+  mojom_data->text = MaybeCopyString(data.text);
+  mojom_data->html = MaybeCopyString(data.html);
+  mojom_data->html_base_url = MaybeCopyString(data.html_base_url);
+
+  if (data.url_infos.items && data.url_infos.len > 0) {
+    auto infos =
+        UNSAFE_BUFFERS(base::span(data.url_infos.items, data.url_infos.len));
+    mojom_data->url_infos.reserve(infos.size());
+    for (const auto& info : infos) {
+      auto mojom_info = cbf::mojom::CbfDragUrlInfo::New();
+      mojom_info->url = MaybeCopyString(info.url);
+      mojom_info->title = MaybeCopyString(info.title);
+      mojom_data->url_infos.push_back(std::move(mojom_info));
+    }
+  }
+
+  if (data.filenames.items && data.filenames.len > 0) {
+    auto filenames =
+        UNSAFE_BUFFERS(base::span(data.filenames.items, data.filenames.len));
+    mojom_data->filenames.reserve(filenames.size());
+    for (const char* filename : filenames) {
+      mojom_data->filenames.push_back(MaybeCopyString(filename));
+    }
+  }
+
+  if (data.file_mime_types.items && data.file_mime_types.len > 0) {
+    auto mime_types = UNSAFE_BUFFERS(
+        base::span(data.file_mime_types.items, data.file_mime_types.len));
+    mojom_data->file_mime_types.reserve(mime_types.size());
+    for (const char* mime_type : mime_types) {
+      mojom_data->file_mime_types.push_back(MaybeCopyString(mime_type));
+    }
+  }
+
+  if (data.custom_data.items && data.custom_data.len > 0) {
+    auto pairs =
+        UNSAFE_BUFFERS(base::span(data.custom_data.items, data.custom_data.len));
+    mojom_data->custom_data.reserve(pairs.size());
+    for (const auto& pair : pairs) {
+      auto mojom_pair = cbf::mojom::CbfStringPair::New();
+      mojom_pair->key = MaybeCopyString(pair.key);
+      mojom_pair->value = MaybeCopyString(pair.value);
+      mojom_data->custom_data.push_back(std::move(mojom_pair));
+    }
+  }
+
+  return mojom_data;
+}
