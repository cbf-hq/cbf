+content::DropData ConvertExternalDragData(const mojom::CbfDragData* data) {
+  content::DropData drop_data;
+  if (!data) {
+    return drop_data;
+  }
+
+  if (!data->text.empty()) {
+    drop_data.text = base::UTF8ToUTF16(data->text);
+  }
+  if (!data->html.empty()) {
+    drop_data.html = base::UTF8ToUTF16(data->html);
+  }
+  if (!data->html_base_url.empty()) {
+    drop_data.html_base_url = GURL(data->html_base_url);
+  }
+
+  drop_data.url_infos.reserve(data->url_infos.size());
+  for (const auto& url_info : data->url_infos) {
+    if (!url_info) {
+      continue;
+    }
+    drop_data.url_infos.push_back(
+        ui::ClipboardUrlInfo{GURL(url_info->url),
+                             base::UTF8ToUTF16(url_info->title)});
+  }
+
+  drop_data.filenames.reserve(data->filenames.size());
+  for (const auto& filename : data->filenames) {
+    drop_data.filenames.push_back(
+        ui::FileInfo(base::FilePath::FromUTF8Unsafe(filename),
+                     base::FilePath()));
+  }
+
+  drop_data.file_mime_types.reserve(data->file_mime_types.size());
+  for (const auto& mime_type : data->file_mime_types) {
+    drop_data.file_mime_types.push_back(base::UTF8ToUTF16(mime_type));
+  }
+
+  for (const auto& pair : data->custom_data) {
+    if (!pair) {
+      continue;
+    }
+    drop_data.custom_data[base::UTF8ToUTF16(pair->key)] =
+        base::UTF8ToUTF16(pair->value);
+  }
+
+  return drop_data;
+}
+
+content::WebContentsImpl* AsWebContentsImpl(content::WebContents* web_contents) {
+  return static_cast<content::WebContentsImpl*>(web_contents);
+}
