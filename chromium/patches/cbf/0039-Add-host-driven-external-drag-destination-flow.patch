+void CbfProfileDragController::ResetExternalDragState(bool notify_operation) {
+  if (!external_drag_state_) {
+    return;
+  }
+
+  const TabId tab_id = external_drag_state_->tab_id;
+  external_drag_state_.reset();
+  if (notify_operation) {
+    NotifyExternalDragOperationChanged(tab_id,
+                                       ui::mojom::DragOperation::kNone);
