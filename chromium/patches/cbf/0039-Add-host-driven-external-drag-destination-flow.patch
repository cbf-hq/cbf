+  content::WebContentsImpl* web_contents =
+      AsWebContentsImpl(context_->tab_manager().GetWebContents(tab_id));
+  if (web_contents) {
+    web_contents->PreHandleDragExit();
+  }
+  if (external_drag_state_->current_target_rwh) {
+    external_drag_state_->current_target_rwh->DragTargetDragLeave(
+        gfx::PointF(), gfx::PointF());
