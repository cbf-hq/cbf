+mojom::CbfDragDataPtr ConvertDropDataToMojomDragData(
+    const content::DropData& drop_data) {
+  auto data = mojom::CbfDragData::New();
+  data->text = base::UTF16ToUTF8(drop_data.text.value_or(std::u16string()));
+  data->html = base::UTF16ToUTF8(drop_data.html.value_or(std::u16string()));
+  data->html_base_url = drop_data.html_base_url.spec();
+
+  data->url_infos.reserve(drop_data.url_infos.size());
+  for (const auto& url_info : drop_data.url_infos) {
+    auto info = mojom::CbfDragUrlInfo::New();
+    info->url = url_info.url.spec();
+    info->title = base::UTF16ToUTF8(url_info.title);
+    data->url_infos.push_back(std::move(info));
+  }
+
+  data->filenames.reserve(drop_data.filenames.size());
+  for (const auto& file_info : drop_data.filenames) {
+    data->filenames.push_back(file_info.path.AsUTF8Unsafe());
+  }
+
+  data->file_mime_types.reserve(drop_data.file_mime_types.size());
+  for (const auto& mime_type : drop_data.file_mime_types) {
+    data->file_mime_types.push_back(base::UTF16ToUTF8(mime_type));
+  }
+
+  data->custom_data.reserve(drop_data.custom_data.size());
+  for (const auto& [key, value] : drop_data.custom_data) {
+    auto pair = mojom::CbfStringPair::New();
+    pair->key = base::UTF16ToUTF8(key);
+    pair->value = base::UTF16ToUTF8(value);
+    data->custom_data.push_back(std::move(pair));
+  }
+
+  return data;
+}
