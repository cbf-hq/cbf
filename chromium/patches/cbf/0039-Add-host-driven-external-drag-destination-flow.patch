+void CbfBridgeClientImpl::Observer::OnExternalDragOperationChanged(
+    uint64_t tab_id,
+    uint32_t operation) {
+  CbfBridgeEventData event;
+  event.kind = kEventExternalDragOperationChanged;
+  event.tab_id = tab_id;
+  event.profile_id = profile_id_;
+  event.drag_operation = operation;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
