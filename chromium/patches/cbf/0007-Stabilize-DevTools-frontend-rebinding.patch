+bool IsDevToolsAllowed(content::WebContents* inspected_contents) {
+  if (!inspected_contents) {
+    return false;
+  }
+  Profile* profile = Profile::FromBrowserContext(
+      inspected_contents->GetBrowserContext());
+  if (!profile) {
+    return false;
+  }
+  return DevToolsWindow::AllowDevToolsFor(profile, inspected_contents);
