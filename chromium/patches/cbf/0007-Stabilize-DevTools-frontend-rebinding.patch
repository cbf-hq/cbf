+class CbfProfileDevToolsController::DevToolsFrontendObserver final
+    : public content::WebContentsObserver {
+ public:
+  DevToolsFrontendObserver(
+      content::WebContents* web_contents,
+      base::WeakPtr<CbfProfileDevToolsController> controller,
+      TabId inspected_tab_id,
+      TabId devtools_tab_id)
+      : content::WebContentsObserver(web_contents),
+        controller_(std::move(controller)),
+        inspected_tab_id_(inspected_tab_id),
+        devtools_tab_id_(devtools_tab_id) {}
+  ~DevToolsFrontendObserver() override = default;
+
+  void RenderFrameHostChanged(content::RenderFrameHost* old_frame,
+                              content::RenderFrameHost* new_frame) override {
+    if (!new_frame || !new_frame->IsInPrimaryMainFrame()) {
+      return;
+    }
+    if (!controller_) {
+      return;
+    }
+    controller_->OnDevToolsFrontendFrameChanged(inspected_tab_id_,
+                                                devtools_tab_id_);
