+bool CbfBrowserService::IsManagedWebContents(
+    content::WebContents* web_contents) const {
+  if (!web_contents) {
+    return false;
+  }
+
+  for (const auto& entry : profile_services_) {
+    const auto& service = entry.second;
+    if (!service) {
+      continue;
+    }
+    if (service->GetTabIdForWebContents(web_contents) !=
+        kInvalidTabId) {
+      return true;
+    }
+  }
+  return false;
