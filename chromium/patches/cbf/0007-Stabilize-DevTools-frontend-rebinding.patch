+  // Cross-RFH navigation: old DevToolsUIBindings destroyed, new one created.
+  // Transfer the delegate and session from old to new bindings.
+  if (session->bindings) {
+    session->bindings->TransferDelegate(*bindings);
+  } else {
+    // Shouldn't happen — initial attach sets bindings. Recover gracefully.
+    content::WebContents* inspected_contents =
