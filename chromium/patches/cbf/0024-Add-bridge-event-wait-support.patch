@@ -0,0 +1,139 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge_event_wait_state.h"
+
+#include <chrono>
+
+namespace cbf_bridge::internal {
+
+CbfBridgeEventData::CbfBridgeEventData() = default;
+CbfBridgeEventData::CbfBridgeEventData(CbfBridgeEventData&&) = default;
+CbfBridgeEventData& CbfBridgeEventData::operator=(CbfBridgeEventData&&) =
+    default;
+CbfBridgeEventData::~CbfBridgeEventData() = default;
+
+CbfBridgeEventData::ImeCompositionBoundsData::ImeCompositionBoundsData() =
+    default;
+CbfBridgeEventData::ImeCompositionBoundsData::ImeCompositionBoundsData(
+    const ImeCompositionBoundsData&) = default;
+CbfBridgeEventData::ImeCompositionBoundsData&
+CbfBridgeEventData::ImeCompositionBoundsData::operator=(
+    const ImeCompositionBoundsData&) = default;
+CbfBridgeEventData::ImeCompositionBoundsData::ImeCompositionBoundsData(
+    ImeCompositionBoundsData&&) = default;
+CbfBridgeEventData::ImeCompositionBoundsData&
+CbfBridgeEventData::ImeCompositionBoundsData::operator=(
+    ImeCompositionBoundsData&&) = default;
+CbfBridgeEventData::ImeCompositionBoundsData::~ImeCompositionBoundsData() =
+    default;
+
+CbfBridgeEventData::TextSelectionBoundsData::TextSelectionBoundsData() =
+    default;
+CbfBridgeEventData::TextSelectionBoundsData::TextSelectionBoundsData(
+    const TextSelectionBoundsData&) = default;
+CbfBridgeEventData::TextSelectionBoundsData&
+CbfBridgeEventData::TextSelectionBoundsData::operator=(
+    const TextSelectionBoundsData&) = default;
+CbfBridgeEventData::TextSelectionBoundsData::TextSelectionBoundsData(
+    TextSelectionBoundsData&&) = default;
+CbfBridgeEventData::TextSelectionBoundsData&
+CbfBridgeEventData::TextSelectionBoundsData::operator=(
+    TextSelectionBoundsData&&) = default;
+CbfBridgeEventData::TextSelectionBoundsData::~TextSelectionBoundsData() =
+    default;
+
+CbfBridgeEventWaitState::EventQueue::EventQueue(CbfBridgeEventWaitState* owner)
+    : owner_(owner) {}
+
+CbfBridgeEventWaitState::EventQueue::~EventQueue() = default;
+
+bool CbfBridgeEventWaitState::EventQueue::empty() const {
+  return queue_.empty();
+}
+
+CbfBridgeEventData& CbfBridgeEventWaitState::EventQueue::front() {
+  return queue_.front();
+}
+
+void CbfBridgeEventWaitState::EventQueue::pop() {
+  queue_.pop();
+}
+
+void CbfBridgeEventWaitState::EventQueue::push(CbfBridgeEventData event) {
+  queue_.push(std::move(event));
+  owner_->events_cv_.notify_all();
+}
+
+CbfBridgeEventWaitState::CbfBridgeEventWaitState() : events_(this) {}
+CbfBridgeEventWaitState::~CbfBridgeEventWaitState() = default;
+
+CbfBridgeEventWaitStatus CbfBridgeEventWaitState::WaitForEvent(
+    int64_t timeout_ms) {
+  std::unique_lock<std::mutex> lock(mutex_);
+
+  auto has_signal = [this]() {
+    return !events_.empty() || is_closed_ || is_disconnected_;
+  };
+
+  if (timeout_ms < 0) {
+    events_cv_.wait(lock, has_signal);
+  } else if (timeout_ms == 0) {
+    if (!has_signal()) {
+      return kCbfBridgeEventWaitStatusTimedOut;
+    }
+  } else {
+    const auto timeout = std::chrono::milliseconds(timeout_ms);
+    if (!events_cv_.wait_for(lock, timeout, has_signal)) {
+      return kCbfBridgeEventWaitStatusTimedOut;
+    }
+  }
+
+  if (!events_.empty()) {
+    return kCbfBridgeEventWaitStatusEventAvailable;
+  }
+  if (is_closed_) {
+    return kCbfBridgeEventWaitStatusClosed;
+  }
+  if (is_disconnected_) {
+    return kCbfBridgeEventWaitStatusDisconnected;
+  }
+
+  return kCbfBridgeEventWaitStatusTimedOut;
+}
+
+void CbfBridgeEventWaitState::PushEvent(CbfBridgeEventData event) {
+  std::lock_guard<std::mutex> lock(mutex_);
+  events_.push(std::move(event));
+}
+
+std::optional<CbfBridgeEventData> CbfBridgeEventWaitState::PopEvent() {
+  std::lock_guard<std::mutex> lock(mutex_);
+  if (events_.empty()) {
+    return std::nullopt;
+  }
+  CbfBridgeEventData event = std::move(events_.front());
+  events_.pop();
+  return event;
+}
+
+void CbfBridgeEventWaitState::MarkDisconnected() {
+  std::lock_guard<std::mutex> lock(mutex_);
+  if (is_closed_ || is_disconnected_) {
+    return;
+  }
+  is_disconnected_ = true;
+  events_cv_.notify_all();
+}
+
+void CbfBridgeEventWaitState::MarkClosed() {
+  std::lock_guard<std::mutex> lock(mutex_);
+  if (is_closed_) {
+    return;
+  }
+  is_closed_ = true;
+  events_cv_.notify_all();
+}
+
+void CbfBridgeEventWaitState::NotifyShutdown() {
+  MarkClosed();
+}
+
+}  // namespace cbf_bridge::internal
