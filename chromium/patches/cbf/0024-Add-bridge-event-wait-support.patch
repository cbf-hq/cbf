diff --git a/chrome/browser/cbf/bridge/cbf_bridge_event_wait_state_unittest.cc b/chrome/browser/cbf/bridge/cbf_bridge_event_wait_state_unittest.cc
new file mode 100644
index 0000000000000..7be753541d67c
--- /dev/null
+++ b/chrome/browser/cbf/bridge/cbf_bridge_event_wait_state_unittest.cc
@@ -0,0 +1,129 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge_event_wait_state.h"
+
+#include <optional>
+#include <thread>
+
+#include "base/synchronization/waitable_event.h"
+#include "testing/gtest/include/gtest/gtest.h"
+
+namespace cbf_bridge::internal {
+namespace {
+
+TEST(CbfBridgeEventWaitStateTest, WaitForEventTimesOutWhenQueueIsEmpty) {
+  CbfBridgeEventWaitState state;
+
+  EXPECT_EQ(kCbfBridgeEventWaitStatusTimedOut, state.WaitForEvent(5));
+}
+
+TEST(CbfBridgeEventWaitStateTest, EnqueueEventWakesWaitingThread) {
+  CbfBridgeEventWaitState state;
+  base::WaitableEvent waiter_started(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  std::optional<CbfBridgeEventWaitStatus> status;
+
+  std::thread waiter([&]() {
+    waiter_started.Signal();
+    status = state.WaitForEvent(-1);
+  });
+
+  waiter_started.Wait();
+
+  CbfBridgeEventData event;
+  event.kind = kEventShutdownCancelled;
+  event.request_id = 17u;
+  state.PushEvent(std::move(event));
+
+  waiter.join();
+
+  ASSERT_TRUE(status.has_value());
+  EXPECT_EQ(kCbfBridgeEventWaitStatusEventAvailable, *status);
+
+  auto popped = state.PopEvent();
+  ASSERT_TRUE(popped.has_value());
+  EXPECT_EQ(kEventShutdownCancelled, popped->kind);
+  EXPECT_EQ(17u, popped->request_id);
+}
+
+TEST(CbfBridgeEventWaitStateTest, MarkClosedWakesWaitingThread) {
+  CbfBridgeEventWaitState state;
+  base::WaitableEvent waiter_started(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  std::optional<CbfBridgeEventWaitStatus> status;
+
+  std::thread waiter([&]() {
+    waiter_started.Signal();
+    status = state.WaitForEvent(-1);
+  });
+
+  waiter_started.Wait();
+  state.MarkClosed();
+  waiter.join();
+
+  ASSERT_TRUE(status.has_value());
+  EXPECT_EQ(kCbfBridgeEventWaitStatusClosed, *status);
+  EXPECT_EQ(kCbfBridgeEventWaitStatusClosed, state.WaitForEvent(0));
+}
+
+TEST(CbfBridgeEventWaitStateTest, MarkDisconnectedWakesWaitingThread) {
+  CbfBridgeEventWaitState state;
+  base::WaitableEvent waiter_started(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  std::optional<CbfBridgeEventWaitStatus> status;
+
+  std::thread waiter([&]() {
+    waiter_started.Signal();
+    status = state.WaitForEvent(-1);
+  });
+
+  waiter_started.Wait();
+  state.MarkDisconnected();
+  waiter.join();
+
+  ASSERT_TRUE(status.has_value());
+  EXPECT_EQ(kCbfBridgeEventWaitStatusDisconnected, *status);
+  EXPECT_EQ(kCbfBridgeEventWaitStatusDisconnected, state.WaitForEvent(0));
+}
+
+TEST(CbfBridgeEventWaitStateTest, PendingEventCanBePoppedWithoutWaiting) {
+  CbfBridgeEventWaitState state;
+  CbfBridgeEventData event;
+  event.kind = kEventShutdownProceeding;
+  event.request_id = 33u;
+
+  state.PushEvent(std::move(event));
+
+  EXPECT_EQ(kCbfBridgeEventWaitStatusEventAvailable, state.WaitForEvent(0));
+
+  auto popped = state.PopEvent();
+  ASSERT_TRUE(popped.has_value());
+  EXPECT_EQ(kEventShutdownProceeding, popped->kind);
+  EXPECT_EQ(33u, popped->request_id);
+  EXPECT_EQ(kCbfBridgeEventWaitStatusTimedOut, state.WaitForEvent(0));
+}
+
+TEST(CbfBridgeEventWaitStateTest, NotifyShutdownWakesWaitingThread) {
+  CbfBridgeEventWaitState state;
+  base::WaitableEvent waiter_started(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  std::optional<CbfBridgeEventWaitStatus> status;
+
+  std::thread waiter([&]() {
+    waiter_started.Signal();
+    status = state.WaitForEvent(-1);
+  });
+
+  waiter_started.Wait();
+  state.NotifyShutdown();
+  waiter.join();
+
+  ASSERT_TRUE(status.has_value());
+  EXPECT_EQ(kCbfBridgeEventWaitStatusClosed, *status);
+  EXPECT_EQ(kCbfBridgeEventWaitStatusClosed, state.WaitForEvent(0));
+}
+
+}  // namespace
+}  // namespace cbf_bridge::internal
