+void CbfProfileService::FindInPage(uint64_t tab_id,
+                                   uint64_t request_id,
+                                   const std::string& query,
+                                   bool forward,
+                                   bool match_case,
+                                   bool new_session,
+                                   bool find_match) {
+  content::WebContents* web_contents = tab_manager_.GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  if (query.empty()) {
+    LOG(WARNING) << "CBF FindInPage ignored empty query: tab_id=" << tab_id
+                 << " request_id=" << request_id;
+    return;
+  }
+
+  const std::optional<int> chromium_request_id = ToFindRequestId(request_id);
+  if (!chromium_request_id.has_value()) {
+    LOG(WARNING) << "CBF FindInPage ignored out-of-range request id: tab_id="
+                 << tab_id << " request_id=" << request_id;
+    return;
+  }
+
+  auto options = blink::mojom::FindOptions::New();
+  options->forward = forward;
+  options->match_case = match_case;
+  options->new_session = new_session;
+  options->find_match = find_match;
+
+  web_contents->Find(*chromium_request_id, base::UTF8ToUTF16(query),
+                     std::move(options), false);
+}
+
+void CbfProfileService::StopFinding(uint64_t tab_id,
+                                    mojom::CbfStopFindAction action) {
+  content::WebContents* web_contents = tab_manager_.GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  web_contents->StopFinding(ToBlinkStopFindAction(action));
+}
