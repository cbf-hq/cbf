+bool CbfBridgeClient::FindInPage(uint64_t tab_id,
+                                 uint64_t request_id,
+                                 const std::string& query,
+                                 bool forward,
+                                 bool match_case,
+                                 bool new_session,
+                                 bool find_match) {
+  if (!impl_ || query.empty()) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id, uint64_t request_id,
+             std::string query, bool forward, bool match_case,
+             bool new_session, bool find_match) {
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->FindInPage(
+                tab_id, request_id, query, forward, match_case, new_session,
+                find_match);
+          },
+          impl, tab_id, request_id, query, forward, match_case, new_session,
+          find_match));
+  return true;
+}
+
+bool CbfBridgeClient::StopFinding(uint64_t tab_id, uint8_t action) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id, uint8_t action) {
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->StopFinding(
+                tab_id, static_cast<cbf::mojom::CbfStopFindAction>(action));
+          },
+          impl, tab_id, action));
+  return true;
+}
