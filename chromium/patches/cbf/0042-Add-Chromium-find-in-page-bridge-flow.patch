+void CbfBridgeClientImpl::Observer::OnFindReply(
+    uint64_t tab_id,
+    uint64_t request_id,
+    uint32_t number_of_matches,
+    cbf::mojom::CbfRectPtr selection_rect,
+    int32_t active_match_ordinal,
+    bool final_update) {
+  CbfBridgeEventData event;
+  event.kind = kEventFindReply;
+  event.tab_id = tab_id;
+  event.request_id = request_id;
+  event.profile_id = profile_id_;
+  event.find_number_of_matches = number_of_matches;
+  event.find_active_match_ordinal = active_match_ordinal;
+  event.find_final_update = final_update;
+  if (selection_rect) {
+    event.find_selection_rect = gfx::Rect(selection_rect->x, selection_rect->y,
+                                          selection_rect->width,
+                                          selection_rect->height);
+  }
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
