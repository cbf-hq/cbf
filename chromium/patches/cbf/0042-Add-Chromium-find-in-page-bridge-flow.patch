+using FindReplyEvent = cbf::test::CbfTestProfileObserver::FindReplyEvent;
+
+size_t CountFinalFindRepliesSince(const std::vector<FindReplyEvent>& events,
+                                  size_t baseline_count,
+                                  uint64_t tab_id) {
+  return std::count_if(events.begin() + baseline_count, events.end(),
+                       [tab_id](const FindReplyEvent& event) {
+                         return event.tab_id == tab_id && event.final_update;
+                       });
+}
+
+const FindReplyEvent* FindNthFinalFindReplySince(
+    const std::vector<FindReplyEvent>& events,
+    size_t baseline_count,
+    uint64_t tab_id,
+    size_t ordinal) {
+  size_t seen = 0;
+  for (auto it = events.begin() + baseline_count; it != events.end(); ++it) {
