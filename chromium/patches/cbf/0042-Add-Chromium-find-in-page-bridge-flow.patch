+void CbfProfileService::NotifyFindReply(content::WebContents* web_contents,
+                                        uint64_t request_id,
+                                        int number_of_matches,
+                                        const gfx::Rect& selection_rect,
+                                        int active_match_ordinal,
+                                        bool final_update) {
+  if (!web_contents || !observer_) {
+    return;
+  }
+
+  if (GetActiveExtensionPopup(web_contents)) {
+    return;
+  }
+
+  const TabId tab_id = tab_manager_.GetTabIdForWebContents(web_contents);
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  observer_->OnFindReply(tab_id, request_id, number_of_matches,
+                         mojo_converters::ToCbfRect(selection_rect),
+                         active_match_ordinal, final_update);
+}
