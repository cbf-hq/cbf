From c10d8bbfd93ce0acd5851618aa6d416f22bdf3bd Mon Sep 17 00:00:00 2001
From: Takagi Tasuku <tasuren@outlook.jp>
Date: Sat, 21 Feb 2026 17:32:32 +0900
Subject: [PATCH 4/9] chore(chrome): add devtools ui bindings diagnostics

---
 .../browser/devtools/devtools_ui_bindings.cc  | 25 +++++++++++++++++++
 1 file changed, 25 insertions(+)

diff --git a/chrome/browser/devtools/devtools_ui_bindings.cc b/chrome/browser/devtools/devtools_ui_bindings.cc
index bca7234c606be..21f332160b77c 100644
--- a/chrome/browser/devtools/devtools_ui_bindings.cc
+++ b/chrome/browser/devtools/devtools_ui_bindings.cc
@@ -860,6 +860,8 @@ DevToolsUIBindings::~DevToolsUIBindings() {
 void DevToolsUIBindings::HandleMessageFromDevToolsFrontend(
     base::DictValue message) {
   if (!frontend_host_) {
+    LOG(INFO) << "[CBF][DevToolsUIBindings] Drop frontend message: "
+              << "frontend_host is null";
     return;
   }
   const std::string* method = message.FindString(kFrontendHostMethod);
@@ -869,6 +871,8 @@ void DevToolsUIBindings::HandleMessageFromDevToolsFrontend(
     return;
   }
   int id = message.FindInt(kFrontendHostId).value_or(0);
+  LOG(INFO) << "[CBF][DevToolsUIBindings] Frontend->Embedder method="
+            << (method ? *method : std::string("<null>")) << " id=" << id;
   base::ListValue params_list;
   if (params) {
     params_list = std::move(*params).TakeList();
@@ -891,8 +895,12 @@ void DevToolsUIBindings::DispatchProtocolMessage(
     base::span<const uint8_t> message) {
   DCHECK(agent_host == agent_host_.get());
   if (!frontend_host_) {
+    LOG(INFO) << "[CBF][DevToolsUIBindings] Drop backend protocol message: "
+              << "frontend_host is null";
     return;
   }
+  LOG(INFO) << "[CBF][DevToolsUIBindings] Backend->Frontend protocol bytes="
+            << message.size();
 
   std::string_view message_sp(reinterpret_cast<const char*>(message.data()),
                               message.size());
@@ -2156,6 +2164,7 @@ void DevToolsUIBindings::ReadyForTest() {
 }
 
 void DevToolsUIBindings::ConnectionReady() {
+  LOG(INFO) << "[CBF][DevToolsUIBindings] ConnectionReady delegate call";
   delegate_->ConnectionReady();
 }
 
@@ -2166,8 +2175,12 @@ void DevToolsUIBindings::SetOpenNewWindowForPopups(bool value) {
 void DevToolsUIBindings::DispatchProtocolMessageFromDevToolsFrontend(
     const std::string& message) {
   if (!agent_host_) {
+    LOG(INFO) << "[CBF][DevToolsUIBindings] Drop frontend protocol message: "
+              << "agent_host is null";
     return;
   }
+  LOG(INFO) << "[CBF][DevToolsUIBindings] Frontend->Backend protocol bytes="
+            << message.size();
   agent_host_->DispatchProtocolMessage(this, base::as_byte_span(message));
 }
 
@@ -2939,6 +2952,11 @@ void DevToolsUIBindings::CallClientMethodImpl(
 void DevToolsUIBindings::ReadyToCommitNavigation(
     content::NavigationHandle* navigation_handle) {
   if (navigation_handle->IsInPrimaryMainFrame()) {
+    LOG(INFO) << "[CBF][DevToolsUIBindings] ReadyToCommitNavigation url="
+              << navigation_handle->GetURL()
+              << " frontend_loaded=" << frontend_loaded_
+              << " has_agent_host=" << static_cast<bool>(agent_host_.get())
+              << " has_frontend_host=" << static_cast<bool>(frontend_host_);
     if (frontend_loaded_ && agent_host_.get()) {
       agent_host_->DetachClient(this);
       InnerAttach();
@@ -2950,6 +2968,8 @@ void DevToolsUIBindings::ReadyToCommitNavigation(
       return;
     }
     if (frontend_host_) {
+      LOG(INFO) << "[CBF][DevToolsUIBindings] ReadyToCommitNavigation: "
+                << "frontend_host already exists";
       return;
     }
     if (content::RenderFrameHost* opener = web_contents_->GetOpener()) {
@@ -2958,6 +2978,9 @@ void DevToolsUIBindings::ReadyToCommitNavigation(
       DevToolsUIBindings* opener_bindings =
           opener_wc ? DevToolsUIBindings::ForWebContents(opener_wc) : nullptr;
       if (!opener_bindings || !opener_bindings->frontend_host_) {
+        LOG(INFO) << "[CBF][DevToolsUIBindings] ReadyToCommitNavigation: "
+                  << "waiting for opener frontend host; opener_wc="
+                  << static_cast<const void*>(opener_wc);
         return;
       }
     }
@@ -2966,6 +2989,8 @@ void DevToolsUIBindings::ReadyToCommitNavigation(
         base::BindRepeating(
             &DevToolsUIBindings::HandleMessageFromDevToolsFrontend,
             base::Unretained(this)));
+    LOG(INFO) << "[CBF][DevToolsUIBindings] ReadyToCommitNavigation: "
+              << "frontend_host created";
     return;
   }
 
-- 
