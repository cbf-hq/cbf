 }
 
 void CbfJavaScriptDialogManager::ResolvePendingBeforeUnload(bool proceed) {
-  for (auto& callback : pending_beforeunload_callbacks_) {
-    std::move(callback).Run(proceed, std::u16string());
+  for (auto& pending : pending_beforeunload_callbacks_) {
+    std::move(pending.callback).Run(proceed, std::u16string());
   }
   pending_beforeunload_callbacks_.clear();
 }
@@ -42,9 +62,9 @@ void CbfJavaScriptDialogManager::ResolvePendingBeforeUnloadRequest(
   if (it == pending_beforeunload_requests_.end()) {
     return;
   }
-  auto callback = std::move(it->second);
+  auto pending = std::move(it->second);
   pending_beforeunload_requests_.erase(it);
-  std::move(callback).Run(proceed, std::u16string());
+  std::move(pending.callback).Run(proceed, std::u16string());
 }
 
 void CbfJavaScriptDialogManager::ResolvePendingJavaScriptDialogRequest(
@@ -96,6 +116,7 @@ void CbfJavaScriptDialogManager::RunJavaScriptDialog(
 
   const uint64_t request_id = next_javascript_dialog_request_id_++;
   PendingJavaScriptDialogRequest pending;
+  pending.web_contents = web_contents->GetWeakPtr();
   pending.callback = std::move(callback);
   pending_javascript_dialog_requests_.emplace(request_id, std::move(pending));
   profile_service_->NotifyJavaScriptDialogRequested(
@@ -111,7 +132,12 @@ void CbfJavaScriptDialogManager::RunBeforeUnloadDialog(
     DialogClosedCallback callback) {
   (void)render_frame_host;
   if (profile_service_ && profile_service_->IsShutdownRequested()) {
-    pending_beforeunload_callbacks_.push_back(std::move(callback));
+    PendingBeforeUnloadCallback pending;
+    if (web_contents) {
+      pending.web_contents = web_contents->GetWeakPtr();
+    }
+    pending.callback = std::move(callback);
+    pending_beforeunload_callbacks_.push_back(std::move(pending));
     profile_service_->OnBeforeUnloadDialogRequested(web_contents);
     return;
   }
@@ -123,7 +149,10 @@ void CbfJavaScriptDialogManager::RunBeforeUnloadDialog(
   const auto reason =
       profile_service_->ResolveBeforeUnloadReason(web_contents, is_reload);
   const uint64_t request_id = next_beforeunload_request_id_++;
-  pending_beforeunload_requests_.emplace(request_id, std::move(callback));
+  PendingBeforeUnloadRequest pending;
+  pending.web_contents = web_contents->GetWeakPtr();
+  pending.callback = std::move(callback);
+  pending_beforeunload_requests_.emplace(request_id, std::move(pending));
   profile_service_->NotifyBeforeUnloadDialogRequested(web_contents, request_id,
                                                       reason);
 }
@@ -131,12 +160,51 @@ void CbfJavaScriptDialogManager::RunBeforeUnloadDialog(
 void CbfJavaScriptDialogManager::CancelDialogs(
     content::WebContents* web_contents,
     bool reset_state) {
-  (void)web_contents;
-  if (reset_state) {
-    pending_beforeunload_callbacks_.clear();
-    pending_beforeunload_requests_.clear();
-    pending_javascript_dialog_requests_.clear();
+  const auto matches_web_contents =
+      [web_contents](const base::WeakPtr<content::WebContents>& pending) {
+        return pending && pending.get() == web_contents;
+      };
+
+  auto beforeunload_callback_it = pending_beforeunload_callbacks_.begin();
+  while (beforeunload_callback_it != pending_beforeunload_callbacks_.end()) {
+    if (!matches_web_contents(beforeunload_callback_it->web_contents)) {
+      ++beforeunload_callback_it;
+      continue;
+    }
+
+    auto pending = std::move(*beforeunload_callback_it);
+    beforeunload_callback_it =
+        pending_beforeunload_callbacks_.erase(beforeunload_callback_it);
+    std::move(pending.callback).Run(false, std::u16string());
   }
+
+  auto beforeunload_request_it = pending_beforeunload_requests_.begin();
+  while (beforeunload_request_it != pending_beforeunload_requests_.end()) {
+    if (!matches_web_contents(beforeunload_request_it->second.web_contents)) {
+      ++beforeunload_request_it;
+      continue;
+    }
+
+    auto pending = std::move(beforeunload_request_it->second);
+    beforeunload_request_it =
+        pending_beforeunload_requests_.erase(beforeunload_request_it);
+    std::move(pending.callback).Run(false, std::u16string());
+  }
+
+  auto javascript_request_it = pending_javascript_dialog_requests_.begin();
+  while (javascript_request_it != pending_javascript_dialog_requests_.end()) {
+    if (!matches_web_contents(javascript_request_it->second.web_contents)) {
+      ++javascript_request_it;
+      continue;
+    }
+
+    auto pending = std::move(javascript_request_it->second);
+    javascript_request_it =
+        pending_javascript_dialog_requests_.erase(javascript_request_it);
+    std::move(pending.callback).Run(false, std::u16string());
+  }
+
+  (void)reset_state;
 }
 
 }  // namespace cbf
