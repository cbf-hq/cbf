+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       ClosingManagedTabWithPendingAlertDoesNotCrash) {
+  browser_observer_->RegisterResponse(
+      "/dialog.html", "text/html; charset=utf-8",
+      "<!doctype html><title>dialog</title><body>dialog</body>");
+
+  const TabId tab_id = CreatePage("app://simpleapp/dialog.html");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+  AllowMainFrameJavaScriptInjection(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  content::ExecuteScriptAsync(web_contents, "window.alert('managed alert');");
+  observer_.WaitForJavaScriptDialogCount(1);
+
+  ASSERT_EQ(observer_.javascript_dialog_events().size(), 1u);
+  const auto& dialog = observer_.javascript_dialog_events()[0];
+  EXPECT_EQ(dialog.tab_id, tab_id);
+  EXPECT_EQ(dialog.type, mojom::CbfJavaScriptDialogType::kAlert);
+  EXPECT_EQ(dialog.message, "managed alert");
+
+  profile_service_->CloseWebContents(web_contents);
+  observer_.WaitForWebPageClosedCount(1);
+
+  EXPECT_EQ(observer_.web_page_closed_events().size(), 1u);
+  EXPECT_EQ(observer_.web_page_closed_events()[0], tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       ClosingPopupWithPendingAlertDoesNotCrash) {
+  auto extension = LoadActionPopupExtensionWithScript(
+      "Popup Pending Dialog Extension", "alert('popup alert');",
+      "<!doctype html><title>Popup Dialog</title>"
+      "<body>popup<script src='popup.js'></script></body>");
+  ASSERT_TRUE(extension);
+
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  profile_service_->ActivateExtensionAction(tab_id, extension->id());
+  observer_.WaitForExtensionPopupOpenedCount(1);
+  observer_.WaitForExtensionPopupJavaScriptDialogCount(1);
+
+  ASSERT_EQ(observer_.extension_popup_javascript_dialog_events().size(), 1u);
+  const auto& dialog = observer_.extension_popup_javascript_dialog_events()[0];
+  EXPECT_EQ(dialog.type, mojom::CbfJavaScriptDialogType::kAlert);
+  EXPECT_EQ(dialog.message, "popup alert");
+
+  profile_service_->CloseExtensionPopup(dialog.popup_id);
+  observer_.WaitForExtensionPopupClosedCount(1);
+}
