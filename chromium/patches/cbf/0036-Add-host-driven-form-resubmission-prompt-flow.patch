+void CbfProfileService::ResolvePendingFormResubmissionPrompt(
+    PendingFormResubmissionPrompt pending,
+    mojom::CbfPromptUiResolutionResult result) {
+  content::WebContents* web_contents = pending.web_contents.get();
+  if (web_contents) {
+    if (result == mojom::CbfPromptUiResolutionResult::kAllowed) {
+      web_contents->GetController().ContinuePendingReload();
+    } else {
+      web_contents->GetController().CancelPendingReload();
+    }
+  }
+
+  NotifyPromptUiResolved(
+      pending.source_tab_id, pending.request_id,
+      mojom::CbfPromptUiKind::kFormResubmissionPrompt,
+      mojom::CbfPromptUiPermissionType::kUnknown, std::string(), result, 0,
+      std::nullopt, pending.reason, pending.target_url);
+}
+
+void CbfProfileService::ResolvePendingFormResubmissionPromptsForTab(
+    TabId tab_id,
+    mojom::CbfPromptUiResolutionResult result) {
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  for (auto it = pending_form_resubmission_prompts_.begin();
+       it != pending_form_resubmission_prompts_.end();) {
+    if (it->second.source_tab_id != std::optional<TabId>(tab_id)) {
+      ++it;
+      continue;
+    }
+    PendingFormResubmissionPrompt pending = std::move(it->second);
+    it = pending_form_resubmission_prompts_.erase(it);
+    ResolvePendingFormResubmissionPrompt(std::move(pending), result);
+  }
+}
+
+void CbfProfileService::ResolvePendingFormResubmissionPromptsForShutdown(
+    mojom::CbfPromptUiResolutionResult result) {
+  for (auto it = pending_form_resubmission_prompts_.begin();
+       it != pending_form_resubmission_prompts_.end();) {
+    PendingFormResubmissionPrompt pending = std::move(it->second);
+    it = pending_form_resubmission_prompts_.erase(it);
+    ResolvePendingFormResubmissionPrompt(std::move(pending), result);
+  }
+}
