+        std::string());
+  }
+  for (auto it = pending_extension_uninstall_prompts_.begin();
+       it != pending_extension_uninstall_prompts_.end();) {
+    const uint64_t request_id = it->first;
+    ++it;
+    ResolveExtensionUninstallPrompt(
+        request_id, mojom::CbfExtensionUninstallPromptResult::kAborted,
+        std::string(), false,
+        mojom::CbfAuxiliaryWindowCloseReason::kSystemDismissed);
+  }
+  ResolvePendingPermissionPromptsForShutdown(
+      mojom::CbfPromptUiResolutionResult::kAborted);
+  ResolvePendingDownloadPromptsForShutdown(
+      mojom::CbfPromptUiResolutionResult::kAborted);
+  ResolvePendingFormResubmissionPromptsForShutdown(
+      mojom::CbfPromptUiResolutionResult::kAborted);
+}
