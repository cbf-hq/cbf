+mojom::CbfFormResubmissionReason ToFormResubmissionReason(
+    content::NavigationController& controller) {
+  const content::NavigationEntry* pending_entry = controller.GetPendingEntry();
+  if (!pending_entry) {
+    return mojom::CbfFormResubmissionReason::kUnknown;
+  }
+
+  const ui::PageTransition transition = pending_entry->GetTransitionType();
+  if ((transition & ui::PAGE_TRANSITION_FORWARD_BACK) != 0) {
+    return mojom::CbfFormResubmissionReason::kBackForward;
+  }
+  if (ui::PageTransitionCoreTypeIs(transition, ui::PAGE_TRANSITION_RELOAD)) {
+    return mojom::CbfFormResubmissionReason::kReload;
+  }
+  return mojom::CbfFormResubmissionReason::kOther;
+}
+
+class CbfFormResubmissionPromptController final
+    : public TabModalConfirmDialogDelegate {
+ public:
+  CbfFormResubmissionPromptController(
+      content::WebContents* web_contents,
+      base::OnceCallback<void(mojom::CbfPromptUiResolutionResult)>
+          resolution_callback)
+      : TabModalConfirmDialogDelegate(web_contents),
+        resolution_callback_(std::move(resolution_callback)) {}
+
+  CbfFormResubmissionPromptController(
+      const CbfFormResubmissionPromptController&) = delete;
+  CbfFormResubmissionPromptController& operator=(
+      const CbfFormResubmissionPromptController&) = delete;
+  ~CbfFormResubmissionPromptController() override = default;
+
+ private:
+  std::u16string GetTitle() override {
+    return l10n_util::GetStringUTF16(IDS_HTTP_POST_WARNING_TITLE);
+  }
+
+  std::u16string GetDialogMessage() override {
+    return l10n_util::GetStringUTF16(IDS_HTTP_POST_WARNING);
+  }
+
+  std::u16string GetAcceptButtonTitle() override {
+    return l10n_util::GetStringUTF16(IDS_HTTP_POST_WARNING_RESEND);
+  }
+
+  void OnAccepted() override {
+    if (web_contents()) {
+      web_contents()->GetController().ContinuePendingReload();
+    }
+    Resolve(mojom::CbfPromptUiResolutionResult::kAllowed);
+  }
+
+  void OnCanceled() override {
+    if (web_contents()) {
+      web_contents()->GetController().CancelPendingReload();
+    }
+    Resolve(mojom::CbfPromptUiResolutionResult::kDenied);
+  }
+
+  void OnClosed() override {
+    if (web_contents()) {
+      web_contents()->GetController().CancelPendingReload();
+    }
+    Resolve(mojom::CbfPromptUiResolutionResult::kAborted);
+  }
+
+  void BeforeFormRepostWarningShow() override { Cancel(); }
+
+  void Resolve(mojom::CbfPromptUiResolutionResult result) {
+    if (!resolution_callback_) {
+      return;
+    }
+    std::move(resolution_callback_).Run(result);
+  }
+
+  base::OnceCallback<void(mojom::CbfPromptUiResolutionResult)>
+      resolution_callback_;
+};
