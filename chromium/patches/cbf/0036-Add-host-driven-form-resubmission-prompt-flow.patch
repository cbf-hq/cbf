+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       ReloadPostPageRequestsFormResubmissionPromptAndDenyCancels) {
+  EnsureFormResubmissionServerStarted();
+
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  const GURL post_url = embedded_test_server()->GetURL("/cbf-form-submit");
+  content::NavigationController::LoadURLParams load_params(post_url);
+  load_params.load_type = content::NavigationController::LOAD_TYPE_HTTP_POST;
+  load_params.extra_headers = "Content-Type: application/x-www-form-urlencoded";
+  const std::vector<uint8_t> post_data_bytes{
+      'p', 'a', 'y', 'l', 'o', 'a', 'd', '=', 'h', 'e', 'l', 'l', 'o'};
+  load_params.post_data =
+      network::ResourceRequestBody::CreateFromCopyOfBytes(post_data_bytes);
+  web_contents->GetController().LoadURLWithParams(load_params);
+  WaitForLoad(tab_id);
+  ASSERT_EQ(form_submit_count_, 1);
+
+  profile_service_->Reload(tab_id, /*ignore_cache=*/false);
+
+  observer_.WaitForPromptUiRequestedCount(1);
+  ASSERT_FALSE(observer_.prompt_ui_requested_events().empty());
+  const auto& request = observer_.prompt_ui_requested_events().back();
+  EXPECT_EQ(request.kind, mojom::CbfPromptUiKind::kFormResubmissionPrompt);
+  EXPECT_TRUE(request.repost_reason == mojom::CbfFormResubmissionReason::kReload ||
+              request.repost_reason == mojom::CbfFormResubmissionReason::kUnknown);
+  EXPECT_FALSE(request.repost_target_url.empty());
+
+  auto response = mojom::CbfPromptUiResponse::New();
+  response->kind = mojom::CbfPromptUiKind::kFormResubmissionPrompt;
+  response->allow = false;
+  profile_service_->RespondPromptUi(CanonicalProfileId(), request.request_id,
+                                    std::move(response));
+
+  observer_.WaitForPromptUiResolvedCount(1);
+  ASSERT_FALSE(observer_.prompt_ui_resolved_events().empty());
+  const auto& resolution = observer_.prompt_ui_resolved_events().back();
+  EXPECT_EQ(resolution.request_id, request.request_id);
+  EXPECT_EQ(resolution.kind, mojom::CbfPromptUiKind::kFormResubmissionPrompt);
+  EXPECT_EQ(resolution.result, mojom::CbfPromptUiResolutionResult::kDenied);
+  EXPECT_EQ(resolution.repost_reason, request.repost_reason);
+  EXPECT_FALSE(resolution.repost_target_url.empty());
+
+  base::RunLoop().RunUntilIdle();
+  EXPECT_EQ(form_submit_count_, 1);
+}
