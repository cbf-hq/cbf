+bool CbfProfileService::RequestFormResubmissionPromptForWebContents(
+    content::WebContents* web_contents) {
+  if (!web_contents || !observer_) {
+    return false;
+  }
+
+  const TabId tab_id = tab_manager_.GetTabIdForWebContents(web_contents);
+  if (tab_id == kInvalidTabId) {
+    return false;
+  }
+
+  ResolvePendingFormResubmissionPromptsForTab(
+      tab_id, mojom::CbfPromptUiResolutionResult::kAborted);
+
+  PendingFormResubmissionPrompt pending;
+  pending.source_tab_id = tab_id;
+  pending.request_id = next_prompt_ui_request_id_++;
+  pending.web_contents = web_contents->GetWeakPtr();
+  pending.reason = ToFormResubmissionReason(web_contents->GetController());
+  if (const content::NavigationEntry* pending_entry =
+          web_contents->GetController().GetPendingEntry()) {
+    pending.target_url = pending_entry->GetURL().spec();
+  } else {
+    pending.target_url = web_contents->GetLastCommittedURL().spec();
+  }
+
+  const uint64_t request_id = pending.request_id;
+  const mojom::CbfFormResubmissionReason reason = pending.reason;
+  const std::string target_url = pending.target_url;
+  pending_form_resubmission_prompts_[request_id] = std::move(pending);
+
+  NotifyPromptUiRequested(
+      std::optional<TabId>(tab_id), request_id,
+      mojom::CbfPromptUiKind::kFormResubmissionPrompt,
+      mojom::CbfPromptUiPermissionType::kUnknown, std::string(),
+      mojom::CbfDownloadPromptReason::kUnknown, 0, std::string(), std::nullopt,
+      std::nullopt, reason, target_url);
+  return true;
+}
