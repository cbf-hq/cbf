+bool CbfProfileService::OpenDefaultFormResubmissionPromptImpl(
+    uint64_t request_id) {
+  auto it = pending_form_resubmission_prompts_.find(request_id);
+  if (it == pending_form_resubmission_prompts_.end()) {
+    return false;
+  }
+
+  content::WebContents* web_contents = it->second.web_contents.get();
+  if (!web_contents) {
+    PendingFormResubmissionPrompt pending = std::move(it->second);
+    pending_form_resubmission_prompts_.erase(it);
+    ResolvePendingFormResubmissionPrompt(
+        std::move(pending), mojom::CbfPromptUiResolutionResult::kAborted);
+    return false;
+  }
+
+  auto* dialog = TabModalConfirmDialog::Create(
+      std::make_unique<CbfFormResubmissionPromptController>(
+          web_contents,
+          base::BindOnce(
+              [](base::WeakPtr<CbfProfileService> self, uint64_t request_id,
+                 mojom::CbfPromptUiResolutionResult result) {
+                if (!self) {
+                  return;
+                }
+                auto pending_it =
+                    self->pending_form_resubmission_prompts_.find(request_id);
+                if (pending_it ==
+                    self->pending_form_resubmission_prompts_.end()) {
+                  return;
+                }
+                PendingFormResubmissionPrompt pending =
+                    std::move(pending_it->second);
+                self->pending_form_resubmission_prompts_.erase(pending_it);
+                self->ResolvePendingFormResubmissionPrompt(std::move(pending),
+                                                           result);
+              },
+              weak_factory_.GetWeakPtr(), request_id)),
+      web_contents);
+  if (!dialog) {
+    PendingFormResubmissionPrompt pending = std::move(it->second);
+    pending_form_resubmission_prompts_.erase(it);
+    ResolvePendingFormResubmissionPrompt(
+        std::move(pending), mojom::CbfPromptUiResolutionResult::kAborted);
+    return false;
+  }
+  return true;
+}
