     CbfBridgeClientHandle* client,
     uint64_t session_id,
     uint64_t tab_id);
-CBF_BRIDGE_EXPORT bool cbf_bridge_client_send_mac_event(
-    CbfBridgeClientHandle* client,
-    uint64_t tab_id,
-    void* nsevent);
 CBF_BRIDGE_EXPORT bool cbf_bridge_client_set_composition(
     CbfBridgeClientHandle* client,
     const CbfImeComposition* composition);
diff --git a/chrome/browser/cbf/bridge/cbf_bridge_ffi.h b/chrome/browser/cbf/bridge/cbf_bridge_ffi.h
