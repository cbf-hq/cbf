+++ b/chrome/browser/cbf/bridge/cbf_bridge_ffi.h
@@ -127,6 +127,19 @@ enum CbfPromptUiResolutionResult {
   kCbfPromptUiResolutionResultAborted = 3,
 };
 
+enum CbfPromptUiDialogResult {
+  kCbfPromptUiDialogResultUnknown = 0,
+  kCbfPromptUiDialogResultProceeded = 1,
+  kCbfPromptUiDialogResultCanceled = 2,
+  kCbfPromptUiDialogResultAborted = 3,
+};
+
+enum CbfDownloadPromptResult {
+  kCbfDownloadPromptResultAllowed = 1,
+  kCbfDownloadPromptResultDenied = 2,
+  kCbfDownloadPromptResultAborted = 3,
+};
+
 enum CbfDownloadPromptReason {
   kCbfDownloadPromptReasonNone = 0,
   kCbfDownloadPromptReasonUnexpected = 1,
