index 0000000000000..b1c61a34d8c34
--- /dev/null
+++ b/chrome/browser/cbf/cbf_service.cc
@@ -0,0 +1,79 @@
+#include "chrome/browser/cbf/cbf_service.h"
+
+#include <string>
+
+#include "base/command_line.h"
+#include "base/functional/bind.h"
+#include "chrome/browser/cbf/cbf_switches.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/global_features.h"
+#include "components/named_mojo_ipc_server/connection_info.h"
+#include "components/named_mojo_ipc_server/endpoint_options.h"
+#include "mojo/public/cpp/platform/named_platform_channel.h"
+
+namespace cbf {
+
+CbfService::CbfService(BrowserProcess* browser_process)
+    : browser_service_(std::make_unique<CbfBrowserService>()) {
+  (void)browser_process;
+}
+
+CbfService::~CbfService() = default;
+
+CbfService* CbfService::GetForProcess() {
+  if (!g_browser_process) {
+    return nullptr;
+  }
+  GlobalFeatures* features = g_browser_process->GetFeatures();
+  if (!features) {
+    return nullptr;
+  }
+  return features->cbf_service();
+}
+
+void CbfService::EnsureIpcServerStarted() {
+  if (ipc_server_started_) {
+    return;
+  }
+
+  const base::CommandLine* command_line =
+    base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kCbfIpcChannel)) {
+    return;
+  }
+
+  const std::string channel_name =
+    command_line->GetSwitchValueASCII(switches::kCbfIpcChannel);
+  if (channel_name.empty()) {
+    return;
+  }
+
+  constexpr std::uint64_t kCbfMessagePipeId = 0u;
+  named_mojo_ipc_server::EndpointOptions options(
+      mojo::NamedPlatformChannel::ServerName(channel_name),
+      kCbfMessagePipeId);
+  // Emergency hatch: BindRepeating requires a callable target and we currently
+  // bind a raw pointer here.
+  //
+  // Safety rationale:
+  // - `browser_service_` and `ipc_server_` are owned by `CbfService`.
+  // - member destruction order is reverse declaration order in `cbf_service.h`,
+  //   so `ipc_server_` is destroyed before `browser_service_`.
+  // - therefore callbacks owned by `ipc_server_` cannot outlive
+  //   `browser_service_`.
+  //
+  // TODO: Replace this with an explicit weak-lifetime-safe binding
+  // style if/when NamedMojoIpcServer API allows it cleanly.
+  ipc_server_ = std::make_unique<
+      named_mojo_ipc_server::NamedMojoIpcServer<mojom::CbfBrowserService>>(
+      options, base::BindRepeating(
+                   [](CbfBrowserService* service,
+                      const named_mojo_ipc_server::ConnectionInfo&) {
+                     return static_cast<mojom::CbfBrowserService*>(service);
+                   },
+                   base::Unretained(browser_service_.get())));
+  ipc_server_->StartServer();
+  ipc_server_started_ = true;
+}
+
+}  // namespace cbf
