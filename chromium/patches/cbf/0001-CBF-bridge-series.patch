+      return cbf::mojom::CbfScrollGranularity::kScrollByPixel;
+    case kCbfScrollByLine:
+      return cbf::mojom::CbfScrollGranularity::kScrollByLine;
+    case kCbfScrollByPage:
+      return cbf::mojom::CbfScrollGranularity::kScrollByPage;
+    case kCbfScrollByDocument:
+      return cbf::mojom::CbfScrollGranularity::kScrollByDocument;
+    default:
+      return cbf::mojom::CbfScrollGranularity::kScrollByPixel;
+  }
+}
+
+cbf::mojom::CbfImeTextSpanType ToMojomImeTextSpanType(uint8_t type) {
+  switch (type) {
+    case kCbfImeTextSpanTypeComposition:
+      return cbf::mojom::CbfImeTextSpanType::kComposition;
+    case kCbfImeTextSpanTypeSuggestion:
+      return cbf::mojom::CbfImeTextSpanType::kSuggestion;
+    case kCbfImeTextSpanTypeMisspellingSuggestion:
+      return cbf::mojom::CbfImeTextSpanType::kMisspellingSuggestion;
+    case kCbfImeTextSpanTypeAutocorrect:
+      return cbf::mojom::CbfImeTextSpanType::kAutocorrect;
+    case kCbfImeTextSpanTypeGrammarSuggestion:
+      return cbf::mojom::CbfImeTextSpanType::kGrammarSuggestion;
+    default:
+      return cbf::mojom::CbfImeTextSpanType::kComposition;
+  }
+}
+
+cbf::mojom::CbfImeTextSpanThickness ToMojomImeTextSpanThickness(uint8_t value) {
+  switch (value) {
+    case kCbfImeTextSpanThicknessNone:
+      return cbf::mojom::CbfImeTextSpanThickness::kNone;
+    case kCbfImeTextSpanThicknessThin:
+      return cbf::mojom::CbfImeTextSpanThickness::kThin;
+    case kCbfImeTextSpanThicknessThick:
+      return cbf::mojom::CbfImeTextSpanThickness::kThick;
+    default:
+      return cbf::mojom::CbfImeTextSpanThickness::kThin;
+  }
+}
+
+cbf::mojom::CbfImeTextSpanUnderlineStyle ToMojomImeTextSpanUnderlineStyle(
+    uint8_t value) {
+  switch (value) {
+    case kCbfImeTextSpanUnderlineStyleNone:
+      return cbf::mojom::CbfImeTextSpanUnderlineStyle::kNone;
+    case kCbfImeTextSpanUnderlineStyleSolid:
+      return cbf::mojom::CbfImeTextSpanUnderlineStyle::kSolid;
+    case kCbfImeTextSpanUnderlineStyleDot:
+      return cbf::mojom::CbfImeTextSpanUnderlineStyle::kDot;
+    case kCbfImeTextSpanUnderlineStyleDash:
+      return cbf::mojom::CbfImeTextSpanUnderlineStyle::kDash;
+    case kCbfImeTextSpanUnderlineStyleSquiggle:
+      return cbf::mojom::CbfImeTextSpanUnderlineStyle::kSquiggle;
+    default:
+      return cbf::mojom::CbfImeTextSpanUnderlineStyle::kSolid;
+  }
+}
+
+cbf::mojom::CbfConfirmCompositionBehavior ToMojomConfirmCompositionBehavior(
+    uint8_t value) {
+  switch (value) {
+    case kCbfConfirmCompositionDoNotKeepSelection:
+      return cbf::mojom::CbfConfirmCompositionBehavior::kDoNotKeepSelection;
+    case kCbfConfirmCompositionKeepSelection:
+      return cbf::mojom::CbfConfirmCompositionBehavior::kKeepSelection;
+    default:
+      return cbf::mojom::CbfConfirmCompositionBehavior::kDoNotKeepSelection;
+  }
+}
+
+std::vector<cbf::mojom::CbfImeTextSpanPtr> ToMojomImeTextSpans(
+    const CbfImeTextSpanList& list) {
+  std::vector<cbf::mojom::CbfImeTextSpanPtr> spans;
+  if (!list.items || list.len == 0) {
+    return spans;
+  }
+  spans.reserve(list.len);
+  auto items = UNSAFE_BUFFERS(base::span(list.items, list.len));
+  for (const CbfImeTextSpan& span : items) {
+    auto mojom_span = cbf::mojom::CbfImeTextSpan::New();
+    mojom_span->type = ToMojomImeTextSpanType(span.type);
+    mojom_span->start_offset = span.start_offset;
+    mojom_span->end_offset = span.end_offset;
+    mojom_span->underline_color = span.underline_color;
+    mojom_span->thickness = ToMojomImeTextSpanThickness(span.thickness);
+    mojom_span->underline_style =
+        ToMojomImeTextSpanUnderlineStyle(span.underline_style);
+    mojom_span->text_color = span.text_color;
+    mojom_span->background_color = span.background_color;
+    mojom_span->suggestion_highlight_color = span.suggestion_highlight_color;
+    mojom_span->remove_on_finish_composing = span.remove_on_finish_composing;
+    mojom_span->interim_char_selection = span.interim_char_selection;
+    mojom_span->should_hide_suggestion_menu = span.should_hide_suggestion_menu;
+    spans.push_back(std::move(mojom_span));
+  }
+  return spans;
+}
+
+}  // namespace cbf_bridge::internal
