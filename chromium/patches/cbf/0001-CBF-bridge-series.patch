+void CbfProfileService::NotifyDragStartRequested(
+    content::WebContents* web_contents,
+    const content::DropData& drop_data,
+    const url::Origin& source_origin,
+    blink::DragOperationsMask allowed_ops,
+    const SkBitmap& drag_image,
+    const gfx::Vector2d& cursor_offset_in_dip,
+    const gfx::Rect& drag_obj_rect_in_dip,
+    const blink::mojom::DragEventSourceInfo& event_info,
+    content::RenderWidgetHost* source_rwh) {
+  if (!observer_ || !web_contents || !source_rwh) {
+    return;
+  }
+
+  auto* source_rwh_impl = content::RenderWidgetHostImpl::From(source_rwh);
+  if (!source_rwh_impl) {
+    return;
+  }
+
+  const WebPageId web_page_id =
+      tab_manager_.GetWebPageIdForWebContents(web_contents);
+  if (web_page_id == kInvalidWebPageId) {
+    return;
+  }
+
+  const uint64_t session_id = next_drag_session_id_++;
+  DragSessionState session;
+  session.web_page_id = web_page_id;
+  session.source_rwh = source_rwh_impl->GetWeakPtr();
+  session.drop_data = drop_data;
+  // Match Chromium's native drag path: set view_id and sanitize drop payload
+  // before any DragTarget* call, otherwise DragTargetDrop checks can fail.
+  source_rwh_impl->FilterDropData(&session.drop_data);
+  drag_sessions_[session_id] = std::move(session);
+
+  auto request = mojom::CbfDragStartRequest::New();
+  request->session_id = session_id;
+  request->web_page_id = web_page_id;
+  request->allowed_operations = static_cast<uint32_t>(allowed_ops);
+  request->source_origin = source_origin.Serialize();
+
+  auto data = mojom::CbfDragData::New();
+  data->text = base::UTF16ToUTF8(drop_data.text.value_or(std::u16string()));
+  data->html = base::UTF16ToUTF8(drop_data.html.value_or(std::u16string()));
+  data->html_base_url = drop_data.html_base_url.spec();
+  data->url_infos.reserve(drop_data.url_infos.size());
+  for (const auto& url_info : drop_data.url_infos) {
+    auto info = mojom::CbfDragUrlInfo::New();
+    info->url = url_info.url.spec();
+    info->title = base::UTF16ToUTF8(url_info.title);
+    data->url_infos.push_back(std::move(info));
+  }
+  request->data = std::move(data);
+
+  if (!drag_image.drawsNothing()) {
+    std::optional<std::vector<uint8_t>> png_bytes =
+        gfx::PNGCodec::EncodeBGRASkBitmap(drag_image,
+                                          /*discard_transparency=*/false);
+    if (png_bytes.has_value()) {
+      auto image = mojom::CbfDragImage::New();
+      image->png_bytes = std::move(*png_bytes);
+      image->pixel_width = static_cast<uint32_t>(drag_image.width());
+      image->pixel_height = static_cast<uint32_t>(drag_image.height());
+      if (drag_image.width() > 0 && drag_obj_rect_in_dip.width() > 0) {
+        // Keep scale as pixel-per-DIP (device scale factor equivalent) so that
+        // host side can derive point size via `pixel_size / scale`.
+        image->scale = static_cast<float>(drag_image.width()) /
+                       static_cast<float>(drag_obj_rect_in_dip.width());
+      } else {
+        image->scale = 1.0f;
+      }
+      image->cursor_offset_x = cursor_offset_in_dip.x();
+      image->cursor_offset_y = cursor_offset_in_dip.y();
+      request->image = std::move(image);
+    }
+  }
+
+  observer_->OnDragStartRequested(std::move(request));
+}
