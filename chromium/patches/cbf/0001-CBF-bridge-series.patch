+                           uint64_t request_id,
+                           bool proceed);
+  bool Navigate(uint64_t web_page_id, const std::string& url);
+  bool GoBack(uint64_t web_page_id);
+  bool GoForward(uint64_t web_page_id);
+  bool Reload(uint64_t web_page_id, bool ignore_cache);
+  bool GetWebPageDomHtml(uint64_t web_page_id, uint64_t request_id);
+  void Shutdown();
+
+ private:
+  std::string channel_name_;
+  std::unique_ptr<CbfBridgeClientImpl> impl_;
+};
+
+}  // namespace cbf_bridge::internal
