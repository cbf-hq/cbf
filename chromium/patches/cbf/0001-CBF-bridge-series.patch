diff --git a/chrome/browser/cbf/bridge/cbf_bridge_mac.mm b/chrome/browser/cbf/bridge/cbf_bridge_mac.mm
new file mode 100644
index 0000000000000..1a7e1d76a9085
--- /dev/null
+++ b/chrome/browser/cbf/bridge/cbf_bridge_mac.mm
@@ -0,0 +1,224 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge_internal.h"
+
+#import <AppKit/AppKit.h>
+
+#include "base/apple/owned_objc.h"
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/browser/cbf/mojom/cbf_browser.mojom.h"
+#include "components/input/web_input_event_builders_mac.h"
+#include "components/input/native_web_keyboard_event.h"
+#include "third_party/blink/public/common/input/web_input_event.h"
+#include "ui/events/keycodes/dom/keycode_converter.h"
+#include "ui/events/event_constants.h"
+#include "ui/events/types/scroll_types.h"
+
+namespace cbf {
+
+namespace {
+
+mojom::CbfKeyEventType ToMojomKeyEventType(blink::WebInputEvent::Type type) {
+  switch (type) {
+    case blink::WebInputEvent::Type::kRawKeyDown:
+      return mojom::CbfKeyEventType::kRawKeyDown;
+    case blink::WebInputEvent::Type::kKeyDown:
+      return mojom::CbfKeyEventType::kKeyDown;
+    case blink::WebInputEvent::Type::kKeyUp:
+      return mojom::CbfKeyEventType::kKeyUp;
+    case blink::WebInputEvent::Type::kChar:
+      return mojom::CbfKeyEventType::kChar;
+    default:
+      return mojom::CbfKeyEventType::kRawKeyDown;
+  }
+}
+
+mojom::CbfMouseEventType ToMojomMouseEventType(
+    blink::WebInputEvent::Type type) {
+  switch (type) {
+    case blink::WebInputEvent::Type::kMouseDown:
+      return mojom::CbfMouseEventType::kMouseDown;
+    case blink::WebInputEvent::Type::kMouseUp:
+      return mojom::CbfMouseEventType::kMouseUp;
+    case blink::WebInputEvent::Type::kMouseMove:
+      return mojom::CbfMouseEventType::kMouseMove;
+    case blink::WebInputEvent::Type::kMouseEnter:
+      return mojom::CbfMouseEventType::kMouseEnter;
+    case blink::WebInputEvent::Type::kMouseLeave:
+      return mojom::CbfMouseEventType::kMouseLeave;
+    default:
+      return mojom::CbfMouseEventType::kMouseMove;
+  }
+}
+
+mojom::CbfMouseButton ToMojomMouseButton(blink::WebMouseEvent::Button button) {
+  switch (button) {
+    case blink::WebMouseEvent::Button::kLeft:
+      return mojom::CbfMouseButton::kLeft;
+    case blink::WebMouseEvent::Button::kMiddle:
+      return mojom::CbfMouseButton::kMiddle;
+    case blink::WebMouseEvent::Button::kRight:
+      return mojom::CbfMouseButton::kRight;
+    case blink::WebMouseEvent::Button::kBack:
+      return mojom::CbfMouseButton::kBack;
+    case blink::WebMouseEvent::Button::kForward:
+      return mojom::CbfMouseButton::kForward;
+    case blink::WebMouseEvent::Button::kNoButton:
+    default:
+      return mojom::CbfMouseButton::kNoButton;
+  }
+}
+
+mojom::CbfPointerType ToMojomPointerType(ui::EventPointerType type) {
+  switch (type) {
+    case ui::EventPointerType::kMouse:
+      return mojom::CbfPointerType::kPointerMouse;
+    case ui::EventPointerType::kPen:
+      return mojom::CbfPointerType::kPointerPen;
+    case ui::EventPointerType::kTouch:
+      return mojom::CbfPointerType::kPointerTouch;
+    case ui::EventPointerType::kEraser:
+      return mojom::CbfPointerType::kPointerEraser;
+    case ui::EventPointerType::kUnknown:
+    default:
+      return mojom::CbfPointerType::kPointerUnknown;
+  }
+}
+
+mojom::CbfScrollGranularity ToMojomScrollGranularity(
+    ui::ScrollGranularity value) {
+  switch (value) {
+    case ui::ScrollGranularity::kScrollByPrecisePixel:
+      return mojom::CbfScrollGranularity::kScrollByPrecisePixel;
+    case ui::ScrollGranularity::kScrollByPixel:
+      return mojom::CbfScrollGranularity::kScrollByPixel;
+    case ui::ScrollGranularity::kScrollByLine:
+      return mojom::CbfScrollGranularity::kScrollByLine;
+    case ui::ScrollGranularity::kScrollByPage:
+      return mojom::CbfScrollGranularity::kScrollByPage;
+    case ui::ScrollGranularity::kScrollByDocument:
+      return mojom::CbfScrollGranularity::kScrollByDocument;
+  }
+  return mojom::CbfScrollGranularity::kScrollByPixel;
+}
+
+ui::EventPointerType ToEventPointerType(uint8_t pointer_type) {
+  if (pointer_type >
+      static_cast<uint8_t>(ui::EventPointerType::kMaxValue)) {
+    return ui::EventPointerType::kUnknown;
+  }
+  return static_cast<ui::EventPointerType>(pointer_type);
+}
+
+}  // namespace
+
+mojom::CbfKeyEventPtr ConvertNSEventToMojom(void* nsevent, uint64_t web_page_id) {
+  NSEvent* event = (__bridge NSEvent*)(nsevent);
+  input::NativeWebKeyboardEvent web_event((base::apple::OwnedNSEvent(event)));
+
+  auto mojom_event = mojom::CbfKeyEvent::New();
+  mojom_event->web_page_id = web_page_id;
+  mojom_event->type = ToMojomKeyEventType(web_event.GetType());
+  mojom_event->modifiers = web_event.GetModifiers();
+  mojom_event->windows_key_code = web_event.windows_key_code;
+  mojom_event->native_key_code = web_event.native_key_code;
+  mojom_event->dom_code = ui::KeycodeConverter::DomCodeToCodeString(
+      static_cast<ui::DomCode>(web_event.dom_code));
+  mojom_event->dom_key = ui::KeycodeConverter::DomKeyToKeyString(
+      static_cast<ui::DomKey>(web_event.dom_key));
+  mojom_event->text = base::UTF16ToUTF8(
+      std::u16string(web_event.text.data(), 0,
+                     std::char_traits<char16_t>::length(web_event.text.data())));
+  mojom_event->unmodified_text = base::UTF16ToUTF8(
+      std::u16string(web_event.unmodified_text.data(), 0,
+                     std::char_traits<char16_t>::length(web_event.unmodified_text.data())));
+
+  if (event.type == NSEventTypeKeyDown || event.type == NSEventTypeKeyUp) {
+    mojom_event->auto_repeat = event.isARepeat;
+  } else {
+    mojom_event->auto_repeat = false;
+  }
+
+  mojom_event->is_keypad = (event.modifierFlags & NSEventModifierFlagNumericPad) != 0;
+  mojom_event->is_system_key = web_event.is_system_key;
+
+  // TODO: Derive location properly if needed.
+  mojom_event->location = 0;
+
+  return mojom_event;
+}
+
+mojom::CbfMouseEventPtr ConvertNSEventToMouseMojom(
+    void* nsevent,
+    void* nsview,
+    uint64_t web_page_id,
+    uint8_t pointer_type,
+    bool unaccelerated_movement) {
+  NSEvent* event = (__bridge NSEvent*)(nsevent);
+  NSView* view = (__bridge NSView*)(nsview);
+  if (!event || !view) {
+    return nullptr;
+  }
+
+  auto pointer = ToEventPointerType(pointer_type);
+  blink::WebMouseEvent web_event = input::WebMouseEventBuilder::Build(
+      event, view, static_cast<blink::WebPointerProperties::PointerType>(pointer),
+      unaccelerated_movement);
+
+  auto mojom_event = mojom::CbfMouseEvent::New();
+  mojom_event->web_page_id = web_page_id;
+  mojom_event->type = ToMojomMouseEventType(web_event.GetType());
+  mojom_event->modifiers = web_event.GetModifiers();
+  mojom_event->button = ToMojomMouseButton(web_event.button);
+  mojom_event->click_count = web_event.click_count;
+  mojom_event->position_in_widget_x = web_event.PositionInWidget().x();
+  mojom_event->position_in_widget_y = web_event.PositionInWidget().y();
+  mojom_event->position_in_screen_x = web_event.PositionInScreen().x();
+  mojom_event->position_in_screen_y = web_event.PositionInScreen().y();
+  mojom_event->movement_x = static_cast<float>(web_event.movement_x);
+  mojom_event->movement_y = static_cast<float>(web_event.movement_y);
+  mojom_event->is_raw_movement_event = web_event.is_raw_movement_event;
+  mojom_event->pointer_type = ToMojomPointerType(web_event.pointer_type);
+
+  return mojom_event;
+}
+
+mojom::CbfMouseWheelEventPtr ConvertNSEventToMouseWheelMojom(
+    void* nsevent,
+    void* nsview,
+    uint64_t web_page_id) {
+  NSEvent* event = (__bridge NSEvent*)(nsevent);
+  NSView* view = (__bridge NSView*)(nsview);
+  if (!event || !view) {
+    return nullptr;
+  }
+
+  blink::WebMouseWheelEvent web_event =
+      input::WebMouseWheelEventBuilder::Build(event, view);
+
+  auto mojom_event = mojom::CbfMouseWheelEvent::New();
+  mojom_event->web_page_id = web_page_id;
+  mojom_event->modifiers = web_event.GetModifiers();
+  mojom_event->position_in_widget_x = web_event.PositionInWidget().x();
+  mojom_event->position_in_widget_y = web_event.PositionInWidget().y();
+  mojom_event->position_in_screen_x = web_event.PositionInScreen().x();
+  mojom_event->position_in_screen_y = web_event.PositionInScreen().y();
+  mojom_event->movement_x = static_cast<float>(web_event.movement_x);
+  mojom_event->movement_y = static_cast<float>(web_event.movement_y);
+  mojom_event->is_raw_movement_event = web_event.is_raw_movement_event;
+  mojom_event->delta_x = web_event.delta_x;
+  mojom_event->delta_y = web_event.delta_y;
+  mojom_event->wheel_ticks_x = web_event.wheel_ticks_x;
+  mojom_event->wheel_ticks_y = web_event.wheel_ticks_y;
+  mojom_event->phase = static_cast<uint32_t>(web_event.phase);
+  mojom_event->momentum_phase =
+      static_cast<uint32_t>(web_event.momentum_phase);
+  mojom_event->delta_units =
+      ToMojomScrollGranularity(web_event.delta_units);
+
+  return mojom_event;
+}
+
+void ReleaseNSEvent(void* nsevent) {
+  CFBridgingRelease(nsevent);
+}
+
+}  // namespace cbf
