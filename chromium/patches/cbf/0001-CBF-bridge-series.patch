@@ -0,0 +1,32 @@
+#import "chrome/browser/cbf/cbf_context_menu_mac.h"
+
+#import <AppKit/AppKit.h>
+
+#include "base/strings/sys_string_conversions.h"
+#include "ui/base/accelerators/platform_accelerator_cocoa.h"
+
+namespace cbf {
+
+bool GetCocoaKeyEquivalentForAccelerator(const ui::Accelerator& accelerator,
+                                         std::string* key_equivalent,
+                                         uint32_t* modifier_mask) {
+  if (!key_equivalent || !modifier_mask) {
+    return false;
+  }
+
+  if (accelerator.key_code() == ui::VKEY_UNKNOWN) {
+    return false;
+  }
+
+  KeyEquivalentAndModifierMask* equivalent =
+      ui::GetKeyEquivalentAndModifierMaskFromAccelerator(accelerator);
+  if (!equivalent) {
+    return false;
+  }
+
+  *key_equivalent = base::SysNSStringToUTF8(equivalent.keyEquivalent);
+  *modifier_mask = static_cast<uint32_t>(equivalent.modifierMask);
+  return !key_equivalent->empty();
+}
+
+}  // namespace cbf
