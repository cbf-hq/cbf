+namespace cbf {
+
+CbfWebContentsDelegate::CbfWebContentsDelegate(
+    CbfProfileService* profile_service,
+    CbfJavaScriptDialogManager* dialog_manager)
+    : profile_service_(profile_service), dialog_manager_(dialog_manager) {}
+
