+
+content::JavaScriptDialogManager* CbfWebContentsDelegate::GetJavaScriptDialogManager(
+    content::WebContents* source) {
+  (void)source;
+  return dialog_manager_;
+}
+
+void CbfWebContentsDelegate::CloseContents(content::WebContents* source) {
+  if (!profile_service_ || !source) {
+    return;
+  }
+  profile_service_->CloseWebContents(source);
+}
+
+void CbfWebContentsDelegate::BeforeUnloadFired(content::WebContents* tab,
+                                               bool proceed,
+                                               bool* proceed_to_fire_unload) {
+  if (profile_service_ && tab) {
+    profile_service_->OnBeforeUnloadFired(tab, proceed);
+  }
+  if (proceed_to_fire_unload) {
+    *proceed_to_fire_unload = proceed;
+  }
+}
+
+content::WebContents* CbfWebContentsDelegate::OpenURLFromTab(
+    content::WebContents* source,
+    const content::OpenURLParams& params,
+    base::OnceCallback<void(content::NavigationHandle&)>
+        navigation_handle_callback) {
+  (void)navigation_handle_callback;
+
+  if (!profile_service_ || !source) {
+    return nullptr;
+  }
+
+  switch (params.disposition) {
+    case WindowOpenDisposition::NEW_FOREGROUND_TAB:
+    case WindowOpenDisposition::NEW_BACKGROUND_TAB:
+    case WindowOpenDisposition::NEW_WINDOW:
+    case WindowOpenDisposition::NEW_POPUP:
+      profile_service_->NotifyNewWebPageRequested(source, params.url,
+                                                  params.disposition);
+      return nullptr;
+    default:
+      break;
+  }
+
+  return nullptr;
+}
+
+content::WebContents* CbfWebContentsDelegate::AddNewContents(
+    ::content::WebContents* source,
+    std::unique_ptr<::content::WebContents> new_contents,
+    const ::GURL& target_url,
+    ::WindowOpenDisposition disposition,
+    const ::blink::mojom::WindowFeatures& window_features,
+    bool user_gesture,
+    bool* was_blocked) {
+  (void)new_contents;
+  (void)window_features;
+  (void)user_gesture;
+
+  if (was_blocked) {
+    *was_blocked = false;
+  }
+
+  if (profile_service_ && source) {
+    profile_service_->NotifyNewWebPageRequested(source, target_url, disposition);
+  }
+
+  return nullptr;
+}
+
+bool CbfWebContentsDelegate::HandleContextMenu(
+    content::RenderFrameHost& render_frame_host,
+    const content::ContextMenuParams& params) {
+  if (!profile_service_) {
+    return true;
+  }
+
+  return profile_service_->HandleContextMenu(render_frame_host, params);
+}
+
+bool CbfWebContentsDelegate::HandleRendererDragStart(
+    content::WebContents* source,
+    const content::DropData& drop_data,
+    const url::Origin& source_origin,
+    blink::DragOperationsMask allowed_ops,
+    const SkBitmap& drag_image,
+    const gfx::Vector2d& cursor_offset_in_dip,
+    const gfx::Rect& drag_obj_rect_in_dip,
+    const blink::mojom::DragEventSourceInfo& event_info,
+    content::RenderWidgetHost* source_rwh) {
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kCbfDisableHostOwnedDrag)) {
+    return false;
+  }
+
+  if (!profile_service_ || !source || !source_rwh) {
+    return false;
+  }
+
+  profile_service_->NotifyDragStartRequested(
+      source, drop_data, source_origin, allowed_ops, drag_image,
+      cursor_offset_in_dip, drag_obj_rect_in_dip, event_info, source_rwh);
+  return true;
+}
+
+void CbfWebContentsDelegate::OnCursorChanged(
+    content::WebContents* source,
+    ui::mojom::CursorType cursor_type) {
+  if (!profile_service_ || !source) {
+    return;
+  }
+  profile_service_->NotifyCursorChanged(source, cursor_type);
+}
+
+}  // namespace cbf
