+
+namespace {
+
+constexpr base::TimeDelta kPollInterval = base::Milliseconds(100);
+constexpr int kMaxPollAttempts = 50;  // ~5 seconds.
+
+}  // namespace
+
+CbfCaContextIdObserver::CbfCaContextIdObserver(
+    content::WebContents* web_contents,
+    CbfProfileService* profile_service)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<CbfCaContextIdObserver>(*web_contents),
+      profile_service_(profile_service) {
+  StartPollingIfNeeded();
+}
+
+CbfCaContextIdObserver::~CbfCaContextIdObserver() = default;
+
+void CbfCaContextIdObserver::DidFirstVisuallyNonEmptyPaint() {
+  StartPollingIfNeeded();
+}
+
+void CbfCaContextIdObserver::DidStartNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!profile_service_ || !web_contents() || !navigation_handle) {
+    return;
+  }
+  if (!navigation_handle->IsInPrimaryMainFrame() ||
+      navigation_handle->IsSameDocument()) {
+    return;
+  }
+  profile_service_->NotifyNavigationStateChanged(web_contents(), true);
+}
+
+void CbfCaContextIdObserver::DidFinishNavigation(
+    content::NavigationHandle* navigation_handle) {
+  if (!profile_service_ || !web_contents() || !navigation_handle) {
+    return;
+  }
+  if (!navigation_handle->IsInPrimaryMainFrame() ||
+      navigation_handle->IsSameDocument()) {
+    return;
+  }
+  profile_service_->NotifyNavigationStateChanged(web_contents(), false);
+}
+
+void CbfCaContextIdObserver::TitleWasSet(content::NavigationEntry* entry) {
+  (void)entry;
+  if (!profile_service_ || !web_contents()) {
+    return;
+  }
+  profile_service_->NotifyTitleUpdated(web_contents());
+}
+
+void CbfCaContextIdObserver::DidUpdateFaviconURL(
+    content::RenderFrameHost* render_frame_host,
+    const std::vector<blink::mojom::FaviconURLPtr>& candidates) {
+  (void)render_frame_host;
+  if (!profile_service_ || !web_contents()) {
+    return;
+  }
+
+  const blink::mojom::FaviconURL* selected = nullptr;
+  for (const auto& candidate : candidates) {
+    if (!candidate || !candidate->icon_url.is_valid()) {
+      continue;
+    }
+    if (!candidate->is_default_icon) {
+      selected = candidate.get();
+      break;
+    }
+    if (!selected) {
+      selected = candidate.get();
+    }
+  }
+
+  if (!selected) {
+    return;
+  }
+
+  profile_service_->NotifyFaviconUrlUpdated(web_contents(),
+                                            selected->icon_url.spec());
+}
+
+void CbfCaContextIdObserver::WebContentsDestroyed() {
+  poll_timer_.Stop();
+}
+
+void CbfCaContextIdObserver::StartPollingIfNeeded() {
+  if (poll_timer_.IsRunning()) {
+    return;
+  }
+
+  poll_attempts_ = 0;
+  poll_timer_.Start(FROM_HERE, kPollInterval, this,
+                    &CbfCaContextIdObserver::PollOnce);
+}
+
+void CbfCaContextIdObserver::PollOnce() {
+  if (!web_contents()) {
+    poll_timer_.Stop();
+    return;
+  }
+
+  if (poll_attempts_++ >= kMaxPollAttempts) {
+    poll_timer_.Stop();
+    return;
+  }
+
+  std::uint32_t context_id = 0;
+  if (!TryGetWebContentsCaContextId(web_contents(), &context_id)) {
+    return;
+  }
+
+  if (context_id == 0 || context_id == last_logged_context_id_) {
+    return;
+  }
+
+  last_logged_context_id_ = context_id;
+  if (profile_service_) {
+    profile_service_->NotifySurfaceHandleUpdated(web_contents(), context_id);
+  }
+  poll_timer_.Stop();
+}
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(CbfCaContextIdObserver);
+
+}  // namespace cbf
