+cbf::mojom::CbfMenuAcceleratorPtr BuildMenuAccelerator(
+    const ui::MenuModel* model,
+    size_t index) {
+  ui::Accelerator accelerator;
+  if (!model->GetAcceleratorAt(index, &accelerator)) {
+    return nullptr;
+  }
+
+#if BUILDFLAG(IS_MAC)
+  std::string key_equivalent;
+  uint32_t modifier_mask = 0;
+  if (!cbf::GetCocoaKeyEquivalentForAccelerator(accelerator, &key_equivalent,
+                                                &modifier_mask)) {
+    return nullptr;
+  }
+
+  auto out = cbf::mojom::CbfMenuAccelerator::New();
+  out->key_equivalent = std::move(key_equivalent);
+  out->modifier_mask = modifier_mask;
+  return out;
+#else
+  return nullptr;
+#endif
+}
