+  WebPageId next_web_page_id_ = 1;
+  base::flat_map<WebPageId, std::unique_ptr<content::WebContents>> pages_;
+  base::flat_map<raw_ptr<content::WebContents>, WebPageId> reverse_lookup_;
+
+  base::flat_map<WebPageId, gfx::Size> pending_resizes_;
+  base::flat_set<WebPageId> in_flight_resizes_;
+  base::flat_map<WebPageId, std::vector<base::OnceClosure>> pending_callbacks_;
+
+  base::WeakPtrFactory<CbfTabManager> weak_factory_{this};
+};
+
+}  // namespace cbf
+
+#endif  // CHROME_BROWSER_CBF_CBF_TAB_MANAGER_H_
