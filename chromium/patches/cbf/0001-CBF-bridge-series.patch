+++ b/chrome/browser/cbf/bridge/cbf_bridge_support.cc
@@ -0,0 +1,54 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+
+#include <mutex>
+#include <utility>
+
+#include "base/compiler_specific.h"
+#include "base/message_loop/message_pump_type.h"
+#include "base/no_destructor.h"
+#include "base/strings/string_util.h"
+#include "base/task/single_thread_task_runner.h"
+#include "mojo/core/embedder/configuration.h"
+#include "mojo/core/embedder/embedder.h"
+#include "mojo/core/embedder/scoped_ipc_support.h"
+
+namespace cbf_bridge::internal {
+
+char* CopyCString(const std::string& value) {
+  char* buffer = UNSAFE_BUFFERS(new char[value.size() + 1]);
+  base::strlcpy(buffer, value.c_str(), value.size() + 1);
+  return buffer;
+}
+
+std::string MaybeCopyString(const char* value) {
+  return value ? std::string(value) : std::string();
+}
+
+base::Thread& GetMojoThread() {
+  static base::NoDestructor<base::Thread> thread("CbfMojoThread");
+  return *thread;
+}
+
+void EnsureMojoThreadStarted() {
+  static std::once_flag once;
+  std::call_once(once, []() {
+    mojo::core::Configuration config;
+    config.is_broker_process = false;
+    mojo::core::Init(config);
+
+    base::Thread::Options options;
+    options.message_pump_type = base::MessagePumpType::IO;
+    GetMojoThread().StartWithOptions(std::move(options));
+
+    static base::NoDestructor<mojo::core::ScopedIPCSupport> ipc_support(
+        GetMojoThread().task_runner(),
+        mojo::core::ScopedIPCSupport::ShutdownPolicy::FAST);
+  });
+}
+
+scoped_refptr<base::SingleThreadTaskRunner> GetMojoTaskRunner() {
+  EnsureMojoThreadStarted();
+  return GetMojoThread().task_runner();
+}
+
+}  // namespace cbf_bridge::internal
