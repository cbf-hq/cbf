+
+void CbfProfileService::OnBeforeUnloadFired(
+    content::WebContents* web_contents,
+    bool proceed) {
+  if (!browser_service_ || !web_contents) {
+    return;
+  }
+  const WebPageId web_page_id =
+      tab_manager_.GetWebPageIdForWebContents(web_contents);
+  if (web_page_id == kInvalidWebPageId) {
+    return;
+  }
+
+  auto it = beforeunload_reasons_.find(web_contents);
+  bool is_close_request = false;
+  if (it != beforeunload_reasons_.end()) {
+    is_close_request =
+        (it->second == mojom::CbfBeforeUnloadReason::kCloseWebPage);
+    beforeunload_reasons_.erase(it);
+  }
+
+  browser_service_->NotifyBeforeUnloadFired(web_page_id, proceed);
+
+  if (proceed && is_close_request) {
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+        FROM_HERE, base::BindOnce(
+                       [](base::WeakPtr<CbfProfileService> self,
+                          WebPageId web_page_id) {
+                         if (!self) {
+                           return;
+                         }
+                         content::WebContents* target =
+                             self->tab_manager_.GetWebContents(web_page_id);
+                         if (!target) {
+                           return;
+                         }
+                         target->Close();
+                       },
+                       weak_factory_.GetWeakPtr(), web_page_id));
+  }
+}
+
+void CbfProfileService::NotifyBeforeUnloadDialogRequested(
+    content::WebContents* web_contents,
+    uint64_t request_id,
+    mojom::CbfBeforeUnloadReason reason) {
+  if (!observer_ || !web_contents) {
+    return;
+  }
+  const WebPageId web_page_id =
+      tab_manager_.GetWebPageIdForWebContents(web_contents);
+  if (web_page_id == kInvalidWebPageId) {
+    return;
+  }
+  observer_->OnBeforeUnloadDialogRequested(web_page_id, request_id, reason);
+}
+
+mojom::CbfBeforeUnloadReason CbfProfileService::ResolveBeforeUnloadReason(
+    content::WebContents* web_contents,
+    bool is_reload) {
+  if (is_reload) {
+    return mojom::CbfBeforeUnloadReason::kReload;
+  }
+  if (!web_contents) {
+    return mojom::CbfBeforeUnloadReason::kUnknown;
+  }
+  const auto it = beforeunload_reasons_.find(web_contents);
+  if (it == beforeunload_reasons_.end()) {
+    return mojom::CbfBeforeUnloadReason::kUnknown;
+  }
+  const auto reason = it->second;
+  return reason;
+}
