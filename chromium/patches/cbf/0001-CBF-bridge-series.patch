+void CbfProfileService::ExecuteContextMenuCommand(uint64_t menu_id,
+                                                  int32_t command_id,
+                                                  int32_t event_flags) {
+  auto it = context_menus_.find(menu_id);
+  if (it == context_menus_.end()) {
