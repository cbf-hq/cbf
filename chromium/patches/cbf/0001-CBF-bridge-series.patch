+#include "chrome/browser/cbf/bridge/cbf_bridge.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+
+#include "base/functional/bind.h"
+#include "base/location.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client_impl.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+
+namespace cbf_bridge::internal {
+
+bool CbfBridgeClient::RequestShutdown(uint64_t request_id) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t request_id) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            impl->browser_remote->RequestShutdown(request_id);
+          },
+          impl, request_id));
+  return true;
+}
+
+bool CbfBridgeClient::ConfirmShutdown(uint64_t request_id, bool proceed) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t request_id, bool proceed) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            impl->browser_remote->ConfirmShutdown(request_id, proceed);
+          },
+          impl, request_id, proceed));
+  return true;
+}
+
+bool CbfBridgeClient::ForceShutdown() {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            impl->browser_remote->ForceShutdown();
+          },
+          impl));
+  return true;
+}
+
+}  // namespace cbf_bridge::internal
+
+extern "C" bool cbf_bridge_client_request_shutdown(CbfBridgeClientHandle* client,
+                                                   uint64_t request_id) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->RequestShutdown(request_id);
+}
+
+extern "C" bool cbf_bridge_client_confirm_shutdown(CbfBridgeClientHandle* client,
+                                                   uint64_t request_id,
+                                                   bool proceed) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->ConfirmShutdown(request_id, proceed);
+}
+
+extern "C" bool cbf_bridge_client_force_shutdown(CbfBridgeClientHandle* client) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->ForceShutdown();
+}
+
+extern "C" void cbf_bridge_client_shutdown(CbfBridgeClientHandle* client) {
+  if (client) {
+    reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)->Shutdown();
+  }
+}
