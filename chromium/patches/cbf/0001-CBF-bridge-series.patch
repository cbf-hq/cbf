+void CbfProfileService::NotifyWebPageClosed(WebPageId web_page_id) {
+  wheel_phase_states_.erase(web_page_id);
+  if (!observer_ || web_page_id == kInvalidWebPageId) {
+    return;
+  }
+  for (auto it = drag_sessions_.begin(); it != drag_sessions_.end();) {
+    if (it->second.web_page_id == web_page_id) {
+      it = drag_sessions_.erase(it);
+    } else {
+      ++it;
+    }
+  }
+  observer_->OnWebPageClosed(web_page_id);
+}
