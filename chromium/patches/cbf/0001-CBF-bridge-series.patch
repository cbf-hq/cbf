+void CbfProfileService::CloseWebContents(content::WebContents* web_contents) {
+  beforeunload_reasons_.erase(web_contents);
+  const WebPageId web_page_id =
+      tab_manager_.GetWebPageIdForWebContents(web_contents);
+  if (web_page_id != kInvalidWebPageId) {
+    for (auto it = drag_sessions_.begin(); it != drag_sessions_.end();) {
+      if (it->second.web_page_id == web_page_id) {
+        it = drag_sessions_.erase(it);
+      } else {
+        ++it;
+      }
+    }
+  }
+
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileService> self, WebPageId web_page_id) {
+            if (!self) {
+              return;
+            }
+            if (web_page_id != kInvalidWebPageId) {
+              self->tab_manager_.CloseWebPage(web_page_id);
+            }
+            if (self->browser_service_) {
+              self->browser_service_->NotifyWebPageClosed();
+            }
+            if (web_page_id != kInvalidWebPageId) {
+              self->NotifyWebPageClosed(web_page_id);
+            }
+          },
+          weak_factory_.GetWeakPtr(), web_page_id));
+}
