+bool CbfBridgeClient::CreateWebPage(const uint64_t request_id,
+                                    const std::string& initial_url,
+                                    const std::string& profile_id) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+           [](CbfBridgeClientImpl* impl, uint64_t request_id, std::string url,
+              std::string profile) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto& connection = impl->profile_connections[profile];
+            if (!connection.remote.is_bound()) {
+              mojo::PendingRemote<cbf::mojom::CbfProfileService>
+                  profile_remote;
+              mojo::PendingReceiver<cbf::mojom::CbfProfileService> receiver =
+                  profile_remote.InitWithNewPipeAndPassReceiver();
+              impl->browser_remote->BindProfileService(profile,
+                                                       std::move(receiver));
+              connection.remote.Bind(std::move(profile_remote));
+              connection.observer = std::make_unique<
+                  CbfBridgeClientImpl::Observer>(impl, profile);
+              mojo::PendingRemote<cbf::mojom::CbfProfileObserver>
+                  observer_remote;
+              connection.observer_receiver = std::make_unique<
+                  mojo::Receiver<cbf::mojom::CbfProfileObserver>>(
+                  connection.observer.get(),
+                  observer_remote.InitWithNewPipeAndPassReceiver());
+              connection.remote->SetObserver(std::move(observer_remote));
+            }
+            connection.remote->CreateWebPage(
+                std::move(url),
+                request_id,
+                base::BindOnce(
+                    [](CbfBridgeClientImpl* impl, std::string profile_id,
+                       uint64_t web_page_id) {
+                      impl->web_page_profiles.emplace(web_page_id,
+                                                      std::move(profile_id));
+                    },
+                    impl, profile));
+          },
+          impl, request_id, initial_url, profile_id));
+  return true;
+}
