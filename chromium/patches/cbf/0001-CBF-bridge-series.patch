diff --git a/chrome/browser/cbf/cbf_tab_manager.cc b/chrome/browser/cbf/cbf_tab_manager.cc
new file mode 100644
index 0000000000000..cb9f6acca5fff
--- /dev/null
+++ b/chrome/browser/cbf/cbf_tab_manager.cc
@@ -0,0 +1,242 @@
+#include "chrome/browser/cbf/cbf_tab_manager.h"
+
+#include <string>
+#include <vector>
+
+#include "base/functional/bind.h"
+#include "base/functional/callback.h"
+#include "base/logging.h"
+#include "chrome/browser/cbf/cbf_ca_context_id_observer.h"
+#include "chrome/browser/cbf/cbf_profile_service.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/common/referrer.h"
+#include "chrome/browser/profiles/profile.h"
+#include "ui/base/page_transition_types.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace cbf {
+namespace {
+
+bool NeedToFireBeforeUnloadOrUnload(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return false;
+  }
+  return web_contents->NeedToFireBeforeUnloadOrUnloadEvents();
+}
+
+}  // namespace
+
+CbfTabManager::CbfTabManager(::Profile* profile,
+                             CbfProfileService* profile_service)
+    : profile_(profile),
+      profile_service_(profile_service) {}
+
+CbfTabManager::~CbfTabManager() = default;
+
+WebPageId CbfTabManager::CreateWebPage(const GURL& initial_url) {
+  if (!profile_) {
+    return kInvalidWebPageId;
+  }
+
+  content::WebContents::CreateParams params(profile_);
+  std::unique_ptr<content::WebContents> web_contents =
+      content::WebContents::Create(params);
+  content::WebContents* web_contents_ptr = web_contents.get();
+  if (profile_service_) {
+    web_contents_ptr->SetDelegate(profile_service_->GetWebContentsDelegate());
+  }
+
+  const WebPageId web_page_id = next_web_page_id_++;
+  pages_.emplace(web_page_id, std::move(web_contents));
+  reverse_lookup_.emplace(web_contents_ptr, web_page_id);
+
+  web_contents_ptr->Resize(gfx::Rect(0, 0, 1, 1));
+  CbfCaContextIdObserver::CreateForWebContents(web_contents_ptr,
+                                               profile_service_);
+
+  if (initial_url.is_valid()) {
+    web_contents_ptr->GetController().LoadURL(
+        initial_url, content::Referrer(), ui::PAGE_TRANSITION_AUTO_TOPLEVEL,
+        std::string());
+  }
+
+  web_contents_ptr->WasShown();
+  web_contents_ptr->Focus();
+
+  return web_page_id;
+}
+
+content::WebContents* CbfTabManager::GetWebContents(
+    WebPageId web_page_id) const {
+  auto it = pages_.find(web_page_id);
+  if (it == pages_.end()) {
+    return nullptr;
+  }
+  return it->second.get();
+}
+
+WebPageId CbfTabManager::GetWebPageIdForWebContents(
+    content::WebContents* web_contents) const {
+  auto it = reverse_lookup_.find(web_contents);
+  if (it == reverse_lookup_.end()) {
+    return kInvalidWebPageId;
+  }
+  return it->second;
+}
+
+std::vector<WebPageId> CbfTabManager::GetDirtyWebPageIds() const {
+  std::vector<WebPageId> ids;
+  ids.reserve(pages_.size());
+  for (const auto& [web_page_id, web_contents] : pages_) {
+    if (web_contents && NeedToFireBeforeUnloadOrUnload(web_contents.get())) {
+      ids.push_back(web_page_id);
+    }
+  }
+  return ids;
+}
+
+std::vector<WebPageId> CbfTabManager::GetAllWebPageIds() const {
+  std::vector<WebPageId> ids;
+  ids.reserve(pages_.size());
+  for (const auto& [web_page_id, web_contents] : pages_) {
+    if (web_contents) {
+      ids.push_back(web_page_id);
+    }
+  }
+  return ids;
+}
+
+size_t CbfTabManager::GetWebPageCount() const {
+  return pages_.size();
+}
+
+void CbfTabManager::DispatchBeforeUnloadForAll() {
+  for (const auto& entry : pages_) {
+    const auto& web_contents = entry.second;
+    if (web_contents) {
+      web_contents->DispatchBeforeUnload(false);
+    }
+  }
+}
+
+void CbfTabManager::RequestCloseWebPage(WebPageId web_page_id) {
+  auto it = pages_.find(web_page_id);
+  if (it == pages_.end()) {
+    return;
+  }
+  auto* web_contents = it->second.get();
+  if (!web_contents) {
+    return;
+  }
+  web_contents->DispatchBeforeUnload(false);
+}
+
+void CbfTabManager::CloseWebPage(WebPageId web_page_id) {
+  auto it = pages_.find(web_page_id);
+  if (it == pages_.end()) {
+    return;
+  }
+  pending_resizes_.erase(web_page_id);
+  in_flight_resizes_.erase(web_page_id);
+
+  auto cb_it = pending_callbacks_.find(web_page_id);
+  if (cb_it != pending_callbacks_.end()) {
+    for (auto& cb : cb_it->second) {
+      std::move(cb).Run();
+    }
+    pending_callbacks_.erase(cb_it);
+  }
+
+  reverse_lookup_.erase(it->second.get());
+  pages_.erase(it);
+}
+
+void CbfTabManager::CloseWebContents(content::WebContents* web_contents) {
+  if (!web_contents) {
+    return;
+  }
+  auto it = reverse_lookup_.find(web_contents);
+  if (it == reverse_lookup_.end()) {
+    return;
+  }
+  CloseWebPage(it->second);
+}
+
+void CbfTabManager::CloseAllWebPages() {
+  std::vector<WebPageId> targets;
+  targets.reserve(pages_.size());
+  for (const auto& [web_page_id, web_contents] : pages_) {
+    if (!web_contents) {
+      continue;
+    }
+    targets.push_back(web_page_id);
+  }
+  for (const auto web_page_id : targets) {
+    auto it = pages_.find(web_page_id);
+    if (it == pages_.end() || !it->second) {
+      continue;
+    }
+    it->second->Close();
+  }
+}
+
+void CbfTabManager::SetWebPageSize(WebPageId web_page_id,
+                                   std::uint32_t width,
+                                   std::uint32_t height,
+                                   base::OnceClosure callback) {
+  auto it = pages_.find(web_page_id);
+  if (it == pages_.end()) {
+    std::move(callback).Run();
+    return;
+  }
+
+  pending_callbacks_[web_page_id].push_back(std::move(callback));
+
+  if (in_flight_resizes_.contains(web_page_id)) {
+    pending_resizes_[web_page_id] = gfx::Size(width, height);
+    return;
+  }
+
+  PerformResize(web_page_id, width, height);
+}
+
+void CbfTabManager::PerformResize(WebPageId web_page_id,
+                                 std::uint32_t width,
+                                 std::uint32_t height) {
+  auto it = pages_.find(web_page_id);
+  if (it == pages_.end()) {
+    return;
+  }
+
+  content::WebContents* web_contents = it->second.get();
+  in_flight_resizes_.insert(web_page_id);
+  web_contents->Resize(gfx::Rect(0, 0, width, height));
+
+  web_contents->GetPrimaryMainFrame()->InsertVisualStateCallback(
+      base::BindOnce(&CbfTabManager::OnResizeFinished,
+                     weak_factory_.GetWeakPtr(), web_page_id));
+}
+
+void CbfTabManager::OnResizeFinished(WebPageId web_page_id, bool success) {
+  in_flight_resizes_.erase(web_page_id);
+
+  auto cb_it = pending_callbacks_.find(web_page_id);
+  if (cb_it != pending_callbacks_.end()) {
+    auto callbacks = std::move(cb_it->second);
+    pending_callbacks_.erase(cb_it);
+    for (auto& cb : callbacks) {
+      std::move(cb).Run();
+    }
+  }
+
+  auto it = pending_resizes_.find(web_page_id);
+  if (it != pending_resizes_.end()) {
+    gfx::Size size = it->second;
+    pending_resizes_.erase(it);
+    PerformResize(web_page_id, size.width(), size.height());
+  }
+}
+
+}  // namespace cbf
