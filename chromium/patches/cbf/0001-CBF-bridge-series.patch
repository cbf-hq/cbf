index 0000000000000..d766b597b0e95
--- /dev/null
+++ b/chrome/browser/cbf/bridge/cbf_bridge_events.cc
@@ -0,0 +1,387 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+
+#include "base/containers/span.h"
+#include "base/compiler_specific.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client_impl.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+#include "chrome/browser/cbf/mojom/cbf_browser.mojom.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace cbf_bridge::internal {
+
+namespace {
+
+CbfRect ToCbfRect(const gfx::Rect& rect) {
+  CbfRect out = {};
+  out.x = rect.x();
+  out.y = rect.y();
+  out.width = rect.width();
+  out.height = rect.height();
+  return out;
+}
+
+CbfContextMenuIcon ToCbfMenuIcon(const cbf::mojom::CbfMenuIconPtr& icon) {
+  CbfContextMenuIcon out = {};
+  if (!icon || icon->png_bytes.empty()) {
+    return out;
+  }
+  const size_t len = icon->png_bytes.size();
+  auto* bytes = new uint8_t[len];
+  auto out_bytes = UNSAFE_BUFFERS(base::span(bytes, len));
+  for (size_t i = 0; i < out_bytes.size(); ++i) {
+    out_bytes[i] = icon->png_bytes[i];
+  }
+  out.png_bytes = bytes;
+  out.len = static_cast<uint32_t>(len);
+  out.width = icon->width;
+  out.height = icon->height;
+  return out;
+}
+
+CbfContextMenuItemList ToCbfMenuItems(
+    const std::vector<cbf::mojom::CbfMenuItemPtr>& items);
+
+void FillCbfMenuItem(const cbf::mojom::CbfMenuItemPtr& item,
+                     CbfContextMenuItem* out_item) {
+  if (!out_item) {
+    return;
+  }
+  *out_item = {};
+  if (!item) {
+    return;
+  }
+
+  out_item->type = static_cast<uint8_t>(item->type);
+  out_item->command_id = item->command_id;
+  out_item->label = CopyCString(item->label);
+  out_item->secondary_label = CopyCString(item->secondary_label);
+  out_item->minor_text = CopyCString(item->minor_text);
+  out_item->accessible_name = CopyCString(item->accessible_name);
+  out_item->enabled = item->enabled;
+  out_item->visible = item->visible;
+  out_item->checked = item->checked;
+  out_item->group_id = item->group_id;
+  out_item->is_new_feature = item->is_new_feature;
+  out_item->is_alerted = item->is_alerted;
+  out_item->may_have_mnemonics = item->may_have_mnemonics;
+
+  if (item->accelerator) {
+    out_item->has_accelerator = true;
+    out_item->accelerator_key_equivalent =
+        CopyCString(item->accelerator->key_equivalent);
+    out_item->accelerator_modifier_mask =
+        item->accelerator->modifier_mask;
+  }
+
+  out_item->icon = ToCbfMenuIcon(item->icon);
+  out_item->minor_icon = ToCbfMenuIcon(item->minor_icon);
+  out_item->submenu = ToCbfMenuItems(item->submenu);
+}
+
+CbfContextMenuItemList ToCbfMenuItems(
+    const std::vector<cbf::mojom::CbfMenuItemPtr>& items) {
+  CbfContextMenuItemList out = {};
+  if (items.empty()) {
+    return out;
+  }
+  auto* out_items = new CbfContextMenuItem[items.size()];
+  auto out_span = UNSAFE_BUFFERS(base::span(out_items, items.size()));
+  for (size_t i = 0; i < out_span.size(); ++i) {
+    FillCbfMenuItem(items[i], &out_span[i]);
+  }
+  out.items = out_items;
+  out.len = static_cast<uint32_t>(items.size());
+  return out;
+}
+
+void FillContextMenu(const cbf::mojom::CbfContextMenuPtr& menu,
+                     CbfContextMenu* out_menu) {
+  if (!out_menu) {
+    return;
+  }
+  *out_menu = {};
+  if (!menu) {
+    return;
+  }
+  out_menu->menu_id = menu->menu_id;
+  out_menu->x = menu->x;
+  out_menu->y = menu->y;
+  out_menu->source_type = menu->source_type;
+  out_menu->items = ToCbfMenuItems(menu->items);
+}
+
+CbfDragUrlInfoList ToCbfDragUrlInfos(
+    const std::vector<cbf::mojom::CbfDragUrlInfoPtr>& infos) {
+  CbfDragUrlInfoList out = {};
+  if (infos.empty()) {
+    return out;
+  }
+  auto* out_infos = new CbfDragUrlInfo[infos.size()];
+  auto out_span = UNSAFE_BUFFERS(base::span(out_infos, infos.size()));
+  for (size_t i = 0; i < out_span.size(); ++i) {
+    out_span[i] = {};
+    if (!infos[i]) {
+      continue;
+    }
+    out_span[i].url = CopyCString(infos[i]->url);
+    out_span[i].title = CopyCString(infos[i]->title);
+  }
+  out.items = out_infos;
+  out.len = static_cast<uint32_t>(infos.size());
+  return out;
+}
+
+CbfDragImage ToCbfDragImage(const cbf::mojom::CbfDragImagePtr& image) {
+  CbfDragImage out = {};
+  if (!image || image->png_bytes.empty()) {
+    return out;
+  }
+  const size_t len = image->png_bytes.size();
+  auto* bytes = new uint8_t[len];
+  auto out_bytes = UNSAFE_BUFFERS(base::span(bytes, len));
+  for (size_t i = 0; i < out_bytes.size(); ++i) {
+    out_bytes[i] = image->png_bytes[i];
+  }
+  out.png_bytes = bytes;
+  out.png_len = static_cast<uint32_t>(len);
+  out.pixel_width = image->pixel_width;
+  out.pixel_height = image->pixel_height;
+  out.scale = image->scale;
+  out.cursor_offset_x = image->cursor_offset_x;
+  out.cursor_offset_y = image->cursor_offset_y;
+  return out;
+}
+
+}  // namespace
+
+bool CbfBridgeClient::PollEvent(CbfBridgeEvent* out_event) {
+  if (!impl_ || !out_event) {
+    return false;
+  }
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  if (impl_->events.empty()) {
+    return false;
+  }
+  CbfBridgeEventData event = std::move(impl_->events.front());
+  out_event->kind = event.kind;
+  out_event->web_page_id = event.web_page_id;
+  out_event->request_id = event.request_id;
+  out_event->profile_id =
+      event.profile_id.empty() ? nullptr : CopyCString(event.profile_id);
+  out_event->surface_handle = event.surface_handle;
+  out_event->ime_bounds = {};
+  out_event->ime_bounds.has_composition = false;
+  out_event->ime_bounds.has_selection = false;
+  out_event->ime_bounds.composition.character_bounds.items = nullptr;
+  out_event->ime_bounds.composition.character_bounds.len = 0;
+  out_event->dirty_web_page_ids.items = nullptr;
+  out_event->dirty_web_page_ids.len = 0;
+  out_event->context_menu = {};
+  out_event->target_url = nullptr;
+  out_event->url = nullptr;
+  out_event->is_popup = false;
+  out_event->can_go_back = false;
+  out_event->can_go_forward = false;
+  out_event->is_loading = false;
+  out_event->dom_html = nullptr;
+  out_event->title = nullptr;
+  out_event->favicon_url = nullptr;
+  out_event->beforeunload_reason = kCbfBeforeUnloadReasonUnknown;
+  out_event->cursor_type = kCbfCursorDefault;
+  out_event->drag_start_request = {};
+
+  if (event.kind == kEventImeBoundsUpdated) {
+    if (event.composition_bounds.has_value()) {
+      const auto& composition = *event.composition_bounds;
+      out_event->ime_bounds.has_composition = true;
+      out_event->ime_bounds.composition.range_start = composition.range_start;
+      out_event->ime_bounds.composition.range_end = composition.range_end;
+      const size_t bounds_len = composition.character_bounds.size();
+      if (bounds_len > 0) {
+        auto* bounds = new CbfRect[bounds_len];
+        auto out_bounds = UNSAFE_BUFFERS(base::span(bounds, bounds_len));
+        for (size_t i = 0; i < out_bounds.size(); ++i) {
+          out_bounds[i] = ToCbfRect(composition.character_bounds[i]);
+        }
+        out_event->ime_bounds.composition.character_bounds.items = bounds;
+        out_event->ime_bounds.composition.character_bounds.len =
+            static_cast<uint32_t>(bounds_len);
+      }
+    }
+
+    if (event.selection_bounds.has_value()) {
+      const auto& selection = *event.selection_bounds;
+      out_event->ime_bounds.has_selection = true;
+      out_event->ime_bounds.selection.range_start = selection.range_start;
+      out_event->ime_bounds.selection.range_end = selection.range_end;
+      out_event->ime_bounds.selection.caret_rect =
+          ToCbfRect(selection.caret_rect);
+      out_event->ime_bounds.selection.first_selection_rect =
+          ToCbfRect(selection.first_selection_rect);
+    }
+  }
+  if (event.kind == kEventShutdownBlocked) {
+    const size_t list_len = event.dirty_web_page_ids.size();
+    if (list_len > 0) {
+      auto* ids = new uint64_t[list_len];
+      auto out_ids = UNSAFE_BUFFERS(base::span(ids, list_len));
+      for (size_t i = 0; i < out_ids.size(); ++i) {
+        out_ids[i] = event.dirty_web_page_ids[i];
+      }
+      out_event->dirty_web_page_ids.items = ids;
+      out_event->dirty_web_page_ids.len = static_cast<uint32_t>(list_len);
+    }
+  }
+  if (event.kind == kEventContextMenuRequested) {
+    FillContextMenu(event.context_menu, &out_event->context_menu);
+  }
+  if (event.kind == kEventNewWebPageRequested) {
+    out_event->target_url =
+        event.target_url.empty() ? nullptr : CopyCString(event.target_url);
+    out_event->is_popup = event.is_popup;
+  }
+  if (event.kind == kEventBeforeUnloadDialogRequested) {
+    out_event->beforeunload_reason = event.beforeunload_reason;
+  }
+  if (event.kind == kEventCursorChanged) {
+    out_event->cursor_type = event.cursor_type;
+  }
+  if (event.kind == kEventWebPageClosed) {
+    // No extra payload.
+  }
+  if (event.kind == kEventNavigationStateChanged) {
+    out_event->url = event.url.empty() ? nullptr : CopyCString(event.url);
+    out_event->can_go_back = event.can_go_back;
+    out_event->can_go_forward = event.can_go_forward;
+    out_event->is_loading = event.is_loading;
+  }
+  if (event.kind == kEventWebPageDomHtmlRead) {
+    out_event->dom_html =
+        event.dom_html.empty() ? nullptr : CopyCString(event.dom_html);
+  }
+  if (event.kind == kEventTitleUpdated) {
+    out_event->title = event.title.empty() ? nullptr : CopyCString(event.title);
+  }
+  if (event.kind == kEventFaviconUrlUpdated) {
+    out_event->favicon_url =
+        event.favicon_url.empty() ? nullptr : CopyCString(event.favicon_url);
+  }
+  if (event.kind == kEventDragStartRequested) {
+    if (event.drag_start_request) {
+      out_event->drag_start_request.session_id =
+          event.drag_start_request->session_id;
+      out_event->drag_start_request.web_page_id =
+          event.drag_start_request->web_page_id;
+      out_event->drag_start_request.allowed_operations =
+          event.drag_start_request->allowed_operations;
+      out_event->drag_start_request.source_origin =
+          CopyCString(event.drag_start_request->source_origin);
+      if (event.drag_start_request->data) {
+        out_event->drag_start_request.data.text =
+            CopyCString(event.drag_start_request->data->text);
+        out_event->drag_start_request.data.html =
+            CopyCString(event.drag_start_request->data->html);
+        out_event->drag_start_request.data.html_base_url =
+            CopyCString(event.drag_start_request->data->html_base_url);
+        out_event->drag_start_request.data.url_infos =
+            ToCbfDragUrlInfos(event.drag_start_request->data->url_infos);
+      }
+      out_event->drag_start_request.image =
+          ToCbfDragImage(event.drag_start_request->image);
+    }
+  }
+  impl_->events.pop();
+  return true;
+}
+
+}  // namespace cbf_bridge::internal
+
+namespace {
+
+void FreeContextMenuItemList(CbfContextMenuItemList list) {
+  if (!list.items || list.len == 0) {
+    return;
+  }
+  auto items = UNSAFE_BUFFERS(base::span(list.items, list.len));
+  for (auto& item : items) {
+    delete[] item.label;
+    delete[] item.secondary_label;
+    delete[] item.minor_text;
+    delete[] item.accessible_name;
+    delete[] item.accelerator_key_equivalent;
+    if (item.icon.png_bytes) {
+      delete[] item.icon.png_bytes;
+    }
+    if (item.minor_icon.png_bytes) {
+      delete[] item.minor_icon.png_bytes;
+    }
+    if (item.submenu.items) {
+      FreeContextMenuItemList(item.submenu);
+    }
+  }
+  delete[] list.items;
+}
+
+void FreeDragUrlInfoList(CbfDragUrlInfoList list) {
+  if (!list.items || list.len == 0) {
+    return;
+  }
+  auto infos = UNSAFE_BUFFERS(base::span(list.items, list.len));
+  for (auto& info : infos) {
+    delete[] info.url;
+    delete[] info.title;
+  }
+  delete[] list.items;
+}
+
+}  // namespace
+
+extern "C" void cbf_bridge_event_free(CbfBridgeEvent* event) {
+  if (!event) {
+    return;
+  }
+  delete[] event->profile_id;
+  event->profile_id = nullptr;
+  delete[] event->target_url;
+  event->target_url = nullptr;
+  delete[] event->url;
+  event->url = nullptr;
+  delete[] event->dom_html;
+  event->dom_html = nullptr;
+  delete[] event->title;
+  event->title = nullptr;
+  delete[] event->favicon_url;
+  event->favicon_url = nullptr;
+  if (event->ime_bounds.has_composition &&
+      event->ime_bounds.composition.character_bounds.items) {
+    delete[] event->ime_bounds.composition.character_bounds.items;
+    event->ime_bounds.composition.character_bounds.items = nullptr;
+    event->ime_bounds.composition.character_bounds.len = 0;
+  }
+  if (event->dirty_web_page_ids.items) {
+    delete[] event->dirty_web_page_ids.items;
+    event->dirty_web_page_ids.items = nullptr;
+    event->dirty_web_page_ids.len = 0;
+  }
+  if (event->kind == kEventContextMenuRequested) {
+    FreeContextMenuItemList(event->context_menu.items);
+    event->context_menu.items.items = nullptr;
+    event->context_menu.items.len = 0;
+  }
+  if (event->kind == kEventDragStartRequested) {
+    delete[] event->drag_start_request.source_origin;
+    event->drag_start_request.source_origin = nullptr;
+    delete[] event->drag_start_request.data.text;
+    event->drag_start_request.data.text = nullptr;
+    delete[] event->drag_start_request.data.html;
+    event->drag_start_request.data.html = nullptr;
+    delete[] event->drag_start_request.data.html_base_url;
+    event->drag_start_request.data.html_base_url = nullptr;
+    FreeDragUrlInfoList(event->drag_start_request.data.url_infos);
+    event->drag_start_request.data.url_infos.items = nullptr;
+    event->drag_start_request.data.url_infos.len = 0;
+    delete[] event->drag_start_request.image.png_bytes;
+    event->drag_start_request.image.png_bytes = nullptr;
+    event->drag_start_request.image.png_len = 0;
+  }
+}
