diff --git a/chrome/browser/cbf/bridge/cbf_bridge.cc b/chrome/browser/cbf/bridge/cbf_bridge.cc
new file mode 100644
index 0000000000000..f46e8fa78298d
--- /dev/null
+++ b/chrome/browser/cbf/bridge/cbf_bridge.cc
@@ -0,0 +1,35 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge.h"
+
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+
+extern "C" CbfBridgeClientHandle* cbf_bridge_client_create(void) {
+  return reinterpret_cast<CbfBridgeClientHandle*>(
+      new cbf_bridge::internal::CbfBridgeClient());
+}
+
+extern "C" void cbf_bridge_client_destroy(CbfBridgeClientHandle* client) {
+  delete reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client);
+}
+
+extern "C" void cbf_bridge_init(void) {
+  cbf_bridge::internal::EnsureMojoThreadStarted();
+}
+
+extern "C" bool cbf_bridge_client_connect(CbfBridgeClientHandle* client,
+                                           const char* channel_name) {
+  if (!client || !channel_name) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->Connect(channel_name);
+}
+
+extern "C" bool cbf_bridge_client_poll_event(CbfBridgeClientHandle* client,
+                                              CbfBridgeEvent* out_event) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->PollEvent(out_event);
+}
