+  delete[] event->dom_code;
+  event->dom_code = nullptr;
+  delete[] event->dom_key;
+  event->dom_key = nullptr;
+  delete[] event->text;
+  event->text = nullptr;
+  delete[] event->unmodified_text;
+  event->unmodified_text = nullptr;
+}
