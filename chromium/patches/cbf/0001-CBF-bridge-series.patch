+
+  auto* widget_impl = content::RenderWidgetHostImpl::From(
+      ResolveInputRenderWidgetHost(web_contents));
+
+  if (focused) {
+    if (widget_impl) {
+      widget_impl->SetPageFocus(true);
+    }
+    web_contents->Focus();
+    web_contents->RestoreFocus();
+    return;
+  }
+
+  web_contents->StoreFocus();
