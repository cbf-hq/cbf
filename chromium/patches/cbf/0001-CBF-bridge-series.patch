+extern "C" void cbf_bridge_convert_nsevent(
+    void* nsevent,
+    uint64_t web_page_id,
+    CbfKeyEvent* out_event) {
+#if defined(__APPLE__)
+  if (!nsevent || !out_event) {
+    return;
+  }
+  // Convert on the current thread (Main Thread)
+  auto mojom_event = cbf::ConvertNSEventToMojom(nsevent, web_page_id);
+
+  out_event->web_page_id = mojom_event->web_page_id;
+  out_event->type = static_cast<uint8_t>(mojom_event->type);
+  out_event->modifiers = mojom_event->modifiers;
+  out_event->windows_key_code = mojom_event->windows_key_code;
+  out_event->native_key_code = mojom_event->native_key_code;
+
+  out_event->dom_code =
+      !mojom_event->dom_code.empty()
+          ? cbf_bridge::internal::CopyCString(mojom_event->dom_code)
+          : nullptr;
+  out_event->dom_key =
+      !mojom_event->dom_key.empty()
+          ? cbf_bridge::internal::CopyCString(mojom_event->dom_key)
+          : nullptr;
+  out_event->text = !mojom_event->text.empty()
+                        ? cbf_bridge::internal::CopyCString(mojom_event->text)
+                        : nullptr;
+  out_event->unmodified_text =
+      !mojom_event->unmodified_text.empty()
+          ? cbf_bridge::internal::CopyCString(mojom_event->unmodified_text)
+          : nullptr;
+
+  out_event->auto_repeat = mojom_event->auto_repeat;
+  out_event->is_keypad = mojom_event->is_keypad;
+  out_event->is_system_key = mojom_event->is_system_key;
+  out_event->location = mojom_event->location;
+#endif
+}
