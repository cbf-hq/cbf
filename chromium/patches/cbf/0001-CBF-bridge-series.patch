+void CbfProfileService::SendDragUpdate(mojom::CbfDragUpdatePtr update) {
+  const auto it = drag_sessions_.find(update->session_id);
+  if (it == drag_sessions_.end()) {
+    return;
+  }
+
+  DragSessionState& session = it->second;
+  if (session.web_page_id != update->web_page_id || !session.source_rwh) {
+    return;
+  }
+
+  gfx::PointF client_point(update->position_in_widget_x,
+                           update->position_in_widget_y);
+  gfx::PointF screen_point(update->position_in_screen_x,
+                           update->position_in_screen_y);
+  const int modifiers = static_cast<int>(update->modifiers);
+  const blink::DragOperationsMask allowed_ops =
+      static_cast<blink::DragOperationsMask>(update->allowed_operations);
+
+  if (!session.entered) {
+    session.source_rwh->DragTargetDragEnter(
+        session.drop_data, client_point, screen_point, allowed_ops, modifiers,
+        base::BindOnce(
+            [](base::WeakPtr<CbfProfileService> self, uint64_t session_id,
+               ui::mojom::DragOperation operation,
+               bool document_is_handling_drag) {
+              if (!self) {
+                return;
+              }
+              auto session_it = self->drag_sessions_.find(session_id);
+              if (session_it == self->drag_sessions_.end()) {
+                return;
+              }
+              session_it->second.last_operation = operation;
+              session_it->second.document_is_handling_drag =
+                  document_is_handling_drag;
+            },
+            weak_factory_.GetWeakPtr(), update->session_id));
+    session.entered = true;
+    return;
+  }
+
+  session.source_rwh->DragTargetDragOver(
+      client_point, screen_point, allowed_ops, modifiers,
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileService> self, uint64_t session_id,
+             ui::mojom::DragOperation operation,
+             bool document_is_handling_drag) {
+            if (!self) {
+              return;
+            }
+            auto session_it = self->drag_sessions_.find(session_id);
+            if (session_it == self->drag_sessions_.end()) {
+              return;
+            }
+            session_it->second.last_operation = operation;
+            session_it->second.document_is_handling_drag =
+                document_is_handling_drag;
+          },
+          weak_factory_.GetWeakPtr(), update->session_id));
+}
+
+void CbfProfileService::SendDragDrop(mojom::CbfDragDropPtr drop) {
+  const auto it = drag_sessions_.find(drop->session_id);
+  if (it == drag_sessions_.end()) {
+    return;
+  }
+
+  DragSessionState session = std::move(it->second);
+  drag_sessions_.erase(it);
+
+  if (session.web_page_id != drop->web_page_id || !session.source_rwh) {
+    return;
+  }
+
+  gfx::PointF client_point(drop->position_in_widget_x, drop->position_in_widget_y);
+  gfx::PointF screen_point(drop->position_in_screen_x, drop->position_in_screen_y);
+  const int modifiers = static_cast<int>(drop->modifiers);
+  session.drop_data.document_is_handling_drag =
+      session.document_is_handling_drag;
+
+  session.source_rwh->DragTargetDrop(session.drop_data, client_point, screen_point,
+                                     modifiers, base::DoNothing());
+  session.source_rwh->DragSourceEndedAt(client_point, screen_point,
+                                        session.last_operation, base::DoNothing());
+  session.source_rwh->DragSourceSystemDragEnded();
+}
+
+void CbfProfileService::SendDragCancel(uint64_t session_id, uint64_t web_page_id) {
+  const auto it = drag_sessions_.find(session_id);
+  if (it == drag_sessions_.end()) {
+    return;
+  }
+
+  DragSessionState session = std::move(it->second);
+  drag_sessions_.erase(it);
+
+  if (session.web_page_id != web_page_id || !session.source_rwh) {
+    return;
+  }
+
+  const gfx::PointF zero_point;
+  if (session.entered) {
+    session.source_rwh->DragTargetDragLeave(zero_point, zero_point);
+  }
+  session.source_rwh->DragSourceEndedAt(zero_point, zero_point,
+                                        ui::mojom::DragOperation::kNone,
+                                        base::DoNothing());
+  session.source_rwh->DragSourceSystemDragEnded();
+}
