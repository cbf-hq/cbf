+    default:
+      return cbf::mojom::CbfKeyEventType::kRawKeyDown;
+  }
+}
+
+cbf::mojom::CbfMouseEventType ToMojomMouseEventType(uint8_t type) {
+  switch (type) {
+    case kCbfMouseEventDown:
+      return cbf::mojom::CbfMouseEventType::kMouseDown;
+    case kCbfMouseEventUp:
+      return cbf::mojom::CbfMouseEventType::kMouseUp;
+    case kCbfMouseEventMove:
+      return cbf::mojom::CbfMouseEventType::kMouseMove;
+    case kCbfMouseEventEnter:
+      return cbf::mojom::CbfMouseEventType::kMouseEnter;
+    case kCbfMouseEventLeave:
+      return cbf::mojom::CbfMouseEventType::kMouseLeave;
+    default:
+      return cbf::mojom::CbfMouseEventType::kMouseMove;
