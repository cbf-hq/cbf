diff --git a/chrome/browser/cbf/bridge/cbf_bridge_client.cc b/chrome/browser/cbf/bridge/cbf_bridge_client.cc
new file mode 100644
index 0000000000000..6a260a8c33bdc
--- /dev/null
+++ b/chrome/browser/cbf/bridge/cbf_bridge_client.cc
@@ -0,0 +1,116 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/location.h"
+#include "base/synchronization/waitable_event.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client_impl.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+#include "components/named_mojo_ipc_server/named_mojo_ipc_server_client_util.h"
+#include "mojo/public/cpp/platform/platform_channel_endpoint.h"
+#include "mojo/public/cpp/system/invitation.h"
+#include "mojo/public/cpp/system/message_pipe.h"
+
+namespace cbf_bridge::internal {
+
+CbfBridgeClient::CbfBridgeClient() = default;
+
+CbfBridgeClient::~CbfBridgeClient() {
+  Shutdown();
+}
+
+bool CbfBridgeClient::Connect(const std::string& channel_name) {
+  channel_name_ = channel_name;
+  impl_ = std::make_unique<CbfBridgeClientImpl>();
+
+  constexpr uint64_t kCbfMessagePipeId = 0u;
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+
+  base::WaitableEvent done(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  bool success = false;
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, std::string channel, bool* success,
+             base::WaitableEvent* done) {
+            mojo::PlatformChannelEndpoint endpoint =
+                named_mojo_ipc_server::ConnectToServer(
+                    mojo::NamedPlatformChannel::ServerName(channel));
+            if (!endpoint.is_valid()) {
+              *success = false;
+              done->Signal();
+              return;
+            }
+
+            auto invitation =
+                mojo::IncomingInvitation::Accept(std::move(endpoint));
+            mojo::ScopedMessagePipeHandle message_pipe =
+                invitation.ExtractMessagePipe(kCbfMessagePipeId);
+            if (!message_pipe.is_valid()) {
+              *success = false;
+              done->Signal();
+              return;
+            }
+            impl->browser_remote.Bind(
+                mojo::PendingRemote<cbf::mojom::CbfBrowserService>(
+                    std::move(message_pipe),
+                    /*version=*/0));
+            impl->browser_observer =
+                std::make_unique<CbfBridgeClientImpl::BrowserObserver>(impl);
+            mojo::PendingRemote<cbf::mojom::CbfBrowserObserver> observer_remote;
+            impl->browser_observer_receiver = std::make_unique<
+                mojo::Receiver<cbf::mojom::CbfBrowserObserver>>(
+                impl->browser_observer.get(),
+                observer_remote.InitWithNewPipeAndPassReceiver());
+            impl->browser_remote->SetObserver(std::move(observer_remote));
+
+            *success = true;
+            done->Signal();
+          },
+          impl_.get(), channel_name, &success, &done));
+  done.Wait();
+  if (!success) {
+    impl_.reset();
+    return false;
+  }
+
+  return true;
+}
+
+void CbfBridgeClient::Shutdown() {
+  if (impl_) {
+    auto task_runner = GetMojoTaskRunner();
+    if (task_runner) {
+      base::WaitableEvent done(
+          base::WaitableEvent::ResetPolicy::MANUAL,
+          base::WaitableEvent::InitialState::NOT_SIGNALED);
+      task_runner->PostTask(
+          FROM_HERE,
+          base::BindOnce(
+              [](std::unique_ptr<CbfBridgeClientImpl> impl,
+                 base::WaitableEvent* done) {
+                if (impl) {
+                  impl->browser_remote.reset();
+                  impl->browser_observer_receiver.reset();
+                  impl->browser_observer.reset();
+                  impl->profile_connections.clear();
+                  impl->web_page_profiles.clear();
+                  impl->context_menu_profiles.clear();
+                }
+                done->Signal();
+              },
+              std::move(impl_), &done));
+      done.Wait();
+      return;
+    }
+  }
+  impl_.reset();
+}
+
+}  // namespace cbf_bridge::internal
