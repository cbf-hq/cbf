+bool RenderWidgetHostViewMac::GetLastFrameCaContextId(
+    uint32_t* out_context_id) const {
+  if (!out_context_id)
+    return false;
+
+  *out_context_id = 0;
+
+  if (!browser_compositor_)
+    return false;
+
+  const gfx::CALayerParams* ca_layer_params =
+      browser_compositor_->GetLastCALayerParams();
+  if (!ca_layer_params) {
+    ui::Compositor* compositor = browser_compositor_->GetCompositor();
+    if (!compositor || !compositor->has_accelerated_widget())
+      return false;
+    ui::CALayerFrameSink* frame_sink =
+        ui::CALayerFrameSink::FromAcceleratedWidget(compositor->widget());
+    if (!frame_sink)
+      return false;
+    auto* accelerated_widget =
+        static_cast<ui::AcceleratedWidgetMac*>(frame_sink);
+    ca_layer_params = accelerated_widget->GetCALayerParams();
+    if (!ca_layer_params)
+      return false;
+  }
+  if (ca_layer_params->is_empty)
+    return false;
+  if (ca_layer_params->ca_context_id == 0)
+    return false;
+
+  *out_context_id = ca_layer_params->ca_context_id;
+  return true;
+}
