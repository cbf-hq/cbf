+  ~CbfBridgeClient();
+
+  bool Connect(const std::string& channel_name);
+  bool PollEvent(CbfBridgeEvent* out_event);
+  bool GetProfiles(CbfProfileList* out_list);
+  bool CreateWebPage(uint64_t request_id,
+                     const std::string& initial_url,
+                     const std::string& profile_id);
+  bool SetWebPageSize(uint64_t web_page_id, uint32_t width, uint32_t height);
