@@ -0,0 +1,94 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+
+#include "base/containers/span.h"
+#include "base/compiler_specific.h"
+#include "base/functional/bind.h"
+#include "base/location.h"
+#include "base/synchronization/waitable_event.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client_impl.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+
+namespace cbf_bridge::internal {
+
+bool CbfBridgeClient::GetProfiles(CbfProfileList* out_list) {
+  if (!impl_ || !out_list) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner || !impl_->browser_remote.is_bound()) {
+    return false;
+  }
+
+  base::WaitableEvent done(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+  bool success = false;
+  std::vector<cbf::mojom::CbfProfileInfoPtr> profiles;
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl,
+             std::vector<cbf::mojom::CbfProfileInfoPtr>* out_profiles,
+             bool* success, base::WaitableEvent* done) {
+            if (!impl->browser_remote.is_bound()) {
+              done->Signal();
+              return;
+            }
+            impl->browser_remote->GetProfiles(base::BindOnce(
+                [](std::vector<cbf::mojom::CbfProfileInfoPtr>* out_profiles,
+                   bool* success, base::WaitableEvent* done,
+                   std::vector<cbf::mojom::CbfProfileInfoPtr> profiles) {
+                  *out_profiles = std::move(profiles);
+                  *success = true;
+                  done->Signal();
+                },
+                out_profiles, success, done));
+          },
+          impl_.get(), &profiles, &success, &done));
+  done.Wait();
+  if (!success) {
+    return false;
+  }
+
+  out_list->len = static_cast<uint32_t>(profiles.size());
+  out_list->profiles =
+      profiles.empty() ? nullptr : new CbfProfileInfo[profiles.size()];
+  auto out_profiles =
+      UNSAFE_BUFFERS(base::span(out_list->profiles, out_list->len));
+  size_t index = 0;
+  for (auto& entry : out_profiles) {
+    const auto& profile = profiles[index++];
+    entry.profile_id = CopyCString(profile->profile_id);
+    entry.profile_path = CopyCString(profile->profile_path);
+    entry.display_name = CopyCString(profile->display_name);
+  }
+  return true;
+}
+
+}  // namespace cbf_bridge::internal
+
+extern "C" bool cbf_bridge_client_get_profiles(CbfBridgeClientHandle* client,
+                                               CbfProfileList* out_list) {
+  if (!client || !out_list) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->GetProfiles(out_list);
+}
+
+extern "C" void cbf_bridge_profile_list_free(CbfProfileList* list) {
+  if (!list || !list->profiles) {
+    return;
+  }
+  auto profiles = UNSAFE_BUFFERS(base::span(list->profiles, list->len));
+  for (auto& profile : profiles) {
+    delete[] profile.profile_id;
+    delete[] profile.profile_path;
+    delete[] profile.display_name;
+  }
+  delete[] list->profiles;
+  list->profiles = nullptr;
+  list->len = 0;
+}
