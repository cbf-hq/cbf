+namespace cbf {
+
+CbfJavaScriptDialogManager::CbfJavaScriptDialogManager(
+    CbfProfileService* profile_service)
+    : profile_service_(profile_service) {}
+
+CbfJavaScriptDialogManager::~CbfJavaScriptDialogManager() = default;
+
+void CbfJavaScriptDialogManager::SetAutoConfirmBeforeUnload(bool enabled) {
+  auto_confirm_beforeunload_ = enabled;
+}
+
+void CbfJavaScriptDialogManager::ResolvePendingBeforeUnload(bool proceed) {
+  for (auto& callback : pending_beforeunload_callbacks_) {
+    std::move(callback).Run(proceed, std::u16string());
+  }
+  pending_beforeunload_callbacks_.clear();
+}
+
+void CbfJavaScriptDialogManager::ResolvePendingBeforeUnloadRequest(
+    uint64_t request_id,
+    bool proceed) {
+  const auto it = pending_beforeunload_requests_.find(request_id);
+  if (it == pending_beforeunload_requests_.end()) {
+    return;
+  }
+  auto callback = std::move(it->second);
+  pending_beforeunload_requests_.erase(it);
+  std::move(callback).Run(proceed, std::u16string());
+}
+
+void CbfJavaScriptDialogManager::RunJavaScriptDialog(
+    content::WebContents* web_contents,
+    content::RenderFrameHost* render_frame_host,
+    content::JavaScriptDialogType dialog_type,
+    const std::u16string& message_text,
+    const std::u16string& default_prompt_text,
+    DialogClosedCallback callback,
+    bool* did_suppress_message) {
+  (void)web_contents;
+  (void)render_frame_host;
+  (void)dialog_type;
+  (void)message_text;
+  (void)default_prompt_text;
+  if (did_suppress_message) {
+    *did_suppress_message = true;
+  }
+  std::move(callback).Run(false, std::u16string());
+}
+
+void CbfJavaScriptDialogManager::RunBeforeUnloadDialog(
+    content::WebContents* web_contents,
+    content::RenderFrameHost* render_frame_host,
+    bool is_reload,
+    DialogClosedCallback callback) {
+  (void)render_frame_host;
+  if (profile_service_ && profile_service_->IsShutdownRequested()) {
+    pending_beforeunload_callbacks_.push_back(std::move(callback));
+    profile_service_->OnBeforeUnloadDialogRequested(web_contents);
+    return;
+  }
+  if (!profile_service_ || !web_contents) {
+    std::move(callback).Run(false, std::u16string());
+    return;
+  }
+
+  const auto reason =
+      profile_service_->ResolveBeforeUnloadReason(web_contents, is_reload);
+  const uint64_t request_id = next_beforeunload_request_id_++;
+  pending_beforeunload_requests_.emplace(request_id, std::move(callback));
+  profile_service_->NotifyBeforeUnloadDialogRequested(web_contents, request_id,
+                                                      reason);
+}
+
+void CbfJavaScriptDialogManager::CancelDialogs(
+    content::WebContents* web_contents,
+    bool reset_state) {
+  (void)web_contents;
+  if (reset_state) {
+    pending_beforeunload_callbacks_.clear();
+    pending_beforeunload_requests_.clear();
+  }
+}
+
+}  // namespace cbf
