@@ -0,0 +1,103 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+
+#include "base/functional/bind.h"
+#include "base/location.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client_impl.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+
+namespace cbf_bridge::internal {
+
+bool CbfBridgeClient::ExecuteContextMenuCommand(uint64_t menu_id,
+                                                int32_t command_id,
+                                                int32_t event_flags) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t menu_id, int32_t command_id,
+             int32_t event_flags) {
+            auto profile_it = impl->context_menu_profiles.find(menu_id);
+            if (profile_it == impl->context_menu_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(profile_it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              impl->context_menu_profiles.erase(profile_it);
+              return;
+            }
+            remote_it->second.remote->ExecuteContextMenuCommand(
+                menu_id, command_id, event_flags);
+            impl->context_menu_profiles.erase(profile_it);
+          },
+          impl, menu_id, command_id, event_flags));
+  return true;
+}
+
+bool CbfBridgeClient::DismissContextMenu(uint64_t menu_id) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t menu_id) {
+            auto profile_it = impl->context_menu_profiles.find(menu_id);
+            if (profile_it == impl->context_menu_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(profile_it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              impl->context_menu_profiles.erase(profile_it);
+              return;
+            }
+            remote_it->second.remote->DismissContextMenu(menu_id);
+            impl->context_menu_profiles.erase(profile_it);
+          },
+          impl, menu_id));
+  return true;
+}
+
+}  // namespace cbf_bridge::internal
+
+extern "C" bool cbf_bridge_client_execute_context_menu_command(
+    CbfBridgeClientHandle* client,
+    uint64_t menu_id,
+    int32_t command_id,
+    int32_t event_flags) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->ExecuteContextMenuCommand(menu_id, command_id, event_flags);
+}
+
+extern "C" bool cbf_bridge_client_dismiss_context_menu(
+    CbfBridgeClientHandle* client,
+    uint64_t menu_id) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->DismissContextMenu(menu_id);
+}
