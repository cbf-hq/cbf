+
+namespace cbf_bridge::internal {
+
+bool CbfBridgeClient::SendKeyEvent(const CbfKeyEvent* event,
+                                   const CbfCommandList* commands) {
+  if (!event) {
+    return false;
+  }
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  auto key_event = cbf::mojom::CbfKeyEvent::New();
+  key_event->web_page_id = event->web_page_id;
+  key_event->type = ToMojomKeyEventType(event->type);
+  key_event->modifiers = event->modifiers;
+  key_event->windows_key_code = event->windows_key_code;
+  key_event->native_key_code = event->native_key_code;
+  key_event->dom_code = MaybeCopyString(event->dom_code);
+  key_event->dom_key = MaybeCopyString(event->dom_key);
+  key_event->text = MaybeCopyString(event->text);
+  key_event->unmodified_text = MaybeCopyString(event->unmodified_text);
+  key_event->auto_repeat = event->auto_repeat;
+  key_event->is_keypad = event->is_keypad;
+  key_event->is_system_key = event->is_system_key;
+  key_event->location = event->location;
+
+  std::optional<std::vector<std::string>> command_list;
+  if (commands && commands->len > 0 && commands->items) {
+    command_list.emplace();
+    command_list->reserve(commands->len);
+    auto items =
+        UNSAFE_BUFFERS(base::span(commands->items, commands->len));
+    for (const char* item : items) {
+      command_list->push_back(MaybeCopyString(item));
+    }
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, cbf::mojom::CbfKeyEventPtr event,
+             std::optional<std::vector<std::string>> commands) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(event->web_page_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->SendKeyEvent(std::move(event),
+                                                   commands);
+          },
+          impl, std::move(key_event), std::move(command_list)));
+  return true;
+}
