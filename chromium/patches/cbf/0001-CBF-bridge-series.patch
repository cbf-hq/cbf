+  bool SendKeyEvent(const CbfKeyEvent* event, const CbfCommandList* commands);
+  bool SendMouseEvent(const CbfMouseEvent* event);
+  bool SendMouseWheelEvent(const CbfMouseWheelEvent* event);
+  bool SendDragUpdate(const CbfDragUpdate* update);
+  bool SendDragDrop(const CbfDragDrop* drop);
+  bool SendDragCancel(uint64_t session_id, uint64_t web_page_id);
+  bool SetComposition(const CbfImeComposition* composition);
+  bool CommitText(const CbfImeCommitText* commit);
+  bool FinishComposingText(uint64_t web_page_id, uint8_t behavior);
+  bool ExecuteContextMenuCommand(uint64_t menu_id,
+                                 int32_t command_id,
+                                 int32_t event_flags);
+  bool DismissContextMenu(uint64_t menu_id);
+  bool RequestShutdown(uint64_t request_id);
+  bool ConfirmShutdown(uint64_t request_id, bool proceed);
+  bool ForceShutdown();
+
+  bool RequestCloseWebPage(uint64_t web_page_id);
