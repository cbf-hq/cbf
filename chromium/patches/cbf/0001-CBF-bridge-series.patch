+content::RenderWidgetHost* ResolveInputRenderWidgetHost(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+
+  // Prefer the focused frame when available.
+  if (content::RenderFrameHost* focused_frame =
+          web_contents->GetFocusedFrame()) {
+    if (content::RenderWidgetHost* widget_host =
+            focused_frame->GetRenderWidgetHost()) {
+      return widget_host;
+    }
+  }
+
+  // Fall back to the primary frame to keep routing stable after focus changes.
+  if (content::RenderFrameHost* primary_frame =
+          web_contents->GetPrimaryMainFrame()) {
+    if (content::RenderWidgetHost* widget_host =
+            primary_frame->GetRenderWidgetHost()) {
+      return widget_host;
+    }
+  }
+
+  // Last-resort fallback for cases where frame information is temporarily unset.
+  content::RenderWidgetHostView* view =
+      web_contents->GetRenderWidgetHostView();
+  return view ? view->GetRenderWidgetHost() : nullptr;
+}
