+}
+
+cbf::mojom::CbfMouseButton ToMojomMouseButton(uint8_t button) {
+  switch (button) {
+    case kCbfMouseButtonLeft:
+      return cbf::mojom::CbfMouseButton::kLeft;
+    case kCbfMouseButtonMiddle:
+      return cbf::mojom::CbfMouseButton::kMiddle;
+    case kCbfMouseButtonRight:
+      return cbf::mojom::CbfMouseButton::kRight;
+    case kCbfMouseButtonBack:
+      return cbf::mojom::CbfMouseButton::kBack;
+    case kCbfMouseButtonForward:
+      return cbf::mojom::CbfMouseButton::kForward;
+    case kCbfMouseButtonNone:
+    default:
+      return cbf::mojom::CbfMouseButton::kNoButton;
