+void CbfProfileService::GetWebPageDomHtml(uint64_t web_page_id,
+                                          uint64_t request_id) {
+  content::WebContents* web_contents = tab_manager_.GetWebContents(web_page_id);
+  if (!web_contents || !observer_) {
+    return;
+  }
+  content::RenderFrameHost* main_frame = web_contents->GetPrimaryMainFrame();
+  if (!main_frame || !main_frame->IsRenderFrameLive()) {
+    if (observer_) {
+      observer_->OnWebPageDomHtmlRead(web_page_id, request_id, "");
+    }
+    return;
+  }
+
+  main_frame->ExecuteJavaScriptInIsolatedWorld(
+      u"document.documentElement.outerHTML",
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileService> self, uint64_t web_page_id,
+             uint64_t request_id, base::Value value) {
+            if (!self || !self->observer_) {
+              return;
+            }
+            std::string html;
+            if (value.is_string()) {
+              html = value.GetString();
+            }
+            self->observer_->OnWebPageDomHtmlRead(web_page_id, request_id,
+                                                   html);
+          },
+          weak_factory_.GetWeakPtr(), web_page_id, request_id),
+      content::ISOLATED_WORLD_ID_CONTENT_END);
+}
