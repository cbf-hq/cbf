diff --git a/chrome/browser/cbf/cbf_browser_service.cc b/chrome/browser/cbf/cbf_browser_service.cc
new file mode 100644
index 0000000000000..5e686ca39c5a7
--- /dev/null
+++ b/chrome/browser/cbf/cbf_browser_service.cc
@@ -0,0 +1,300 @@
+#include "chrome/browser/cbf/cbf_browser_service.h"
+
+#include <utility>
+#include <vector>
+
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/cbf/cbf_profile_service.h"
+#include "chrome/browser/lifetime/application_lifetime.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/profiles/profile_attributes_entry.h"
+#include "chrome/browser/profiles/profile_attributes_storage.h"
+#include "chrome/browser/profiles/profile_manager.h"
+
+namespace cbf {
+
+CbfBrowserService::CbfBrowserService() = default;
+
+CbfBrowserService::~CbfBrowserService() = default;
+
+void CbfBrowserService::SetObserver(
+    mojo::PendingRemote<mojom::CbfBrowserObserver> observer) {
+  if (observer_.is_bound()) { observer_.reset(); } observer_.Bind(std::move(observer));
+}
+
+void CbfBrowserService::GetProfiles(GetProfilesCallback callback) {
+  std::vector<mojom::CbfProfileInfoPtr> profiles;
+  ProfileManager* profile_manager =
+      g_browser_process ? g_browser_process->profile_manager() : nullptr;
+  if (!profile_manager) {
+    std::move(callback).Run(std::move(profiles));
+    return;
+  }
+
+  ProfileAttributesStorage& storage =
+      profile_manager->GetProfileAttributesStorage();
+  auto entries = storage.GetAllProfilesAttributes();
+
+  profile_paths_.clear();
+  profiles.reserve(entries.size());
+  for (auto* entry : entries) {
+    const base::FilePath path = entry->GetPath();
+    const std::string profile_id = storage.StorageKeyFromProfilePath(path);
+    profile_paths_[profile_id] = path;
+
+    auto info = mojom::CbfProfileInfo::New();
+    info->profile_id = profile_id;
+    info->profile_path = path.AsUTF8Unsafe();
+    info->display_name = base::UTF16ToUTF8(entry->GetName());
+    profiles.push_back(std::move(info));
+  }
+
+  std::move(callback).Run(std::move(profiles));
+}
+
+void CbfBrowserService::BindProfileService(
+    const std::string& profile_id,
+    mojo::PendingReceiver<mojom::CbfProfileService> receiver) {
+  std::string resolved_id;
+  ::Profile* profile = ResolveProfile(profile_id, &resolved_id);
+  if (!profile) {
+    return;
+  }
+
+  auto it = profile_services_.find(resolved_id);
+  if (it == profile_services_.end()) {
+    auto service = std::make_unique<CbfProfileService>(profile, this);
+    it = profile_services_.emplace(resolved_id, std::move(service)).first;
+  }
+  it->second->BindReceiver(std::move(receiver));
+}
+
+void CbfBrowserService::RequestShutdown(uint64_t request_id) {
+  if (shutdown_state_ == ShutdownState::kProceeding || shutdown_in_progress_) {
+    if (observer_) {
+      observer_->OnShutdownProceeding(request_id);
+    }
+    return;
+  }
+  if (shutdown_state_ != ShutdownState::kIdle) {
+    if (shutdown_state_ == ShutdownState::kBlocked && observer_) {
+      std::vector<uint64_t> blocked_ids(beforeunload_dialog_pages_.begin(),
+                                        beforeunload_dialog_pages_.end());
+      observer_->OnShutdownBlocked(request_id, blocked_ids);
+    }
+    return;
+  }
+
+  shutdown_state_ = ShutdownState::kWaitingBeforeUnload;
+  shutdown_request_id_ = request_id;
+  pending_beforeunload_pages_.clear();
+  beforeunload_dialog_pages_.clear();
+
+  for (const auto& entry : profile_services_) {
+    const auto& service = entry.second;
+    const auto ids = service->GetAllWebPageIds();
+    pending_beforeunload_pages_.insert(ids.begin(), ids.end());
+  }
+
+  if (pending_beforeunload_pages_.empty()) {
+    StartShutdown(request_id);
+    return;
+  }
+
+  for (const auto& entry : profile_services_) {
+    entry.second->DispatchBeforeUnloadForShutdown();
+  }
+}
+
+void CbfBrowserService::ConfirmShutdown(uint64_t request_id, bool proceed) {
+  if (shutdown_state_ != ShutdownState::kBlocked ||
+      !shutdown_request_id_.has_value() ||
+      shutdown_request_id_.value() != request_id) {
+    return;
+  }
+  if (!proceed) {
+    CancelShutdown(request_id);
+    return;
+  }
+
+  for (const auto& entry : profile_services_) {
+    entry.second->ResolveBeforeUnloadForShutdown(true);
+  }
+  StartShutdown(request_id);
+}
+
+void CbfBrowserService::ForceShutdown() {
+  chrome::ExitIgnoreUnloadHandlers();
+}
+
+void CbfBrowserService::NotifyWebPageClosed() {
+  if (!shutdown_in_progress_) {
+    return;
+  }
+  if (!HasOpenWebPages()) {
+    chrome::AttemptExit();
+  }
+}
+
+void CbfBrowserService::StartShutdown(uint64_t request_id) {
+  shutdown_state_ = ShutdownState::kProceeding;
+  shutdown_in_progress_ = true;
+  shutdown_request_id_.reset();
+  pending_beforeunload_pages_.clear();
+  beforeunload_dialog_pages_.clear();
+
+  for (const auto& entry : profile_services_) {
+    entry.second->SetShutdownDialogAutoConfirm(true);
+  }
+
+  if (observer_) {
+    observer_->OnShutdownProceeding(request_id);
+  }
+
+  for (const auto& entry : profile_services_) {
+    entry.second->CloseAllWebPages();
+  }
+
+  if (!HasOpenWebPages()) {
+    chrome::AttemptExit();
+  }
+}
+
+void CbfBrowserService::CancelShutdown(uint64_t request_id) {
+  for (const auto& entry : profile_services_) {
+    entry.second->ResolveBeforeUnloadForShutdown(false);
+    entry.second->SetShutdownDialogAutoConfirm(false);
+  }
+  shutdown_state_ = ShutdownState::kIdle;
+  shutdown_request_id_.reset();
+  pending_beforeunload_pages_.clear();
+  beforeunload_dialog_pages_.clear();
+  if (observer_) {
+    observer_->OnShutdownCancelled(request_id);
+  }
+}
+
+bool CbfBrowserService::IsShutdownRequested() const {
+  return shutdown_state_ == ShutdownState::kWaitingBeforeUnload ||
+         shutdown_state_ == ShutdownState::kBlocked;
+}
+
+void CbfBrowserService::NotifyBeforeUnloadDialogRequested(
+    WebPageId web_page_id) {
+  if (shutdown_state_ != ShutdownState::kWaitingBeforeUnload &&
+      shutdown_state_ != ShutdownState::kBlocked) {
+    return;
+  }
+  beforeunload_dialog_pages_.insert(web_page_id);
+  MarkBeforeUnloadDispatchComplete(web_page_id);
+}
+
+void CbfBrowserService::NotifyBeforeUnloadFired(WebPageId web_page_id,
+                                                bool proceed) {
+  if (shutdown_state_ == ShutdownState::kWaitingBeforeUnload) {
+    MarkBeforeUnloadDispatchComplete(web_page_id);
+    return;
+  }
+  if (shutdown_state_ == ShutdownState::kBlocked && !proceed) {
+    return;
+  }
+}
+
+void CbfBrowserService::MarkBeforeUnloadDispatchComplete(
+    WebPageId web_page_id) {
+  const auto it = pending_beforeunload_pages_.find(web_page_id);
+  if (it == pending_beforeunload_pages_.end()) {
+    return;
+  }
+  pending_beforeunload_pages_.erase(it);
+  MaybeFinalizeShutdownRequest();
+}
+
+void CbfBrowserService::MaybeFinalizeShutdownRequest() {
+  if (shutdown_state_ != ShutdownState::kWaitingBeforeUnload ||
+      !pending_beforeunload_pages_.empty()) {
+    return;
+  }
+  if (!shutdown_request_id_.has_value()) {
+    return;
+  }
+
+  if (beforeunload_dialog_pages_.empty()) {
+    StartShutdown(shutdown_request_id_.value());
+    return;
+  }
+
+  shutdown_state_ = ShutdownState::kBlocked;
+  if (observer_) {
+    std::vector<uint64_t> blocked_ids(beforeunload_dialog_pages_.begin(),
+                                      beforeunload_dialog_pages_.end());
+    observer_->OnShutdownBlocked(shutdown_request_id_.value(), blocked_ids);
+  }
+}
+
+bool CbfBrowserService::HasOpenWebPages() const {
+  for (const auto& entry : profile_services_) {
+    if (entry.second->GetWebPageCount() > 0) {
+      return true;
+    }
+  }
+  return false;
+}
+
+void CbfBrowserService::RebuildProfileCache() {
+  profile_paths_.clear();
+  ProfileManager* profile_manager =
+      g_browser_process ? g_browser_process->profile_manager() : nullptr;
+  if (!profile_manager) {
+    return;
+  }
+
+  ProfileAttributesStorage& storage =
+      profile_manager->GetProfileAttributesStorage();
+  auto entries = storage.GetAllProfilesAttributes();
+  for (auto* entry : entries) {
+    const base::FilePath path = entry->GetPath();
+    profile_paths_[storage.StorageKeyFromProfilePath(path)] = path;
+  }
+}
+
+::Profile* CbfBrowserService::ResolveProfile(const std::string& profile_id,
+                                             std::string* resolved_id) {
+  ProfileManager* profile_manager =
+      g_browser_process ? g_browser_process->profile_manager() : nullptr;
+  if (!profile_manager) {
+    return nullptr;
+  }
+
+  if (profile_id.empty()) {
+    ::Profile* profile = ProfileManager::GetLastUsedProfile();
+    if (!profile) {
+      return nullptr;
+    }
+    ProfileAttributesStorage& storage =
+        profile_manager->GetProfileAttributesStorage();
+    const std::string id = storage.StorageKeyFromProfilePath(profile->GetPath());
+    profile_paths_[id] = profile->GetPath();
+    if (resolved_id) {
+      *resolved_id = id;
+    }
+    return profile;
+  }
+
+  auto it = profile_paths_.find(profile_id);
+  if (it == profile_paths_.end()) {
+    RebuildProfileCache();
+    it = profile_paths_.find(profile_id);
+  }
+  if (it == profile_paths_.end()) {
+    return nullptr;
+  }
+
+  if (resolved_id) {
+    *resolved_id = profile_id;
+  }
+  return profile_manager->GetProfileByPath(it->second);
+}
+
+}  // namespace cbf
