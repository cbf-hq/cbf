@@ -0,0 +1,41 @@
+#include "chrome/browser/cbf/cbf_surface_provider_mac.h"
+
+#include "build/buildflag.h"
+
+#if BUILDFLAG(IS_MAC)
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+#endif
+
+namespace cbf {
+
+#if BUILDFLAG(IS_MAC)
+
+bool TryGetWebContentsCaContextId(content::WebContents* web_contents,
+                                 std::uint32_t* out_context_id) {
+  if (!out_context_id)
+    return false;
+
+  *out_context_id = 0;
+
+  if (!web_contents)
+    return false;
+
+  content::RenderWidgetHostView* view = web_contents->GetRenderWidgetHostView();
+  if (!view)
+    return false;
+
+  uint32_t ca_context_id = 0;
+  if (!view->GetLastFrameCaContextId(&ca_context_id))
+    return false;
+
+  if (ca_context_id == 0)
+    return false;
+
+  *out_context_id = ca_context_id;
+  return true;
+}
+
+#endif  // BUILDFLAG(IS_MAC)
+
+}  // namespace cbf
