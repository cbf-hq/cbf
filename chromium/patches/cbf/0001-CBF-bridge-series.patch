+void CbfBridgeClientImpl::Observer::OnImeBoundsUpdated(
+    cbf::mojom::CbfImeBoundsUpdatePtr update) {
+  if (!update) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventImeBoundsUpdated;
+  event.web_page_id = update->web_page_id;
+  event.profile_id = profile_id_;
+
+  if (update->composition) {
+    CbfBridgeEventData::ImeCompositionBoundsData composition;
+    composition.range_start = update->composition->range_start;
+    composition.range_end = update->composition->range_end;
+    composition.character_bounds.reserve(
+        update->composition->character_bounds.size());
+    for (const auto& rect : update->composition->character_bounds) {
+      if (!rect) {
+        continue;
+      }
+      composition.character_bounds.emplace_back(
+          rect->x, rect->y, rect->width, rect->height);
+    }
+    event.composition_bounds = std::move(composition);
+  }
+
+  if (update->selection) {
+    CbfBridgeEventData::TextSelectionBoundsData selection;
+    selection.range_start = update->selection->range_start;
+    selection.range_end = update->selection->range_end;
+    if (update->selection->caret_rect) {
+      selection.caret_rect = gfx::Rect(update->selection->caret_rect->x,
+                                       update->selection->caret_rect->y,
+                                       update->selection->caret_rect->width,
+                                       update->selection->caret_rect->height);
+    }
+    if (update->selection->first_selection_rect) {
+      selection.first_selection_rect =
+          gfx::Rect(update->selection->first_selection_rect->x,
+                    update->selection->first_selection_rect->y,
+                    update->selection->first_selection_rect->width,
+                    update->selection->first_selection_rect->height);
+    }
+    event.selection_bounds = std::move(selection);
+  }
+
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
