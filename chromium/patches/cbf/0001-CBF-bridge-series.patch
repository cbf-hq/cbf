+using WebPageId = std::uint64_t;
+inline constexpr WebPageId kInvalidWebPageId = 0;
+
+class CbfProfileService;
+
+class CbfTabManager {
+ public:
+  CbfTabManager(::Profile* profile, CbfProfileService* profile_service);
+  CbfTabManager(const CbfTabManager&) = delete;
+  CbfTabManager& operator=(const CbfTabManager&) = delete;
+  ~CbfTabManager();
+
+  WebPageId CreateWebPage(const GURL& initial_url);
+  content::WebContents* GetWebContents(WebPageId web_page_id) const;
+  WebPageId GetWebPageIdForWebContents(content::WebContents* web_contents) const;
+  std::vector<WebPageId> GetDirtyWebPageIds() const;
+  std::vector<WebPageId> GetAllWebPageIds() const;
