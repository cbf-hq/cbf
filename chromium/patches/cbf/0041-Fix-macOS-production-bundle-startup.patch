From 5bb2fe45f96dc6b687ca68cb95ae35fd44f3c228 Mon Sep 17 00:00:00 2001
From: Takagi Tasuku <tasuren@outlook.jp>
Date: Thu, 26 Mar 2026 12:35:18 +0900
Subject: [PATCH 41/52] Fix macOS production bundle startup

---
 chrome/app/chrome_main_mac.mm           | 33 ++++++++++++++++++++++---
 chrome/browser/cbf/bridge/cbf_bridge.cc | 11 +++++++++
 chrome/browser/cbf/bridge/cbf_bridge.h  |  1 +
 3 files changed, 42 insertions(+), 3 deletions(-)

diff --git a/chrome/app/chrome_main_mac.mm b/chrome/app/chrome_main_mac.mm
index 78ddfa064b06e..ab8f46c887aca 100644
--- a/chrome/app/chrome_main_mac.mm
+++ b/chrome/app/chrome_main_mac.mm
@@ -12,6 +12,7 @@
 #import "base/apple/foundation_util.h"
 #include "base/command_line.h"
 #include "base/environment.h"
+#include "base/files/file_util.h"
 #include "base/files/file_path.h"
 #include "base/path_service.h"
 #include "base/strings/string_util.h"
@@ -100,6 +101,34 @@ bool IsHelperAppLaunchedBySafeExamBrowser() {
   }
 }
 
+base::FilePath ResolveBaseHelperExecutablePath() {
+  base::FilePath helpers_dir = chrome::GetFrameworkBundlePath().Append("Helpers");
+
+  @autoreleasepool {
+    NSBundle* outer_bundle = OuterAppBundle();
+    if (outer_bundle) {
+      NSString* executable_path = outer_bundle.executablePath;
+      if ([executable_path length] > 0) {
+        std::string runtime_name = base::FilePath(
+                                       base::SysNSStringToUTF8(executable_path))
+                                       .BaseName()
+                                       .value();
+        std::string helper_name = runtime_name + " Helper";
+        base::FilePath helper_executable_path =
+            helpers_dir.Append(helper_name + ".app")
+                .Append("Contents")
+                .Append("MacOS")
+                .Append(helper_name);
+        if (base::PathExists(helper_executable_path)) {
+          return helper_executable_path;
+        }
+      }
+    }
+  }
+
+  return helpers_dir.Append(chrome::kHelperProcessExecutablePath);
+}
+
 }  // namespace
 
 void SetUpBundleOverrides() {
@@ -112,9 +141,7 @@ void SetUpBundleOverrides() {
     base::apple::SetBaseBundleIDOverride(
         base::SysNSStringToUTF8(base_bundle.bundleIdentifier));
 
-    base::FilePath child_exe_path =
-        chrome::GetFrameworkBundlePath().Append("Helpers").Append(
-            chrome::kHelperProcessExecutablePath);
+    base::FilePath child_exe_path = ResolveBaseHelperExecutablePath();
 
     // On the Mac, the child executable lives at a predefined location within
     // the app bundle's versioned directory.
diff --git a/chrome/browser/cbf/bridge/cbf_bridge.cc b/chrome/browser/cbf/bridge/cbf_bridge.cc
index 55796ccd14769..74b506f6e1d59 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge.cc
+++ b/chrome/browser/cbf/bridge/cbf_bridge.cc
@@ -10,8 +10,19 @@
 #if BUILDFLAG(MOJO_USE_APPLE_CHANNEL)
 #include "base/apple/mach_port_rendezvous_mac.h"
 #include "base/synchronization/lock.h"
+#include "base/apple/foundation_util.h"
 #endif
 
+extern "C" void cbf_bridge_set_base_bundle_id(const char* bundle_id) {
+#if BUILDFLAG(IS_MAC)
+  if (bundle_id) {
+    base::apple::SetBaseBundleIDOverride(bundle_id);
+  }
+#else
+  (void)bundle_id;
+#endif
+}
+
 extern "C" CbfBridgeClientHandle* cbf_bridge_client_create(void) {
   return reinterpret_cast<CbfBridgeClientHandle*>(
       new cbf_bridge::internal::CbfBridgeClient());
diff --git a/chrome/browser/cbf/bridge/cbf_bridge.h b/chrome/browser/cbf/bridge/cbf_bridge.h
index bd10db17bf0cf..4fab10e654faf 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge.h
+++ b/chrome/browser/cbf/bridge/cbf_bridge.h
@@ -17,6 +17,7 @@ extern "C" {
 
 typedef struct CbfBridgeClientHandle CbfBridgeClientHandle;
 
+CBF_BRIDGE_EXPORT void cbf_bridge_set_base_bundle_id(const char* bundle_id);
 CBF_BRIDGE_EXPORT CbfBridgeClientHandle* cbf_bridge_client_create(void);
 CBF_BRIDGE_EXPORT void cbf_bridge_client_destroy(CbfBridgeClientHandle* client);
 CBF_BRIDGE_EXPORT void cbf_bridge_init(void);
-- 
