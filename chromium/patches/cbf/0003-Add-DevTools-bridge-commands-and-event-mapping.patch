   return true;
 }
 
+bool CbfBridgeClient::OpenDevTools(uint64_t tab_id) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id) {
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->OpenDevTools(tab_id);
+          },
+          impl, tab_id));
+  return true;
+}
+
+bool CbfBridgeClient::InspectElement(uint64_t tab_id, int32_t x, int32_t y) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id, int32_t x,
+             int32_t y) {
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->InspectElement(tab_id, x, y);
+          },
+          impl, tab_id, x, y));
+  return true;
+}
+
 bool CbfBridgeClient::GetWebPageDomHtml(uint64_t tab_id, uint64_t request_id) {
   if (!impl_) {
     return false;
@@ -449,3 +504,25 @@ extern "C" bool cbf_bridge_client_get_web_page_dom_html(
   return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
       ->GetWebPageDomHtml(tab_id, request_id);
 }
+
+extern "C" bool cbf_bridge_client_open_dev_tools(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->OpenDevTools(tab_id);
+}
+
+extern "C" bool cbf_bridge_client_inspect_element(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id,
+    int32_t x,
+    int32_t y) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->InspectElement(tab_id, x, y);
+}
