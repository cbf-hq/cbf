index 0000000000000..12e4f086b13d5
--- /dev/null
+++ b/chrome/browser/cbf/cbf_settings_policy.h
@@ -0,0 +1,31 @@
+#ifndef CHROME_BROWSER_CBF_CBF_SETTINGS_POLICY_H_
+#define CHROME_BROWSER_CBF_CBF_SETTINGS_POLICY_H_
+
+#include "base/command_line.h"
+#include "chrome/browser/cbf/cbf_switches.h"
+#include "chrome/common/url_constants.h"
+#include "content/public/common/url_constants.h"
+#include "url/gurl.h"
+
+namespace cbf {
+
+inline bool IsSettingsUrlBlocked(const GURL& url) {
+  if (!url.is_valid()) {
+    return false;
+  }
+
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  const bool allow_unsafe_settings =
+      command_line &&
+      command_line->HasSwitch(switches::kCbfAllowUnsafeSettings);
+  if (allow_unsafe_settings) {
+    return false;
+  }
+
+  return url.SchemeIs(content::kChromeUIScheme) &&
+         url.host() == chrome::kChromeUISettingsHost;
+}
+
+}  // namespace cbf
+
+#endif  // CHROME_BROWSER_CBF_CBF_SETTINGS_POLICY_H_
