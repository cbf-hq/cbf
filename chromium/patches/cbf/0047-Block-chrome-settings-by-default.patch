+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SettingsNavigateRequestKeepsCurrentPage) {
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  const size_t baseline_event_count =
+      observer_.navigation_state_changed_events().size();
+  profile_service_->Navigate(tab_id, "chrome://settings");
+  base::RunLoop().RunUntilIdle();
+
+  EXPECT_EQ(web_contents->GetLastCommittedURL(), GURL("about:blank"));
+  EXPECT_EQ(observer_.navigation_state_changed_events().size(),
+            baseline_event_count);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SettingsCurrentTabOpenRequestKeepsCurrentPage) {
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  const size_t baseline_event_count =
+      observer_.navigation_state_changed_events().size();
+  content::OpenURLParams params(GURL("chrome://settings"), content::Referrer(),
+                                WindowOpenDisposition::CURRENT_TAB,
+                                ui::PAGE_TRANSITION_LINK, false);
+  content::WebContents* returned_contents =
+      profile_service_->GetWebContentsDelegate()->OpenURLFromTab(
+          web_contents, params, {});
+  EXPECT_EQ(returned_contents, web_contents);
+  base::RunLoop().RunUntilIdle();
+
+  EXPECT_EQ(web_contents->GetLastCommittedURL(), GURL("about:blank"));
+  EXPECT_EQ(observer_.navigation_state_changed_events().size(),
+            baseline_event_count);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SettingsNewTabOpenRequestIsDenied) {
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  const size_t baseline_result_count =
+      observer_.tab_open_resolved_events().size();
+  const size_t baseline_tab_count = profile_service_->GetTabCount();
+  profile_service_->NotifyNewTabRequested(
+      web_contents, GURL("chrome://settings"),
+      WindowOpenDisposition::NEW_FOREGROUND_TAB, true);
+  observer_.WaitForTabOpenResolvedCount(baseline_result_count + 1);
+
+  const auto& result = observer_.tab_open_resolved_events().back();
+  EXPECT_EQ(result.result, mojom::CbfTabOpenResultKind::kDenied);
+  EXPECT_FALSE(result.target_tab_id.has_value());
+  EXPECT_EQ(profile_service_->GetTabCount(), baseline_tab_count);
+}
