+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SetTabBackgroundPolicyUpdatesWebContentsBaseBackgroundColor) {
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  profile_service_->SetTabBackgroundPolicy(tab_id, true);
+  base::RunLoop().RunUntilIdle();
+  EXPECT_EQ(GetBaseBackgroundColor(web_contents), std::optional<SkColor>(SK_ColorTRANSPARENT));
+
+  profile_service_->SetTabBackgroundPolicy(tab_id, true);
+  base::RunLoop().RunUntilIdle();
+  EXPECT_EQ(GetBaseBackgroundColor(web_contents), std::optional<SkColor>(SK_ColorTRANSPARENT));
+
+  profile_service_->SetTabBackgroundPolicy(tab_id, false);
+  base::RunLoop().RunUntilIdle();
+  EXPECT_EQ(GetBaseBackgroundColor(web_contents), std::optional<SkColor>(SK_ColorWHITE));
+}
