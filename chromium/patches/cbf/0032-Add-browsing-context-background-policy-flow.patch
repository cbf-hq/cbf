+bool CbfBridgeClient::SetTabBackgroundPolicy(const uint64_t tab_id,
+                                             const bool transparent) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, const uint64_t tab_id,
+             const bool transparent) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->SetTabBackgroundPolicy(tab_id, transparent);
+          },
+          impl, tab_id, transparent));
+  return true;
+}
