+void CbfBridgeClientImpl::Observer::OnExtensionPopupOpened(
+    uint64_t tab_id,
+    uint64_t popup_id,
+    const std::string& extension_id,
+    const std::string& title) {
+  impl_->popup_profiles[popup_id] = profile_id_;
+  CbfBridgeEventData event;
+  event.kind = kEventExtensionPopupOpened;
+  event.tab_id = tab_id;
+  event.extension_popup_id = popup_id;
+  event.extension_id = extension_id;
+  event.title = title;
+  event.profile_id = profile_id_;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
