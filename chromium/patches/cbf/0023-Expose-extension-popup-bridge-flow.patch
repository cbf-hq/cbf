+bool CbfProfileContextMenuController::HandleExtensionPopupContextMenu(
+    TabId tab_id,
+    uint64_t popup_id,
+    content::RenderFrameHost& render_frame_host,
+    const content::ContextMenuParams& params) {
+  content::WebContents* web_contents =
+      content::WebContents::FromRenderFrameHost(&render_frame_host);
+  if (!web_contents) {
+    return true;
+  }
+
+  auto& observer = context_->observer_remote();
+  if (!observer.is_bound()) {
+    return true;
+  }
+
+  const content::ContextMenuParams enriched_params =
+      AddContextMenuParamsPropertiesFromPreferences(web_contents, params);
+
+  auto menu = std::make_unique<CbfRenderViewContextMenu>(render_frame_host,
+                                                         enriched_params);
+  menu->Init();
+  menu->menu_model_mutable()->MenuWillShow();
+
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents->GetBrowserContext());
+
+  auto menu_payload = cbf::mojom::CbfContextMenu::New();
+  const std::uint64_t menu_id = next_context_menu_id_++;
+  menu_payload->menu_id = menu_id;
+  menu_payload->x = enriched_params.x;
+  menu_payload->y = enriched_params.y;
+  menu_payload->source_type =
+      static_cast<uint32_t>(enriched_params.source_type);
+  menu_payload->items =
+      mojo_converters::BuildMenuItems(menu->menu_model_mutable(), profile);
+
+  auto entry = std::make_unique<ContextMenuEntry>();
+  entry->tab_id = tab_id;
+  entry->inspect_frame_id = render_frame_host.GetGlobalId();
+  entry->x = enriched_params.x;
+  entry->y = enriched_params.y;
+  entry->menu = std::move(menu);
+  context_menus_[menu_id] = std::move(entry);
+
+  observer->OnExtensionPopupContextMenuRequested(tab_id, popup_id,
+                                                 std::move(menu_payload));
+  return true;
+}
