+bool CbfBridgeClient::RespondJavaScriptDialog(const uint64_t tab_id,
+                                              const uint64_t request_id,
+                                              const bool accept,
+                                              const std::string& prompt_text) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, const uint64_t tab_id,
+             const uint64_t request_id, const bool accept,
+             std::string prompt_text) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->RespondJavaScriptDialog(
+                request_id, accept, prompt_text);
+          },
+          impl, tab_id, request_id, accept, prompt_text));
+  return true;
+}
