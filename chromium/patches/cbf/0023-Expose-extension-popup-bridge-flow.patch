+class TestPopupMenuClient final : public blink::mojom::PopupMenuClient {
+ public:
+  TestPopupMenuClient() = default;
+  TestPopupMenuClient(const TestPopupMenuClient&) = delete;
+  TestPopupMenuClient& operator=(const TestPopupMenuClient&) = delete;
+  ~TestPopupMenuClient() override = default;
+
+  mojo::PendingRemote<blink::mojom::PopupMenuClient> BindNewPipeAndPassRemote() {
+    receiver_.reset();
+    return receiver_.BindNewPipeAndPassRemote();
+  }
+
+  const std::vector<int32_t>& accepted_indices() const {
+    return accepted_indices_;
+  }
+
+  bool was_cancelled() const { return was_cancelled_; }
+
+  void WaitForAccept() {
+    if (!accepted_indices_.empty()) {
+      return;
+    }
+    base::RunLoop loop;
+    quit_closure_ = loop.QuitClosure();
+    loop.Run();
+    quit_closure_.Reset();
+  }
+
+  void WaitForCancel() {
+    if (was_cancelled_) {
+      return;
+    }
+    base::RunLoop loop;
+    quit_closure_ = loop.QuitClosure();
+    loop.Run();
+    quit_closure_.Reset();
+  }
+
+  void DidAcceptIndices(const std::vector<int32_t>& indices) override {
+    accepted_indices_ = indices;
+    was_cancelled_ = false;
+    if (quit_closure_) {
+      std::move(quit_closure_).Run();
+    }
+  }
+
+  void DidCancel() override {
+    was_cancelled_ = true;
+    if (quit_closure_) {
+      std::move(quit_closure_).Run();
+    }
+  }
+
+ private:
+  mojo::Receiver<blink::mojom::PopupMenuClient> receiver_{this};
+  std::vector<int32_t> accepted_indices_;
+  bool was_cancelled_ = false;
+  base::OnceClosure quit_closure_;
+};
