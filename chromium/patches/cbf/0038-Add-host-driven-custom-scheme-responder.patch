+void CbfBridgeClientImpl::BrowserObserver::OnCustomSchemeRequest(
+    cbf::mojom::CbfCustomSchemeRequestPtr request) {
+  if (!request) {
+    return;
+  }
+
+  CbfBridgeEventData event;
+  event.kind = kEventCustomSchemeRequestReceived;
+  event.request_id = request->request_id;
+  event.profile_id = request->profile_id;
+  event.url = request->url;
+  event.custom_scheme_scheme = request->scheme;
+  event.custom_scheme_host = request->host;
+  event.custom_scheme_path = request->path;
+  event.custom_scheme_query = request->query.value_or(std::string());
+  event.custom_scheme_method = request->method;
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
+
