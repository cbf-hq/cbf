+  for (const auto& raw_scheme : base::SplitString(
+           command_line.GetSwitchValueASCII(switches::kCbfCustomSchemes), ",",
+           base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+    std::string normalized_scheme = base::ToLowerASCII(raw_scheme);
+    if (normalized_scheme.empty() || !seen.insert(normalized_scheme).second) {
+      continue;
+    }
+    schemes.push_back(std::move(normalized_scheme));
+  }
+  return schemes;
+}
+
+inline std::vector<std::string> GetConfiguredCustomSchemes() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return {};
+  }
+  return GetConfiguredCustomSchemes(*command_line);
+}
