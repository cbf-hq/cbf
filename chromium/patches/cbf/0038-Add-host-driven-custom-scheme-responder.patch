+#include "services/network/public/mojom/url_loader.mojom.h"
+#include "services/network/public/mojom/url_response_head.mojom.h"
+
+namespace cbf {
+
+namespace {
+
+std::string BuildRawHeaders(const std::string& status_line,
+                            const std::string& mime_type,
+                            const std::string& content_security_policy,
+                            const std::string& access_control_allow_origin) {
+  std::string headers = base::StrCat({"HTTP/1.1 ", status_line, "\r\n"});
+  if (!mime_type.empty()) {
+    headers.append("Content-Type: ");
+    headers.append(mime_type);
+    headers.append("\r\n");
+  }
+  if (!content_security_policy.empty()) {
+    headers.append("Content-Security-Policy: ");
+    headers.append(content_security_policy);
+    headers.append("\r\n");
+  }
+  if (!access_control_allow_origin.empty()) {
+    headers.append("Access-Control-Allow-Origin: ");
+    headers.append(access_control_allow_origin);
+    headers.append("\r\n");
+  }
+  headers.append("\r\n");
+  return headers;
+}
+
+void CompleteWithResponse(
+    mojo::Remote<network::mojom::URLLoaderClient> client_remote,
+    const std::string& status_line,
+    net::Error completion_error,
+    const std::string& mime_type,
+    const std::string& content_security_policy,
+    const std::string& access_control_allow_origin,
+    std::string body) {
+  auto response = network::mojom::URLResponseHead::New();
+  response->headers = net::HttpResponseHeaders::TryToCreate(
+      BuildRawHeaders(status_line, mime_type, content_security_policy,
+                      access_control_allow_origin));
+  std::string parsed_mime_type;
+  std::string parsed_charset;
+  bool had_charset = false;
+  net::HttpUtil::ParseContentType(mime_type, &parsed_mime_type, &parsed_charset,
+                                  &had_charset, nullptr);
+  response->mime_type =
+      parsed_mime_type.empty() ? mime_type : std::move(parsed_mime_type);
+  if (had_charset) {
+    response->charset = std::move(parsed_charset);
+  }
+  response->content_length = body.size();
+  const auto now_ticks = base::TimeTicks::Now();
+  response->load_timing.request_start = now_ticks;
+  response->load_timing.send_start = now_ticks;
+  response->load_timing.send_end = now_ticks;
+  response->load_timing.request_start_time = base::Time::Now();
+  response->response_start = now_ticks;
+  response->response_time = base::Time::Now();
+  response->load_timing.receive_headers_start = now_ticks;
+  response->load_timing.receive_headers_end = now_ticks;
+
+  mojo::ScopedDataPipeProducerHandle producer;
+  mojo::ScopedDataPipeConsumerHandle consumer;
+  if (CreateDataPipe(nullptr, producer, consumer) != MOJO_RESULT_OK) {
+    client_remote->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_INSUFFICIENT_RESOURCES));
+    return;
+  }
+
+  if (producer->WriteAllData(base::as_byte_span(body)) != MOJO_RESULT_OK) {
+    client_remote->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_FAILED));
+    return;
+  }
+  client_remote->OnReceiveResponse(std::move(response), std::move(consumer),
+                                   std::nullopt);
+
+  network::URLLoaderCompletionStatus status(completion_error);
+  status.encoded_data_length = body.size();
+  status.encoded_body_length = body.size();
+  status.decoded_body_length = body.size();
+  status.completion_time = base::TimeTicks::Now();
+  client_remote->OnComplete(status);
+}
+
+void OnCustomSchemeResponse(
+    base::WeakPtr<CbfCustomSchemeURLLoaderFactory> factory,
+    mojo::Remote<network::mojom::URLLoaderClient> client_remote,
+    cbf::mojom::CbfCustomSchemeResponsePtr response) {
+  if (!factory || !response) {
+    client_remote->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_ABORTED));
+    return;
+  }
+
+  switch (response->result) {
+    case cbf::mojom::CbfCustomSchemeResponseResult::kOk:
+      CompleteWithResponse(
+          std::move(client_remote), "200 OK", net::OK, response->mime_type,
+          response->content_security_policy.value_or(""),
+          response->access_control_allow_origin.value_or(""),
+          std::string(response->body.begin(), response->body.end()));
+      return;
+    case cbf::mojom::CbfCustomSchemeResponseResult::kNotFound:
+      CompleteWithResponse(
+          std::move(client_remote), "404 Not Found", net::ERR_FILE_NOT_FOUND,
+          response->mime_type, response->content_security_policy.value_or(""),
+          response->access_control_allow_origin.value_or(""),
+          std::string(response->body.begin(), response->body.end()));
+      return;
+    case cbf::mojom::CbfCustomSchemeResponseResult::kAborted:
+      client_remote->OnComplete(
+          network::URLLoaderCompletionStatus(net::ERR_ABORTED));
+      return;
+  }
+}
+
+}  // namespace
+
+CbfCustomSchemeURLLoaderFactory::CbfCustomSchemeURLLoaderFactory(
+    content::BrowserContext* browser_context,
+    mojo::PendingReceiver<network::mojom::URLLoaderFactory> receiver)
+    : network::SelfDeletingURLLoaderFactory(std::move(receiver)),
+      browser_context_(browser_context) {}
+
+CbfCustomSchemeURLLoaderFactory::~CbfCustomSchemeURLLoaderFactory() = default;
+
+void CbfCustomSchemeURLLoaderFactory::CreateLoaderAndStart(
+    mojo::PendingReceiver<network::mojom::URLLoader> loader,
+    int32_t request_id,
+    uint32_t options,
+    const network::ResourceRequest& request,
+    mojo::PendingRemote<network::mojom::URLLoaderClient> client,
+    const net::MutableNetworkTrafficAnnotationTag& traffic_annotation) {
+  mojo::Remote<network::mojom::URLLoaderClient> client_remote(
+      std::move(client));
+  auto* cbf_service = CbfService::GetForProcess();
+  auto* browser_service =
+      cbf_service ? cbf_service->browser_service() : nullptr;
+  auto* profile = Profile::FromBrowserContext(browser_context_);
+  if (!browser_service || !profile || !request.url.is_valid() ||
+      !browser_service->HasCustomSchemeHandler(request.url)) {
+    client_remote->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_INVALID_URL));
+    return;
+  }
+
+  if (request.method != "GET") {
+    client_remote->OnComplete(
+        network::URLLoaderCompletionStatus(net::ERR_METHOD_NOT_SUPPORTED));
+    return;
+  }
+
+  browser_service->DispatchCustomSchemeRequest(
+      profile, request.url, request.method,
+      base::BindOnce(OnCustomSchemeResponse, weak_factory_.GetWeakPtr(),
+                     std::move(client_remote)));
+}
+
+mojo::PendingRemote<network::mojom::URLLoaderFactory>
+CbfCustomSchemeURLLoaderFactory::Create(
+    content::BrowserContext* browser_context) {
+  mojo::PendingRemote<network::mojom::URLLoaderFactory> pending_remote;
+  new CbfCustomSchemeURLLoaderFactory(
+      browser_context, pending_remote.InitWithNewPipeAndPassReceiver());
+  return pending_remote;
+}
+
+}  // namespace cbf
