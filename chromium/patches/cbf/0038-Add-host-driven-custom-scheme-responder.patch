+bool CbfBridgeClient::RegisterCustomSchemeHandler(const std::string& scheme,
+                                                  const std::string& host) {
+  if (!impl_ || scheme.empty() || host.empty()) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner || !impl_->browser_remote.is_bound()) {
+    return false;
+  }
+
+  base::WaitableEvent done(base::WaitableEvent::ResetPolicy::MANUAL,
+                           base::WaitableEvent::InitialState::NOT_SIGNALED);
+  bool success = false;
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, std::string scheme, std::string host,
+             bool* success, base::WaitableEvent* done) {
+            if (!impl->browser_remote.is_bound()) {
+              done->Signal();
+              return;
+            }
+            auto registration = cbf::mojom::CbfCustomSchemeRegistration::New();
+            registration->scheme = std::move(scheme);
+            registration->host = std::move(host);
+            impl->browser_remote->RegisterCustomSchemeHandler(
+                std::move(registration));
+            *success = true;
+            done->Signal();
+          },
+          impl_.get(), scheme, host, &success, &done));
+  done.Wait();
+  return success;
+}
+
+bool CbfBridgeClient::RespondCustomSchemeRequest(
+    uint64_t request_id,
+    uint8_t result,
+    const std::string& mime_type,
+    const std::string& content_security_policy,
+    const std::string& access_control_allow_origin,
+    const std::vector<uint8_t>& body) {
+  if (!impl_ || mime_type.empty()) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner || !impl_->browser_remote.is_bound()) {
+    return false;
+  }
+
+  base::WaitableEvent done(base::WaitableEvent::ResetPolicy::MANUAL,
+                           base::WaitableEvent::InitialState::NOT_SIGNALED);
+  bool success = false;
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t request_id, uint8_t result,
+             std::string mime_type, std::string content_security_policy,
+             std::string access_control_allow_origin, std::vector<uint8_t> body,
+             bool* success, base::WaitableEvent* done) {
+            if (!impl->browser_remote.is_bound()) {
+              done->Signal();
+              return;
+            }
+            auto response = cbf::mojom::CbfCustomSchemeResponse::New();
+            response->request_id = request_id;
+            response->result =
+                static_cast<cbf::mojom::CbfCustomSchemeResponseResult>(result);
+            response->mime_type = std::move(mime_type);
+            response->content_security_policy =
+                content_security_policy.empty()
+                    ? std::nullopt
+                    : std::make_optional(std::move(content_security_policy));
+            response->access_control_allow_origin =
+                access_control_allow_origin.empty()
+                    ? std::nullopt
+                    : std::make_optional(
+                          std::move(access_control_allow_origin));
+            response->body = std::move(body);
+            impl->browser_remote->RespondCustomSchemeRequest(
+                std::move(response));
+            *success = true;
+            done->Signal();
+          },
+          impl_.get(), request_id, result, mime_type, content_security_policy,
+          access_control_allow_origin, body, &success, &done));
+  done.Wait();
+  return success;
+}
