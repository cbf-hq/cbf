+class TestBrowserObserver final : public mojom::CbfBrowserObserver {
+ public:
+  explicit TestBrowserObserver(CbfBrowserService* browser_service)
+      : browser_service_(browser_service) {}
+
+  mojo::PendingRemote<mojom::CbfBrowserObserver> BindNewPipeAndPassRemote() {
+    receiver_.reset();
+    return receiver_.BindNewPipeAndPassRemote();
+  }
+
+  void RegisterResponse(const std::string& path,
+                        const std::string& mime_type,
+                        const std::string& body) {
+    responses_[path] = {mime_type, body};
+  }
+
+  void ClearResponses() { responses_.clear(); }
+
+  void OnShutdownBlocked(uint64_t request_id,
+                         const std::vector<uint64_t>& dirty_tab_ids) override {}
+  void OnShutdownProceeding(uint64_t request_id) override {}
+  void OnShutdownCancelled(uint64_t request_id) override {}
+
+  void OnCustomSchemeRequest(
+      mojom::CbfCustomSchemeRequestPtr request) override {
+    ASSERT_TRUE(request);
+    auto response = mojom::CbfCustomSchemeResponse::New();
+    response->request_id = request->request_id;
+    response->content_security_policy = "default-src 'self' 'unsafe-inline'";
+    response->access_control_allow_origin = "app://simpleapp";
+
+    auto it = responses_.find(request->path);
+    if (it == responses_.end()) {
+      constexpr std::string_view kNotFoundBody = "not found";
+      response->result = mojom::CbfCustomSchemeResponseResult::kNotFound;
+      response->mime_type = "text/plain; charset=utf-8";
+      response->body.assign(kNotFoundBody.begin(), kNotFoundBody.end());
+    } else {
+      response->result = mojom::CbfCustomSchemeResponseResult::kOk;
+      response->mime_type = it->second.mime_type;
+      response->body.assign(it->second.body.begin(), it->second.body.end());
+    }
+
+    browser_service_->RespondCustomSchemeRequest(std::move(response));
+  }
+
+ private:
+  struct StaticResponse {
+    std::string mime_type;
+    std::string body;
+  };
+
+  raw_ptr<CbfBrowserService> browser_service_;
+  std::map<std::string, StaticResponse> responses_;
+  mojo::Receiver<mojom::CbfBrowserObserver> receiver_{this};
+};
