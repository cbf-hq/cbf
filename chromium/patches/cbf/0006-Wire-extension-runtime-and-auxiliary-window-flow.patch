+void CbfBridgeClientImpl::Observer::OnBrowsingContextOpenResolved(
+    cbf::mojom::CbfBrowsingContextOpenResultPtr result) {
+  if (!result) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventBrowsingContextOpenResolved;
+  event.request_id = result->request_id;
+  event.profile_id = profile_id_;
+  event.browsing_context_open_result = static_cast<uint8_t>(result->result);
+  if (result->target_tab_id.has_value()) {
+    event.has_target_tab_id = true;
+    event.target_tab_id = result->target_tab_id.value();
+  }
