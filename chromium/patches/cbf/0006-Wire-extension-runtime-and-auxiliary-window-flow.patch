+bool CbfBridgeClient::RespondBrowsingContextOpen(uint64_t request_id,
+                                                 uint8_t response_kind,
+                                                 uint64_t target_tab_id,
+                                                 bool activate) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t request_id,
+             uint8_t response_kind, uint64_t target_tab_id, bool activate) {
+            auto profile_it =
+                impl->browsing_context_open_request_profiles.find(request_id);
+            if (profile_it == impl->browsing_context_open_request_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(profile_it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            auto response = cbf::mojom::CbfBrowsingContextOpenResponse::New();
+            response->request_id = request_id;
+            response->activate = activate;
+            switch (response_kind) {
+              case kCbfBrowsingContextOpenResponseAllowNewContext:
+                response->action =
+                    cbf::mojom::CbfBrowsingContextOpenResponseAction::kAllowNewContext;
+                break;
+              case kCbfBrowsingContextOpenResponseAllowExistingContext:
+                response->action =
+                    cbf::mojom::CbfBrowsingContextOpenResponseAction::kAllowExistingContext;
+                response->target_tab_id = target_tab_id;
+                break;
+              case kCbfBrowsingContextOpenResponseDeny:
+              default:
+                response->action =
+                    cbf::mojom::CbfBrowsingContextOpenResponseAction::kDeny;
+                response->target_tab_id.reset();
+                response->activate = false;
+                break;
+            }
+            remote_it->second.remote->RespondBrowsingContextOpen(std::move(response));
+          },
+          impl, request_id, response_kind, target_tab_id, activate));
+  return true;
+}
