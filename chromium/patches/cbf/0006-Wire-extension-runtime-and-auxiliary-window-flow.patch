+      g_browser_process ? g_browser_process->profile_manager() : nullptr;
+  if (!profile_manager) {
+    return nullptr;
+  }
+  ProfileAttributesStorage& storage = profile_manager->GetProfileAttributesStorage();
+  const std::string id = storage.StorageKeyFromProfilePath(profile->GetPath());
+  auto it = profile_services_.find(id);
+  if (it == profile_services_.end()) {
+    return nullptr;
+  }
+  return it->second.get();
