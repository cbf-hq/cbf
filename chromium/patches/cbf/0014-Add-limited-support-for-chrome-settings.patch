--- /dev/null
+++ b/chrome/browser/cbf/cbf_settings_browsertest.cc
@@ -0,0 +1,257 @@
+#include "chrome/browser/cbf/cbf_profile_service.h"
+
+#include <array>
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/run_loop.h"
+#include "base/values.h"
+#include "chrome/browser/cbf/test/cbf_test_profile_observer.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/common/pref_names.h"
+#include "chrome/common/url_constants.h"
+#include "components/prefs/pref_service.h"
+#include "chrome/test/base/in_process_browser_test.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/common/url_constants.h"
+#include "content/public/test/browser_test.h"
+#include "content/public/test/browser_test_utils.h"
+#include "testing/gtest/include/gtest/gtest.h"
+#include "url/gurl.h"
+
+namespace cbf {
+namespace {
+
+class CbfSettingsBrowserTest : public InProcessBrowserTest {
+ protected:
+  void SetUpOnMainThread() override {
+    InProcessBrowserTest::SetUpOnMainThread();
+    profile_service_ =
+        std::make_unique<CbfProfileService>(browser()->profile(), nullptr);
+    profile_service_->SetObserver(observer_.BindNewPipeAndPassRemote());
+  }
+
+  void TearDownOnMainThread() override {
+    if (profile_service_) {
+      const auto tab_ids = profile_service_->GetAllTabIds();
+      for (TabId tab_id : tab_ids) {
+        profile_service_->NotifyWebPageClosed(tab_id);
+      }
+      profile_service_->CloseAllWebPages();
+      base::RunLoop().RunUntilIdle();
+      profile_service_.reset();
+    }
+
+    InProcessBrowserTest::TearDownOnMainThread();
+  }
+
+  TabId CreatePage(const std::string& url) {
+    TabId created_id = kInvalidTabId;
+    base::RunLoop run_loop;
+    profile_service_->CreateWebPage(
+        url, 1,
+        base::BindOnce(
+            [](TabId* out_id, base::RunLoop* run_loop, TabId tab_id) {
+              *out_id = tab_id;
+              run_loop->Quit();
+            },
+            &created_id, &run_loop));
+    run_loop.Run();
+    return created_id;
+  }
+
+  content::WebContents* GetWebContents(TabId tab_id) const {
+    return profile_service_->GetWebContentsForTesting(tab_id);
+  }
+
+  void WaitForLoad(TabId tab_id) {
+    content::WebContents* web_contents = GetWebContents(tab_id);
+    ASSERT_NE(web_contents, nullptr);
+    ASSERT_TRUE(content::WaitForLoadStop(web_contents));
+  }
+
+  content::WebUI* GetWebUI(TabId tab_id) const {
+    content::WebContents* web_contents = GetWebContents(tab_id);
+    return web_contents ? web_contents->GetWebUI() : nullptr;
+  }
+
+  void ExpectSettingsPageStillAlive(TabId tab_id) {
+    content::WebContents* web_contents = GetWebContents(tab_id);
+    ASSERT_NE(web_contents, nullptr);
+    EXPECT_NE(GetWebUI(tab_id), nullptr);
+
+    const GURL committed_url = web_contents->GetLastCommittedURL();
+    EXPECT_TRUE(committed_url.SchemeIs(content::kChromeUIScheme));
+    EXPECT_EQ(committed_url.host(), chrome::kChromeUISettingsHost);
+  }
+
+  void ProcessMessage(TabId tab_id, const char* message, base::ListValue args) {
+    content::WebUI* web_ui = GetWebUI(tab_id);
+    ASSERT_NE(web_ui, nullptr);
+    web_ui->ProcessWebUIMessage(GURL(), message, std::move(args));
+    base::RunLoop().RunUntilIdle();
+  }
+
+  std::unique_ptr<CbfProfileService> profile_service_;
+  cbf::test::CbfTestProfileObserver observer_;
+};
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest, SettingsRootLoadsWithoutCrash) {
+  const TabId tab_id = CreatePage("chrome://settings");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsAppearanceSubPageLoadsWithoutCrash) {
+  const TabId tab_id = CreatePage("chrome://settings/appearance");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsPrivacySubPageLoadsWithoutCrash) {
+  const TabId tab_id = CreatePage("chrome://settings/privacy");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsPerformanceSubPageLoadsWithoutCrash) {
+  const TabId tab_id = CreatePage("chrome://settings/performance");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SelectedSettingsSubPagesLoadWithoutCrash) {
+  constexpr std::array<const char*, 6> kUrls = {
+      "chrome://settings/downloads",
+      "chrome://settings/onStartup",
+      "chrome://settings/search",
+      "chrome://settings/languages",
+      "chrome://settings/autofill",
+      "chrome://settings/system",
+  };
+
+  for (const char* url : kUrls) {
+    const TabId tab_id = CreatePage(url);
+    ASSERT_NE(tab_id, kInvalidTabId) << url;
+
+    WaitForLoad(tab_id);
+    ExpectSettingsPageStillAlive(tab_id);
+  }
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsAppearanceCustomizeToolbarRequestIsSafe) {
+  const TabId tab_id = CreatePage("chrome://settings/appearance");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ProcessMessage(tab_id, "openCustomizeChromeToolbarSection", base::ListValue());
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsPerformanceOpenFeedbackRequestIsSafe) {
+  const TabId tab_id = CreatePage("chrome://settings/performance");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+
+  base::ListValue args;
+  args.Append("cbf-settings");
+  ProcessMessage(tab_id, "openPerformanceFeedbackDialog", std::move(args));
+
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsPasswordManagerOpenRequestIsSafe) {
+  const TabId tab_id = CreatePage("chrome://settings");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+
+  base::ListValue passwords_args;
+  passwords_args.Append(0);
+  ProcessMessage(tab_id, "showPasswordManager", std::move(passwords_args));
+  ExpectSettingsPageStillAlive(tab_id);
+
+  base::ListValue checkup_args;
+  checkup_args.Append(1);
+  ProcessMessage(tab_id, "showPasswordManager", std::move(checkup_args));
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsAboutOpenHelpAndFeedbackRequestsAreSafe) {
+  const TabId tab_id = CreatePage("chrome://settings/help");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+
+  ProcessMessage(tab_id, "openFeedbackDialog", base::ListValue());
+  ExpectSettingsPageStillAlive(tab_id);
+
+  ProcessMessage(tab_id, "openHelpPage", base::ListValue());
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsDownloadsSelectDownloadLocationIsSafe) {
+  const TabId tab_id = CreatePage("chrome://settings/downloads");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ProcessMessage(tab_id, "selectDownloadLocation", base::ListValue());
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfSettingsBrowserTest,
+                       SettingsImportDataSelectFileIsSafe) {
+  const TabId tab_id = CreatePage("chrome://settings");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+  ProcessMessage(tab_id, "importFromBookmarksFile", base::ListValue());
+  ExpectSettingsPageStillAlive(tab_id);
+}
+
+IN_PROC_BROWSER_TEST_F(
+    CbfSettingsBrowserTest,
+    SettingsAppearanceResetPinnedToolbarActionsRemainsNonCrashingAndAppliesPref) {
+  const TabId tab_id = CreatePage("chrome://settings/appearance");
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  WaitForLoad(tab_id);
+
+  PrefService* prefs = browser()->profile()->GetPrefs();
+  ASSERT_NE(prefs, nullptr);
+  prefs->SetBoolean(prefs::kShowHomeButton, true);
+  prefs->SetBoolean(prefs::kShowForwardButton, false);
+
+  EXPECT_TRUE(prefs->GetBoolean(prefs::kShowHomeButton));
+  EXPECT_FALSE(prefs->GetBoolean(prefs::kShowForwardButton));
+
+  ProcessMessage(tab_id, "resetPinnedToolbarActions", base::ListValue());
+
+  ExpectSettingsPageStillAlive(tab_id);
+  EXPECT_FALSE(prefs->GetBoolean(prefs::kShowHomeButton));
+  EXPECT_TRUE(prefs->GetBoolean(prefs::kShowForwardButton));
+}
+
+}  // namespace
+}  // namespace cbf
