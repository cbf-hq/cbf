+#ifndef CHROME_BROWSER_CBF_CBF_BROWSING_CONTEXT_POLICY_H_
+#define CHROME_BROWSER_CBF_CBF_BROWSING_CONTEXT_POLICY_H_
+
+#include <optional>
+#include <string>
+#include <vector>
+
+namespace content {
+class WebContents;
+}  // namespace content
+
+namespace cbf {
+
+enum class CbfCapabilityPolicy {
+  kAllow = 0,
+  kDeny = 1,
+};
+
+struct CbfIpcPolicy {
+  enum class Kind {
+    kDeny = 0,
+    kAllow = 1,
+  };
+
+  CbfIpcPolicy();
+  CbfIpcPolicy(const CbfIpcPolicy&);
+  CbfIpcPolicy(CbfIpcPolicy&&);
+  CbfIpcPolicy& operator=(const CbfIpcPolicy&);
+  CbfIpcPolicy& operator=(CbfIpcPolicy&&);
+  ~CbfIpcPolicy();
+
+  Kind kind = Kind::kDeny;
+  std::vector<std::string> allowed_origins;
+};
+
+struct CbfBrowsingContextPolicy {
+  CbfBrowsingContextPolicy();
+  CbfBrowsingContextPolicy(const CbfBrowsingContextPolicy&);
+  CbfBrowsingContextPolicy(CbfBrowsingContextPolicy&&);
+  CbfBrowsingContextPolicy& operator=(const CbfBrowsingContextPolicy&);
+  CbfBrowsingContextPolicy& operator=(CbfBrowsingContextPolicy&&);
+  ~CbfBrowsingContextPolicy();
+
+  CbfIpcPolicy ipc;
+  CbfCapabilityPolicy extensions = CbfCapabilityPolicy::kAllow;
+};
+
+CbfBrowsingContextPolicy LegacyBrowsingContextPolicy();
+
+class ScopedPendingBrowsingContextPolicy {
+ public:
+  explicit ScopedPendingBrowsingContextPolicy(
+      std::optional<CbfBrowsingContextPolicy> policy);
+  ScopedPendingBrowsingContextPolicy(
+      const ScopedPendingBrowsingContextPolicy&) = delete;
+  ScopedPendingBrowsingContextPolicy& operator=(
+      const ScopedPendingBrowsingContextPolicy&) = delete;
+  ~ScopedPendingBrowsingContextPolicy();
+
+ private:
+  std::optional<CbfBrowsingContextPolicy> previous_;
+};
+
+void SetBrowsingContextPolicyForWebContents(
+    content::WebContents* web_contents,
+    const CbfBrowsingContextPolicy& policy);
+void AttachPendingBrowsingContextPolicyIfAny(
+    content::WebContents* web_contents);
+const CbfBrowsingContextPolicy* GetBrowsingContextPolicyForWebContents(
+    content::WebContents* web_contents);
+CbfBrowsingContextPolicy GetEffectiveBrowsingContextPolicyForWebContents(
+    content::WebContents* web_contents);
+bool AreExtensionsDisabledForWebContents(content::WebContents* web_contents);
+
+}  // namespace cbf
+
+#endif  // CHROME_BROWSER_CBF_CBF_BROWSING_CONTEXT_POLICY_H_
