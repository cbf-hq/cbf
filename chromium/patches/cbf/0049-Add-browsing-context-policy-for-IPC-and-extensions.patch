new file mode 100644
index 0000000000000..83ff06d224e4c
--- /dev/null
+++ b/chrome/browser/cbf/cbf_browsing_context_policy.cc
@@ -0,0 +1,113 @@
+#include "chrome/browser/cbf/cbf_browsing_context_policy.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/no_destructor.h"
+#include "base/supports_user_data.h"
+#include "content/public/browser/web_contents.h"
+
+namespace cbf {
+namespace {
+
+class BrowsingContextPolicyData : public base::SupportsUserData::Data {
+ public:
+  explicit BrowsingContextPolicyData(CbfBrowsingContextPolicy policy);
+  BrowsingContextPolicyData(const BrowsingContextPolicyData&) = delete;
+  BrowsingContextPolicyData& operator=(const BrowsingContextPolicyData&) =
+      delete;
+  ~BrowsingContextPolicyData() override;
+
+  CbfBrowsingContextPolicy policy;
+};
+
+std::optional<CbfBrowsingContextPolicy>& PendingPolicyStorage() {
+  static base::NoDestructor<std::optional<CbfBrowsingContextPolicy>>
+      pending_policy;
+  return *pending_policy;
+}
+
+const int kBrowsingContextPolicyUserDataKey = 0;
+
+}  // namespace
+
+CbfIpcPolicy::CbfIpcPolicy() = default;
+CbfIpcPolicy::CbfIpcPolicy(const CbfIpcPolicy&) = default;
+CbfIpcPolicy::CbfIpcPolicy(CbfIpcPolicy&&) = default;
+CbfIpcPolicy& CbfIpcPolicy::operator=(const CbfIpcPolicy&) = default;
+CbfIpcPolicy& CbfIpcPolicy::operator=(CbfIpcPolicy&&) = default;
+CbfIpcPolicy::~CbfIpcPolicy() = default;
+
+CbfBrowsingContextPolicy::CbfBrowsingContextPolicy() = default;
+CbfBrowsingContextPolicy::CbfBrowsingContextPolicy(
+    const CbfBrowsingContextPolicy&) = default;
+CbfBrowsingContextPolicy::CbfBrowsingContextPolicy(
+    CbfBrowsingContextPolicy&&) = default;
+CbfBrowsingContextPolicy& CbfBrowsingContextPolicy::operator=(
+    const CbfBrowsingContextPolicy&) = default;
+CbfBrowsingContextPolicy& CbfBrowsingContextPolicy::operator=(
+    CbfBrowsingContextPolicy&&) = default;
+CbfBrowsingContextPolicy::~CbfBrowsingContextPolicy() = default;
+
+CbfBrowsingContextPolicy LegacyBrowsingContextPolicy() {
+  return {};
+}
+
+ScopedPendingBrowsingContextPolicy::ScopedPendingBrowsingContextPolicy(
+    std::optional<CbfBrowsingContextPolicy> policy)
+    : previous_(std::move(PendingPolicyStorage())) {
+  PendingPolicyStorage() = std::move(policy);
+}
+
+ScopedPendingBrowsingContextPolicy::~ScopedPendingBrowsingContextPolicy() {
+  PendingPolicyStorage() = std::move(previous_);
+}
+
+void SetBrowsingContextPolicyForWebContents(
+    content::WebContents* web_contents,
+    const CbfBrowsingContextPolicy& policy) {
+  if (!web_contents) {
+    return;
+  }
+  web_contents->SetUserData(
+      &kBrowsingContextPolicyUserDataKey,
+      std::make_unique<BrowsingContextPolicyData>(policy));
+}
+
+void AttachPendingBrowsingContextPolicyIfAny(content::WebContents* web_contents) {
+  const std::optional<CbfBrowsingContextPolicy>& pending = PendingPolicyStorage();
+  if (!pending.has_value()) {
+    return;
+  }
+  SetBrowsingContextPolicyForWebContents(web_contents, *pending);
+}
+
+const CbfBrowsingContextPolicy* GetBrowsingContextPolicyForWebContents(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+  auto* data = static_cast<BrowsingContextPolicyData*>(
+      web_contents->GetUserData(&kBrowsingContextPolicyUserDataKey));
+  return data ? &data->policy : nullptr;
+}
+
+CbfBrowsingContextPolicy GetEffectiveBrowsingContextPolicyForWebContents(
+    content::WebContents* web_contents) {
+  const CbfBrowsingContextPolicy* policy =
+      GetBrowsingContextPolicyForWebContents(web_contents);
+  return policy ? *policy : LegacyBrowsingContextPolicy();
+}
+
+bool AreExtensionsDisabledForWebContents(content::WebContents* web_contents) {
+  return GetEffectiveBrowsingContextPolicyForWebContents(web_contents)
+             .extensions == CbfCapabilityPolicy::kDeny;
+}
+
+BrowsingContextPolicyData::BrowsingContextPolicyData(
+    CbfBrowsingContextPolicy policy)
+    : policy(std::move(policy)) {}
+
+BrowsingContextPolicyData::~BrowsingContextPolicyData() = default;
+
+}  // namespace cbf
