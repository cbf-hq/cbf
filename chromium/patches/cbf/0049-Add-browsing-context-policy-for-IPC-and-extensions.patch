+std::optional<CbfBrowsingContextPolicy> ToBrowsingContextPolicy(
+    cbf::mojom::CbfBrowsingContextPolicyPtr policy) {
+  if (!policy) {
+    return std::nullopt;
+  }
+
+  CbfBrowsingContextPolicy converted;
+  converted.ipc.kind =
+      policy->ipc->kind == cbf::mojom::CbfBrowsingContextIpcPolicyKind::kAllow
+          ? CbfIpcPolicy::Kind::kAllow
+          : CbfIpcPolicy::Kind::kDeny;
+  converted.ipc.allowed_origins = std::move(policy->ipc->allowed_origins);
+  converted.extensions =
+      policy->extensions == cbf::mojom::CbfCapabilityPolicy::kDeny
+          ? CbfCapabilityPolicy::kDeny
+          : CbfCapabilityPolicy::kAllow;
+  return converted;
+}
