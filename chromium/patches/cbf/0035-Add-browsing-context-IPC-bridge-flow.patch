+void CbfProfileService::PostTabIpcMessage(uint64_t tab_id,
+                                          mojom::CbfIpcMessagePtr message) {
+  if (!message ||
+      tab_ipc_allowed_origins_.find(tab_id) == tab_ipc_allowed_origins_.end()) {
+    return;
+  }
+  content::WebContents* web_contents = tab_manager_.GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+  content::RenderFrameHost* main_frame = web_contents->GetPrimaryMainFrame();
+  if (!main_frame || !main_frame->IsRenderFrameLive()) {
+    return;
+  }
+  main_frame->ExecuteJavaScriptInIsolatedWorld(
+      base::UTF8ToUTF16(BuildHostIpcDispatchScript(*message)), base::DoNothing(),
+      content::ISOLATED_WORLD_ID_CONTENT_END);
+}
+
+bool CbfProfileService::DispatchTabIpcInvoke(
+    uint64_t tab_id,
+    const url::Origin& origin,
+    mojom::CbfIpcMessagePtr message,
+    mojom::CbfIpcErrorCode* error_code) {
+  auto set_error = [&](mojom::CbfIpcErrorCode code) {
+    if (error_code) {
+      *error_code = code;
+    }
+  };
+
+  if (!message) {
+    set_error(mojom::CbfIpcErrorCode::kProtocolError);
+    return false;
+  }
+  if (tab_ipc_allowed_origins_.find(tab_id) == tab_ipc_allowed_origins_.end()) {
+    set_error(mojom::CbfIpcErrorCode::kIpcDisabled);
+    return false;
+  }
+  if (!IsTabIpcOriginAllowed(tab_id, origin)) {
+    set_error(mojom::CbfIpcErrorCode::kIpcDisabled);
+    return false;
+  }
+  if (!observer_) {
+    set_error(mojom::CbfIpcErrorCode::kDisconnected);
+    return false;
+  }
+
+  message->message_type = mojom::CbfIpcMessageType::kRequest;
+  NotifyTabIpcMessageReceived(tab_id, std::move(message));
+  set_error(mojom::CbfIpcErrorCode::kNone);
+  return true;
+}
