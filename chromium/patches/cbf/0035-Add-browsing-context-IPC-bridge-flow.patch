+++ b/chrome/browser/cbf/cbf_page_ipc_host.cc
@@ -0,0 +1,139 @@
+#include "chrome/browser/cbf/cbf_page_ipc_host.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "chrome/browser/cbf/cbf_browser_service.h"
+#include "chrome/browser/cbf/cbf_profile_service.h"
+#include "chrome/browser/cbf/cbf_service.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/web_contents.h"
+#include "url/origin.h"
+
+namespace cbf {
+
+namespace {
+
+mojom::CbfIpcPayloadKind ToCbfPayloadKind(
+    chrome::mojom::CbfPageIpcPayloadKind payload_kind) {
+  switch (payload_kind) {
+    case chrome::mojom::CbfPageIpcPayloadKind::kText:
+      return mojom::CbfIpcPayloadKind::kText;
+    case chrome::mojom::CbfPageIpcPayloadKind::kBinary:
+      return mojom::CbfIpcPayloadKind::kBinary;
+  }
+}
+
+chrome::mojom::CbfPageIpcErrorCode ToPageErrorCode(
+    cbf::mojom::CbfIpcErrorCode error_code) {
+  switch (error_code) {
+    case cbf::mojom::CbfIpcErrorCode::kNone:
+      return chrome::mojom::CbfPageIpcErrorCode::kNone;
+    case cbf::mojom::CbfIpcErrorCode::kTimeout:
+      return chrome::mojom::CbfPageIpcErrorCode::kTimeout;
+    case cbf::mojom::CbfIpcErrorCode::kAborted:
+      return chrome::mojom::CbfPageIpcErrorCode::kAborted;
+    case cbf::mojom::CbfIpcErrorCode::kDisconnected:
+      return chrome::mojom::CbfPageIpcErrorCode::kDisconnected;
+    case cbf::mojom::CbfIpcErrorCode::kIpcDisabled:
+      return chrome::mojom::CbfPageIpcErrorCode::kIpcDisabled;
+    case cbf::mojom::CbfIpcErrorCode::kContextClosed:
+      return chrome::mojom::CbfPageIpcErrorCode::kContextClosed;
+    case cbf::mojom::CbfIpcErrorCode::kRemoteError:
+      return chrome::mojom::CbfPageIpcErrorCode::kRemoteError;
+    case cbf::mojom::CbfIpcErrorCode::kProtocolError:
+      return chrome::mojom::CbfPageIpcErrorCode::kProtocolError;
+  }
+}
+
+}  // namespace
+
+// static
+void CbfPageIpcHost::Create(
+    content::RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<chrome::mojom::CbfPageIpcHost> receiver) {
+  if (!render_frame_host) {
+    return;
+  }
+  new CbfPageIpcHost(render_frame_host, std::move(receiver));
+}
+
+CbfPageIpcHost::CbfPageIpcHost(
+    content::RenderFrameHost* render_frame_host,
+    mojo::PendingReceiver<chrome::mojom::CbfPageIpcHost> receiver)
+    : render_frame_host_(render_frame_host), receiver_(this, std::move(receiver)) {
+  receiver_.set_disconnect_handler(
+      base::BindOnce([](CbfPageIpcHost* self) { delete self; }, this));
+}
+
+CbfPageIpcHost::~CbfPageIpcHost() = default;
+
+void CbfPageIpcHost::Invoke(chrome::mojom::CbfPageIpcInvokeRequestPtr request,
+                            InvokeCallback callback) {
+  auto result = chrome::mojom::CbfPageIpcInvokeResult::New();
+  result->accepted = false;
+  result->error_code = chrome::mojom::CbfPageIpcErrorCode::kContextClosed;
+
+  if (!request || !render_frame_host_) {
+    result->error_code = chrome::mojom::CbfPageIpcErrorCode::kProtocolError;
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  content::WebContents* web_contents =
+      content::WebContents::FromRenderFrameHost(render_frame_host_);
+  if (!web_contents || web_contents->GetPrimaryMainFrame() != render_frame_host_) {
+    result->error_code = chrome::mojom::CbfPageIpcErrorCode::kIpcDisabled;
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  Profile* profile =
+      Profile::FromBrowserContext(render_frame_host_->GetBrowserContext());
+  CbfService* cbf_service = CbfService::GetForProcess();
+  CbfBrowserService* browser_service =
+      cbf_service ? cbf_service->browser_service() : nullptr;
+  CbfProfileService* profile_service =
+      browser_service ? browser_service->GetProfileServiceForProfile(profile)
+                      : nullptr;
+  if (!profile_service) {
+    profile_service = CbfProfileService::GetForProfile(profile);
+  }
+  if (!profile_service) {
+    result->error_code = chrome::mojom::CbfPageIpcErrorCode::kDisconnected;
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  const TabId tab_id = profile_service->GetTabIdForWebContents(web_contents);
+  if (tab_id == kInvalidTabId) {
+    result->error_code = chrome::mojom::CbfPageIpcErrorCode::kContextClosed;
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  auto message = mojom::CbfIpcMessage::New();
+  message->channel = request->channel;
+  message->message_type = mojom::CbfIpcMessageType::kRequest;
+  message->request_id = request->request_id;
+  message->payload_kind = ToCbfPayloadKind(request->payload_kind);
+  message->payload_text = request->payload_text;
+  message->payload_binary = std::move(request->payload_binary);
+  message->content_type = request->content_type;
+  message->error_code = mojom::CbfIpcErrorCode::kNone;
+
+  mojom::CbfIpcErrorCode error_code = mojom::CbfIpcErrorCode::kNone;
+  if (!profile_service->DispatchTabIpcInvoke(
+          tab_id, render_frame_host_->GetLastCommittedOrigin(),
+          std::move(message), &error_code)) {
+    result->error_code = ToPageErrorCode(error_code);
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  result->accepted = true;
+  result->error_code = chrome::mojom::CbfPageIpcErrorCode::kNone;
+  std::move(callback).Run(std::move(result));
+}
+
+}  // namespace cbf
