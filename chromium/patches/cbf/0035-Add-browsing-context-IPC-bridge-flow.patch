+void CbfBridgeClientImpl::Observer::OnTabIpcMessageReceived(
+    uint64_t tab_id,
+    cbf::mojom::CbfIpcMessagePtr message) {
+  if (!message) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventTabIpcMessageReceived;
+  event.tab_id = tab_id;
+  event.request_id = message->request_id;
+  event.profile_id = profile_id_;
+  event.ipc_channel = message->channel;
+  event.ipc_message_type = static_cast<uint8_t>(message->message_type);
+  event.ipc_payload_kind = static_cast<uint8_t>(message->payload_kind);
+  event.ipc_payload_text = message->payload_text;
+  event.ipc_payload_binary = std::move(message->payload_binary);
+  event.ipc_content_type = message->content_type;
+  event.ipc_error_code = static_cast<uint8_t>(message->error_code);
+  std::lock_guard<std::mutex> lock(impl_->events_mutex);
+  impl_->events.push(std::move(event));
+}
