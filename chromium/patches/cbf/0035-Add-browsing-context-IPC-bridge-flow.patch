+bool CbfBridgeClient::PostTabIpcMessage(
+    const uint64_t tab_id,
+    const std::string& channel,
+    const uint8_t message_type,
+    const uint64_t request_id,
+    const uint8_t payload_kind,
+    const std::string& payload_text,
+    const std::vector<uint8_t>& payload_binary,
+    const std::string& content_type,
+    const uint8_t error_code) {
+  if (!impl_ || channel.empty()) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id, std::string channel,
+             uint8_t message_type, uint64_t request_id, uint8_t payload_kind,
+             std::string payload_text, std::vector<uint8_t> payload_binary,
+             std::string content_type, uint8_t error_code) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            auto message = cbf::mojom::CbfIpcMessage::New();
+            message->channel = std::move(channel);
+            message->message_type =
+                static_cast<cbf::mojom::CbfIpcMessageType>(message_type);
+            message->request_id = request_id;
+            message->payload_kind =
+                static_cast<cbf::mojom::CbfIpcPayloadKind>(payload_kind);
+            message->payload_text = std::move(payload_text);
+            message->payload_binary = std::move(payload_binary);
+            message->content_type = std::move(content_type);
+            message->error_code =
+                static_cast<cbf::mojom::CbfIpcErrorCode>(error_code);
+            remote_it->second.remote->PostTabIpcMessage(tab_id,
+                                                        std::move(message));
+          },
+          impl, tab_id, channel, message_type, request_id, payload_kind,
+          payload_text, payload_binary, content_type, error_code));
+  return true;
+}
