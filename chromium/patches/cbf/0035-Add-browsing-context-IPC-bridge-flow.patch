+  const IPC_ERROR_DISCONNECTED = 3;
+  const IPC_ERROR_IPC_DISABLED = 4;
+  const IPC_ERROR_CONTEXT_CLOSED = 5;
+  const IPC_ERROR_REMOTE_ERROR = 6;
+  const IPC_ERROR_PROTOCOL_ERROR = 7;
+  const ERROR_CODE_MAP = {
+    [IPC_ERROR_TIMEOUT]: 'TIMEOUT',
+    [IPC_ERROR_ABORTED]: 'ABORTED',
+    [IPC_ERROR_DISCONNECTED]: 'DISCONNECTED',
+    [IPC_ERROR_IPC_DISABLED]: 'IPC_DISABLED',
+    [IPC_ERROR_CONTEXT_CLOSED]: 'CONTEXT_CLOSED',
+    [IPC_ERROR_REMOTE_ERROR]: 'REMOTE_ERROR',
+    [IPC_ERROR_PROTOCOL_ERROR]: 'PROTOCOL_ERROR',
+  };
+  const listeners = new Set();
+  const pendingInvokes = new Map();
+  let nextRequestId = 1;
+  function normalizeErrorCode(errorCode) {
+    return ERROR_CODE_MAP[errorCode] || 'PROTOCOL_ERROR';
+  }
+  function toArrayBufferFromBase64(base64Text) {
+    if (!base64Text) {
+      return new ArrayBuffer(0);
+    }
+    const decoded = atob(base64Text);
+    const out = new Uint8Array(decoded.length);
+    for (let i = 0; i < decoded.length; i += 1) {
+      out[i] = decoded.charCodeAt(i);
+    }
+    return out.buffer;
+  }
+  function normalizeIncomingPayload(message) {
+    if (!message) {
+      return '';
+    }
+    if (message.payload_kind === IPC_PAYLOAD_BINARY) {
+      return toArrayBufferFromBase64(message.payload_binary_base64 || '');
+    }
+    return typeof message.payload_text === 'string' ? message.payload_text : '';
+  }
+  function rejectPending(requestId, code) {
+    const pending = pendingInvokes.get(requestId);
+    if (!pending) {
+      return;
+    }
+    pendingInvokes.delete(requestId);
+    if (pending.abortCleanup) {
+      pending.abortCleanup();
+    }
+    if (pending.timeoutId !== null) {
+      clearTimeout(pending.timeoutId);
+    }
+    pending.reject({ code });
+  }
+  window.__cbfReceiveHostIpc = function(message) {
+    if (!message) {
+      return;
+    }
+    if (message.message_type === IPC_MESSAGE_RESPONSE) {
+      const pending = pendingInvokes.get(message.request_id);
+      if (!pending) {
+        return;
+      }
+      pendingInvokes.delete(message.request_id);
+      if (pending.abortCleanup) {
+        pending.abortCleanup();
+      }
+      if (pending.timeoutId !== null) {
+        clearTimeout(pending.timeoutId);
+      }
+      if (message.error_code && message.error_code !== IPC_ERROR_NONE) {
+        pending.reject({ code: normalizeErrorCode(message.error_code) });
+        return;
+      }
+      pending.resolve(normalizeIncomingPayload(message));
+      return;
+    }
+    if (message.message_type !== IPC_MESSAGE_EVENT) {
+      return;
+    }
+    const eventMessage = {
+      channel: typeof message.channel === 'string' ? message.channel : '',
+      message_type: message.message_type,
+      request_id: message.request_id || 0,
+      payload_kind: message.payload_kind,
+      payload: normalizeIncomingPayload(message),
+      content_type:
+          typeof message.content_type === 'string' ? message.content_type : '',
+      error_code: message.error_code || IPC_ERROR_NONE,
+    };
+    listeners.forEach((handler) => {
+      try {
+        handler(eventMessage);
+      } catch (_) {}
+    });
+  };
+  document.addEventListener('__cbfHostIpc', (event) => {
+    if (!event || typeof event.detail !== 'string') {
+      return;
+    }
+    let message = null;
+    try {
+      message = JSON.parse(event.detail);
+    } catch (_) {
+      return;
+    }
+    window.__cbfReceiveHostIpc(message);
+  });
+  window.cbf = window.cbf || {};
+  window.cbf.listen = function(handler) {
+    if (typeof handler !== 'function') {
+      return function() {};
+    }
+    listeners.add(handler);
+    return function() {
+      listeners.delete(handler);
+    };
+  };
+  window.cbf.invoke = function(channel, payload, options) {
+    if (typeof channel !== 'string' || !channel) {
+      return Promise.reject({ code: 'PROTOCOL_ERROR' });
+    }
+    if (typeof window.__cbfInvokeNative !== 'function') {
+      return Promise.reject({ code: 'DISCONNECTED' });
+    }
+    const resolvedOptions = options || {};
+    const requestId = nextRequestId;
+    nextRequestId += 1;
+    const timeoutMs =
+        typeof resolvedOptions.timeout_ms === 'number' &&
+            resolvedOptions.timeout_ms > 0
+            ? resolvedOptions.timeout_ms
+            : null;
+    let payloadKind = IPC_PAYLOAD_TEXT;
+    let payloadText = '';
+    let payloadBinary = new ArrayBuffer(0);
+    if (payload instanceof ArrayBuffer) {
+      payloadKind = IPC_PAYLOAD_BINARY;
+      payloadBinary = payload;
+    } else if (ArrayBuffer.isView(payload)) {
+      payloadKind = IPC_PAYLOAD_BINARY;
+      const view = new Uint8Array(payload.buffer, payload.byteOffset,
+                                  payload.byteLength);
+      const binaryCopy = new Uint8Array(view.byteLength);
+      binaryCopy.set(view);
+      payloadBinary = binaryCopy.buffer;
+    } else if (typeof payload === 'string') {
+      payloadText = payload;
+    } else if (payload === null || payload === undefined) {
+      payloadText = '';
+    } else {
+      payloadText = String(payload);
+    }
+    const contentType =
+        typeof resolvedOptions.content_type === 'string'
+            ? resolvedOptions.content_type
+            : '';
+
+    return new Promise((resolve, reject) => {
+      const pending = {
+        resolve,
+        reject,
+        timeoutId: null,
+        abortCleanup: null,
+      };
+      if (timeoutMs !== null) {
+        pending.timeoutId = setTimeout(() => {
+          rejectPending(requestId, 'TIMEOUT');
+        }, timeoutMs);
+      }
+      if (resolvedOptions.signal &&
+          typeof resolvedOptions.signal.addEventListener === 'function') {
+        const onAbort = function() {
+          rejectPending(requestId, 'ABORTED');
+        };
+        if (resolvedOptions.signal.aborted) {
+          reject({ code: 'ABORTED' });
+          return;
+        }
+        resolvedOptions.signal.addEventListener('abort', onAbort, {
+          once: true,
+        });
+        pending.abortCleanup = function() {
+          resolvedOptions.signal.removeEventListener('abort', onAbort);
+        };
+      }
+      pendingInvokes.set(requestId, pending);
+      try {
+        window.__cbfInvokeNative(
+            channel, requestId, payloadKind, payloadText, payloadBinary,
+            contentType, function(result) {
+              if (!result || !result.accepted) {
+                const code = normalizeErrorCode(result ? result.error_code : 0);
+                rejectPending(requestId, code);
+              }
+            });
+      } catch (_) {
+        rejectPending(requestId, 'DISCONNECTED');
+      }
+    });
+  };
+})();
+)";
+
+chrome::mojom::CbfPageIpcPayloadKind ParsePayloadKind(int32_t payload_kind) {
+  return payload_kind == 1 ? chrome::mojom::CbfPageIpcPayloadKind::kBinary
+                           : chrome::mojom::CbfPageIpcPayloadKind::kText;
+}
+
+}  // namespace
+
+// static
+void CbfIpcExtension::Create(content::RenderFrame* frame) {
+  new CbfIpcExtension(frame);
+}
+
+CbfIpcExtension::CbfIpcExtension(content::RenderFrame* frame)
+    : content::RenderFrameObserver(frame) {}
+
+CbfIpcExtension::~CbfIpcExtension() = default;
+
+void CbfIpcExtension::OnDestruct() {
+  delete this;
+}
+
+void CbfIpcExtension::DidCreateScriptContext(v8::Local<v8::Context> v8_context,
+                                             int32_t world_id) {
+  if (!render_frame() || world_id != content::ISOLATED_WORLD_ID_GLOBAL ||
+      !render_frame()->IsMainFrame()) {
+    return;
+  }
+  Install();
+}
+
+void CbfIpcExtension::Install() {
+  DCHECK(render_frame());
+  blink::WebLocalFrame* web_frame = render_frame()->GetWebFrame();
+  if (!web_frame) {
+    return;
+  }
+
+  v8::Isolate* isolate = web_frame->GetAgentGroupScheduler()->Isolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = web_frame->MainWorldScriptContext();
+  if (context.IsEmpty()) {
+    return;
+  }
+
+  v8::Context::Scope context_scope(context);
+  v8::Local<v8::Object> window =
+      content::GetOrCreateObject(isolate, context, "window");
+  v8::Local<v8::Value> existing;
+  if (window
+          ->Get(context, gin::StringToSymbol(isolate, "__cbfInvokeNative"))
+          .ToLocal(&existing) &&
+      existing->IsFunction()) {
+    return;
+  }
+
+  window
+      ->Set(context, gin::StringToSymbol(isolate, "__cbfInvokeNative"),
+            gin::CreateFunctionTemplate(
+                isolate, base::BindRepeating(&CbfIpcExtension::InvokeNative,
+                                             weak_ptr_factory_.GetWeakPtr()))
+                ->GetFunction(context)
+                .ToLocalChecked())
+      .Check();
+
+  v8::Local<v8::String> bootstrap_source;
+  if (!v8::String::NewFromUtf8(isolate, kCbfIpcBootstrapScript,
+                               v8::NewStringType::kNormal)
+           .ToLocal(&bootstrap_source)) {
+    return;
+  }
+  v8::Local<v8::Script> bootstrap_script;
+  if (!v8::Script::Compile(context, bootstrap_source)
+           .ToLocal(&bootstrap_script)) {
+    return;
+  }
+  (void)bootstrap_script->Run(context);
+}
+
+void CbfIpcExtension::InvokeNative(gin::Arguments* args) {
+  if (!render_frame() || !render_frame()->IsMainFrame()) {
+    args->ThrowError();
+    return;
+  }
+
+  std::string channel;
+  if (!args->GetNext(&channel)) {
+    args->ThrowError();
+    return;
+  }
+
+  uint32_t request_id = 0;
+  if (!args->GetNext(&request_id)) {
+    args->ThrowError();
+    return;
+  }
+
+  int32_t payload_kind = 0;
+  if (!args->GetNext(&payload_kind)) {
+    args->ThrowError();
+    return;
+  }
+
+  std::string payload_text;
+  if (!args->GetNext(&payload_text)) {
+    args->ThrowError();
+    return;
+  }
+
+  v8::Local<v8::Value> payload_binary_value;
+  if (!args->GetNext(&payload_binary_value) ||
+      !payload_binary_value->IsArrayBuffer()) {
+    args->ThrowError();
+    return;
+  }
+  v8::Local<v8::ArrayBuffer> payload_binary_buffer =
+      payload_binary_value.As<v8::ArrayBuffer>();
+  const auto backing_store = payload_binary_buffer->GetBackingStore();
+  std::vector<uint8_t> payload_binary;
+  if (backing_store->ByteLength() > 0) {
+    const auto* binary_start =
+        static_cast<const uint8_t*>(backing_store->Data());
+    payload_binary = UNSAFE_BUFFERS(std::vector<uint8_t>(
+        binary_start, binary_start + backing_store->ByteLength()));
+  }
+
+  std::string content_type;
+  if (!args->GetNext(&content_type)) {
+    args->ThrowError();
+    return;
+  }
+
+  v8::Local<v8::Function> callback;
+  if (!args->GetNext(&callback)) {
+    args->ThrowError();
+    return;
+  }
+
+  if (!remote_.is_bound()) {
+    render_frame()->GetBrowserInterfaceBroker().GetInterface(
+        remote_.BindNewPipeAndPassReceiver());
+  }
+
+  auto request = chrome::mojom::CbfPageIpcInvokeRequest::New();
+  request->channel = std::move(channel);
+  request->request_id = request_id;
+  request->payload_kind = ParsePayloadKind(payload_kind);
+  request->payload_text = std::move(payload_text);
+  request->payload_binary = std::move(payload_binary);
+  request->content_type = std::move(content_type);
+
+  remote_->Invoke(
+      std::move(request),
+      base::BindOnce(&CbfIpcExtension::OnInvokeResult,
+                     weak_ptr_factory_.GetWeakPtr(),
+                     std::make_unique<v8::Global<v8::Function>>(args->isolate(),
+                                                                 callback)));
+}
+
+void CbfIpcExtension::OnInvokeResult(
+    std::unique_ptr<v8::Global<v8::Function>> callback,
+    chrome::mojom::CbfPageIpcInvokeResultPtr result) {
+  if (!render_frame() || !callback) {
+    return;
+  }
+  blink::WebLocalFrame* web_frame = render_frame()->GetWebFrame();
+  if (!web_frame) {
+    return;
+  }
+  v8::Isolate* isolate = web_frame->GetAgentGroupScheduler()->Isolate();
+  v8::HandleScope handle_scope(isolate);
+  v8::Local<v8::Context> context = web_frame->MainWorldScriptContext();
+  if (context.IsEmpty()) {
+    return;
+  }
+  v8::Context::Scope context_scope(context);
+  v8::MicrotasksScope microtasks_scope(
+      isolate, context->GetMicrotaskQueue(),
+      v8::MicrotasksScope::kDoNotRunMicrotasks);
+
+  v8::Local<v8::Object> response = v8::Object::New(isolate);
+  response
+      ->Set(context, gin::StringToSymbol(isolate, "accepted"),
+            v8::Boolean::New(isolate, result && result->accepted))
+      .Check();
+  response
+      ->Set(
+          context, gin::StringToSymbol(isolate, "error_code"),
+          v8::Integer::New(
+              isolate,
+              static_cast<int>(result ? result->error_code
+                                      : chrome::mojom::CbfPageIpcErrorCode::
+                                            kDisconnected)))
+      .Check();
+
+  v8::Local<v8::Function> local_callback = callback->Get(isolate);
+  v8::Local<v8::Value> argv[] = {response};
+  (void)local_callback->Call(context, context->Global(), 1, argv);
+}
