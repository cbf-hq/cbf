+bool CbfBridgeClient::EnableTabIpc(const uint64_t tab_id,
+                                   const CbfCommandList* allowed_origins) {
+  if (!impl_ || !allowed_origins) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  std::vector<std::string> origins;
+  if (allowed_origins->items && allowed_origins->len > 0) {
+    auto items = UNSAFE_BUFFERS(
+        base::span(allowed_origins->items, allowed_origins->len));
+    origins.reserve(items.size());
+    for (const char* item : items) {
+      origins.emplace_back(item ? item : "");
+    }
+  }
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t tab_id,
+             std::vector<std::string> origins) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+            remote_it->second.remote->EnableTabIpc(tab_id, std::move(origins));
+          },
+          impl, tab_id, std::move(origins)));
+  return true;
+}
