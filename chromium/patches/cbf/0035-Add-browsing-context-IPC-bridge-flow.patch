+extern "C" bool cbf_bridge_client_post_tab_ipc_message(
+    CbfBridgeClientHandle* client,
+    const uint64_t tab_id,
+    const char* channel,
+    const uint8_t message_type,
+    const uint64_t request_id,
+    const uint8_t payload_kind,
+    const char* payload_text,
+    const uint8_t* payload_binary,
+    const uint32_t payload_binary_len,
+    const char* content_type,
+    const uint8_t error_code) {
+  if (!client || !channel || channel[0] == '\0') {
+    return false;
+  }
+  std::vector<uint8_t> binary;
+  if (payload_binary && payload_binary_len > 0) {
+    auto source = UNSAFE_BUFFERS(base::span(payload_binary, payload_binary_len));
+    binary.assign(source.begin(), source.end());
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->PostTabIpcMessage(tab_id, channel, message_type, request_id,
+                          payload_kind, payload_text ? payload_text : "",
