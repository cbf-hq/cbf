 chrome/browser/cbf/bridge/cbf_bridge_auth.cc  | 83 +++++++++++++++++++
 chrome/browser/cbf/cbf_browser_service.cc     | 20 ++++-
 chrome/browser/cbf/cbf_browser_service.h      |  7 +-
 .../cbf/cbf_browser_service_unittest.cc       | 49 +++++++++++
