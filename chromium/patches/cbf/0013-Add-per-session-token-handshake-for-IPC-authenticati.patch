@@ -14,16 +14,30 @@
 
 namespace cbf {
 
-CbfBrowserService::CbfBrowserService() = default;
+CbfBrowserService::CbfBrowserService(std::string session_token)
+    : expected_token_(std::move(session_token)),
+      authenticated_(expected_token_.empty()) {}
 
 CbfBrowserService::~CbfBrowserService() = default;
 
+void CbfBrowserService::Authenticate(const std::string& token,
+                                     AuthenticateCallback callback) {
+  if (token == expected_token_) {
+    authenticated_ = true;
+    std::move(callback).Run(true);
+  } else {
+    std::move(callback).Run(false);
+  }
+}
+
 void CbfBrowserService::SetObserver(
     mojo::PendingRemote<mojom::CbfBrowserObserver> observer) {
+  if (!authenticated_) { return; }
   if (observer_.is_bound()) { observer_.reset(); } observer_.Bind(std::move(observer));
 }
 
 void CbfBrowserService::GetProfiles(GetProfilesCallback callback) {
+  if (!authenticated_) { std::move(callback).Run({}); return; }
   std::vector<mojom::CbfProfileInfoPtr> profiles;
   ProfileManager* profile_manager =
       g_browser_process ? g_browser_process->profile_manager() : nullptr;
@@ -56,6 +70,7 @@ void CbfBrowserService::GetProfiles(GetProfilesCallback callback) {
