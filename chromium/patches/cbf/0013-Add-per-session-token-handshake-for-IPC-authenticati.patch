     const std::string& profile_id,
     mojo::PendingReceiver<mojom::CbfProfileService> receiver) {
+  if (!authenticated_) { return; }
   std::string resolved_id;
   ::Profile* profile = ResolveProfile(profile_id, &resolved_id);
   if (!profile) {
@@ -71,6 +86,7 @@ void CbfBrowserService::BindProfileService(
 }
 
 void CbfBrowserService::RequestShutdown(uint64_t request_id) {
+  if (!authenticated_) { return; }
   if (shutdown_state_ == ShutdownState::kProceeding || shutdown_in_progress_) {
     if (observer_) {
       observer_->OnShutdownProceeding(request_id);
@@ -108,6 +124,7 @@ void CbfBrowserService::RequestShutdown(uint64_t request_id) {
 }
 
 void CbfBrowserService::ConfirmShutdown(uint64_t request_id, bool proceed) {
+  if (!authenticated_) { return; }
   if (shutdown_state_ != ShutdownState::kBlocked ||
       !shutdown_request_id_.has_value() ||
       shutdown_request_id_.value() != request_id) {
@@ -125,6 +142,7 @@ void CbfBrowserService::ConfirmShutdown(uint64_t request_id, bool proceed) {
 }
 
 void CbfBrowserService::ForceShutdown() {
+  if (!authenticated_) { return; }
   chrome::ExitIgnoreUnloadHandlers();
 }
 
