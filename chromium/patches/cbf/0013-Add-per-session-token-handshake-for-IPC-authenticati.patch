diff --git a/chrome/browser/cbf/bridge/cbf_bridge_auth.cc b/chrome/browser/cbf/bridge/cbf_bridge_auth.cc
new file mode 100644
index 0000000000000..989a8c1694eba
--- /dev/null
+++ b/chrome/browser/cbf/bridge/cbf_bridge_auth.cc
@@ -0,0 +1,83 @@
+#include "chrome/browser/cbf/bridge/cbf_bridge.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client.h"
+
+#include "base/functional/bind.h"
+#include "base/location.h"
+#include "base/synchronization/waitable_event.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_client_impl.h"
+#include "chrome/browser/cbf/bridge/cbf_bridge_support.h"
+#include "chrome/browser/cbf/mojom/cbf_browser.mojom.h"
+#include "mojo/public/cpp/bindings/receiver.h"
+
+namespace cbf_bridge::internal {
+
+bool CbfBridgeClient::Authenticate(const std::string& token) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+
+  base::WaitableEvent done(base::WaitableEvent::ResetPolicy::MANUAL,
+                            base::WaitableEvent::InitialState::NOT_SIGNALED);
+  bool auth_ok = false;
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, std::string token, bool* auth_ok,
+             base::WaitableEvent* done) {
+            if (!impl->browser_remote.is_bound()) {
+              done->Signal();
+              return;
+            }
+            // Signal done on disconnect so done.Wait() never blocks forever.
+            impl->browser_remote.set_disconnect_handler(
+                base::BindOnce([](bool* auth_ok,
+                                  base::WaitableEvent* done) {
+                  *auth_ok = false;
+                  done->Signal();
+                }, auth_ok, done));
+            impl->browser_remote->Authenticate(
+                token,
+                base::BindOnce(
+                    [](CbfBridgeClientImpl* impl, bool* auth_ok,
+                       base::WaitableEvent* done, bool ok) {
+                      // Clear the disconnect handler so it doesn't fire after
+                      // we've already signaled done.
+                      impl->browser_remote.set_disconnect_handler(
+                          base::OnceClosure());
+                      if (ok) {
+                        impl->browser_observer = std::make_unique<
+                            CbfBridgeClientImpl::BrowserObserver>(impl);
+                        mojo::PendingRemote<cbf::mojom::CbfBrowserObserver>
+                            observer_remote;
+                        impl->browser_observer_receiver = std::make_unique<
+                            mojo::Receiver<cbf::mojom::CbfBrowserObserver>>(
+                            impl->browser_observer.get(),
+                            observer_remote.InitWithNewPipeAndPassReceiver());
+                        impl->browser_remote->SetObserver(
+                            std::move(observer_remote));
+                      }
+                      *auth_ok = ok;
+                      done->Signal();
+                    },
+                    impl, auth_ok, done));
+          },
+          impl_.get(), token, &auth_ok, &done));
+  done.Wait();
+  return auth_ok;
+}
+
+}  // namespace cbf_bridge::internal
+
+extern "C" bool cbf_bridge_client_authenticate(CbfBridgeClientHandle* client,
+                                                const char* token) {
+  if (!client || !token) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->Authenticate(std::string(token));
+}
diff --git a/chrome/browser/cbf/cbf_browser_service.cc b/chrome/browser/cbf/cbf_browser_service.cc
index e1bf43758771b..a28dd6369090e 100644
