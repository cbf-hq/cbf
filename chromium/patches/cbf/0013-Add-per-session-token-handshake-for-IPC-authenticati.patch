@@ -0,0 +1,49 @@
+#include "chrome/browser/cbf/cbf_browser_service.h"
+
+#include "base/functional/bind.h"
+#include "testing/gtest/include/gtest/gtest.h"
+
+namespace cbf {
+namespace {
+
+TEST(CbfBrowserServiceTest, RejectsMismatchedTokenAndRemainsUnauthenticated) {
+  CbfBrowserService service("expected-token");
+
+  bool callback_called = false;
+  bool authenticated = true;
+  service.Authenticate(
+      "wrong-token",
+      base::BindOnce(
+          [](bool* callback_called, bool* authenticated, bool ok) {
+            *callback_called = true;
+            *authenticated = ok;
+          },
+          &callback_called, &authenticated));
+
+  EXPECT_TRUE(callback_called);
+  EXPECT_FALSE(authenticated);
+
+  service.RequestShutdown(/*request_id=*/1u);
+  EXPECT_FALSE(service.IsShutdownRequested());
+}
+
+TEST(CbfBrowserServiceTest, AcceptsMatchingToken) {
+  CbfBrowserService service("expected-token");
+
+  bool callback_called = false;
+  bool authenticated = false;
+  service.Authenticate(
+      "expected-token",
+      base::BindOnce(
+          [](bool* callback_called, bool* authenticated, bool ok) {
+            *callback_called = true;
+            *authenticated = ok;
+          },
+          &callback_called, &authenticated));
+
+  EXPECT_TRUE(callback_called);
+  EXPECT_TRUE(authenticated);
+}
+
+}  // namespace
+}  // namespace cbf
