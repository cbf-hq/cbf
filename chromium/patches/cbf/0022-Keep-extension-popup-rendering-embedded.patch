+class CbfProfileService::ActiveExtensionPopup
+    : public content::WebContentsObserver {
+ public:
+  ActiveExtensionPopup(base::WeakPtr<CbfProfileService> service,
+                       uint64_t popup_id,
+                       TabId tab_id,
+                       extensions::ExtensionId extension_id,
+                       std::unique_ptr<extensions::ExtensionViewHost> host)
+      : content::WebContentsObserver(host ? host->host_contents() : nullptr),
+        service_(std::move(service)),
+        popup_id_(popup_id),
+        tab_id_(tab_id),
+        extension_id_(std::move(extension_id)),
+        host_(std::move(host)),
+        host_view_(base::BindRepeating(&ActiveExtensionPopup::OnHostLoaded,
+                                       base::Unretained(this)),
+                   base::BindRepeating(&ActiveExtensionPopup::OnAutoResize,
+                                       base::Unretained(this))) {
+    CHECK(host_);
+    host_->set_view(&host_view_);
+    host_->SetCloseHandler(
+        base::BindOnce(&ActiveExtensionPopup::HandleCloseRequested,
+                       weak_factory_.GetWeakPtr()));
+  }
+
+  ~ActiveExtensionPopup() override { CloseFromService(); }
+
+  void Start() {
+    LOG(INFO) << "CBF extension popup starting: tab_id=" << tab_id_
+              << " popup_id=" << popup_id_ << " extension_id=" << extension_id_;
+    if (host_ && host_->host_contents()) {
+      host_->host_contents()->WasShown();
+      if (content::RenderFrameHost* frame_host =
+              host_->host_contents()->GetPrimaryMainFrame();
+          frame_host && frame_host->IsRenderFrameLive()) {
+        EnableAutoResize(frame_host);
+      }
+    }
+    UpdateEffectiveSize(kExtensionPopupMinSize, "startup-default");
+    if (service_) {
+      service_->NotifyExtensionPopupOpened(
+          tab_id_, popup_id_, extension_id_,
+          base::UTF16ToUTF8(host_->host_contents()->GetTitle()));
+    }
+    host_->CreateRendererSoon();
+    StartPollingIfNeeded();
+  }
+
+  TabId tab_id() const { return tab_id_; }
+  content::WebContents* contents() const {
+    return host_ ? host_->host_contents() : nullptr;
+  }
+
+  void CloseFromService() {
+    closing_ = true;
+    poll_timer_.Stop();
+    Observe(nullptr);
+    if (host_) {
+      host_->set_view(nullptr);
+      host_.reset();
+    }
+    LOG(INFO) << "CBF extension popup closed from service: tab_id=" << tab_id_
+              << " popup_id=" << popup_id_;
+  }
+
+  void DidFirstVisuallyNonEmptyPaint() override {
+    StartPollingIfNeeded();
+    MaybeNotifyPreferredSizeChanged("first-paint");
+  }
+
+  void DidStopLoading() override {
+    StartPollingIfNeeded();
+    MaybeNotifyPreferredSizeChanged("stop-loading");
+  }
+
+  void DocumentOnLoadCompletedInPrimaryMainFrame() override {
+    StartPollingIfNeeded();
+    MaybeNotifyPreferredSizeChanged("document-load-complete");
+  }
+
+  void RenderFrameCreated(content::RenderFrameHost* frame_host) override {
+    if (!contents() || frame_host != contents()->GetPrimaryMainFrame()) {
+      return;
+    }
+    EnableAutoResize(frame_host);
+  }
+
+  void RenderFrameHostChanged(content::RenderFrameHost* old_host,
+                              content::RenderFrameHost* new_host) override {
+    (void)old_host;
+    if (!contents() || new_host != contents()->GetPrimaryMainFrame()) {
+      return;
+    }
+    EnableAutoResize(new_host);
+  }
+
+  void WebContentsDestroyed() override {
+    poll_timer_.Stop();
+    if (!closing_ && service_) {
+      LOG(INFO) << "CBF extension popup web contents destroyed: tab_id="
+                << tab_id_ << " popup_id=" << popup_id_;
+      service_->CloseExtensionPopupById(popup_id_);
+    }
+  }
+
+  void SetSize(uint32_t width, uint32_t height) {
+    UpdateEffectiveSize(gfx::Size(width, height), "host-size");
+  }
+
+  void SetFocus(bool focused) { SetWebContentsFocus(contents(), focused); }
+
+ private:
+  void OnHostLoaded() {
+    LOG(INFO) << "CBF extension popup host loaded: tab_id=" << tab_id_
+              << " popup_id=" << popup_id_;
+    MaybeNotifyPreferredSizeChanged("host-loaded");
+  }
+
+  void OnAutoResize(const gfx::Size& preferred_size) {
+    LOG(INFO) << "CBF extension popup auto resize: tab_id=" << tab_id_
+              << " popup_id=" << popup_id_
+              << " width=" << preferred_size.width()
+              << " height=" << preferred_size.height();
+    UpdateEffectiveSize(preferred_size, "auto-resize");
+  }
+
+  void EnableAutoResize(content::RenderFrameHost* frame_host) {
+    if (!frame_host || !frame_host->IsRenderFrameLive()) {
+      return;
+    }
+
+    if (content::RenderViewHost* render_view_host =
+            frame_host->GetRenderViewHost()) {
+      render_view_host->EnablePreferredSizeMode();
+    }
+
+    content::RenderWidgetHostView* view = frame_host->GetView();
+    if (!view) {
+      return;
+    }
+
+    view->EnableAutoResize(kExtensionPopupMinSize, kExtensionPopupMaxSize);
+    LOG(INFO) << "CBF extension popup auto resize enabled: tab_id=" << tab_id_
+              << " popup_id=" << popup_id_;
+  }
+
+  void MaybeNotifyPreferredSizeChanged(const char* reason) {
+    if (!contents()) {
+      return;
+    }
+    const gfx::Size preferred_size = contents()->GetPreferredSize();
+    if (preferred_size.IsEmpty()) {
+      return;
+    }
+    UpdateEffectiveSize(preferred_size, reason);
+  }
+
+  void UpdateEffectiveSize(gfx::Size requested_size, const char* reason) {
+    const gfx::Size effective_size = ClampExtensionPopupBounds(requested_size);
+    if (effective_size == effective_size_) {
+      return;
+    }
+
+    effective_size_ = effective_size;
+    if (contents()) {
+      contents()->Resize(gfx::Rect(gfx::Point(), effective_size_));
+    }
+    if (service_) {
+      LOG(INFO) << "CBF extension popup preferred size updated: tab_id="
+                << tab_id_ << " popup_id=" << popup_id_
+                << " width=" << effective_size_.width()
+                << " height=" << effective_size_.height()
+                << " reason=" << reason;
+      service_->NotifyExtensionPopupPreferredSizeChanged(
+          tab_id_, popup_id_, effective_size_.width(),
+          effective_size_.height());
+    }
+  }
+
+  void HandleCloseRequested(extensions::ExtensionHost* host) {
+    (void)host;
+    if (service_) {
+      LOG(INFO) << "CBF extension popup close requested: tab_id=" << tab_id_
+                << " popup_id=" << popup_id_;
+      service_->CloseExtensionPopupById(popup_id_);
+    }
+  }
+
+  void StartPollingIfNeeded() {
+    if (poll_timer_.IsRunning()) {
+      return;
+    }
+    poll_attempts_ = 0;
+    poll_timer_.Start(FROM_HERE, kExtensionPopupPollInterval, this,
+                      &ActiveExtensionPopup::PollOnce);
+  }
+
+  void PollOnce() {
+    if (!web_contents()) {
+      poll_timer_.Stop();
+      return;
+    }
+    if (poll_attempts_++ >= kMaxExtensionPopupPollAttempts) {
+      poll_timer_.Stop();
+      return;
+    }
+    uint32_t context_id = 0;
+    if (!TryGetWebContentsCaContextId(web_contents(), &context_id)) {
+      return;
+    }
+    if (context_id == 0 || context_id == last_context_id_) {
+      return;
+    }
+    last_context_id_ = context_id;
+    if (service_) {
+      LOG(INFO) << "CBF extension popup surface handle updated: tab_id="
+                << tab_id_ << " popup_id=" << popup_id_
+                << " ca_context_id=" << context_id;
+      service_->NotifyExtensionPopupSurfaceHandleUpdated(tab_id_, popup_id_,
+                                                         context_id);
+    }
+    poll_timer_.Stop();
+  }
+
+  base::WeakPtr<CbfProfileService> service_;
+  const uint64_t popup_id_;
+  const TabId tab_id_;
+  const extensions::ExtensionId extension_id_;
+  std::unique_ptr<extensions::ExtensionViewHost> host_;
+  CbfExtensionPopupHostView host_view_;
+  base::RepeatingTimer poll_timer_;
+  int poll_attempts_ = 0;
+  uint32_t last_context_id_ = 0;
+  gfx::Size effective_size_;
+  bool closing_ = false;
+  base::WeakPtrFactory<ActiveExtensionPopup> weak_factory_{this};
+};
