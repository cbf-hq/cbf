+void CbfProfileService::ActivateExtensionAction(
+    uint64_t tab_id,
+    const std::string& extension_id) {
+  content::WebContents* web_contents = tab_manager_.GetWebContents(tab_id);
+  if (!web_contents || !profile_) {
+    return;
+  }
+
+  BrowserWindowInterface* browser_window_interface =
+      webui::GetBrowserWindowInterface(web_contents);
+  if (!browser_window_interface) {
+    return;
+  }
+
+  const extensions::Extension* extension =
+      extensions::ExtensionRegistry::Get(profile_.get())
+          ->enabled_extensions()
+          .GetByID(extension_id);
+  if (!extension) {
+    return;
+  }
+
+  auto* action_runner =
+      extensions::ExtensionActionRunner::GetForWebContents(web_contents);
+  if (!action_runner) {
+    return;
+  }
+
+  constexpr bool kGrantTabPermissions = true;
+  const auto action = action_runner->RunAction(extension, kGrantTabPermissions);
+  if (action != extensions::ExtensionAction::ShowAction::kShowPopup) {
+    return;
+  }
+
+  auto* extension_action =
+      extensions::ExtensionActionManager::Get(profile_.get())
+          ->GetExtensionAction(*extension);
+  if (!extension_action) {
+    return;
+  }
+
+  const int session_tab_id =
+      sessions::SessionTabHelper::IdForTab(web_contents).id();
+  if (!extension_action->GetIsVisible(session_tab_id) ||
+      !extension_action->HasPopup(session_tab_id)) {
+    return;
+  }
+
+  auto host = extensions::ExtensionViewHostFactory::CreatePopupHost(
+      *extension, extension_action->GetPopupUrl(session_tab_id),
+      browser_window_interface);
+  if (!host) {
+    return;
+  }
+
+  std::vector<uint64_t> popup_ids_to_close;
+  for (const auto& [popup_id, popup] : active_extension_popups_) {
+    if (popup && popup->tab_id() == tab_id) {
+      popup_ids_to_close.push_back(popup_id);
+    }
+  }
+  for (uint64_t popup_id : popup_ids_to_close) {
+    CloseExtensionPopupById(popup_id);
+  }
+
+  const uint64_t popup_id =
+      g_next_extension_popup_id.fetch_add(1, std::memory_order_relaxed);
+  auto popup = std::make_unique<ActiveExtensionPopup>(
+      weak_factory_.GetWeakPtr(), popup_id, tab_id, extension->id(),
+      std::move(host));
+  ActiveExtensionPopup* popup_ptr = popup.get();
+  active_extension_popups_.emplace(popup_id, std::move(popup));
+  popup_ptr->Start();
+}
