diff --git a/chrome/browser/cbf/test/cbf_test_profile_observer.cc b/chrome/browser/cbf/test/cbf_test_profile_observer.cc
new file mode 100644
index 0000000000000..4c7a0fb44ab43
--- /dev/null
+++ b/chrome/browser/cbf/test/cbf_test_profile_observer.cc
@@ -0,0 +1,108 @@
+#include "chrome/browser/cbf/test/cbf_test_profile_observer.h"
+
+namespace cbf::test {
+
+CbfTestProfileObserver::CbfTestProfileObserver() = default;
+CbfTestProfileObserver::~CbfTestProfileObserver() = default;
+
+mojo::PendingRemote<cbf::mojom::CbfProfileObserver>
+CbfTestProfileObserver::BindNewPipeAndPassRemote() {
+  return receiver_.BindNewPipeAndPassRemote();
+}
+
+void CbfTestProfileObserver::WaitForWebPageClosedCount(size_t expected_count) {
+  wait_web_page_closed_count_ = expected_count;
+  if (web_page_closed_events_.size() >= wait_web_page_closed_count_) {
+    return;
+  }
+  base::RunLoop loop;
+  quit_wait_loop_ = loop.QuitClosure();
+  loop.Run();
+  quit_wait_loop_.Reset();
+}
+
+void CbfTestProfileObserver::WaitForDevToolsOpenedCount(size_t expected_count) {
+  wait_devtools_opened_count_ = expected_count;
+  if (devtools_opened_events_.size() >= wait_devtools_opened_count_) {
+    return;
+  }
+  base::RunLoop loop;
+  quit_wait_loop_ = loop.QuitClosure();
+  loop.Run();
+  quit_wait_loop_.Reset();
+}
+
+void CbfTestProfileObserver::OnSurfaceHandleUpdated(uint64_t tab_id,
+                                                    uint32_t ca_context_id) {}
+
+void CbfTestProfileObserver::OnWebPageCreated(uint64_t tab_id,
+                                              uint64_t request_id) {}
+
+void CbfTestProfileObserver::OnDevToolsOpened(uint64_t tab_id,
+                                              uint64_t devtools_tab_id) {
+  devtools_opened_events_.emplace_back(tab_id, devtools_tab_id);
+  MaybeQuitWaitLoop();
+}
+
+void CbfTestProfileObserver::OnWebPageClosed(uint64_t tab_id) {
+  web_page_closed_events_.push_back(tab_id);
+  MaybeQuitWaitLoop();
+}
+
+void CbfTestProfileObserver::OnWebPageResizeAcknowledged(uint64_t tab_id) {}
+
+void CbfTestProfileObserver::OnImeBoundsUpdated(
+    cbf::mojom::CbfImeBoundsUpdatePtr update) {}
+
+void CbfTestProfileObserver::OnContextMenuRequested(
+    uint64_t tab_id,
+    cbf::mojom::CbfContextMenuPtr menu) {}
+
+void CbfTestProfileObserver::OnNewWebPageRequested(uint64_t tab_id,
+                                                   const std::string& target_url,
+                                                   bool is_popup) {}
+
+void CbfTestProfileObserver::OnTitleUpdated(uint64_t tab_id,
+                                            const std::string& title) {}
+
+void CbfTestProfileObserver::OnFaviconUrlUpdated(uint64_t tab_id,
+                                                 const std::string& url) {}
+
+void CbfTestProfileObserver::OnBeforeUnloadDialogRequested(
+    uint64_t tab_id,
+    uint64_t request_id,
+    cbf::mojom::CbfBeforeUnloadReason reason) {}
+
+void CbfTestProfileObserver::OnCursorChanged(
+    uint64_t tab_id,
+    cbf::mojom::CbfCursorType cursor_type) {}
+
+void CbfTestProfileObserver::OnNavigationStateChanged(uint64_t tab_id,
+                                                      const std::string& url,
+                                                      bool can_go_back,
+                                                      bool can_go_forward,
+                                                      bool is_loading) {}
+
+void CbfTestProfileObserver::OnWebPageDomHtmlRead(uint64_t tab_id,
+                                                  uint64_t request_id,
+                                                  const std::string& html) {}
+
+void CbfTestProfileObserver::OnDragStartRequested(
+    cbf::mojom::CbfDragStartRequestPtr request) {}
+
+void CbfTestProfileObserver::MaybeQuitWaitLoop() {
+  if (quit_wait_loop_.is_null()) {
+    return;
+  }
+  if (wait_web_page_closed_count_ > 0 &&
+      web_page_closed_events_.size() >= wait_web_page_closed_count_) {
+    quit_wait_loop_.Run();
+    return;
+  }
+  if (wait_devtools_opened_count_ > 0 &&
+      devtools_opened_events_.size() >= wait_devtools_opened_count_) {
+    quit_wait_loop_.Run();
+  }
+}
+
+}  // namespace cbf::test
