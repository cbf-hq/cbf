diff --git a/chrome/browser/cbf/cbf_profile_service_browsertest.cc b/chrome/browser/cbf/cbf_profile_service_browsertest.cc
new file mode 100644
index 0000000000000..1b815c419088b
--- /dev/null
+++ b/chrome/browser/cbf/cbf_profile_service_browsertest.cc
@@ -0,0 +1,56 @@
+#include "chrome/browser/cbf/cbf_profile_service.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/run_loop.h"
+#include "chrome/browser/cbf/test/cbf_test_profile_observer.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/test/base/in_process_browser_test.h"
+#include "content/public/test/browser_test.h"
+#include "testing/gtest/include/gtest/gtest.h"
+
+namespace cbf {
+namespace {
+
+class CbfProfileServiceBrowserTest : public InProcessBrowserTest {
+ protected:
+  void SetUpOnMainThread() override {
+    InProcessBrowserTest::SetUpOnMainThread();
+    profile_service_ =
+        std::make_unique<CbfProfileService>(browser()->profile(), nullptr);
+    profile_service_->SetObserver(observer_.BindNewPipeAndPassRemote());
+  }
+
+  std::unique_ptr<CbfProfileService> profile_service_;
+  cbf::test::CbfTestProfileObserver observer_;
+};
+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest, InvalidRequestsAreSafeNoOp) {
+  profile_service_->RequestCloseWebPage(kInvalidTabId);
+  profile_service_->SendDragCancel(9999, kInvalidTabId);
+  profile_service_->OpenDevTools(kInvalidTabId);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       NotifyWebPageClosedEmitsObserverEvent) {
+  TabId created_id = kInvalidTabId;
+  base::RunLoop run_loop;
+  profile_service_->CreateWebPage(
+      "about:blank", 1,
+      base::BindOnce(
+          [](TabId* out_id, base::RunLoop* run_loop, TabId tab_id) {
+            *out_id = tab_id;
+            run_loop->Quit();
+          },
+          &created_id, &run_loop));
+  run_loop.Run();
+  ASSERT_NE(created_id, kInvalidTabId);
+
+  profile_service_->NotifyWebPageClosed(created_id);
+  observer_.WaitForWebPageClosedCount(1);
+  EXPECT_EQ(observer_.web_page_closed_events().front(), created_id);
+}
+
+}  // namespace
+}  // namespace cbf
diff --git a/chrome/browser/cbf/profile/cbf_profile_devtools_controller_browsertest.cc b/chrome/browser/cbf/profile/cbf_profile_devtools_controller_browsertest.cc
new file mode 100644
index 0000000000000..13b9afe7a324b
--- /dev/null
+++ b/chrome/browser/cbf/profile/cbf_profile_devtools_controller_browsertest.cc
@@ -0,0 +1,57 @@
+#include "chrome/browser/cbf/cbf_profile_service.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/run_loop.h"
+#include "chrome/browser/cbf/test/cbf_test_profile_observer.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/test/base/in_process_browser_test.h"
+#include "content/public/test/browser_test.h"
+#include "testing/gtest/include/gtest/gtest.h"
+
+namespace cbf {
+namespace {
+
+class CbfProfileDevToolsControllerBrowserTest : public InProcessBrowserTest {
+ protected:
+  void SetUpOnMainThread() override {
+    InProcessBrowserTest::SetUpOnMainThread();
+    profile_service_ =
+        std::make_unique<CbfProfileService>(browser()->profile(), nullptr);
+    profile_service_->SetObserver(observer_.BindNewPipeAndPassRemote());
+  }
+
+  TabId CreatePage() {
+    TabId created_id = kInvalidTabId;
+    base::RunLoop run_loop;
+    profile_service_->CreateWebPage(
+        "about:blank", 1,
+        base::BindOnce(
+            [](TabId* out_id, base::RunLoop* run_loop, TabId tab_id) {
+              *out_id = tab_id;
+              run_loop->Quit();
+            },
+            &created_id, &run_loop));
+    run_loop.Run();
+    return created_id;
+  }
+
+  std::unique_ptr<CbfProfileService> profile_service_;
+  cbf::test::CbfTestProfileObserver observer_;
+};
+
+IN_PROC_BROWSER_TEST_F(CbfProfileDevToolsControllerBrowserTest,
+                       OpenDevToolsAndCloseRaceDoesNotCrash) {
+  const TabId tab_id = CreatePage();
+  ASSERT_NE(tab_id, kInvalidTabId);
+
+  profile_service_->OpenDevTools(tab_id);
+  observer_.WaitForDevToolsOpenedCount(1);
+
+  profile_service_->NotifyWebPageClosed(tab_id);
+  profile_service_->OpenDevTools(tab_id);
+}
+
+}  // namespace
+}  // namespace cbf
