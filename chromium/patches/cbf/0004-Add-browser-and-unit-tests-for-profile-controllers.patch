+#ifndef CHROME_BROWSER_CBF_TEST_CBF_TEST_PROFILE_OBSERVER_H_
+#define CHROME_BROWSER_CBF_TEST_CBF_TEST_PROFILE_OBSERVER_H_
+
+#include <cstdint>
+#include <string>
+#include <utility>
+#include <vector>
+
+#include "base/functional/callback.h"
+#include "base/run_loop.h"
+#include "chrome/browser/cbf/mojom/cbf_browser.mojom.h"
+#include "mojo/public/cpp/bindings/receiver.h"
+#include "mojo/public/cpp/bindings/remote.h"
+
+namespace cbf::test {
+
+// Simple mojom observer implementation used by CBF tests.
+class CbfTestProfileObserver final : public cbf::mojom::CbfProfileObserver {
+ public:
+  CbfTestProfileObserver();
+  CbfTestProfileObserver(const CbfTestProfileObserver&) = delete;
+  CbfTestProfileObserver& operator=(const CbfTestProfileObserver&) = delete;
+  ~CbfTestProfileObserver() override;
+
+  mojo::PendingRemote<cbf::mojom::CbfProfileObserver> BindNewPipeAndPassRemote();
+
+  const std::vector<uint64_t>& web_page_closed_events() const {
+    return web_page_closed_events_;
+  }
+  const std::vector<std::pair<uint64_t, uint64_t>>& devtools_opened_events()
+      const {
+    return devtools_opened_events_;
+  }
+
+  void WaitForWebPageClosedCount(size_t expected_count);
+  void WaitForDevToolsOpenedCount(size_t expected_count);
+
+  // cbf::mojom::CbfProfileObserver
+  void OnSurfaceHandleUpdated(uint64_t tab_id,
+                              uint32_t ca_context_id) override;
+  void OnWebPageCreated(uint64_t tab_id, uint64_t request_id) override;
+  void OnDevToolsOpened(uint64_t tab_id,
+                        uint64_t devtools_tab_id) override;
+  void OnWebPageClosed(uint64_t tab_id) override;
+  void OnWebPageResizeAcknowledged(uint64_t tab_id) override;
+  void OnImeBoundsUpdated(cbf::mojom::CbfImeBoundsUpdatePtr update) override;
+  void OnContextMenuRequested(
