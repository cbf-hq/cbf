+std::optional<uint64_t> CbfProfileService::RequestExtensionUninstallPrompt(
+    base::WeakPtr<CbfExtensionUninstallDialog> dialog,
+    const extensions::Extension* extension,
+    const extensions::Extension* triggering_extension,
+    bool can_report_abuse) {
+  if (!observer_ || !dialog || !extension) {
+    return std::nullopt;
+  }
+
+  const uint64_t request_id = next_prompt_ui_request_id_++;
+  PendingExtensionUninstallPrompt pending;
+  pending.request_id = request_id;
+  pending.extension_id = extension->id();
+  pending.extension_name = extension->name();
+  if (triggering_extension) {
+    pending.triggering_extension_name = triggering_extension->name();
+  }
+  pending.can_report_abuse = can_report_abuse;
+  pending.dialog = std::move(dialog);
+  pending_extension_uninstall_prompts_[request_id] = std::move(pending);
+
+  NotifyExtensionUninstallPromptRequested(
+      std::nullopt, request_id, extension->id(), extension->name(),
+      triggering_extension ? std::make_optional(triggering_extension->name())
+                           : std::nullopt,
+      can_report_abuse);
+  return request_id;
+}
+
+void CbfProfileService::OnExtensionUninstallDialogClosed(
+    uint64_t request_id,
+    extensions::ExtensionUninstallDialog::CloseAction action,
+    bool did_start_uninstall,
+    const std::u16string& error,
+    bool report_abuse) {
+  auto it = pending_extension_uninstall_prompts_.find(request_id);
+  if (it == pending_extension_uninstall_prompts_.end()) {
+    return;
+  }
+
+  mojom::CbfExtensionUninstallPromptResult result =
+      mojom::CbfExtensionUninstallPromptResult::kAborted;
+  if (did_start_uninstall) {
+    result = mojom::CbfExtensionUninstallPromptResult::kAccepted;
+  } else if (it->second.close_reason_override.has_value()) {
+    result = mojom::CbfExtensionUninstallPromptResult::kAborted;
+  } else if (action ==
+                 extensions::ExtensionUninstallDialog::CLOSE_ACTION_UNINSTALL ||
+             action ==
+                 extensions::ExtensionUninstallDialog::
+                     CLOSE_ACTION_UNINSTALL_AND_CHECKBOX_CHECKED) {
+    result = mojom::CbfExtensionUninstallPromptResult::kFailed;
+  } else {
+    result = mojom::CbfExtensionUninstallPromptResult::kUserCanceled;
+  }
+
+  ResolveExtensionUninstallPrompt(request_id, result,
+                                  base::UTF16ToUTF8(error), report_abuse,
+                                  it->second.close_reason_override);
+}
