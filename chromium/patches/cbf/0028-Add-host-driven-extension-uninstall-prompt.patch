+    ResolveExtensionUninstallPrompt(
+        request_id, mojom::CbfExtensionUninstallPromptResult::kAborted,
+        "missing_dialog", false);
+    return false;
+  }
+  if (pending.auxiliary_window_id == 0) {
+    pending.auxiliary_window_id = next_auxiliary_window_id_++;
+  }
+  if (!pending.dialog->OpenDefaultDialog()) {
+    ResolveExtensionUninstallPrompt(
+        request_id, mojom::CbfExtensionUninstallPromptResult::kAborted,
+        "open_default_failed", false);
+    return false;
+  }
+
+  auxiliary_window_to_prompt_request_[pending.auxiliary_window_id] = request_id;
+  NotifyAuxiliaryWindowOpened(
+      pending.source_tab_id, pending.auxiliary_window_id,
+      mojom::CbfAuxiliaryWindowKind::kExtensionUninstallPrompt,
+      pending.extension_name, true);
