--- /dev/null
+++ b/chrome/browser/cbf/cbf_extension_uninstall_dialog.cc
@@ -0,0 +1,201 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/cbf/cbf_extension_uninstall_dialog.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/browser/cbf/cbf_profile_service.h"
+#include "chrome/browser/extensions/extension_util.h"
+#include "chrome/browser/ui/extensions/extension_dialog_utils.h"
+#include "chrome/grit/generated_resources.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/base/models/dialog_model.h"
+#include "ui/gfx/image/image_skia_operations.h"
+
+namespace {
+
+DEFINE_LOCAL_ELEMENT_IDENTIFIER_VALUE(kCheckboxId);
+
+}  // namespace
+
+namespace cbf {
+
+CbfExtensionUninstallDialog::CbfExtensionUninstallDialog(
+    Profile* profile,
+    gfx::NativeWindow parent,
+    CbfProfileService* profile_service,
+    extensions::ExtensionUninstallDialog::Delegate* delegate)
+    : extensions::ExtensionUninstallDialog(profile, parent, this),
+      profile_service_(profile_service),
+      external_delegate_(delegate) {}
+
+CbfExtensionUninstallDialog::~CbfExtensionUninstallDialog() {
+  if (dialog_model_) {
+    dialog_model_->host()->Close();
+  }
+  DCHECK(!dialog_model_);
+}
+
+bool CbfExtensionUninstallDialog::OpenDefaultDialog() {
+  if (closed_) {
+    return false;
+  }
+  if (dialog_model_) {
+    return true;
+  }
+  return ShowDefaultDialogInternal();
+}
+
+void CbfExtensionUninstallDialog::CloseDefaultDialog() {
+  Close();
+}
+
+void CbfExtensionUninstallDialog::HandlePromptResponse(bool proceed,
+                                                       bool report_abuse) {
+  if (closed_) {
+    return;
+  }
+
+  report_abuse_ = proceed && report_abuse && ShouldShowCheckbox();
+  last_close_action_ =
+      proceed
+          ? (report_abuse_
+                 ? extensions::ExtensionUninstallDialog::
+                       CLOSE_ACTION_UNINSTALL_AND_CHECKBOX_CHECKED
+                 : extensions::ExtensionUninstallDialog::CLOSE_ACTION_UNINSTALL)
+          : extensions::ExtensionUninstallDialog::CLOSE_ACTION_CANCELED;
+  closed_ = true;
+  OnDialogClosed(*last_close_action_);
+}
+
+void CbfExtensionUninstallDialog::OnExtensionUninstallDialogClosed(
+    bool did_start_uninstall,
+    const std::u16string& error) {
+  if (profile_service_ && prompt_request_id_.has_value() &&
+      last_close_action_.has_value()) {
+    profile_service_->OnExtensionUninstallDialogClosed(
+        prompt_request_id_.value(), *last_close_action_, did_start_uninstall,
+        error, report_abuse_);
+  }
+
+  if (external_delegate_) {
+    external_delegate_->OnExtensionUninstallDialogClosed(did_start_uninstall,
+                                                         error);
+  }
+}
+
+void CbfExtensionUninstallDialog::Show() {
+  if (closed_) {
+    return;
+  }
+
+  if (profile_service_) {
+    std::optional<uint64_t> request_id =
+        profile_service_->RequestExtensionUninstallPrompt(
+            weak_ptr_factory_.GetWeakPtr(), extension(),
+            triggering_extension(), ShouldShowCheckbox());
+    if (request_id.has_value()) {
+      prompt_request_id_ = request_id;
+      return;
+    }
+  }
+
+  ShowDefaultDialogInternal();
+}
+
+void CbfExtensionUninstallDialog::Close() {
+  if (!dialog_model_) {
+    return;
+  }
+  dialog_model_->host()->Close();
+}
+
+bool CbfExtensionUninstallDialog::ShowDefaultDialogInternal() {
+  ui::DialogModel::Builder dialog_builder;
+  dialog_builder.SetInternalName("CbfExtensionUninstallDialog")
+      .SetTitle(l10n_util::GetStringFUTF16(
+          IDS_EXTENSION_PROMPT_UNINSTALL_TITLE,
+          extensions::util::GetFixupExtensionNameForUIDisplay(
+              extension()->name())))
+      .OverrideShowCloseButton(false)
+      .SetDialogDestroyingCallback(
+          base::BindOnce(&CbfExtensionUninstallDialog::DialogClosing,
+                         weak_ptr_factory_.GetWeakPtr()))
+      .SetIcon(ui::ImageModel::FromImageSkia(
+          gfx::ImageSkiaOperations::CreateResizedImage(
+              icon(), skia::ImageOperations::ResizeMethod::RESIZE_GOOD,
+              gfx::Size(extension_misc::EXTENSION_ICON_SMALL,
+                        extension_misc::EXTENSION_ICON_SMALL))))
+      .AddOkButton(base::BindOnce(&CbfExtensionUninstallDialog::DialogAccepted,
+                                  weak_ptr_factory_.GetWeakPtr()),
+                   ui::DialogModel::Button::Params()
+                       .SetLabel(l10n_util::GetStringUTF16(
+                           IDS_EXTENSION_PROMPT_UNINSTALL_BUTTON))
+                       .SetId(extensions::ExtensionUninstallDialog::
+                                  kOkButtonElementId))
+      .AddCancelButton(
+          base::DoNothing(),
+          ui::DialogModel::Button::Params().SetId(
+              extensions::ExtensionUninstallDialog::kCancelButtonElementId));
+
+  if (triggering_extension()) {
+    dialog_builder.AddParagraph(
+        ui::DialogModelLabel(
+            l10n_util::GetStringFUTF16(
+                IDS_EXTENSION_PROMPT_UNINSTALL_TRIGGERED_BY_EXTENSION,
+                extensions::util::GetFixupExtensionNameForUIDisplay(
+                    triggering_extension()->name())))
+            .set_is_secondary()
+            .set_allow_character_break());
+  }
+
+  if (ShouldShowCheckbox()) {
+    std::u16string checkbox_label =
+        triggering_extension()
+            ? l10n_util::GetStringFUTF16(
+                  IDS_EXTENSION_PROMPT_UNINSTALL_REPORT_ABUSE_FROM_EXTENSION,
+                  extensions::util::GetFixupExtensionNameForUIDisplay(
+                      extension()->name()))
+            : l10n_util::GetStringUTF16(
+                  IDS_EXTENSION_PROMPT_UNINSTALL_REPORT_ABUSE);
+    dialog_builder.AddCheckbox(kCheckboxId,
+                               ui::DialogModelLabel(checkbox_label));
+  }
+
+  std::unique_ptr<ui::DialogModel> dialog_model = dialog_builder.Build();
+  dialog_model_ = dialog_model.get();
+  ShowDialog(parent(), extension()->id(), std::move(dialog_model));
+  return true;
+}
+
+void CbfExtensionUninstallDialog::DialogAccepted() {
+  DCHECK(dialog_model_);
+  report_abuse_ =
+      ShouldShowCheckbox() &&
+      dialog_model_->GetCheckboxByUniqueId(kCheckboxId)->is_checked();
+  last_close_action_ =
+      report_abuse_
+          ? extensions::ExtensionUninstallDialog::
+                CLOSE_ACTION_UNINSTALL_AND_CHECKBOX_CHECKED
+          : extensions::ExtensionUninstallDialog::CLOSE_ACTION_UNINSTALL;
+  dialog_model_ = nullptr;
+  closed_ = true;
+  OnDialogClosed(*last_close_action_);
+}
+
+void CbfExtensionUninstallDialog::DialogClosing() {
+  if (!dialog_model_) {
+    return;
+  }
+  report_abuse_ = false;
+  last_close_action_ = extensions::ExtensionUninstallDialog::CLOSE_ACTION_CANCELED;
+  dialog_model_ = nullptr;
+  closed_ = true;
+  OnDialogClosed(*last_close_action_);
+}
+
