   enum class ShutdownState {
@@ -78,6 +82,7 @@ class CbfBrowserService final : public mojom::CbfBrowserService {
   void RebuildProfileCache();
   ::Profile* ResolveProfile(const std::string& profile_id,
                             std::string* resolved_id);
+  void OnHostDisconnected();
 
   std::string expected_token_;
   bool authenticated_ = false;
@@ -91,8 +96,10 @@ class CbfBrowserService final : public mojom::CbfBrowserService {
   bool shutdown_start_task_pending_ = false;
   base::flat_map<std::string, std::unique_ptr<CbfProfileService>>
       profile_services_;
