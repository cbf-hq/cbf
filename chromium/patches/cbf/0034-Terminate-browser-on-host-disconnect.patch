diff --git a/chrome/browser/cbf/cbf_browser_service_unittest.cc b/chrome/browser/cbf/cbf_browser_service_unittest.cc
index 6b7a8fd6c3bfa..4692975988288 100644
--- a/chrome/browser/cbf/cbf_browser_service_unittest.cc
+++ b/chrome/browser/cbf/cbf_browser_service_unittest.cc
@@ -6,6 +6,7 @@
 
 #include "base/functional/bind.h"
 #include "base/test/task_environment.h"
+#include "mojo/public/cpp/bindings/remote.h"
 #include "testing/gtest/include/gtest/gtest.h"
 
 namespace cbf {
@@ -56,6 +57,45 @@ TEST_F(CbfBrowserServiceTest, AcceptsMatchingToken) {
   EXPECT_TRUE(authenticated);
 }
 
+TEST_F(CbfBrowserServiceTest,
+       HostDisconnectBeforeAuthenticationDoesNotForceShutdown) {
+  CbfBrowserService service("expected-token");
+  int disconnect_count = 0;
+  service.SetHostDisconnectCallbackForTesting(base::BindRepeating(
+      [](int* disconnect_count) { ++*disconnect_count; }, &disconnect_count));
+
+  mojo::Remote<mojom::CbfBrowserService> remote;
+  service.BindReceiver(remote.BindNewPipeAndPassReceiver());
+  remote.reset();
+  task_environment_.RunUntilIdle();
+
+  EXPECT_EQ(disconnect_count, 0);
+}
+
+TEST_F(CbfBrowserServiceTest,
+       HostDisconnectAfterAuthenticationForcesShutdownWithoutUnloadHandlers) {
+  CbfBrowserService service("expected-token");
+  int disconnect_count = 0;
+  service.SetHostDisconnectCallbackForTesting(base::BindRepeating(
+      [](int* disconnect_count) { ++*disconnect_count; }, &disconnect_count));
+
+  mojo::Remote<mojom::CbfBrowserService> remote;
+  service.BindReceiver(remote.BindNewPipeAndPassReceiver());
+
+  bool authenticated = false;
+  remote->Authenticate(
+      "expected-token",
+      base::BindOnce([](bool* authenticated, bool ok) { *authenticated = ok; },
+                     &authenticated));
+  task_environment_.RunUntilIdle();
+  ASSERT_TRUE(authenticated);
+
+  remote.reset();
+  task_environment_.RunUntilIdle();
+
+  EXPECT_EQ(disconnect_count, 1);
+}
+
 TEST_F(CbfBrowserServiceTest, UnauthenticatedGetProfilesReturnsEmptyList) {
   CbfBrowserService service("expected-token");
 
