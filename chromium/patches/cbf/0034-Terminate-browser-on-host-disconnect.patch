 5 files changed, 74 insertions(+), 5 deletions(-)

diff --git a/chrome/browser/cbf/cbf_browser_service.cc b/chrome/browser/cbf/cbf_browser_service.cc
index ba840503f3805..c5eb950cd496e 100644
--- a/chrome/browser/cbf/cbf_browser_service.cc
+++ b/chrome/browser/cbf/cbf_browser_service.cc
@@ -33,6 +33,14 @@ void CbfBrowserService::Authenticate(const std::string& token,
   }
 }
 
+void CbfBrowserService::BindReceiver(
+    mojo::PendingReceiver<mojom::CbfBrowserService> receiver) {
+  receiver_ = std::make_unique<mojo::Receiver<mojom::CbfBrowserService>>(
+      this, std::move(receiver));
+  receiver_->set_disconnect_handler(base::BindOnce(
+      &CbfBrowserService::OnHostDisconnected, weak_factory_.GetWeakPtr()));
+}
+
 void CbfBrowserService::SetObserver(
     mojo::PendingRemote<mojom::CbfBrowserObserver> observer) {
   if (!authenticated_) { return; }
@@ -194,6 +202,11 @@ void CbfBrowserService::CancelShutdownForTesting(uint64_t request_id) {
   CancelShutdown(request_id);
 }
 
+void CbfBrowserService::SetHostDisconnectCallbackForTesting(
+    base::RepeatingClosure callback) {
+  on_host_disconnect_for_testing_ = std::move(callback);
+}
+
 void CbfBrowserService::NotifyTabClosed() {
   if (!shutdown_in_progress_) {
     return;
@@ -370,6 +383,19 @@ void CbfBrowserService::MaybeFinalizeShutdownRequest() {
   }
 }
 
+void CbfBrowserService::OnHostDisconnected() {
+  if (!authenticated_) {
+    return;
+  }
+
+  if (on_host_disconnect_for_testing_) {
+    on_host_disconnect_for_testing_.Run();
+    return;
+  }
+
+  chrome::ExitIgnoreUnloadHandlers();
+}
+
 bool CbfBrowserService::HasOpenWebPages() const {
   for (const auto& entry : profile_services_) {
     if (entry.second->GetTabCount() > 0) {
