 }
 
+extern "C" bool cbf_bridge_client_set_tab_visibility(
+    CbfBridgeClientHandle* client,
+    const uint64_t tab_id,
+    const uint8_t visibility) {
+  if (!client) {
+    return false;
+  }
+  return reinterpret_cast<cbf_bridge::internal::CbfBridgeClient*>(client)
+      ->SetTabVisibility(tab_id, visibility);
+}
