+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SetTabVisibilityUpdatesWebContentsVisibility) {
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+  EXPECT_EQ(web_contents->GetVisibility(), content::Visibility::VISIBLE);
+
+  profile_service_->SetTabVisibility(tab_id, mojom::CbfTabVisibility::kHidden);
+  base::RunLoop().RunUntilIdle();
+  EXPECT_EQ(web_contents->GetVisibility(), content::Visibility::HIDDEN);
+
+  profile_service_->SetTabVisibility(tab_id, mojom::CbfTabVisibility::kVisible);
+  base::RunLoop().RunUntilIdle();
+  EXPECT_EQ(web_contents->GetVisibility(), content::Visibility::VISIBLE);
+}
+
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       SetTabVisibilityRepeatedHideShowIsSafe) {
+  const TabId tab_id = CreatePage("about:blank");
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+
+  for (int i = 0; i < 3; ++i) {
+    profile_service_->SetTabVisibility(tab_id, mojom::CbfTabVisibility::kHidden);
+    base::RunLoop().RunUntilIdle();
+    EXPECT_EQ(web_contents->GetVisibility(), content::Visibility::HIDDEN);
+
+    profile_service_->SetTabVisibility(tab_id,
+                                       mojom::CbfTabVisibility::kVisible);
+    base::RunLoop().RunUntilIdle();
+    EXPECT_EQ(web_contents->GetVisibility(), content::Visibility::VISIBLE);
+  }
 }
 
