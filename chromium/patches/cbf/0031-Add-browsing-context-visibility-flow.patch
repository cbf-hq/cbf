+void CbfProfileNavigationController::SetTabVisibility(
+    TabId tab_id,
+    mojom::CbfTabVisibility visibility) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  switch (visibility) {
+    case mojom::CbfTabVisibility::kVisible:
+      web_contents->UpdateWebContentsVisibility(content::Visibility::VISIBLE);
+      break;
+    case mojom::CbfTabVisibility::kHidden:
+      web_contents->UpdateWebContentsVisibility(content::Visibility::HIDDEN);
+      break;
+  }
+}
