+bool CbfBridgeClient::SetTabVisibility(const uint64_t tab_id,
+                                       const uint8_t visibility) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, const uint64_t tab_id,
+             const uint8_t visibility) {
+            if (!impl->browser_remote.is_bound()) {
+              return;
+            }
+            auto it = impl->web_page_profiles.find(tab_id);
+            if (it == impl->web_page_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              return;
+            }
+
+            cbf::mojom::CbfTabVisibility mojo_visibility =
+                cbf::mojom::CbfTabVisibility::kVisible;
+            switch (visibility) {
+              case kCbfTabVisibilityVisible:
+                mojo_visibility = cbf::mojom::CbfTabVisibility::kVisible;
+                break;
+              case kCbfTabVisibilityHidden:
+                mojo_visibility = cbf::mojom::CbfTabVisibility::kHidden;
+                break;
+              default:
+                return;
+            }
+
+            remote_it->second.remote->SetTabVisibility(tab_id, mojo_visibility);
+          },
+          impl, tab_id, visibility));
+  return true;
+}
+
 bool CbfBridgeClient::RequestCloseTab(const uint64_t tab_id) {
   if (!impl_) {
     return false;
@@ -1043,6 +1092,17 @@ extern "C" bool cbf_bridge_client_set_tab_focus(
