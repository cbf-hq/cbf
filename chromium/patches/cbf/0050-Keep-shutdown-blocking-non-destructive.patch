+void CbfBrowserService::BeginShutdownProceeding(uint64_t request_id) {
+  shutdown_state_ = ShutdownState::kProceeding;
+  shutdown_in_progress_ = true;
+  shutdown_exit_requested_ = false;
+  active_shutdown_target_.reset();
+  blocked_shutdown_target_.reset();
+  blocked_beforeunload_request_id_.reset();
+
+  if (observer_) {
+    observer_->OnShutdownProceeding(request_id);
+  }
+
+  if (on_start_shutdown_for_testing_) {
+    on_start_shutdown_for_testing_.Run(request_id);
+    return;
+  }
+
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&CbfBrowserService::FinishShutdownClosePhase,
+                     weak_factory_.GetWeakPtr()));
+}
+
+void CbfBrowserService::FinishShutdownClosePhase() {
+  if (!shutdown_in_progress_ || shutdown_state_ != ShutdownState::kProceeding) {
+    return;
+  }
+
+  for (const ShutdownTarget& target : shutdown_targets_) {
+    auto service_it = profile_services_.find(target.profile_id);
+    if (service_it == profile_services_.end()) {
+      continue;
+    }
+
+    content::WebContents* web_contents =
+        service_it->second->GetWebContentsForTab(target.tab_id);
+    if (!web_contents) {
+      continue;
+    }
+    service_it->second->CloseWebContents(web_contents);
+  }
+
+  if (!HasOpenWebPages()) {
+    AttemptExitAfterShutdown();
+  }
+}
