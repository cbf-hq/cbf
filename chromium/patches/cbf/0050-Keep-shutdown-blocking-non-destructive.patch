+std::vector<TabId> CbfBrowserService::CollectDirtyTabIds() const {
+  std::vector<TabId> dirty_tab_ids;
+  for (const auto& entry : profile_services_) {
+    const std::vector<TabId> profile_dirty_ids = entry.second->GetDirtyTabIds();
+    dirty_tab_ids.insert(dirty_tab_ids.end(), profile_dirty_ids.begin(),
+                         profile_dirty_ids.end());
+  }
+  return dirty_tab_ids;
+}
+
+std::vector<CbfBrowserService::ShutdownTarget>
+CbfBrowserService::CollectShutdownTargets() const {
+  std::vector<ShutdownTarget> targets;
+  for (const auto& [profile_id, service] : profile_services_) {
+    const std::vector<TabId> tab_ids = service->GetAllTabIds();
+    for (const TabId tab_id : tab_ids) {
+      targets.push_back({profile_id, tab_id});
+    }
+  }
+  return targets;
+}
+
+void CbfBrowserService::CloseConfirmedShutdownTargets() {
+  if (!shutdown_in_progress_ || shutdown_state_ != ShutdownState::kProceeding) {
+    return;
+  }
+
+  for (const ShutdownTarget& target : shutdown_targets_) {
+    auto service_it = profile_services_.find(target.profile_id);
+    if (service_it == profile_services_.end()) {
+      continue;
+    }
+
+    if (shutdown_dirty_tab_ids_.contains(target.tab_id)) {
+      service_it->second->RequestCloseTab(target.tab_id);
+      continue;
+    }
+
+    content::WebContents* web_contents =
+        service_it->second->GetWebContentsForTab(target.tab_id);
+    if (!web_contents) {
+      continue;
+    }
+
+    service_it->second->CloseWebContents(web_contents);
+  }
+
+  if (!HasOpenWebPages()) {
+    AttemptExitAfterShutdown();
+  }
+}
+
+void CbfBrowserService::AbortProceedingShutdown() {
+  if (!shutdown_in_progress_ || shutdown_state_ != ShutdownState::kProceeding) {
+    return;
+  }
+
+  const std::optional<uint64_t> request_id = shutdown_request_id_;
+  for (const auto& entry : profile_services_) {
+    entry.second->SetShutdownDialogAutoConfirm(false);
+  }
+
+  shutdown_dirty_tab_ids_.clear();
+  shutdown_targets_.clear();
+  blocked_dirty_tab_ids_.clear();
+  shutdown_in_progress_ = false;
+  shutdown_exit_requested_ = false;
+  shutdown_state_ = ShutdownState::kIdle;
+  shutdown_request_id_.reset();
+
+  if (observer_ && request_id.has_value()) {
+    observer_->OnShutdownCancelled(request_id.value());
+  }
+}
+
+void CbfBrowserService::AttemptExitAfterShutdown() {
+  if (shutdown_exit_requested_) {
+    return;
+  }
+  shutdown_exit_requested_ = true;
+  if (on_attempt_exit_for_testing_) {
+    on_attempt_exit_for_testing_.Run();
+    return;
+  }
+  chrome::AttemptExit();
+}
