+  shutdown_targets_.clear();
+  current_shutdown_index_ = 0;
+  active_shutdown_target_.reset();
+  blocked_shutdown_target_.reset();
+  blocked_beforeunload_request_id_.reset();
+  shutdown_state_ = ShutdownState::kIdle;
+  shutdown_request_id_.reset();
+  shutdown_in_progress_ = false;
+  shutdown_exit_requested_ = false;
   if (observer_) {
-    std::vector<uint64_t> blocked_ids(beforeunload_dialog_pages_.begin(),
-                                      beforeunload_dialog_pages_.end());
-    observer_->OnShutdownBlocked(shutdown_request_id_.value(), blocked_ids);
+    observer_->OnShutdownCancelled(request_id);
   }
 }

+void CbfBrowserService::ResetShutdownBrowsers() {
+  std::set<Browser*> reset_browsers;
+  for (const ShutdownTarget& target : shutdown_targets_) {
+    Browser* browser = ResolveBrowserForShutdownTarget(target);
+    if (!browser || !reset_browsers.insert(browser).second) {
+      continue;
+    }
+    browser->ResetTryToCloseWindow();
+  }
+}
+
+std::vector<CbfBrowserService::ShutdownTarget>
+CbfBrowserService::CollectShutdownTargets() const {
+  std::vector<ShutdownTarget> targets;
+  for (const auto& [profile_id, service] : profile_services_) {
+    const std::vector<TabId> tab_ids = service->GetAllTabIds();
+    for (const TabId tab_id : tab_ids) {
+      targets.push_back({profile_id, tab_id});
+    }
+  }
+  return targets;
+}
+
+Browser* CbfBrowserService::ResolveBrowserForShutdownTarget(
+    const ShutdownTarget& target) const {
+  auto service_it = profile_services_.find(target.profile_id);
+  if (service_it == profile_services_.end()) {
+    return nullptr;
+  }
+  return service_it->second->GetBrowserForTab(target.tab_id);
+}
+
+bool CbfBrowserService::ResolveBlockedBeforeUnloadRequest(
+    CbfProfileService** out_service,
+    uint64_t* out_request_id) {
+  if (!blocked_shutdown_target_ || !blocked_beforeunload_request_id_) {
+    return false;
+  }
+
+  auto service_it = profile_services_.find(blocked_shutdown_target_->profile_id);
+  if (service_it == profile_services_.end()) {
+    return false;
+  }
+
+  if (out_service) {
+    *out_service = service_it->second.get();
+  }
+  if (out_request_id) {
+    *out_request_id = blocked_beforeunload_request_id_.value();
+  }
+  return true;
+}
