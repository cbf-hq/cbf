+CbfChoiceMenuItemList ToCbfChoiceMenuItems(
+    const std::vector<cbf::mojom::CbfChoiceMenuItemPtr>& items);
+
+void FillCbfChoiceMenuItem(const cbf::mojom::CbfChoiceMenuItemPtr& item,
+                           CbfChoiceMenuItem* out_item) {
+  if (!out_item) {
+    return;
+  }
+  *out_item = {};
+  if (!item) {
+    return;
+  }
+
+  out_item->type_ = static_cast<uint8_t>(item->type);
+  if (item->label.has_value()) {
+    out_item->label = CopyCString(item->label.value());
+  }
+  if (item->tool_tip.has_value()) {
+    out_item->tool_tip = CopyCString(item->tool_tip.value());
+  }
+  out_item->action = item->action;
+  out_item->text_direction = static_cast<uint8_t>(item->text_direction);
+  out_item->has_text_direction_override = item->has_text_direction_override;
+  out_item->enabled = item->enabled;
+  out_item->checked = item->checked;
+  out_item->children = ToCbfChoiceMenuItems(item->children);
+}
+
+CbfChoiceMenuItemList ToCbfChoiceMenuItems(
+    const std::vector<cbf::mojom::CbfChoiceMenuItemPtr>& items) {
+  CbfChoiceMenuItemList out = {};
+  if (items.empty()) {
+    return out;
+  }
+  CbfChoiceMenuItem* out_items = new CbfChoiceMenuItem[items.size()];
+  auto out_span = UNSAFE_BUFFERS(base::span(out_items, items.size()));
+  for (size_t i = 0; i < out_span.size(); ++i) {
+    FillCbfChoiceMenuItem(items[i], &out_span[i]);
+  }
+  out.items = out_items;
+  out.len = static_cast<uint32_t>(items.size());
+  return out;
+}
+
+void FillChoiceMenu(const cbf::mojom::CbfChoiceMenuPtr& menu,
+                    CbfChoiceMenu* out_menu) {
+  if (!out_menu) {
+    return;
+  }
+  *out_menu = {};
+  if (!menu) {
+    return;
+  }
+  out_menu->request_id = menu->request_id;
+  out_menu->x = menu->bounds.x();
+  out_menu->y = menu->bounds.y();
+  out_menu->width = menu->bounds.width();
+  out_menu->height = menu->bounds.height();
+  out_menu->item_font_size = menu->item_font_size;
+  out_menu->selected_item = menu->selected_item;
+  out_menu->right_aligned = menu->right_aligned;
+  out_menu->allow_multiple_selection = menu->allow_multiple_selection;
+  out_menu->items = ToCbfChoiceMenuItems(menu->items);
+}
