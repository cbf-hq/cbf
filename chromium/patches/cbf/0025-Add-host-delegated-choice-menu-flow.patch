+#include "chrome/browser/cbf/profile/cbf_profile_choice_menu_controller.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "chrome/browser/cbf/profile/cbf_profile_service_context.h"
+#include "third_party/blink/public/mojom/choosers/popup_menu.mojom.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace cbf {
+
+namespace {
+
+mojom::CbfChoiceMenuItemType ToCbfChoiceMenuItemType(
+    blink::mojom::MenuItem::Type type) {
+  switch (type) {
+    case blink::mojom::MenuItem::Type::kOption:
+      return mojom::CbfChoiceMenuItemType::kOption;
+    case blink::mojom::MenuItem::Type::kCheckableOption:
+      return mojom::CbfChoiceMenuItemType::kCheckableOption;
+    case blink::mojom::MenuItem::Type::kGroup:
+      return mojom::CbfChoiceMenuItemType::kGroup;
+    case blink::mojom::MenuItem::Type::kSeparator:
+      return mojom::CbfChoiceMenuItemType::kSeparator;
+    case blink::mojom::MenuItem::Type::kSubMenu:
+      return mojom::CbfChoiceMenuItemType::kSubMenu;
+  }
+}
+
+std::vector<mojom::CbfChoiceMenuItemPtr> BuildChoiceMenuItems(
+    std::vector<blink::mojom::MenuItemPtr> items) {
+  std::vector<mojom::CbfChoiceMenuItemPtr> out;
+  out.reserve(items.size());
+  for (auto& item : items) {
+    if (!item) {
+      continue;
+    }
+    auto converted = mojom::CbfChoiceMenuItem::New();
+    converted->label = item->label;
+    converted->tool_tip = item->tool_tip;
+    converted->type = ToCbfChoiceMenuItemType(item->type);
+    converted->action = item->action;
+    converted->text_direction = item->text_direction;
+    converted->has_text_direction_override = item->has_text_direction_override;
+    converted->enabled = item->enabled;
+    converted->checked = item->checked;
+    converted->children.clear();
+    out.push_back(std::move(converted));
+  }
+  return out;
+}
+
+}  // namespace
+
+CbfProfileChoiceMenuController::PendingChoiceMenuEntry::PendingChoiceMenuEntry() =
+    default;
+CbfProfileChoiceMenuController::PendingChoiceMenuEntry::PendingChoiceMenuEntry(
+    PendingChoiceMenuEntry&&) = default;
+CbfProfileChoiceMenuController::PendingChoiceMenuEntry&
+CbfProfileChoiceMenuController::PendingChoiceMenuEntry::operator=(
+    PendingChoiceMenuEntry&&) = default;
+CbfProfileChoiceMenuController::PendingChoiceMenuEntry::~PendingChoiceMenuEntry() =
+    default;
+
+CbfProfileChoiceMenuController::CbfProfileChoiceMenuController(
+    CbfProfileServiceContext* context)
+    : context_(context) {}
+
+CbfProfileChoiceMenuController::~CbfProfileChoiceMenuController() = default;
+
+bool CbfProfileChoiceMenuController::HandleChoiceMenu(
+    TabId tab_id,
+    content::WebContents* web_contents,
+    content::RenderFrameHost& render_frame_host,
+    mojo::PendingRemote<blink::mojom::PopupMenuClient> popup_client,
+    const gfx::Rect& bounds,
+    double item_font_size,
+    int32_t selected_item,
+    std::vector<blink::mojom::MenuItemPtr> menu_items,
+    bool right_aligned,
+    bool allow_multiple_selection,
+    std::optional<uint64_t> popup_id) {
+  if (!web_contents) {
+    return false;
+  }
+
+  if (tab_id == kInvalidTabId) {
+    mojo::Remote<blink::mojom::PopupMenuClient> popup_client_remote(
+        std::move(popup_client));
+    if (popup_client_remote.is_bound()) {
+      popup_client_remote->DidCancel();
+    }
+    return true;
+  }
+
+  mojo::Remote<blink::mojom::PopupMenuClient> popup_client_remote(
+      std::move(popup_client));
+  const uint64_t request_id = next_request_id_++;
+
+  auto payload = BuildChoiceMenuPayload(request_id, bounds, item_font_size,
+                                        selected_item, std::move(menu_items),
+                                        right_aligned, allow_multiple_selection);
+  auto& observer = context_->observer_remote();
+  if (!observer.is_bound() || !payload) {
+    if (popup_client_remote.is_bound()) {
+      popup_client_remote->DidCancel();
+    }
+    return true;
+  }
+
+  PendingChoiceMenuEntry entry;
+  entry.tab_id = tab_id;
+  entry.popup_id = popup_id;
+  entry.popup_client = std::move(popup_client_remote);
+  entry.popup_client.set_disconnect_handler(base::BindOnce(
+      &CbfProfileChoiceMenuController::RemovePendingEntry,
+      weak_factory_.GetWeakPtr(), request_id));
+  pending_choice_menus_[request_id] = std::move(entry);
+
+  if (popup_id.has_value()) {
+    observer->OnExtensionPopupChoiceMenuRequested(tab_id, *popup_id, request_id,
+                                                  std::move(payload));
+  } else {
+    observer->OnChoiceMenuRequested(tab_id, request_id, std::move(payload));
+  }
+  return true;
+}
+
+void CbfProfileChoiceMenuController::AcceptChoiceMenuSelection(
+    uint64_t request_id,
+    const std::vector<int32_t>& indices) {
+  auto it = pending_choice_menus_.find(request_id);
+  if (it == pending_choice_menus_.end()) {
+    return;
+  }
+  if (it->second.popup_client.is_bound()) {
+    it->second.popup_client->DidAcceptIndices(indices);
+  }
+  pending_choice_menus_.erase(it);
+}
+
+void CbfProfileChoiceMenuController::DismissChoiceMenu(uint64_t request_id) {
+  auto it = pending_choice_menus_.find(request_id);
+  if (it == pending_choice_menus_.end()) {
+    return;
+  }
+  if (it->second.popup_client.is_bound()) {
+    it->second.popup_client->DidCancel();
+  }
+  pending_choice_menus_.erase(it);
+}
+
+void CbfProfileChoiceMenuController::OnTabClosed(TabId tab_id) {
+  for (auto it = pending_choice_menus_.begin(); it != pending_choice_menus_.end();) {
+    if (it->second.tab_id == tab_id && !it->second.popup_id.has_value()) {
+      if (it->second.popup_client.is_bound()) {
+        it->second.popup_client->DidCancel();
+      }
+      it = pending_choice_menus_.erase(it);
+      continue;
+    }
+    ++it;
+  }
+}
+
+void CbfProfileChoiceMenuController::OnExtensionPopupClosed(uint64_t popup_id) {
+  for (auto it = pending_choice_menus_.begin(); it != pending_choice_menus_.end();) {
+    if (it->second.popup_id == popup_id) {
+      if (it->second.popup_client.is_bound()) {
+        it->second.popup_client->DidCancel();
+      }
+      it = pending_choice_menus_.erase(it);
+      continue;
+    }
+    ++it;
+  }
+}
+
+void CbfProfileChoiceMenuController::RemovePendingEntry(uint64_t request_id) {
+  pending_choice_menus_.erase(request_id);
+}
+
+mojom::CbfChoiceMenuPtr CbfProfileChoiceMenuController::BuildChoiceMenuPayload(
+    uint64_t request_id,
+    const gfx::Rect& bounds,
+    double item_font_size,
+    int32_t selected_item,
+    std::vector<blink::mojom::MenuItemPtr> menu_items,
+    bool right_aligned,
+    bool allow_multiple_selection) {
+  auto payload = mojom::CbfChoiceMenu::New();
+  payload->request_id = request_id;
+  payload->bounds = bounds;
+  payload->item_font_size = item_font_size;
+  payload->selected_item = selected_item;
+  payload->right_aligned = right_aligned;
+  payload->allow_multiple_selection = allow_multiple_selection;
+  payload->items = BuildChoiceMenuItems(std::move(menu_items));
+  return payload;
+}
+
+}  // namespace cbf
