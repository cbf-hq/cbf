+bool CbfBridgeClient::AcceptChoiceMenuSelection(
+    uint64_t request_id,
+    const CbfChoiceMenuSelectedIndices* indices) {
+  if (!impl_ || !indices) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  std::vector<int32_t> selection;
+  if (indices->len > 0 && indices->items) {
+    auto selected_indices =
+        UNSAFE_BUFFERS(base::span(indices->items, indices->len));
+    selection.assign(selected_indices.begin(), selected_indices.end());
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t request_id,
+             std::vector<int32_t> selection) {
+            auto profile_it = impl->choice_menu_profiles.find(request_id);
+            if (profile_it == impl->choice_menu_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(profile_it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              impl->choice_menu_profiles.erase(profile_it);
+              return;
+            }
+            remote_it->second.remote->AcceptChoiceMenuSelection(
+                request_id, selection);
+            impl->choice_menu_profiles.erase(profile_it);
+          },
+          impl, request_id, std::move(selection)));
+  return true;
+}
+
+bool CbfBridgeClient::DismissChoiceMenu(uint64_t request_id) {
+  if (!impl_) {
+    return false;
+  }
+  auto task_runner = GetMojoTaskRunner();
+  if (!task_runner) {
+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  if (!impl->browser_remote.is_bound()) {
+    return false;
+  }
+
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t request_id) {
+            auto profile_it = impl->choice_menu_profiles.find(request_id);
+            if (profile_it == impl->choice_menu_profiles.end()) {
+              return;
+            }
+            auto remote_it = impl->profile_connections.find(profile_it->second);
+            if (remote_it == impl->profile_connections.end()) {
+              impl->choice_menu_profiles.erase(profile_it);
+              return;
+            }
+            remote_it->second.remote->DismissChoiceMenu(request_id);
+            impl->choice_menu_profiles.erase(profile_it);
+          },
+          impl, request_id));
+  return true;
+}
