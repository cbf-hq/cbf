+tabs::TabInterface* CbfTabManager::ResolveTabInterfaceForTab(
+    TabId tab_id) const {
+  auto it = tabs_.find(tab_id);
+  if (it == tabs_.end()) {
+    return nullptr;
+  }
+
+  Browser* browser = it->second.browser.get();
+  if (!browser || !browser->tab_strip_model() ||
+      browser->tab_strip_model()->count() == 0) {
+    EraseTabRecord(tab_id);
+    return nullptr;
+  }
+
+  tabs::TabInterface* tab_interface =
+      browser->tab_strip_model()->GetActiveTab();
+  if (!tab_interface) {
+    EraseTabRecord(tab_id);
+    return nullptr;
+  }
+
+  content::WebContents* web_contents = tab_interface->GetContents();
+  if (!web_contents) {
+    EraseTabRecord(tab_id);
+    return nullptr;
+  }
+
+  RefreshReverseLookup(tab_id, web_contents, it->second.web_contents);
+  it->second.web_contents = web_contents;
+  it->second.tab_interface = tab_interface;
+  return tab_interface;
+}
+
+content::WebContents* CbfTabManager::ResolveWebContentsForTab(
+    TabId tab_id) const {
+  if (!ResolveTabInterfaceForTab(tab_id)) {
+    return nullptr;
+  }
+
+  auto it = tabs_.find(tab_id);
+  if (it == tabs_.end()) {
+    return nullptr;
+  }
+  return it->second.web_contents;
+}
+
+void CbfTabManager::RefreshReverseLookup(TabId tab_id,
+                                         content::WebContents* new_contents,
+                                         content::WebContents* old_contents)
+    const {
+  if (old_contents && old_contents != new_contents) {
+    auto it = reverse_lookup_.find(old_contents);
+    if (it != reverse_lookup_.end() && it->second == tab_id) {
+      reverse_lookup_.erase(it);
+    }
+  }
+
+  if (new_contents) {
+    reverse_lookup_[new_contents] = tab_id;
+  }
+}
+
+void CbfTabManager::EraseTabRecord(TabId tab_id) const {
+  auto it = tabs_.find(tab_id);
+  if (it == tabs_.end()) {
+    return;
+  }
+
+  if (it->second.web_contents) {
+    auto reverse_it = reverse_lookup_.find(it->second.web_contents);
+    if (reverse_it != reverse_lookup_.end() && reverse_it->second == tab_id) {
+      reverse_lookup_.erase(reverse_it);
+    }
+  }
+
+  tabs_.erase(it);
+}
+
 }  // namespace cbf
