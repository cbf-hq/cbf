+std::optional<base::FilePath> ResolveExtensionIconPath(
+    const extensions::Extension* extension) {
+  if (!extension) {
+    return std::nullopt;
+  }
+  const extensions::ExtensionResource icon_resource =
+      extensions::IconsInfo::GetIconResource(
+          extension, extension_misc::EXTENSION_ICON_LARGE,
+          ExtensionIconSet::Match::kBigger);
+  if (icon_resource.relative_path().empty()) {
+    return std::nullopt;
+  }
+
+  base::FilePath icon_path = extension->path().Append(icon_resource.relative_path());
+  if (!icon_path.MatchesExtension(FILE_PATH_LITERAL(".png"))) {
+    return std::nullopt;
+  }
+
+  return icon_path;
+}
+
+mojom::CbfIconDataPtr ReadExtensionIcon(const base::FilePath& icon_path) {
+  auto encoded = base::ReadFileToBytes(icon_path);
+  if (!encoded.has_value() || encoded->empty()) {
+    return nullptr;
+  }
+
+  auto icon = mojom::CbfIconData::New();
+  icon->kind = mojom::CbfIconDataKind::kPng;
+  icon->bytes = std::move(*encoded);
+  return icon;
+}
