+  scoped_refptr<const extensions::Extension> CreateTestExtensionWithOptionalIcon(
+      const std::string& name,
+      bool write_icon) {
+    base::ScopedAllowBlockingForTesting allow_blocking;
+    auto extension_dir = std::make_unique<base::ScopedTempDir>();
+    CHECK(extension_dir->CreateUniqueTempDir());
+
+    if (write_icon) {
+      SkBitmap bitmap;
+      bitmap.allocN32Pixels(24, 24);
+      bitmap.eraseColor(SK_ColorGREEN);
+      auto encoded = gfx::PNGCodec::EncodeBGRASkBitmap(
+          bitmap, /*discard_transparency=*/false);
+      CHECK(encoded.has_value());
+      CHECK(base::WriteFile(
+          extension_dir->GetPath().AppendASCII("icon.png"), *encoded));
+    }
+
+    extensions::ExtensionBuilder builder(name);
+    builder.SetPath(extension_dir->GetPath());
+    if (write_icon) {
+      base::DictValue icons;
+      icons.Set(base::NumberToString(extension_misc::EXTENSION_ICON_LARGE),
+                "icon.png");
+      builder.SetManifestKey("icons", std::move(icons));
+    }
+
+    auto extension = builder.Build();
+    extension_dirs_.push_back(std::move(extension_dir));
+    return extension;
+  }
