+CbfIconData ToCbfIconData(const cbf::mojom::CbfIconDataPtr& icon) {
+  CbfIconData out = {};
+  if (!icon) {
+    return out;
+  }
+
+  out.kind = static_cast<uint8_t>(icon->kind);
+  if (icon->url.has_value()) {
+    out.url = CopyCString(icon->url.value());
+  }
+  if (icon->media_type.has_value()) {
+    out.media_type = CopyCString(icon->media_type.value());
+  }
+  if (icon->bytes.has_value() && !icon->bytes->empty()) {
+    const size_t len = icon->bytes->size();
+    uint8_t* bytes = new uint8_t[len];
+    auto out_bytes = UNSAFE_BUFFERS(base::span(bytes, len));
+    for (size_t i = 0; i < out_bytes.size(); ++i) {
+      out_bytes[i] = icon->bytes.value()[i];
+    }
+    out.bytes = bytes;
+    out.len = static_cast<uint32_t>(len);
+  }
+  return out;
+}
