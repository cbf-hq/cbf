+void CbfCaContextIdObserver::NotifyNavigationStateChangedIfNeeded(
+    bool is_loading) {
+  if (!profile_service_ || !web_contents()) {
+    return;
+  }
+
+  content::NavigationController& controller = web_contents()->GetController();
+  NavigationStateSnapshot next_state{
+      .url = web_contents()->GetVisibleURL().spec(),
+      .can_go_back = controller.CanGoBack(),
+      .can_go_forward = controller.CanGoForward(),
+      .is_loading = is_loading,
+  };
+
+  if (last_navigation_state_.has_value() &&
+      last_navigation_state_->url == next_state.url &&
+      last_navigation_state_->can_go_back == next_state.can_go_back &&
+      last_navigation_state_->can_go_forward == next_state.can_go_forward &&
+      last_navigation_state_->is_loading == next_state.is_loading) {
+    return;
+  }
+
+  last_navigation_state_ = next_state;
+  profile_service_->NotifyNavigationStateChanged(web_contents(), is_loading);
+}
