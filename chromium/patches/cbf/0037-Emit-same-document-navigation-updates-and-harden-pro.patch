+IN_PROC_BROWSER_TEST_F(
+    CbfProfileServiceBrowserTest,
+    NavigationStateChangedEmitsForSameDocumentHistoryUpdates) {
+  embedded_test_server()->RegisterRequestHandler(base::BindRepeating(
+      [](const net::test_server::HttpRequest& request)
+          -> std::unique_ptr<net::test_server::HttpResponse> {
+        if (request.relative_url != "/cbf-nav-state-spa") {
+          return nullptr;
+        }
+        auto response = std::make_unique<net::test_server::BasicHttpResponse>();
+        response->set_code(net::HTTP_OK);
+        response->set_content_type("text/html");
+        response->set_content("<!doctype html><title>cbf-nav-state-spa</title>");
+        return response;
+      }));
+  ASSERT_TRUE(embedded_test_server()->Start());
+
+  const GURL initial_url = embedded_test_server()->GetURL("/cbf-nav-state-spa");
+  const TabId tab_id = CreatePage(initial_url.spec());
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  const size_t baseline_event_count =
+      observer_.navigation_state_changed_events().size();
+
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+  ASSERT_TRUE(content::ExecJs(web_contents, R"(
+    history.pushState({}, '', '/cbf-nav-state-spa-step1');
+  )"));
+  observer_.WaitForNavigationStateChangedCount(baseline_event_count + 1);
+
+  ASSERT_TRUE(content::ExecJs(web_contents, R"(
+    history.replaceState({}, '', '/cbf-nav-state-spa-step2');
+  )"));
+  observer_.WaitForNavigationStateChangedCount(baseline_event_count + 2);
+
+  ASSERT_TRUE(content::ExecJs(web_contents, R"(
+    history.back();
+  )"));
+  observer_.WaitForNavigationStateChangedCount(baseline_event_count + 3);
+
+  ASSERT_TRUE(content::ExecJs(web_contents, R"(
+    history.forward();
+  )"));
+  observer_.WaitForNavigationStateChangedCount(baseline_event_count + 4);
+
+  const auto& navigation_events = observer_.navigation_state_changed_events();
+  ASSERT_GE(navigation_events.size(), baseline_event_count + 4);
+
+  const auto& push_state_event = navigation_events[baseline_event_count];
+  EXPECT_EQ(push_state_event.tab_id, tab_id);
+  EXPECT_EQ(GURL(push_state_event.url).path(), "/cbf-nav-state-spa-step1");
+  EXPECT_TRUE(push_state_event.can_go_back);
+  EXPECT_FALSE(push_state_event.is_loading);
+
+  const auto& replace_state_event = navigation_events[baseline_event_count + 1];
+  EXPECT_EQ(replace_state_event.tab_id, tab_id);
+  EXPECT_EQ(GURL(replace_state_event.url).path(), "/cbf-nav-state-spa-step2");
+  EXPECT_TRUE(replace_state_event.can_go_back);
+  EXPECT_FALSE(replace_state_event.is_loading);
+
+  const auto& back_event = navigation_events[baseline_event_count + 2];
+  EXPECT_EQ(back_event.tab_id, tab_id);
+  EXPECT_EQ(GURL(back_event.url).path(), "/cbf-nav-state-spa");
+  EXPECT_TRUE(back_event.can_go_forward);
+  EXPECT_FALSE(back_event.is_loading);
+
+  const auto& forward_event = navigation_events[baseline_event_count + 3];
+  EXPECT_EQ(forward_event.tab_id, tab_id);
+  EXPECT_EQ(GURL(forward_event.url).path(), "/cbf-nav-state-spa-step2");
+  EXPECT_TRUE(forward_event.can_go_back);
+  EXPECT_FALSE(forward_event.is_loading);
+}
