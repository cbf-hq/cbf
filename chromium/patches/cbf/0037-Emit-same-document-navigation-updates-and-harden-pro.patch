+void CbfTestProfileObserver::WaitForNavigationStateChangedCount(
+    size_t expected_count) {
+  ResetWaitTargets();
+  wait_navigation_state_changed_count_ = expected_count;
+  if (navigation_state_changed_events_.size() >=
+      wait_navigation_state_changed_count_) {
+    return;
+  }
+  base::RunLoop loop;
+  quit_wait_loop_ = loop.QuitClosure();
+  loop.Run();
+  quit_wait_loop_.Reset();
+}
