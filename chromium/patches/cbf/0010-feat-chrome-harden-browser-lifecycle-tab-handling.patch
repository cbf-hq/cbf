From 91e9cdac122d52bedfd346c1c2c55ffbaae10964 Mon Sep 17 00:00:00 2001
From: Takagi Tasuku <tasuren@outlook.jp>
Date: Sat, 28 Feb 2026 11:20:04 +0900
Subject: [PATCH 10/11] feat(chrome): harden browser lifecycle tab handling

---
 chrome/browser/cbf/BUILD.gn                   |  4 ++++
 chrome/browser/cbf/cbf_browser_service.cc     |  9 +++++++++
 .../cbf/cbf_profile_service_browsertest.cc    | 19 +++++++++++++++++++
 .../browser/extensions/api/runtime/BUILD.gn   |  1 +
 4 files changed, 33 insertions(+)

diff --git a/chrome/browser/cbf/BUILD.gn b/chrome/browser/cbf/BUILD.gn
index db0de55a52c51..c7091dbbd8ec5 100644
--- a/chrome/browser/cbf/BUILD.gn
+++ b/chrome/browser/cbf/BUILD.gn
@@ -53,6 +53,10 @@ source_set("cbf") {
   # bridging. Keep dependency surface explicit in deps while skipping include
   # layering checks for this integration target.
   check_includes = false
+  allow_circular_includes_from = [
+    "//chrome/browser/devtools",
+    "//chrome/browser/extensions",
+  ]
 
   if (is_mac) {
     sources += [
diff --git a/chrome/browser/cbf/cbf_browser_service.cc b/chrome/browser/cbf/cbf_browser_service.cc
index e1bf43758771b..9cbff5473b960 100644
--- a/chrome/browser/cbf/cbf_browser_service.cc
+++ b/chrome/browser/cbf/cbf_browser_service.cc
@@ -201,6 +201,9 @@ bool CbfBrowserService::IsManagedWebContents(
 
 void CbfBrowserService::NotifyBeforeUnloadDialogRequested(
     TabId tab_id) {
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
   if (shutdown_state_ != ShutdownState::kWaitingBeforeUnload &&
       shutdown_state_ != ShutdownState::kBlocked) {
     return;
@@ -211,6 +214,9 @@ void CbfBrowserService::NotifyBeforeUnloadDialogRequested(
 
 void CbfBrowserService::NotifyBeforeUnloadFired(TabId tab_id,
                                                 bool proceed) {
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
   if (shutdown_state_ == ShutdownState::kWaitingBeforeUnload) {
     MarkBeforeUnloadDispatchComplete(tab_id);
     return;
@@ -241,6 +247,9 @@ CbfProfileService* CbfBrowserService::GetProfileServiceForProfile(
 
 void CbfBrowserService::MarkBeforeUnloadDispatchComplete(
     TabId tab_id) {
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
   const auto it = pending_beforeunload_pages_.find(tab_id);
   if (it == pending_beforeunload_pages_.end()) {
     return;
diff --git a/chrome/browser/cbf/cbf_profile_service_browsertest.cc b/chrome/browser/cbf/cbf_profile_service_browsertest.cc
index 1b815c419088b..732521ff0c65b 100644
--- a/chrome/browser/cbf/cbf_profile_service_browsertest.cc
+++ b/chrome/browser/cbf/cbf_profile_service_browsertest.cc
@@ -30,6 +30,7 @@ IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest, InvalidRequestsAreSafeNoOp)
   profile_service_->RequestCloseWebPage(kInvalidTabId);
   profile_service_->SendDragCancel(9999, kInvalidTabId);
   profile_service_->OpenDevTools(kInvalidTabId);
+  profile_service_->Navigate(kInvalidTabId, "about:blank");
 }
 
 IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
@@ -52,5 +53,23 @@ IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
   EXPECT_EQ(observer_.web_page_closed_events().front(), created_id);
 }
 
+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest, DuplicateCloseRequestIsSafe) {
+  TabId created_id = kInvalidTabId;
+  base::RunLoop run_loop;
+  profile_service_->CreateWebPage(
+      "about:blank", 1,
+      base::BindOnce(
+          [](TabId* out_id, base::RunLoop* run_loop, TabId tab_id) {
+            *out_id = tab_id;
+            run_loop->Quit();
+          },
+          &created_id, &run_loop));
+  run_loop.Run();
+  ASSERT_NE(created_id, kInvalidTabId);
+
+  profile_service_->RequestCloseWebPage(created_id);
+  profile_service_->RequestCloseWebPage(created_id);
+}
+
 }  // namespace
 }  // namespace cbf
diff --git a/chrome/browser/extensions/api/runtime/BUILD.gn b/chrome/browser/extensions/api/runtime/BUILD.gn
index 9311af3d4cedb..939b559cd6fd0 100644
--- a/chrome/browser/extensions/api/runtime/BUILD.gn
+++ b/chrome/browser/extensions/api/runtime/BUILD.gn
@@ -23,6 +23,7 @@ source_set("runtime") {
 
   deps = [
     "//build:chromeos_buildflags",
+    "//chrome/browser/cbf",
     "//chrome/browser/devtools",
     "//chrome/browser/extensions",
     "//chrome/browser/profiles:profile",
