+
+void CbfProfileService::OnManagerGoingDown(
+    download::SimpleDownloadManagerCoordinator* manager) {
+  if (manager == download_coordinator_) {
+    download_guid_to_id_.clear();
+    active_downloads_.clear();
+  }
+}
+
+void CbfProfileService::OnDownloadCreated(
+    download::SimpleDownloadManagerCoordinator* manager,
+    download::DownloadItem* item) {
+  (void)manager;
+  OnDownloadUpdated(manager, item);
+}
+
+void CbfProfileService::OnDownloadUpdated(
+    download::SimpleDownloadManagerCoordinator* manager,
+    download::DownloadItem* item) {
+  (void)manager;
+  if (!item) {
+    return;
+  }
+  auto id_it = download_guid_to_id_.find(item->GetGuid());
+  if (id_it == download_guid_to_id_.end()) {
+    return;
+  }
+  auto active_it = active_downloads_.find(id_it->second);
+  if (active_it == active_downloads_.end()) {
+    return;
+  }
+
+  if (!active_it->second.created_notified) {
+    NotifyDownloadCreated(item, active_it->second);
+    active_it->second.created_notified = true;
+  }
+
+  if (item->GetState() == download::DownloadItem::IN_PROGRESS) {
+    NotifyDownloadUpdated(item, active_it->second);
+    return;
+  }
+
+  NotifyDownloadCompleted(item, active_it->second);
+  download_guid_to_id_.erase(active_it->second.guid);
+  active_downloads_.erase(active_it);
+}
+
+void CbfProfileService::OnDownloadOpened(
+    download::SimpleDownloadManagerCoordinator* manager,
+    download::DownloadItem* item) {
+  (void)manager;
+  (void)item;
+}
+
+void CbfProfileService::OnDownloadRemoved(
+    download::SimpleDownloadManagerCoordinator* manager,
+    download::DownloadItem* item) {
+  (void)manager;
+  if (!item) {
+    return;
+  }
+  auto id_it = download_guid_to_id_.find(item->GetGuid());
+  if (id_it == download_guid_to_id_.end()) {
+    return;
+  }
+  active_downloads_.erase(id_it->second);
+  download_guid_to_id_.erase(id_it);
+}
