+void CbfBridgeClientImpl::Observer::OnDownloadCreated(
+    cbf::mojom::CbfDownloadCreatedPtr event_data) {
+  if (!event_data) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventDownloadCreated;
+  event.profile_id = profile_id_;
+  event.download_id = event_data->download_id;
+  if (event_data->source_tab_id.has_value()) {
+    event.download_has_source_tab_id = true;
+    event.download_source_tab_id = event_data->source_tab_id.value();
+  }
+  event.download_file_name = event_data->file_name;
+  if (event_data->total_bytes.has_value()) {
+    event.download_has_total_bytes = true;
+    event.download_total_bytes = event_data->total_bytes.value();
+  }
+  if (event_data->target_path.has_value()) {
+    event.download_target_path = event_data->target_path.value();
+  }
+  {
+    std::lock_guard<std::mutex> lock(impl_->events_mutex);
+    impl_->download_profiles[event.download_id] = profile_id_;
+    impl_->events.push(std::move(event));
+  }
+}
+
+void CbfBridgeClientImpl::Observer::OnDownloadUpdated(
+    cbf::mojom::CbfDownloadUpdatedPtr event_data) {
+  if (!event_data) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventDownloadUpdated;
+  event.profile_id = profile_id_;
+  event.download_id = event_data->download_id;
+  if (event_data->source_tab_id.has_value()) {
+    event.download_has_source_tab_id = true;
+    event.download_source_tab_id = event_data->source_tab_id.value();
+  }
+  event.download_file_name = event_data->file_name;
+  event.download_received_bytes = event_data->received_bytes;
+  if (event_data->total_bytes.has_value()) {
+    event.download_has_total_bytes = true;
+    event.download_total_bytes = event_data->total_bytes.value();
+  }
+  if (event_data->target_path.has_value()) {
+    event.download_target_path = event_data->target_path.value();
+  }
+  event.download_can_resume = event_data->can_resume;
+  event.download_is_paused = event_data->is_paused;
+  event.download_state = static_cast<uint8_t>(event_data->state);
+  {
+    std::lock_guard<std::mutex> lock(impl_->events_mutex);
+    impl_->download_profiles[event.download_id] = profile_id_;
+    impl_->events.push(std::move(event));
+  }
+}
+
+void CbfBridgeClientImpl::Observer::OnDownloadCompleted(
+    cbf::mojom::CbfDownloadCompletedPtr event_data) {
+  if (!event_data) {
+    return;
+  }
+  CbfBridgeEventData event;
+  event.kind = kEventDownloadCompleted;
+  event.profile_id = profile_id_;
+  event.download_id = event_data->download_id;
+  if (event_data->source_tab_id.has_value()) {
+    event.download_has_source_tab_id = true;
+    event.download_source_tab_id = event_data->source_tab_id.value();
+  }
+  event.download_file_name = event_data->file_name;
+  event.download_received_bytes = event_data->received_bytes;
+  if (event_data->total_bytes.has_value()) {
+    event.download_has_total_bytes = true;
+    event.download_total_bytes = event_data->total_bytes.value();
+  }
+  if (event_data->target_path.has_value()) {
+    event.download_target_path = event_data->target_path.value();
+  }
+  event.download_outcome = static_cast<uint8_t>(event_data->outcome);
+  {
+    std::lock_guard<std::mutex> lock(impl_->events_mutex);
+    impl_->download_profiles.erase(event.download_id);
+    impl_->events.push(std::move(event));
+  }
+}
