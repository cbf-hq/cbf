+    return false;
+  }
+  CbfBridgeClientImpl* impl = impl_.get();
+  task_runner->PostTask(
+      FROM_HERE,
+      base::BindOnce(
+          [](CbfBridgeClientImpl* impl, uint64_t download_id) {
+            auto it = impl->download_profiles.find(download_id);
+            if (it == impl->download_profiles.end()) {
+              return;
