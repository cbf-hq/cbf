+mojom::CbfDownloadPromptReason ToCbfDownloadPromptReason(
+    DownloadConfirmationReason reason) {
+  switch (reason) {
+    case DownloadConfirmationReason::NONE:
+      return mojom::CbfDownloadPromptReason::kNone;
+    case DownloadConfirmationReason::UNEXPECTED:
+      return mojom::CbfDownloadPromptReason::kUnexpected;
+    case DownloadConfirmationReason::SAVE_AS:
+      return mojom::CbfDownloadPromptReason::kSaveAs;
+    case DownloadConfirmationReason::PREFERENCE:
+      return mojom::CbfDownloadPromptReason::kPreference;
+    case DownloadConfirmationReason::NAME_TOO_LONG:
+      return mojom::CbfDownloadPromptReason::kNameTooLong;
+    case DownloadConfirmationReason::TARGET_CONFLICT:
+      return mojom::CbfDownloadPromptReason::kTargetConflict;
+    case DownloadConfirmationReason::TARGET_PATH_NOT_WRITEABLE:
+      return mojom::CbfDownloadPromptReason::kTargetPathNotWriteable;
+    case DownloadConfirmationReason::TARGET_NO_SPACE:
+      return mojom::CbfDownloadPromptReason::kTargetNoSpace;
+    case DownloadConfirmationReason::DLP_BLOCKED:
+      return mojom::CbfDownloadPromptReason::kDlpBlocked;
+  }
+}
+
+mojom::CbfDownloadState ToCbfDownloadState(download::DownloadItem* item) {
+  if (!item) {
+    return mojom::CbfDownloadState::kUnknown;
+  }
+  switch (item->GetState()) {
+    case download::DownloadItem::IN_PROGRESS:
+      return item->IsPaused() ? mojom::CbfDownloadState::kPaused
+                              : mojom::CbfDownloadState::kInProgress;
+    case download::DownloadItem::COMPLETE:
+      return mojom::CbfDownloadState::kCompleted;
+    case download::DownloadItem::CANCELLED:
+      return mojom::CbfDownloadState::kCancelled;
+    case download::DownloadItem::INTERRUPTED:
+      return mojom::CbfDownloadState::kInterrupted;
+    case download::DownloadItem::MAX_DOWNLOAD_STATE:
+      return mojom::CbfDownloadState::kUnknown;
+  }
+}
+
+mojom::CbfDownloadOutcome ToCbfDownloadOutcome(download::DownloadItem* item) {
+  if (!item) {
+    return mojom::CbfDownloadOutcome::kUnknown;
+  }
+  switch (item->GetState()) {
+    case download::DownloadItem::COMPLETE:
+      return mojom::CbfDownloadOutcome::kSucceeded;
+    case download::DownloadItem::CANCELLED:
+      return mojom::CbfDownloadOutcome::kCancelled;
+    case download::DownloadItem::INTERRUPTED:
+      return mojom::CbfDownloadOutcome::kInterrupted;
+    case download::DownloadItem::IN_PROGRESS:
+    case download::DownloadItem::MAX_DOWNLOAD_STATE:
+      return mojom::CbfDownloadOutcome::kUnknown;
+  }
+}
