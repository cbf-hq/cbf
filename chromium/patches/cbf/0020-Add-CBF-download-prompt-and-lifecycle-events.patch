+bool CbfProfileService::OpenDefaultDownloadPromptImpl(uint64_t request_id) {
+  auto it = pending_download_prompts_.find(request_id);
+  if (it == pending_download_prompts_.end()) {
+    return false;
+  }
+
+  PendingDownloadPrompt pending = std::move(it->second);
+  pending_download_prompts_.erase(it);
+  if (!pending.delegate) {
+    ResolvePendingDownloadPrompt(
+        std::move(pending), DownloadConfirmationResult::FAILED,
+        ui::SelectedFileInfo(),
+        mojom::CbfPromptUiResolutionResult::kAborted);
+    return false;
+  }
+
+  const std::string download_guid = pending.download_guid;
+  const base::FilePath suggested_path = pending.suggested_path;
+  const DownloadConfirmationReason reason = pending.reason;
+  const TabId tab_id = pending.tab_id;
+  const uint64_t download_id = pending.download_id;
+  const uint64_t response_request_id = pending.request_id;
+  auto callback = std::move(pending.callback);
+  base::WeakPtr<CbfProfileService> weak_self = weak_factory_.GetWeakPtr();
+  if (!pending.delegate->OpenNativeDownloadPrompt(
+          download_guid, suggested_path, reason,
+          base::BindOnce(
+              [](base::WeakPtr<CbfProfileService> self, TabId tab_id,
+                 uint64_t request_id, uint64_t download_id,
+                 std::string download_guid,
+                 DownloadTargetDeterminerDelegate::ConfirmationCallback callback,
+                 DownloadConfirmationResult result,
+                 const ui::SelectedFileInfo& selected_file_info) mutable {
+                mojom::CbfPromptUiResolutionResult resolution =
+                    mojom::CbfPromptUiResolutionResult::kAborted;
+                if (result == DownloadConfirmationResult::CONFIRMED ||
+                    result ==
+                        DownloadConfirmationResult::CONTINUE_WITHOUT_CONFIRMATION) {
+                  resolution = mojom::CbfPromptUiResolutionResult::kAllowed;
+                } else if (result == DownloadConfirmationResult::CANCELED) {
+                  resolution = mojom::CbfPromptUiResolutionResult::kDenied;
+                }
+
+                if (self) {
+                  PendingDownloadPrompt resolved_pending;
+                  resolved_pending.tab_id = tab_id;
+                  resolved_pending.request_id = request_id;
+                  resolved_pending.download_id = download_id;
+                  resolved_pending.download_guid = std::move(download_guid);
+                  resolved_pending.callback = std::move(callback);
+                  self->ResolvePendingDownloadPrompt(
+                      std::move(resolved_pending), result, selected_file_info,
+                      resolution);
+                  return;
+                }
+
+                std::move(callback).Run(result, selected_file_info);
+              },
+              weak_self, tab_id, response_request_id, download_id, download_guid,
+              std::move(callback)))) {
+    ResolvePendingDownloadPrompt(
+        std::move(pending), DownloadConfirmationResult::FAILED,
+        ui::SelectedFileInfo(),
+        mojom::CbfPromptUiResolutionResult::kAborted);
+    return false;
+  }
+  return true;
+}
+
+void CbfProfileService::ResolvePendingDownloadPrompt(
+    PendingDownloadPrompt pending,
+    DownloadConfirmationResult confirmation_result,
+    const ui::SelectedFileInfo& selected_file_info,
+    mojom::CbfPromptUiResolutionResult result) {
+  std::optional<std::string> destination_path;
+  if (!selected_file_info.path().empty()) {
+    destination_path = selected_file_info.path().AsUTF8Unsafe();
+  }
+
+  if (result == mojom::CbfPromptUiResolutionResult::kAllowed &&
+      !pending.download_guid.empty()) {
+    TrackDownload(pending.download_id, pending.download_guid, pending.tab_id);
+  }
+
+  if (pending.callback) {
+    std::move(pending.callback).Run(confirmation_result, selected_file_info);
+  }
+
+  NotifyPromptUiResolved(
+      pending.tab_id, pending.request_id, mojom::CbfPromptUiKind::kDownloadPrompt,
+      mojom::CbfPromptUiPermissionType::kUnknown, std::string(), result,
+      pending.download_id, destination_path);
+}
+
+void CbfProfileService::ResolvePendingDownloadPromptsForTab(
+    TabId tab_id,
+    mojom::CbfPromptUiResolutionResult result) {
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  for (auto it = pending_download_prompts_.begin();
+       it != pending_download_prompts_.end();) {
+    if (it->second.tab_id != tab_id) {
+      ++it;
+      continue;
+    }
+    PendingDownloadPrompt pending = std::move(it->second);
+    it = pending_download_prompts_.erase(it);
+    ResolvePendingDownloadPrompt(std::move(pending),
+                                 DownloadConfirmationResult::FAILED,
+                                 ui::SelectedFileInfo(), result);
+  }
+}
+
+void CbfProfileService::ResolvePendingDownloadPromptsForShutdown(
+    mojom::CbfPromptUiResolutionResult result) {
+  for (auto it = pending_download_prompts_.begin();
+       it != pending_download_prompts_.end();) {
+    PendingDownloadPrompt pending = std::move(it->second);
+    it = pending_download_prompts_.erase(it);
+    ResolvePendingDownloadPrompt(std::move(pending),
+                                 DownloadConfirmationResult::FAILED,
+                                 ui::SelectedFileInfo(), result);
+  }
+}
