+IN_PROC_BROWSER_TEST_F(CbfProfileServiceBrowserTest,
+                       PauseDownloadEmitsPausedDownloadUpdatedEvent) {
+  EnsureDownloadServerStarted();
+
+  const TabId tab_id =
+      CreatePage(embedded_test_server()->GetURL("/cbf-download-page-slow").spec());
+  ASSERT_NE(tab_id, kInvalidTabId);
+  WaitForLoad(tab_id);
+
+  const base::FilePath destination = MakeDownloadDestination("download-pause");
+  content::WebContents* web_contents =
+      profile_service_->GetWebContentsForTesting(tab_id);
+  ASSERT_NE(web_contents, nullptr);
+  ASSERT_TRUE(content::ExecJs(
+      web_contents, "document.getElementById('download-link').click();"));
+  observer_.WaitForPromptUiRequestedCount(1);
+  ASSERT_FALSE(observer_.prompt_ui_requested_events().empty());
+  const auto& prompt = observer_.prompt_ui_requested_events().back();
+  RespondToDownloadPrompt(prompt.tab_id, prompt.request_id, true, destination);
+
+  observer_.WaitForDownloadCreatedCount(1);
+  ASSERT_FALSE(observer_.download_created_events().empty());
+  const uint64_t download_id = observer_.download_created_events().back().download_id;
+  EXPECT_EQ(download_id, prompt.download_id);
+
+  profile_service_->PauseDownload(download_id);
+
+  bool paused_seen = false;
+  size_t inspected = 0;
+  while (!paused_seen) {
+    const auto& updates = observer_.download_updated_events();
+    for (; inspected < updates.size(); ++inspected) {
+      const auto& update = updates[inspected];
+      if (update.download_id == download_id &&
+          update.state == mojom::CbfDownloadState::kPaused &&
+          update.is_paused) {
+        paused_seen = true;
+        break;
+      }
+    }
+    if (!paused_seen) {
+      observer_.WaitForDownloadUpdatedCount(updates.size() + 1);
+    }
+  }
+
+  profile_service_->CancelDownload(download_id);
+  observer_.WaitForDownloadCompletedCount(1);
+  ASSERT_FALSE(observer_.download_completed_events().empty());
+  EXPECT_EQ(observer_.download_completed_events().back().outcome,
+            mojom::CbfDownloadOutcome::kCancelled);
+}
