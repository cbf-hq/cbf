+download::DownloadItem* CbfProfileService::FindDownloadByGuid(
+    const std::string& guid) const {
+  if (!download_coordinator_ || guid.empty()) {
+    return nullptr;
+  }
+  return download_coordinator_->GetDownloadByGuid(guid);
+}
+
+download::DownloadItem* CbfProfileService::FindDownloadById(
+    uint64_t download_id) const {
+  auto it = active_downloads_.find(download_id);
+  if (it == active_downloads_.end()) {
+    return nullptr;
+  }
+  return FindDownloadByGuid(it->second.guid);
+}
+
+void CbfProfileService::TrackDownload(uint64_t download_id,
+                                      const std::string& guid,
+                                      std::optional<TabId> source_tab_id) {
+  auto& active = active_downloads_[download_id];
+  active.download_id = download_id;
+  active.guid = guid;
+  active.source_tab_id = source_tab_id;
+  download_guid_to_id_[guid] = download_id;
+}
+
+void CbfProfileService::NotifyDownloadCreated(download::DownloadItem* download,
+                                              const ActiveDownload& active) {
+  if (!observer_ || !download) {
+    return;
+  }
+  auto event = mojom::CbfDownloadCreated::New();
+  event->download_id = active.download_id;
+  if (active.source_tab_id.has_value()) {
+    event->source_tab_id = active.source_tab_id.value();
+  }
+  event->file_name = download->GetFileNameToReportUser().AsUTF8Unsafe();
+  event->total_bytes = ToOptionalTotalBytes(download->GetTotalBytes());
+  event->target_path = ToOptionalUtf8Path(download->GetTargetFilePath());
+  observer_->OnDownloadCreated(std::move(event));
+}
+
+void CbfProfileService::NotifyDownloadUpdated(download::DownloadItem* download,
+                                              const ActiveDownload& active) {
+  if (!observer_ || !download) {
+    return;
+  }
+  auto event = mojom::CbfDownloadUpdated::New();
+  event->download_id = active.download_id;
+  if (active.source_tab_id.has_value()) {
+    event->source_tab_id = active.source_tab_id.value();
+  }
+  event->state = ToCbfDownloadState(download);
+  event->file_name = download->GetFileNameToReportUser().AsUTF8Unsafe();
+  event->received_bytes = static_cast<uint64_t>(download->GetReceivedBytes());
+  event->total_bytes = ToOptionalTotalBytes(download->GetTotalBytes());
+  event->target_path = ToOptionalUtf8Path(download->GetTargetFilePath());
+  event->can_resume = download->CanResume();
+  event->is_paused = download->IsPaused();
+  observer_->OnDownloadUpdated(std::move(event));
+}
+
+void CbfProfileService::NotifyDownloadCompleted(
+    download::DownloadItem* download,
+    const ActiveDownload& active) {
+  if (!observer_ || !download) {
+    return;
+  }
+  auto event = mojom::CbfDownloadCompleted::New();
+  event->download_id = active.download_id;
+  if (active.source_tab_id.has_value()) {
+    event->source_tab_id = active.source_tab_id.value();
+  }
+  event->outcome = ToCbfDownloadOutcome(download);
+  event->file_name = download->GetFileNameToReportUser().AsUTF8Unsafe();
+  event->received_bytes = static_cast<uint64_t>(download->GetReceivedBytes());
+  event->total_bytes = ToOptionalTotalBytes(download->GetTotalBytes());
+  event->target_path = ToOptionalUtf8Path(download->GetTargetFilePath());
+  observer_->OnDownloadCompleted(std::move(event));
+}
