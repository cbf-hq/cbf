+
+namespace cbf {
+
+CbfDownloadManagerDelegate::CbfDownloadManagerDelegate(
+    Profile* profile,
+    base::WeakPtr<CbfProfileService> profile_service)
+    : ChromeDownloadManagerDelegate(profile),
+      profile_service_(std::move(profile_service)) {
+}
+
+CbfDownloadManagerDelegate::~CbfDownloadManagerDelegate() = default;
+
+void CbfDownloadManagerDelegate::OnDownloadCreated(
+    content::DownloadManager* manager,
+    download::DownloadItem* item) {
+}
+
+base::WeakPtr<CbfDownloadManagerDelegate> CbfDownloadManagerDelegate::GetWeakPtr() {
+  return weak_factory_.GetWeakPtr();
+}
+
+void CbfDownloadManagerDelegate::CheckDownloadAllowed(
+    const content::WebContents::Getter& web_contents_getter,
+    const GURL& url,
+    const std::string& request_method,
+    std::optional<url::Origin> request_initiator,
+    bool from_download_cross_origin_redirect,
+    bool content_initiated,
+    const std::string& mime_type,
+    std::optional<ui::PageTransition> page_transition,
+    content::CheckDownloadAllowedCallback check_download_allowed_cb) {
+  auto wrapped_cb = base::BindOnce(
+      [](content::CheckDownloadAllowedCallback cb, bool allow) {
+        std::move(cb).Run(allow);
+      },
+      std::move(check_download_allowed_cb));
+  ChromeDownloadManagerDelegate::CheckDownloadAllowed(
+      web_contents_getter, url, request_method, std::move(request_initiator),
+      from_download_cross_origin_redirect, content_initiated, mime_type,
+      page_transition, std::move(wrapped_cb));
+}
+
+bool CbfDownloadManagerDelegate::DetermineDownloadTarget(
+    download::DownloadItem* download,
+    download::DownloadTargetCallback* callback) {
+  return ChromeDownloadManagerDelegate::DetermineDownloadTarget(download,
+                                                                callback);
+}
+
+void CbfDownloadManagerDelegate::RequestConfirmation(
+    download::DownloadItem* download,
+    const base::FilePath& suggested_path,
+    DownloadConfirmationReason reason,
+    DownloadTargetDeterminerDelegate::ConfirmationCallback callback) {
+  if (!profile_service_ ||
+      !profile_service_->RequestDownloadPrompt(download, suggested_path, reason,
+                                              std::move(callback),
+                                              GetWeakPtr())) {
+    ChromeDownloadManagerDelegate::RequestConfirmation(
+        download, suggested_path, reason, std::move(callback));
+  }
+}
+
+void CbfDownloadManagerDelegate::GetNextId(
+    content::DownloadIdCallback callback) {
+  ChromeDownloadManagerDelegate::GetNextId(std::move(callback));
+}
+
+bool CbfDownloadManagerDelegate::OpenNativeDownloadPrompt(
+    const std::string& download_guid,
+    const base::FilePath& suggested_path,
+    DownloadConfirmationReason reason,
+    DownloadTargetDeterminerDelegate::ConfirmationCallback callback) {
+  content::DownloadManager* manager = download_manager_.get();
+  if (!manager) {
+    return false;
+  }
+  download::DownloadItem* download = manager->GetDownloadByGuid(download_guid);
+  if (!download) {
+    return false;
+  }
+  ChromeDownloadManagerDelegate::RequestConfirmation(
+      download, suggested_path, reason, std::move(callback));
+  return true;
+}
+
+}  // namespace cbf
