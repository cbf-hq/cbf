+
+  content::WebContents* devtools_contents =
+      profile_service_->GetWebContentsForTesting(devtools_tab_id);
+  ASSERT_NE(devtools_contents, nullptr);
+
+  tabs::TabInterface* tab =
+      tabs::TabInterface::MaybeGetFromContents(devtools_contents);
+  ASSERT_NE(tab, nullptr);
+
+  BrowserWindowInterface* browser_window =
+      webui::GetBrowserWindowInterface(devtools_contents);
+  ASSERT_NE(browser_window, nullptr);
