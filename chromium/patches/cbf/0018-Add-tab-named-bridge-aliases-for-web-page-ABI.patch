From 1f5876d7ec1756891b773ff13b366e2dc05b2121 Mon Sep 17 00:00:00 2001
From: Takagi Tasuku <tasuren@outlook.jp>
Date: Fri, 6 Mar 2026 11:35:06 +0900
Subject: [PATCH 18/21] Add tab-named bridge aliases for web-page ABI

---
 chrome/browser/cbf/bridge/cbf_bridge.h        | 21 +++++++++++
 .../cbf/bridge/cbf_bridge_client_impl.cc      |  8 ++---
 .../browser/cbf/bridge/cbf_bridge_events.cc   |  4 +--
 chrome/browser/cbf/bridge/cbf_bridge_ffi.h    |  6 ++++
 .../browser/cbf/bridge/cbf_bridge_web_page.cc | 36 +++++++++++++++++++
 5 files changed, 69 insertions(+), 6 deletions(-)

diff --git a/chrome/browser/cbf/bridge/cbf_bridge.h b/chrome/browser/cbf/bridge/cbf_bridge.h
index fa7babb34c521..ce8a355fc9dd1 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge.h
+++ b/chrome/browser/cbf/bridge/cbf_bridge.h
@@ -45,18 +45,35 @@ CBF_BRIDGE_EXPORT bool cbf_bridge_client_create_web_page(
     uint64_t request_id,
     const char* initial_url,
     const char* profile_id);
+CBF_BRIDGE_EXPORT bool cbf_bridge_client_create_tab(
+    CbfBridgeClientHandle* client,
+    uint64_t request_id,
+    const char* initial_url,
+    const char* profile_id);
 CBF_BRIDGE_EXPORT bool cbf_bridge_client_request_close_web_page(
     CbfBridgeClientHandle* client,
     uint64_t tab_id);
+CBF_BRIDGE_EXPORT bool cbf_bridge_client_request_close_tab(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id);
 CBF_BRIDGE_EXPORT bool cbf_bridge_client_set_web_page_size(
     CbfBridgeClientHandle* client,
     uint64_t tab_id,
     uint32_t width,
     uint32_t height);
+CBF_BRIDGE_EXPORT bool cbf_bridge_client_set_tab_size(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id,
+    uint32_t width,
+    uint32_t height);
 CBF_BRIDGE_EXPORT bool cbf_bridge_client_set_web_page_focus(
     CbfBridgeClientHandle* client,
     uint64_t tab_id,
     bool focused);
+CBF_BRIDGE_EXPORT bool cbf_bridge_client_set_tab_focus(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id,
+    bool focused);
 CBF_BRIDGE_EXPORT bool cbf_bridge_client_send_key_event(
     CbfBridgeClientHandle* client,
     const CbfKeyEvent* event,
@@ -119,6 +136,10 @@ CBF_BRIDGE_EXPORT bool cbf_bridge_client_get_web_page_dom_html(
     CbfBridgeClientHandle* client,
     uint64_t tab_id,
     uint64_t request_id);
+CBF_BRIDGE_EXPORT bool cbf_bridge_client_get_tab_dom_html(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id,
+    uint64_t request_id);
 CBF_BRIDGE_EXPORT bool cbf_bridge_client_open_default_prompt_ui(
     CbfBridgeClientHandle* client,
     uint64_t tab_id,
diff --git a/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc b/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
index 064eddf9cda3c..5f3253e448d8b 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
+++ b/chrome/browser/cbf/bridge/cbf_bridge_client_impl.cc
@@ -96,7 +96,7 @@ void CbfBridgeClientImpl::Observer::OnWebPageCreated(uint64_t tab_id,
                                                     uint64_t request_id) {
   impl_->web_page_profiles.emplace(tab_id, profile_id_);
   CbfBridgeEventData event;
-  event.kind = kEventWebPageCreated;
+  event.kind = kEventTabCreated;
   event.tab_id = tab_id;
   event.request_id = request_id;
   event.profile_id = profile_id_;
@@ -120,7 +120,7 @@ void CbfBridgeClientImpl::Observer::OnDevToolsOpened(
 void CbfBridgeClientImpl::Observer::OnWebPageClosed(uint64_t tab_id) {
   impl_->web_page_profiles.erase(tab_id);
   CbfBridgeEventData event;
-  event.kind = kEventWebPageClosed;
+  event.kind = kEventTabClosed;
   event.tab_id = tab_id;
   event.profile_id = profile_id_;
   std::lock_guard<std::mutex> lock(impl_->events_mutex);
@@ -129,7 +129,7 @@ void CbfBridgeClientImpl::Observer::OnWebPageClosed(uint64_t tab_id) {
 
 void CbfBridgeClientImpl::Observer::OnWebPageResizeAcknowledged(uint64_t tab_id) {
   CbfBridgeEventData event;
-  event.kind = kEventWebPageResizeAcknowledged;
+  event.kind = kEventTabResizeAcknowledged;
   event.tab_id = tab_id;
   event.profile_id = profile_id_;
   std::lock_guard<std::mutex> lock(impl_->events_mutex);
@@ -311,7 +311,7 @@ void CbfBridgeClientImpl::Observer::OnWebPageDomHtmlRead(uint64_t tab_id,
                                                         uint64_t request_id,
                                                         const std::string& html) {
   CbfBridgeEventData event;
-  event.kind = kEventWebPageDomHtmlRead;
+  event.kind = kEventTabDomHtmlRead;
   event.tab_id = tab_id;
   event.request_id = request_id;
   event.profile_id = profile_id_;
diff --git a/chrome/browser/cbf/bridge/cbf_bridge_events.cc b/chrome/browser/cbf/bridge/cbf_bridge_events.cc
index 06f1c3a9b4252..3ce7cb93fbe00 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge_events.cc
+++ b/chrome/browser/cbf/bridge/cbf_bridge_events.cc
@@ -326,7 +326,7 @@ bool CbfBridgeClient::PollEvent(CbfBridgeEvent* out_event) {
   if (event.kind == kEventCursorChanged) {
     out_event->cursor_type = event.cursor_type;
   }
-  if (event.kind == kEventWebPageClosed) {
+  if (event.kind == kEventTabClosed) {
     // No extra payload.
   }
   if (event.kind == kEventNavigationStateChanged) {
@@ -335,7 +335,7 @@ bool CbfBridgeClient::PollEvent(CbfBridgeEvent* out_event) {
     out_event->can_go_forward = event.can_go_forward;
     out_event->is_loading = event.is_loading;
   }
-  if (event.kind == kEventWebPageDomHtmlRead) {
+  if (event.kind == kEventTabDomHtmlRead) {
     out_event->dom_html =
         event.dom_html.empty() ? nullptr : CopyCString(event.dom_html);
   }
diff --git a/chrome/browser/cbf/bridge/cbf_bridge_ffi.h b/chrome/browser/cbf/bridge/cbf_bridge_ffi.h
index 9533a024158a3..f42511c2c6003 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge_ffi.h
+++ b/chrome/browser/cbf/bridge/cbf_bridge_ffi.h
@@ -39,6 +39,11 @@ enum CbfEventKind {
   kEventTabOpenResolved = 26,
   kEventPromptUiRequested = 27,
   kEventPromptUiResolved = 28,
+  kEventTabCreated = kEventWebPageCreated,
+  kEventNewTabRequested = kEventNewWebPageRequested,
+  kEventTabClosed = kEventWebPageClosed,
+  kEventTabResizeAcknowledged = kEventWebPageResizeAcknowledged,
+  kEventTabDomHtmlRead = kEventWebPageDomHtmlRead,
 };
 
 enum CbfExtensionInstallPromptResult {
@@ -182,6 +187,7 @@ enum CbfBeforeUnloadReason {
   kCbfBeforeUnloadReasonNavigate = 2,
   kCbfBeforeUnloadReasonReload = 3,
   kCbfBeforeUnloadReasonWindowClose = 4,
+  kCbfBeforeUnloadReasonCloseTab = kCbfBeforeUnloadReasonCloseWebPage,
 };
 
 enum CbfCursorType {
diff --git a/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc b/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc
index 2d89b574aef3d..2242e5d543e28 100644
--- a/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc
+++ b/chrome/browser/cbf/bridge/cbf_bridge_web_page.cc
@@ -626,6 +626,14 @@ extern "C" bool cbf_bridge_client_create_web_page(CbfBridgeClientHandle* client,
       ->CreateWebPage(request_id, initial_url, profile_id);
 }
 
+extern "C" bool cbf_bridge_client_create_tab(CbfBridgeClientHandle* client,
+                                             uint64_t request_id,
+                                             const char* initial_url,
+                                             const char* profile_id) {
+  return cbf_bridge_client_create_web_page(client, request_id, initial_url,
+                                           profile_id);
+}
+
 extern "C" bool cbf_bridge_client_request_close_web_page(
     CbfBridgeClientHandle* client,
     const uint64_t tab_id) {
@@ -636,6 +644,12 @@ extern "C" bool cbf_bridge_client_request_close_web_page(
       ->RequestCloseWebPage(tab_id);
 }
 
+extern "C" bool cbf_bridge_client_request_close_tab(
+    CbfBridgeClientHandle* client,
+    const uint64_t tab_id) {
+  return cbf_bridge_client_request_close_web_page(client, tab_id);
+}
+
 extern "C" bool cbf_bridge_client_set_web_page_size(
     CbfBridgeClientHandle* client,
     const uint64_t tab_id,
@@ -648,6 +662,14 @@ extern "C" bool cbf_bridge_client_set_web_page_size(
       ->SetWebPageSize(tab_id, width, height);
 }
 
+extern "C" bool cbf_bridge_client_set_tab_size(
+    CbfBridgeClientHandle* client,
+    const uint64_t tab_id,
+    const uint32_t width,
+    const uint32_t height) {
+  return cbf_bridge_client_set_web_page_size(client, tab_id, width, height);
+}
+
 extern "C" bool cbf_bridge_client_set_web_page_focus(
     CbfBridgeClientHandle* client,
     const uint64_t tab_id,
@@ -659,6 +681,13 @@ extern "C" bool cbf_bridge_client_set_web_page_focus(
       ->SetWebPageFocus(tab_id, focused);
 }
 
+extern "C" bool cbf_bridge_client_set_tab_focus(
+    CbfBridgeClientHandle* client,
+    const uint64_t tab_id,
+    const bool focused) {
+  return cbf_bridge_client_set_web_page_focus(client, tab_id, focused);
+}
+
 extern "C" bool cbf_bridge_client_confirm_beforeunload(
     CbfBridgeClientHandle* client,
     const uint64_t tab_id,
@@ -729,6 +758,13 @@ extern "C" bool cbf_bridge_client_get_web_page_dom_html(
       ->GetWebPageDomHtml(tab_id, request_id);
 }
 
+extern "C" bool cbf_bridge_client_get_tab_dom_html(
+    CbfBridgeClientHandle* client,
+    uint64_t tab_id,
+    uint64_t request_id) {
+  return cbf_bridge_client_get_web_page_dom_html(client, tab_id, request_id);
+}
+
 extern "C" bool cbf_bridge_client_open_dev_tools(
     CbfBridgeClientHandle* client,
     uint64_t tab_id) {
-- 
