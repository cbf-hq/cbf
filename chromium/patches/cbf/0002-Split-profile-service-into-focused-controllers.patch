@@ -0,0 +1,344 @@
+#include "chrome/browser/cbf/profile/cbf_profile_input_controller.h"
+
+#include <algorithm>
+#include <array>
+#include <string>
+#include <vector>
+
+#include "base/logging.h"
+#include "base/strings/utf_string_conversions.h"
