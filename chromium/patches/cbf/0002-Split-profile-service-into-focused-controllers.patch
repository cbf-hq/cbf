-class CbfRenderViewContextMenu final : public RenderViewContextMenu {
- public:
-  CbfRenderViewContextMenu(content::RenderFrameHost& render_frame_host,
-                           const content::ContextMenuParams& params)
-      : RenderViewContextMenu(render_frame_host, params) {}
-
-  void Show() override {}
-
-  void ExecuteCommand(int id, int event_flags) override { 
-    // CBF Chromium does not use standard Browser instances for tab management, 
-    // so GetBrowser() returns nullptr. Default ExecuteCommand for IDC_RELOAD 
-    // crashes when Browser is null, so we handle it manually here. 
-
-    if (id == IDC_RELOAD) { 
-      DCHECK(GetRenderFrameHost());
-      if (content::RenderFrameHost* rfh = GetRenderFrameHost()) { 
-        DCHECK(content::WebContents::FromRenderFrameHost(rfh));
-        if (content::WebContents* wc = content::WebContents::FromRenderFrameHost(rfh)) { 
-          wc->GetController().Reload(content::ReloadType::NORMAL, true); 
-        } 
-      } 
-      return; 
-    } 
-    RenderViewContextMenu::ExecuteCommand(id, event_flags); 
-  }
-
-  ui::SimpleMenuModel* menu_model_mutable() {
-    return const_cast<ui::SimpleMenuModel*>(&menu_model());
-  }
-};
