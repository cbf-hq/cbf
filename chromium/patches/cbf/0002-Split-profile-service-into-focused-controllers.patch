+constexpr char kDevToolsFrontendBaseUrl[] =
+    "devtools://devtools/bundled/devtools_app.html";
+
+GURL BuildDevToolsFrontendUrl() {
+  std::string url = std::string(kDevToolsFrontendBaseUrl) +
+                    "?remoteBase=" + DevToolsUI::GetRemoteBaseURL().spec() +
+                    "&targetType=tab";
+
+  base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(switches::kDevToolsFlags)) {
+    url += "&" + command_line->GetSwitchValueASCII(switches::kDevToolsFlags);
+  }
+  if (command_line->HasSwitch(switches::kCustomDevtoolsFrontend)) {
+    url += "&debugFrontend=true";
+  }
+
+  return DevToolsUIBindings::SanitizeFrontendURL(GURL(url));
+}
+
+class CbfDevToolsUIDelegate final : public DevToolsUIBindings::Delegate {
+ public:
+  CbfDevToolsUIDelegate(content::WebContents* frontend_contents,
+                        content::WebContents* inspected_contents)
