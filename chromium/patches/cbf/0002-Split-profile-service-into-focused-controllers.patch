+#include "chrome/browser/cbf/profile/cbf_profile_popup_controller.h"
+
+#include "chrome/browser/cbf/cbf_tab_manager.h"
+#include "content/public/browser/web_contents.h"
+#include "url/gurl.h"
+
+#include "chrome/browser/cbf/profile/cbf_profile_service_context.h"
+
+namespace cbf {
+
+CbfProfilePopupController::CbfProfilePopupController(CbfProfileServiceContext* context)
+    : context_(context) {}
+
+CbfProfilePopupController::~CbfProfilePopupController() = default;
+
+void CbfProfilePopupController::NotifyNewWebPageRequested(
+    content::WebContents* source,
+    const GURL& target_url,
+    WindowOpenDisposition disposition) {
+  auto& observer = context_->observer_remote();
+  if (!observer.is_bound() || !source) {
+    return;
+  }
+
+  const TabId tab_id =
+      context_->tab_manager().GetTabIdForWebContents(source);
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  const bool is_popup = disposition == WindowOpenDisposition::NEW_POPUP;
+  observer->OnNewWebPageRequested(tab_id, target_url.spec(), is_popup);
+}
+
+void CbfProfilePopupController::MarkCloseWebPageBeforeUnloadReason(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return;
+  }
+  beforeunload_reasons_[web_contents] =
+      mojom::CbfBeforeUnloadReason::kCloseWebPage;
+}
+
+void CbfProfilePopupController::ClearBeforeUnloadReason(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return;
+  }
+  beforeunload_reasons_.erase(web_contents);
+}
+
+bool CbfProfilePopupController::ConsumeCloseWebPageBeforeUnloadReason(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return false;
+  }
+  const auto it = beforeunload_reasons_.find(web_contents);
+  if (it == beforeunload_reasons_.end()) {
+    return false;
+  }
+  const bool is_close_request =
+      it->second == mojom::CbfBeforeUnloadReason::kCloseWebPage;
+  beforeunload_reasons_.erase(it);
+  return is_close_request;
+}
+
+mojom::CbfBeforeUnloadReason CbfProfilePopupController::ResolveBeforeUnloadReason(
+    content::WebContents* web_contents,
+    bool is_reload) const {
+  if (is_reload) {
+    return mojom::CbfBeforeUnloadReason::kReload;
+  }
+  if (!web_contents) {
+    return mojom::CbfBeforeUnloadReason::kUnknown;
+  }
+  const auto it = beforeunload_reasons_.find(web_contents);
+  if (it == beforeunload_reasons_.end()) {
+    return mojom::CbfBeforeUnloadReason::kUnknown;
+  }
+  return it->second;
+}
+
+}  // namespace cbf
