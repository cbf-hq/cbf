+    case cbf::mojom::CbfScrollGranularity::kScrollByDocument:
+      return ui::ScrollGranularity::kScrollByDocument;
+  }
+  return ui::ScrollGranularity::kScrollByPixel;
+}
+
+std::vector<ui::ImeTextSpan> ToImeTextSpans(
+    const std::vector<cbf::mojom::CbfImeTextSpanPtr>& spans) {
+  std::vector<ui::ImeTextSpan> result;
+  result.reserve(spans.size());
+  for (const auto& span : spans) {
+    ui::ImeTextSpan converted(
+        ToImeTextSpanType(span->type), span->start_offset, span->end_offset,
+        ToImeTextSpanThickness(span->thickness),
+        ToImeTextSpanUnderlineStyle(span->underline_style),
+        static_cast<SkColor>(span->background_color),
+        static_cast<SkColor>(span->suggestion_highlight_color), {},
+        static_cast<SkColor>(span->text_color),
+        span->should_hide_suggestion_menu);
+    converted.underline_color = static_cast<SkColor>(span->underline_color);
+    converted.remove_on_finish_composing = span->remove_on_finish_composing;
+    converted.interim_char_selection = span->interim_char_selection;
+    result.push_back(std::move(converted));
+  }
+  return result;
+}
+
+gfx::Range ToReplacementRange(int32_t start, int32_t end) {
+  if (start < 0 || end < 0) {
+    return gfx::Range::InvalidRange();
+  }
+  return gfx::Range(start, end);
+}
+
+cbf::mojom::CbfRectPtr ToCbfRect(const gfx::Rect& rect) {
+  auto out = cbf::mojom::CbfRect::New();
+  out->x = rect.x();
+  out->y = rect.y();
+  out->width = rect.width();
+  out->height = rect.height();
+  return out;
+}
+
+}  // namespace cbf::mojo_converters
