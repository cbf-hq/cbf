+#include "content/public/browser/render_widget_host.h"
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+#include "third_party/blink/public/mojom/input/input_handler.mojom.h"
+#include "ui/events/keycodes/dom/keycode_converter.h"
+#include "ui/latency/latency_info.h"
+
+namespace {
+
+constexpr base::TimeDelta kSyntheticWheelPhaseGap = base::Milliseconds(120);
+
+bool HasWheelPhase(const blink::WebMouseWheelEvent& event) {
+  return event.phase != blink::WebMouseWheelEvent::kPhaseNone ||
+         event.momentum_phase != blink::WebMouseWheelEvent::kPhaseNone;
+}
+
+void FillText(std::array<char16_t, blink::WebKeyboardEvent::kTextLengthCap>& out,
+              const std::string& text_utf8) {
+  if (text_utf8.empty()) {
+    return;
+  }
+  const std::u16string text16 = base::UTF8ToUTF16(text_utf8);
+  const size_t copy_len = std::min(text16.size(), out.size());
+  for (size_t i = 0; i < copy_len; ++i) {
+    out[i] = text16[i];
+  }
+}
+
+content::RenderWidgetHost* ResolveInputRenderWidgetHost(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+
+  if (content::RenderFrameHost* focused_frame = web_contents->GetFocusedFrame()) {
+    if (content::RenderWidgetHost* widget_host =
+            focused_frame->GetRenderWidgetHost()) {
+      return widget_host;
+    }
+  }
+
+  if (content::RenderFrameHost* primary_frame =
+          web_contents->GetPrimaryMainFrame()) {
+    if (content::RenderWidgetHost* widget_host =
+            primary_frame->GetRenderWidgetHost()) {
+      return widget_host;
+    }
+  }
+
+  content::RenderWidgetHostView* view = web_contents->GetRenderWidgetHostView();
+  return view ? view->GetRenderWidgetHost() : nullptr;
+}
+
+content::RenderWidgetHostViewBase* ResolveInputRootView(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+  content::RenderWidgetHostView* view = web_contents->GetRenderWidgetHostView();
+  if (!view) {
+    return nullptr;
+  }
+  return static_cast<content::RenderWidgetHostViewBase*>(view);
+}
+
+input::RenderWidgetHostInputEventRouter* ResolveInputEventRouter(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+  auto* web_contents_impl = static_cast<content::WebContentsImpl*>(web_contents);
+  return web_contents_impl->GetInputEventRouter();
+}
+
+bool RouteMouseEventViaInputRouter(content::WebContents* web_contents,
+                                   blink::WebMouseEvent* event,
+                                   const ui::LatencyInfo& latency_info) {
+  auto* router = ResolveInputEventRouter(web_contents);
+  auto* root_view = ResolveInputRootView(web_contents);
+  if (!router || !root_view) {
+    return false;
+  }
+  router->RouteMouseEvent(root_view, event, latency_info);
+  return true;
+}
+
+bool RouteMouseWheelEventViaInputRouter(content::WebContents* web_contents,
+                                        blink::WebMouseWheelEvent* event,
+                                        const ui::LatencyInfo& latency_info) {
+  auto* router = ResolveInputEventRouter(web_contents);
+  auto* root_view = ResolveInputRootView(web_contents);
+  if (!router || !root_view) {
+    return false;
+  }
+  router->RouteMouseWheelEvent(root_view, event, latency_info);
+  return true;
+}
+
+}  // namespace
+
+namespace cbf {
+
+CbfProfileInputController::CbfProfileInputController(CbfProfileServiceContext* context)
+    : context_(context) {}
+
+CbfProfileInputController::~CbfProfileInputController() = default;
+
+CbfProfileInputController::WheelPhaseState::WheelPhaseState() = default;
+CbfProfileInputController::WheelPhaseState::~WheelPhaseState() = default;
+
+void CbfProfileInputController::SendKeyEvent(
+    mojom::CbfKeyEventPtr event,
+    const std::optional<std::vector<std::string>>& commands) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(event->tab_id);
+  if (!web_contents) {
+    return;
+  }
+  content::RenderWidgetHost* widget_host =
+      ResolveInputRenderWidgetHost(web_contents);
+  if (!widget_host) {
+    DVLOG(1) << "SendKeyEvent dropped: no input widget host for tab_id="
+             << event->tab_id;
+    return;
+  }
+  auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+  if (!widget_impl) {
+    return;
+  }
+
+  input::NativeWebKeyboardEvent key_event(
+      mojo_converters::ToWebInputEventType(event->type),
+      static_cast<int>(event->modifiers),
+      base::TimeTicks::Now());
+  key_event.windows_key_code = event->windows_key_code;
+  key_event.native_key_code = event->native_key_code;
+  key_event.is_system_key = event->is_system_key;
+  key_event.skip_if_unhandled = false;
+
+  if (!event->dom_code.empty()) {
+    key_event.dom_code = static_cast<int>(
+        ui::KeycodeConverter::CodeStringToDomCode(event->dom_code));
+  }
+  if (!event->dom_key.empty()) {
+    key_event.dom_key =
+        static_cast<uint32_t>(ui::KeycodeConverter::KeyStringToDomKey(
+            event->dom_key));
+  }
+
+  FillText(key_event.text, event->text);
+  FillText(key_event.unmodified_text, event->unmodified_text);
+
+  std::vector<blink::mojom::EditCommandPtr> edit_commands;
+  if (commands.has_value()) {
+    edit_commands.reserve(commands->size());
+    for (const auto& command : *commands) {
+      edit_commands.push_back(blink::mojom::EditCommand::New(command, ""));
+    }
+  }
+
+  widget_host->ForwardKeyboardEventWithCommands(
+      key_event, ui::LatencyInfo(), std::move(edit_commands));
+}
+
+void CbfProfileInputController::SendMouseEvent(mojom::CbfMouseEventPtr event) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(event->tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  blink::WebMouseEvent mouse_event(
+      mojo_converters::ToWebInputEventType(event->type),
+      gfx::PointF(event->position_in_widget_x, event->position_in_widget_y),
+      gfx::PointF(event->position_in_screen_x, event->position_in_screen_y),
+      mojo_converters::ToWebMouseButton(event->button),
+      event->click_count,
+      static_cast<int>(event->modifiers),
+      base::TimeTicks::Now());
+  mouse_event.movement_x = static_cast<int>(event->movement_x);
+  mouse_event.movement_y = static_cast<int>(event->movement_y);
+  mouse_event.is_raw_movement_event = event->is_raw_movement_event;
+  mouse_event.pointer_type = mojo_converters::ToWebPointerType(event->pointer_type);
+
+  ui::LatencyInfo latency_info;
+  if (RouteMouseEventViaInputRouter(web_contents, &mouse_event, latency_info)) {
+    return;
+  }
+
+  content::RenderWidgetHost* widget_host =
+      ResolveInputRenderWidgetHost(web_contents);
+  if (!widget_host) {
+    DVLOG(1) << "SendMouseEvent dropped: no input widget host for tab_id="
+             << event->tab_id;
+    return;
+  }
+  auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+  if (!widget_impl) {
+    return;
+  }
+  widget_impl->ForwardMouseEventWithLatencyInfo(mouse_event, latency_info);
+}
+
+void CbfProfileInputController::SendMouseWheelEvent(
+    mojom::CbfMouseWheelEventPtr event) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(event->tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  blink::WebMouseWheelEvent wheel_event(
+      blink::WebInputEvent::Type::kMouseWheel,
+      static_cast<int>(event->modifiers),
+      base::TimeTicks::Now());
+  wheel_event.SetPositionInWidget(event->position_in_widget_x,
+                                  event->position_in_widget_y);
+  wheel_event.SetPositionInScreen(event->position_in_screen_x,
+                                  event->position_in_screen_y);
+  wheel_event.movement_x = static_cast<int>(event->movement_x);
+  wheel_event.movement_y = static_cast<int>(event->movement_y);
+  wheel_event.is_raw_movement_event = event->is_raw_movement_event;
+  wheel_event.delta_x = event->delta_x;
+  wheel_event.delta_y = event->delta_y;
+  wheel_event.wheel_ticks_x = event->wheel_ticks_x;
+  wheel_event.wheel_ticks_y = event->wheel_ticks_y;
+  wheel_event.phase = static_cast<blink::WebMouseWheelEvent::Phase>(event->phase);
+  wheel_event.momentum_phase =
+      static_cast<blink::WebMouseWheelEvent::Phase>(event->momentum_phase);
+  wheel_event.delta_units = mojo_converters::ToScrollGranularity(event->delta_units);
+  if (!HasWheelPhase(wheel_event)) {
+    auto& phase_state_ptr = wheel_phase_states_[event->tab_id];
+    if (!phase_state_ptr) {
+      phase_state_ptr = std::make_unique<WheelPhaseState>();
+    }
+    WheelPhaseState& phase_state = *phase_state_ptr;
+
+    if (!phase_state.in_progress) {
+      wheel_event.phase = blink::WebMouseWheelEvent::kPhaseBegan;
+      phase_state.in_progress = true;
+    } else {
+      wheel_event.phase = blink::WebMouseWheelEvent::kPhaseChanged;
+    }
+    wheel_event.momentum_phase = blink::WebMouseWheelEvent::kPhaseNone;
+    phase_state.last_event = wheel_event;
+    phase_state.end_timer.Start(
+        FROM_HERE, kSyntheticWheelPhaseGap,
+        base::BindOnce(&CbfProfileInputController::SendSyntheticWheelEndedEvent,
+                       weak_factory_.GetWeakPtr(), event->tab_id));
+  } else {
+    wheel_phase_states_.erase(event->tab_id);
+  }
+
+  ui::LatencyInfo latency_info;
+  if (RouteMouseWheelEventViaInputRouter(web_contents, &wheel_event,
+                                         latency_info)) {
+    return;
+  }
+
+  content::RenderWidgetHost* widget_host =
+      ResolveInputRenderWidgetHost(web_contents);
+  if (!widget_host) {
+    DVLOG(1)
+        << "SendMouseWheelEvent dropped: no input widget host for tab_id="
+        << event->tab_id;
+    return;
+  }
+  auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+  if (!widget_impl) {
+    return;
+  }
+  widget_impl->ForwardWheelEventWithLatencyInfo(wheel_event, latency_info);
+}
+
+void CbfProfileInputController::OnWebPageClosed(TabId tab_id) {
+  wheel_phase_states_.erase(tab_id);
+}
+
+void CbfProfileInputController::SendSyntheticWheelEndedEvent(
+    TabId tab_id) {
+  const auto state_it = wheel_phase_states_.find(tab_id);
+  if (state_it == wheel_phase_states_.end()) {
+    return;
+  }
+
+  WheelPhaseState& phase_state = *state_it->second;
+  if (!phase_state.in_progress || !phase_state.last_event.has_value()) {
+    wheel_phase_states_.erase(state_it);
+    return;
+  }
+
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (!web_contents) {
+    wheel_phase_states_.erase(state_it);
+    return;
+  }
+
+  blink::WebMouseWheelEvent ended_event = *phase_state.last_event;
+  ended_event.SetTimeStamp(base::TimeTicks::Now());
+  ended_event.delta_x = 0;
+  ended_event.delta_y = 0;
+  ended_event.wheel_ticks_x = 0;
+  ended_event.wheel_ticks_y = 0;
+  ended_event.phase = blink::WebMouseWheelEvent::kPhaseEnded;
+  ended_event.momentum_phase = blink::WebMouseWheelEvent::kPhaseNone;
+
+  ui::LatencyInfo latency_info;
+  if (!RouteMouseWheelEventViaInputRouter(web_contents, &ended_event,
+                                          latency_info)) {
+    content::RenderWidgetHost* widget_host =
+        ResolveInputRenderWidgetHost(web_contents);
+    if (!widget_host) {
+      wheel_phase_states_.erase(state_it);
+      return;
+    }
+    auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+    if (!widget_impl) {
+      wheel_phase_states_.erase(state_it);
+      return;
+    }
+    widget_impl->ForwardWheelEventWithLatencyInfo(ended_event, latency_info);
+  }
+  wheel_phase_states_.erase(state_it);
+}
+
+}  // namespace cbf
