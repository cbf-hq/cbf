+}
+
+bool CbfProfileContextMenuController::HandleContextMenu(
+    content::RenderFrameHost& render_frame_host,
+    const content::ContextMenuParams& params) {
+  content::WebContents* web_contents =
+      content::WebContents::FromRenderFrameHost(&render_frame_host);
+  if (!web_contents) {
+    return true;
+  }
+
+  auto& observer = context_->observer_remote();
+  if (!observer.is_bound()) {
+    return true;
+  }
+
+  const TabId tab_id =
+      context_->tab_manager().GetTabIdForWebContents(web_contents);
+  if (tab_id == kInvalidTabId) {
+    return true;
+  }
+
+  const content::ContextMenuParams enriched_params =
+      AddContextMenuParamsPropertiesFromPreferences(web_contents, params);
+
+  auto menu = std::make_unique<CbfRenderViewContextMenu>(render_frame_host,
+                                                         enriched_params);
+  menu->Init();
+  menu->menu_model_mutable()->MenuWillShow();
+
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents->GetBrowserContext());
+
+  auto menu_payload = cbf::mojom::CbfContextMenu::New();
+  const std::uint64_t menu_id = next_context_menu_id_++;
+  menu_payload->menu_id = menu_id;
+  menu_payload->x = enriched_params.x;
+  menu_payload->y = enriched_params.y;
+  menu_payload->source_type =
+      static_cast<uint32_t>(enriched_params.source_type);
+  menu_payload->items =
+      mojo_converters::BuildMenuItems(menu->menu_model_mutable(), profile);
+
+  auto entry = std::make_unique<ContextMenuEntry>();
+  entry->tab_id = tab_id;
+  entry->x = enriched_params.x;
+  entry->y = enriched_params.y;
+  entry->menu = std::move(menu);
+  context_menus_[menu_id] = std::move(entry);
+
+  observer->OnContextMenuRequested(tab_id, std::move(menu_payload));
+  return true;
+}
+
+void CbfProfileContextMenuController::ExecuteContextMenuCommand(
+    uint64_t menu_id,
+    int32_t command_id,
+    int32_t event_flags) {
+  auto it = context_menus_.find(menu_id);
+  if (it == context_menus_.end()) {
+    return;
+  }
+
+  auto& entry = it->second;
+  if (entry->menu) {
+    if (command_id == IDC_CONTENT_CONTEXT_INSPECTELEMENT ||
+        command_id == IDC_CONTENT_CONTEXT_INSPECTELEMENT_WITH_DEVTOOLS) {
+      if (inspect_element_handler_) {
+        inspect_element_handler_.Run(entry->tab_id, entry->x, entry->y);
+      }
+    } else {
+      entry->menu->ExecuteCommand(command_id, event_flags);
+    }
+    entry->menu->MenuClosed(entry->menu->menu_model_mutable());
+  }
+
+  context_menus_.erase(it);
+}
+
+void CbfProfileContextMenuController::DismissContextMenu(uint64_t menu_id) {
+  auto it = context_menus_.find(menu_id);
+  if (it == context_menus_.end()) {
+    return;
+  }
+
+  auto& entry = it->second;
+  if (entry->menu) {
+    entry->menu->MenuClosed(entry->menu->menu_model_mutable());
+  }
+
+  context_menus_.erase(it);
+}
+
+void CbfProfileContextMenuController::OnWebPageClosed(TabId tab_id) {
+  for (auto it = context_menus_.begin(); it != context_menus_.end();) {
+    if (it->second && it->second->tab_id == tab_id) {
+      if (it->second->menu) {
+        it->second->menu->MenuClosed(it->second->menu->menu_model_mutable());
+      }
+      it = context_menus_.erase(it);
+      continue;
+    }
+    ++it;
+  }
+}
+
