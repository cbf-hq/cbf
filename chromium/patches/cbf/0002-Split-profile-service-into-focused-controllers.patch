+
+void CbfProfileDragController::NotifyDragStartRequested(
+    content::WebContents* web_contents,
+    const content::DropData& drop_data,
+    const url::Origin& source_origin,
+    blink::DragOperationsMask allowed_ops,
+    const SkBitmap& drag_image,
+    const gfx::Vector2d& cursor_offset_in_dip,
+    const gfx::Rect& drag_obj_rect_in_dip,
+    const blink::mojom::DragEventSourceInfo& event_info,
+    content::RenderWidgetHost* source_rwh) {
+  (void)event_info;
+  if (!context_->observer_remote().is_bound() || !web_contents || !source_rwh) {
+    return;
+  }
+
+  auto* source_rwh_impl = content::RenderWidgetHostImpl::From(source_rwh);
+  if (!source_rwh_impl) {
+    return;
+  }
+
+  const TabId tab_id =
+      context_->tab_manager().GetTabIdForWebContents(web_contents);
+  if (tab_id == kInvalidTabId) {
+    return;
+  }
+
+  const uint64_t session_id = next_drag_session_id_++;
+  DragSessionState session;
+  session.tab_id = tab_id;
+  session.source_rwh = source_rwh_impl->GetWeakPtr();
+  session.drop_data = drop_data;
+  source_rwh_impl->FilterDropData(&session.drop_data);
+  drag_sessions_[session_id] = std::move(session);
+
+  auto request = mojom::CbfDragStartRequest::New();
+  request->session_id = session_id;
+  request->tab_id = tab_id;
+  request->allowed_operations = static_cast<uint32_t>(allowed_ops);
+  request->source_origin = source_origin.Serialize();
+
+  auto data = mojom::CbfDragData::New();
+  data->text = base::UTF16ToUTF8(drop_data.text.value_or(std::u16string()));
+  data->html = base::UTF16ToUTF8(drop_data.html.value_or(std::u16string()));
+  data->html_base_url = drop_data.html_base_url.spec();
+  data->url_infos.reserve(drop_data.url_infos.size());
+  for (const auto& url_info : drop_data.url_infos) {
+    auto info = mojom::CbfDragUrlInfo::New();
+    info->url = url_info.url.spec();
+    info->title = base::UTF16ToUTF8(url_info.title);
+    data->url_infos.push_back(std::move(info));
+  }
+  data->filenames.reserve(drop_data.filenames.size());
+  for (const auto& file_info : drop_data.filenames) {
+    data->filenames.push_back(file_info.path.AsUTF8Unsafe());
+  }
+  data->file_mime_types.reserve(drop_data.file_mime_types.size());
+  for (const auto& mime_type : drop_data.file_mime_types) {
+    data->file_mime_types.push_back(base::UTF16ToUTF8(mime_type));
+  }
+  data->custom_data.reserve(drop_data.custom_data.size());
+  for (const auto& [key, value] : drop_data.custom_data) {
+    auto pair = mojom::CbfStringPair::New();
+    pair->key = base::UTF16ToUTF8(key);
+    pair->value = base::UTF16ToUTF8(value);
+    data->custom_data.push_back(std::move(pair));
+  }
+  request->data = std::move(data);
+
+  if (!drag_image.drawsNothing()) {
+    std::optional<std::vector<uint8_t>> png_bytes =
+        gfx::PNGCodec::EncodeBGRASkBitmap(drag_image,
+                                          /*discard_transparency=*/false);
+    if (png_bytes.has_value()) {
+      auto image = mojom::CbfDragImage::New();
+      image->png_bytes = std::move(*png_bytes);
+      image->pixel_width = static_cast<uint32_t>(drag_image.width());
+      image->pixel_height = static_cast<uint32_t>(drag_image.height());
+      if (drag_image.width() > 0 && drag_obj_rect_in_dip.width() > 0) {
+        image->scale = static_cast<float>(drag_image.width()) /
+                       static_cast<float>(drag_obj_rect_in_dip.width());
+      } else {
+        image->scale = 1.0f;
+      }
+      image->cursor_offset_x = cursor_offset_in_dip.x();
+      image->cursor_offset_y = cursor_offset_in_dip.y();
+      request->image = std::move(image);
+    }
+  }
+
+  context_->observer_remote()->OnDragStartRequested(std::move(request));
+}
+
+void CbfProfileDragController::SendDragUpdate(mojom::CbfDragUpdatePtr update) {
+  const auto it = drag_sessions_.find(update->session_id);
+  if (it == drag_sessions_.end()) {
+    return;
+  }
+
+  DragSessionState& session = it->second;
+  if (session.tab_id != update->tab_id || !session.source_rwh) {
+    return;
+  }
+
+  gfx::PointF client_point(update->position_in_widget_x,
+                           update->position_in_widget_y);
+  gfx::PointF screen_point(update->position_in_screen_x,
+                           update->position_in_screen_y);
+  const int modifiers = static_cast<int>(update->modifiers);
+  const blink::DragOperationsMask allowed_ops =
+      static_cast<blink::DragOperationsMask>(update->allowed_operations);
+
+  if (!session.entered) {
+    session.source_rwh->DragTargetDragEnter(
+        session.drop_data, client_point, screen_point, allowed_ops, modifiers,
+        base::BindOnce(
+            [](base::WeakPtr<CbfProfileDragController> self, uint64_t session_id,
+               ui::mojom::DragOperation operation,
+               bool document_is_handling_drag) {
+              if (!self) {
+                return;
+              }
+              auto session_it = self->drag_sessions_.find(session_id);
+              if (session_it == self->drag_sessions_.end()) {
+                return;
+              }
+              session_it->second.last_operation = operation;
+              session_it->second.document_is_handling_drag =
+                  document_is_handling_drag;
+            },
+            weak_factory_.GetWeakPtr(), update->session_id));
+    session.entered = true;
+    return;
+  }
+
+  session.source_rwh->DragTargetDragOver(
+      client_point, screen_point, allowed_ops, modifiers,
+      base::BindOnce(
+          [](base::WeakPtr<CbfProfileDragController> self, uint64_t session_id,
+             ui::mojom::DragOperation operation,
+             bool document_is_handling_drag) {
+            if (!self) {
+              return;
+            }
+            auto session_it = self->drag_sessions_.find(session_id);
+            if (session_it == self->drag_sessions_.end()) {
+              return;
+            }
+            session_it->second.last_operation = operation;
+            session_it->second.document_is_handling_drag =
+                document_is_handling_drag;
+          },
+          weak_factory_.GetWeakPtr(), update->session_id));
+}
+
+void CbfProfileDragController::SendDragDrop(mojom::CbfDragDropPtr drop) {
+  const auto it = drag_sessions_.find(drop->session_id);
+  if (it == drag_sessions_.end()) {
+    return;
+  }
+
+  DragSessionState session = std::move(it->second);
+  drag_sessions_.erase(it);
+
+  if (session.tab_id != drop->tab_id || !session.source_rwh) {
+    return;
+  }
+
+  gfx::PointF client_point(drop->position_in_widget_x, drop->position_in_widget_y);
+  gfx::PointF screen_point(drop->position_in_screen_x, drop->position_in_screen_y);
+  const int modifiers = static_cast<int>(drop->modifiers);
+  session.drop_data.document_is_handling_drag = session.document_is_handling_drag;
+
+  session.source_rwh->DragTargetDrop(session.drop_data, client_point, screen_point,
+                                     modifiers, base::DoNothing());
+  session.source_rwh->DragSourceEndedAt(client_point, screen_point,
+                                        session.last_operation, base::DoNothing());
+  session.source_rwh->DragSourceSystemDragEnded();
+}
+
+void CbfProfileDragController::SendDragCancel(uint64_t session_id,
+                                              uint64_t tab_id) {
+  const auto it = drag_sessions_.find(session_id);
+  if (it == drag_sessions_.end()) {
+    return;
+  }
+
+  DragSessionState session = std::move(it->second);
+  drag_sessions_.erase(it);
+
+  if (session.tab_id != tab_id || !session.source_rwh) {
+    return;
+  }
+
+  const gfx::PointF zero_point;
+  if (session.entered) {
+    session.source_rwh->DragTargetDragLeave(zero_point, zero_point);
+  }
+  session.source_rwh->DragSourceEndedAt(zero_point, zero_point,
+                                        ui::mojom::DragOperation::kNone,
+                                        base::DoNothing());
+  session.source_rwh->DragSourceSystemDragEnded();
+}
+
+void CbfProfileDragController::OnWebPageClosed(TabId tab_id) {
+  for (auto it = drag_sessions_.begin(); it != drag_sessions_.end();) {
+    if (it->second.tab_id == tab_id) {
+      it = drag_sessions_.erase(it);
+    } else {
+      ++it;
+    }
+  }
+}
+
+}  // namespace cbf
