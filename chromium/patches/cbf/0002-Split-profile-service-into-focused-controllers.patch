+
+void CbfProfileDevToolsController::OpenDevTools(TabId inspected_tab_id) {
+  content::WebContents* inspected_contents =
+      context_->tab_manager().GetWebContents(inspected_tab_id);
+  if (!inspected_contents) {
+    LOG(INFO) << "[CBF][DevTools] OpenDevTools ignored: inspected page not found id="
+              << inspected_tab_id;
+    return;
+  }
+  LOG(INFO) << "[CBF][DevTools] OpenDevTools requested inspected_id="
+            << inspected_tab_id;
+
+  TabId devtools_tab_id = kInvalidTabId;
+  auto existing_it = inspected_to_devtools_.find(inspected_tab_id);
+  if (existing_it != inspected_to_devtools_.end()) {
+    devtools_tab_id = existing_it->second;
+    if (!context_->tab_manager().GetWebContents(devtools_tab_id)) {
+      devtools_to_inspected_.erase(devtools_tab_id);
+      devtools_sessions_.erase(devtools_tab_id);
+      inspected_to_devtools_.erase(existing_it);
+      devtools_tab_id = kInvalidTabId;
+    }
+  }
+
+  if (devtools_tab_id == kInvalidTabId) {
+    devtools_tab_id = context_->tab_manager().CreateWebPage(GURL());
+    if (devtools_tab_id == kInvalidTabId) {
+      LOG(INFO) << "[CBF][DevTools] Failed to create devtools page for inspected_id="
+                << inspected_tab_id;
+      return;
+    }
+
+    content::WebContents* devtools_contents =
+        context_->tab_manager().GetWebContents(devtools_tab_id);
+    if (!devtools_contents) {
+      LOG(INFO) << "[CBF][DevTools] Created devtools id="
+                << devtools_tab_id << " but WebContents lookup failed";
+      context_->tab_manager().CloseWebPage(devtools_tab_id);
+      return;
+    }
+
+    const GURL devtools_frontend_url = BuildDevToolsFrontendUrl();
+    LOG(INFO) << "[CBF][DevTools] Created devtools page id="
+              << devtools_tab_id
+              << " for inspected_id=" << inspected_tab_id
+              << " url=" << devtools_frontend_url;
+
+    if (register_ime_handler_) {
+      register_ime_handler_.Run(devtools_tab_id, devtools_contents);
+    }
+
+    auto session = std::make_unique<DevToolsSession>();
+    session->bindings = nullptr;
+
+    devtools_contents->GetController().LoadURL(
+        devtools_frontend_url, content::Referrer(),
+        ui::PAGE_TRANSITION_AUTO_TOPLEVEL, std::string());
+    LOG(INFO) << "[CBF][DevTools] Navigated devtools page id="
+              << devtools_tab_id << " to url=" << devtools_frontend_url;
+
+    devtools_sessions_[devtools_tab_id] = std::move(session);
+    inspected_to_devtools_[inspected_tab_id] = devtools_tab_id;
+    devtools_to_inspected_[devtools_tab_id] = inspected_tab_id;
+  } else {
+    LOG(INFO) << "[CBF][DevTools] Reusing existing devtools page id="
+              << devtools_tab_id
+              << " for inspected_id=" << inspected_tab_id;
+  }
+
+  TryAttachSession(inspected_tab_id, devtools_tab_id, 0);
+
+  auto& observer = context_->observer_remote();
+  if (observer.is_bound()) {
+    LOG(INFO) << "[CBF][DevTools] Notifying OnDevToolsOpened inspected_id="
+              << inspected_tab_id << " devtools_id=" << devtools_tab_id;
+    observer->OnDevToolsOpened(inspected_tab_id, devtools_tab_id);
+  }
+}
+
+void CbfProfileDevToolsController::InspectElement(TabId inspected_tab_id,
+                                                  int32_t x,
+                                                  int32_t y) {
+  content::WebContents* inspected_contents =
+      context_->tab_manager().GetWebContents(inspected_tab_id);
+  if (!inspected_contents) {
+    LOG(INFO) << "[CBF][DevTools] InspectElement ignored: inspected page not found id="
+              << inspected_tab_id;
+    return;
+  }
+
+  LOG(INFO) << "[CBF][DevTools] InspectElement requested inspected_id="
+            << inspected_tab_id << " x=" << x << " y=" << y;
+  OpenDevTools(inspected_tab_id);
+
+  scoped_refptr<content::DevToolsAgentHost> agent_host =
+      content::DevToolsAgentHost::GetOrCreateForTab(inspected_contents);
+  content::RenderFrameHost* frame = ResolveInspectFrame(inspected_contents);
+  if (!agent_host || !frame) {
+    LOG(INFO) << "[CBF][DevTools] InspectElement aborted: missing agent_host/frame";
+    return;
+  }
+
+  LOG(INFO) << "[CBF][DevTools] Dispatching agent_host->InspectElement id="
+            << agent_host->GetId();
+  agent_host->InspectElement(frame, x, y);
+}
+
+void CbfProfileDevToolsController::OnWebPageClosed(TabId tab_id) {
+  auto inspected_it = inspected_to_devtools_.find(tab_id);
+  if (inspected_it != inspected_to_devtools_.end()) {
+    const TabId devtools_tab_id = inspected_it->second;
+    inspected_to_devtools_.erase(inspected_it);
+    devtools_to_inspected_.erase(devtools_tab_id);
+    devtools_sessions_.erase(devtools_tab_id);
+  }
+
+  auto devtools_it = devtools_to_inspected_.find(tab_id);
+  if (devtools_it != devtools_to_inspected_.end()) {
+    const TabId inspected_tab_id = devtools_it->second;
+    devtools_to_inspected_.erase(devtools_it);
+    inspected_to_devtools_.erase(inspected_tab_id);
+    devtools_sessions_.erase(tab_id);
+  }
+}
+
+void CbfProfileDevToolsController::TryAttachSession(
+    TabId inspected_tab_id,
+    TabId devtools_tab_id,
+    int attempt) {
+  constexpr int kMaxAttempts = 50;
+  constexpr base::TimeDelta kRetryDelay = base::Milliseconds(20);
+
+  auto session_it = devtools_sessions_.find(devtools_tab_id);
+  if (session_it == devtools_sessions_.end()) {
+    return;
+  }
+
+  content::WebContents* inspected_contents =
+      context_->tab_manager().GetWebContents(inspected_tab_id);
+  content::WebContents* devtools_contents =
+      context_->tab_manager().GetWebContents(devtools_tab_id);
+  if (!inspected_contents || !devtools_contents) {
+    LOG(INFO) << "[CBF][DevTools] Attach skipped: missing contents inspected_id="
+              << inspected_tab_id
+              << " devtools_id=" << devtools_tab_id;
+    return;
+  }
+
+  DevToolsUIBindings* bindings =
+      DevToolsUIBindings::ForWebContents(devtools_contents);
+  if (!bindings) {
+    if (attempt >= kMaxAttempts) {
+      LOG(INFO) << "[CBF][DevTools] Attach failed: bindings not found"
+                << " inspected_id=" << inspected_tab_id
+                << " devtools_id=" << devtools_tab_id;
+      return;
+    }
+
+    base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+        FROM_HERE,
+        base::BindOnce(&CbfProfileDevToolsController::TryAttachSession,
+                       weak_factory_.GetWeakPtr(), inspected_tab_id,
+                       devtools_tab_id, attempt + 1),
+        kRetryDelay);
+    return;
+  }
+
+  auto& session = session_it->second;
+  if (session->bindings != bindings) {
+    session->bindings = bindings;
+    bindings->SetDelegate(
+        new CbfDevToolsUIDelegate(devtools_contents, inspected_contents));
+  }
+
+  scoped_refptr<content::DevToolsAgentHost> agent_host =
+      content::DevToolsAgentHost::GetOrCreateForTab(inspected_contents);
+  if (!agent_host) {
+    LOG(INFO) << "[CBF][DevTools] Attach failed: agent_host unavailable"
+              << " inspected_id=" << inspected_tab_id;
+    return;
+  }
+
+  bindings->AttachTo(agent_host);
+  LOG(INFO) << "[CBF][DevTools] Attached session inspected_id="
+            << inspected_tab_id << " devtools_id=" << devtools_tab_id
+            << " agent_host_id="
+            << (agent_host ? agent_host->GetId() : std::string("<null>"));
+}
+
+}  // namespace cbf
