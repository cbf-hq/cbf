+
+namespace cbf {
+
+class CbfProfileServiceContext;
+
+class CbfProfileInputController {
+ public:
+  explicit CbfProfileInputController(CbfProfileServiceContext* context);
+  CbfProfileInputController(const CbfProfileInputController&) = delete;
+  CbfProfileInputController& operator=(const CbfProfileInputController&) = delete;
+  ~CbfProfileInputController();
