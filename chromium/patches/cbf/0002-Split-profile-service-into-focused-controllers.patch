+#include "content/public/browser/reload_type.h"
+#include "content/public/browser/render_widget_host.h"
+#include "content/public/browser/render_widget_host_view.h"
+#include "content/public/browser/web_contents.h"
+#include "chrome/browser/cbf/profile/cbf_profile_service_context.h"
+#include "content/public/common/referrer.h"
+#include "ui/base/page_transition_types.h"
+#include "url/gurl.h"
+
+namespace cbf {
+namespace {
+
+content::RenderWidgetHost* ResolveInputRenderWidgetHost(
+    content::WebContents* web_contents) {
+  if (!web_contents) {
+    return nullptr;
+  }
+
+  if (content::RenderFrameHost* focused_frame = web_contents->GetFocusedFrame()) {
+    if (content::RenderWidgetHost* widget_host =
+            focused_frame->GetRenderWidgetHost()) {
+      return widget_host;
+    }
+  }
+
+  if (content::RenderFrameHost* primary_frame =
+          web_contents->GetPrimaryMainFrame()) {
+    if (content::RenderWidgetHost* widget_host =
+            primary_frame->GetRenderWidgetHost()) {
+      return widget_host;
+    }
+  }
+
+  content::RenderWidgetHostView* view = web_contents->GetRenderWidgetHostView();
+  return view ? view->GetRenderWidgetHost() : nullptr;
+}
+
+}  // namespace
+
+CbfProfileNavigationController::CbfProfileNavigationController(CbfProfileServiceContext* context)
+    : context_(context) {}
+
+CbfProfileNavigationController::~CbfProfileNavigationController() = default;
+
+void CbfProfileNavigationController::Navigate(TabId tab_id,
+                                              const std::string& url) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  const GURL gurl(url);
+  if (!gurl.is_valid()) {
+    return;
+  }
+
+  web_contents->GetController().LoadURL(
+      gurl, content::Referrer(), ui::PAGE_TRANSITION_TYPED, std::string());
+}
+
+void CbfProfileNavigationController::GoBack(TabId tab_id) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (web_contents && web_contents->GetController().CanGoBack()) {
+    web_contents->GetController().GoBack();
+  }
+}
+
+void CbfProfileNavigationController::GoForward(TabId tab_id) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (web_contents && web_contents->GetController().CanGoForward()) {
+    web_contents->GetController().GoForward();
+  }
+}
+
+void CbfProfileNavigationController::Reload(TabId tab_id,
+                                            bool ignore_cache) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  const content::ReloadType type = ignore_cache
+                                       ? content::ReloadType::BYPASSING_CACHE
+                                       : content::ReloadType::NORMAL;
+  web_contents->GetController().Reload(type, true);
+}
+
+void CbfProfileNavigationController::SetWebPageFocus(TabId tab_id,
+                                                     bool focused) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+
+  auto* widget_impl = content::RenderWidgetHostImpl::From(
+      ResolveInputRenderWidgetHost(web_contents));
+
+  if (focused) {
+    if (widget_impl) {
+      widget_impl->SetPageFocus(true);
+    }
+    web_contents->Focus();
+    web_contents->RestoreFocus();
+    return;
+  }
+
+  web_contents->StoreFocus();
+  if (widget_impl) {
+    widget_impl->SetPageFocus(false);
+  }
+}
+
+}  // namespace cbf
