-cbf::mojom::CbfMenuIconPtr BuildMenuIcon(const ui::ImageModel& icon,
-                                        Profile* profile) {
-  if (icon.IsEmpty() || !profile) {
-    return nullptr;
-  }
-
-  auto* theme_service = ThemeServiceFactory::GetForProfile(profile);
-  if (!theme_service) {
-    return nullptr;
-  }
-
-  ui::ColorProvider* color_provider = theme_service->GetColorProvider();
-  if (!color_provider) {
-    return nullptr;
-  }
-
-  gfx::ImageSkia image = icon.Rasterize(color_provider);
-  if (image.isNull()) {
-    return nullptr;
-  }
-
-  const SkBitmap* bitmap = image.bitmap();
-  if (!bitmap || bitmap->drawsNothing()) {
-    return nullptr;
-  }
-
-  auto encoded =
-      gfx::PNGCodec::EncodeBGRASkBitmap(*bitmap, /*discard_transparency=*/false);
-  if (!encoded.has_value()) {
-    return nullptr;
-  }
-
-  auto out = cbf::mojom::CbfMenuIcon::New();
-  out->width = bitmap->width();
-  out->height = bitmap->height();
-  out->png_bytes = std::move(*encoded);
-  return out;
-}
-
-cbf::mojom::CbfMenuAcceleratorPtr BuildMenuAccelerator(
-    const ui::MenuModel* model,
-    size_t index) {
-  ui::Accelerator accelerator;
-  if (!model->GetAcceleratorAt(index, &accelerator)) {
-    return nullptr;
-  }
-
-#if BUILDFLAG(IS_MAC)
-  std::string key_equivalent;
-  uint32_t modifier_mask = 0;
-  if (!cbf::GetCocoaKeyEquivalentForAccelerator(accelerator, &key_equivalent,
-                                                &modifier_mask)) {
-    return nullptr;
-  }
-
-  auto out = cbf::mojom::CbfMenuAccelerator::New();
-  out->key_equivalent = std::move(key_equivalent);
-  out->modifier_mask = modifier_mask;
-  return out;
-#else
-  return nullptr;
-#endif
-}
