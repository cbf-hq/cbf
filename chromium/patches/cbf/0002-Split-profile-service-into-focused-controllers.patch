+content::RenderFrameHost* ResolveInspectFrame(
+    content::WebContents* inspected_contents) {
+  if (!inspected_contents) {
+    return nullptr;
+  }
+  if (content::RenderFrameHost* frame = inspected_contents->GetFocusedFrame()) {
+    return frame;
+  }
+  return inspected_contents->GetPrimaryMainFrame();
