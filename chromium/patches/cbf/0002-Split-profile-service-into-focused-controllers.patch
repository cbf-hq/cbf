+namespace cbf {
+
+CbfProfileImeController::CbfProfileImeController(CbfProfileServiceContext* context)
+    : context_(context) {}
+
+CbfProfileImeController::~CbfProfileImeController() {
+  text_input_observations_.RemoveAllObservations();
+  text_input_map_.clear();
+}
+
+void CbfProfileImeController::RegisterWebContents(
+    TabId tab_id,
+    content::WebContents* web_contents) {
+  if (!web_contents || tab_id == kInvalidTabId) {
+    return;
+  }
+  auto* web_contents_impl = static_cast<content::WebContentsImpl*>(web_contents);
+  content::TextInputManager* text_input_manager =
+      web_contents_impl->GetTextInputManager();
+  if (!text_input_manager) {
+    return;
+  }
+  if (text_input_map_.find(text_input_manager) == text_input_map_.end()) {
+    text_input_observations_.AddObservation(text_input_manager);
+  }
+  text_input_map_[text_input_manager] = tab_id;
+}
+
+void CbfProfileImeController::OnWebPageClosed(TabId tab_id) {
+  for (auto it = text_input_map_.begin(); it != text_input_map_.end();) {
+    if (it->second != tab_id) {
+      ++it;
+      continue;
+    }
+    text_input_observations_.RemoveObservation(it->first);
+    it = text_input_map_.erase(it);
+  }
+}
+
+void CbfProfileImeController::SetComposition(
+    mojom::CbfImeCompositionPtr composition) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(composition->tab_id);
+  if (!web_contents) {
+    return;
+  }
+  content::RenderWidgetHost* widget_host =
+      ResolveInputRenderWidgetHost(web_contents);
+  if (!widget_host) {
+    DVLOG(1) << "SetComposition dropped: no input widget host for tab_id="
+             << composition->tab_id;
+    return;
+  }
+  auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+  if (!widget_impl) {
+    return;
+  }
+
+  const std::u16string text16 = base::UTF8ToUTF16(composition->text);
+  const gfx::Range replacement_range = mojo_converters::ToReplacementRange(
+      composition->replacement_range_start, composition->replacement_range_end);
+  widget_impl->ImeSetComposition(text16, mojo_converters::ToImeTextSpans(composition->spans),
+                                 replacement_range, composition->selection_start,
+                                 composition->selection_end);
+}
+
+void CbfProfileImeController::CommitText(mojom::CbfImeCommitTextPtr commit) {
+  content::WebContents* web_contents =
+      context_->tab_manager().GetWebContents(commit->tab_id);
+  if (!web_contents) {
+    return;
+  }
+  content::RenderWidgetHost* widget_host =
+      ResolveInputRenderWidgetHost(web_contents);
+  if (!widget_host) {
+    DVLOG(1) << "CommitText dropped: no input widget host for tab_id="
+             << commit->tab_id;
+    return;
+  }
+  auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+  if (!widget_impl) {
+    return;
+  }
+
+  const std::u16string text16 = base::UTF8ToUTF16(commit->text);
+  const gfx::Range replacement_range = mojo_converters::ToReplacementRange(
+      commit->replacement_range_start, commit->replacement_range_end);
+  widget_impl->ImeCommitText(text16, mojo_converters::ToImeTextSpans(commit->spans),
+                             replacement_range, commit->relative_caret_position);
+}
+
+void CbfProfileImeController::FinishComposingText(
+    uint64_t tab_id,
+    mojom::CbfConfirmCompositionBehavior behavior) {
+  content::WebContents* web_contents = context_->tab_manager().GetWebContents(tab_id);
+  if (!web_contents) {
+    return;
+  }
+  content::RenderWidgetHost* widget_host =
+      ResolveInputRenderWidgetHost(web_contents);
+  if (!widget_host) {
+    DVLOG(1)
+        << "FinishComposingText dropped: no input widget host for tab_id="
+        << tab_id;
+    return;
+  }
+  auto* widget_impl = content::RenderWidgetHostImpl::From(widget_host);
+  if (!widget_impl) {
+    return;
+  }
+
+  const bool keep_selection =
+      behavior == mojom::CbfConfirmCompositionBehavior::kKeepSelection;
+  widget_impl->ImeFinishComposingText(keep_selection);
+}
+
+void CbfProfileImeController::NotifyImeBoundsUpdated(
+    content::TextInputManager* text_input_manager,
+    bool include_composition,
+    bool include_selection) {
+  if (!context_->observer_remote().is_bound() || !text_input_manager) {
+    return;
+  }
+  const auto it = text_input_map_.find(text_input_manager);
+  if (it == text_input_map_.end()) {
+    return;
+  }
+
+  auto update = cbf::mojom::CbfImeBoundsUpdate::New();
+  update->tab_id = it->second;
+
+  if (include_composition) {
+    const auto* composition_info = text_input_manager->GetCompositionRangeInfo();
+    auto composition = cbf::mojom::CbfImeCompositionBounds::New();
+    if (!composition_info || composition_info->character_bounds.empty()) {
+      composition->range_start = -1;
+      composition->range_end = -1;
+    } else {
+      composition->range_start = composition_info->range.start();
+      composition->range_end = composition_info->range.end();
+      composition->character_bounds.reserve(composition_info->character_bounds.size());
+      for (const auto& rect : composition_info->character_bounds) {
+        composition->character_bounds.push_back(mojo_converters::ToCbfRect(rect));
+      }
+    }
+    update->composition = std::move(composition);
+  }
+
+  if (include_selection) {
+    const auto* selection_region = text_input_manager->GetSelectionRegion();
+    const auto* text_selection = text_input_manager->GetTextSelection();
+    auto selection = cbf::mojom::CbfTextSelectionBounds::New();
+    if (!selection_region || !text_selection) {
+      selection->range_start = -1;
+      selection->range_end = -1;
+      selection->caret_rect = mojo_converters::ToCbfRect(gfx::Rect());
+      selection->first_selection_rect = mojo_converters::ToCbfRect(gfx::Rect());
+    } else {
+      selection->range_start = text_selection->range().start();
+      selection->range_end = text_selection->range().end();
+      selection->caret_rect = mojo_converters::ToCbfRect(selection_region->caret_rect);
+      selection->first_selection_rect =
+          mojo_converters::ToCbfRect(selection_region->first_selection_rect);
+    }
+    update->selection = std::move(selection);
+  }
+
+  context_->observer_remote()->OnImeBoundsUpdated(std::move(update));
+}
+
+void CbfProfileImeController::OnSelectionBoundsChanged(
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* updated_view) {
+  (void)updated_view;
+  NotifyImeBoundsUpdated(text_input_manager, false, true);
+}
+
+void CbfProfileImeController::OnImeCompositionRangeChanged(
+    content::TextInputManager* text_input_manager,
+    content::RenderWidgetHostViewBase* updated_view,
+    bool character_bounds_changed) {
+  (void)updated_view;
+  (void)character_bounds_changed;
+  NotifyImeBoundsUpdated(text_input_manager, true, false);
+}
+
+}  // namespace cbf
