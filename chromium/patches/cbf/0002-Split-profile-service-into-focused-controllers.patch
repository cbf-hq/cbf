-std::vector<cbf::mojom::CbfMenuItemPtr> BuildMenuItems(
-    const ui::MenuModel* model,
-    Profile* profile) {
-  std::vector<cbf::mojom::CbfMenuItemPtr> items;
-  if (!model) {
-    return items;
-  }
-
-  const size_t count = model->GetItemCount();
-  items.reserve(count);
-
-  for (size_t i = 0; i < count; ++i) {
-    if (!model->IsVisibleAt(i)) {
-      continue;
-    }
-
-    auto item = cbf::mojom::CbfMenuItem::New();
-    item->type = ToCbfMenuItemType(model->GetTypeAt(i));
-    item->command_id = model->GetCommandIdAt(i);
-    item->label = base::UTF16ToUTF8(model->GetLabelAt(i));
-    item->secondary_label =
-        base::UTF16ToUTF8(model->GetSecondaryLabelAt(i));
-    item->minor_text = base::UTF16ToUTF8(model->GetMinorTextAt(i));
-    item->enabled = model->IsEnabledAt(i);
-    item->visible = true;
-    item->checked = model->IsItemCheckedAt(i);
-    item->group_id = model->GetGroupIdAt(i);
-    item->is_new_feature = model->IsNewFeatureAt(i);
-    item->is_alerted = model->IsAlertedAt(i);
-    item->may_have_mnemonics = model->MayHaveMnemonicsAt(i);
-    item->accessible_name =
-        base::UTF16ToUTF8(model->GetAccessibleNameAt(i));
-    item->icon = BuildMenuIcon(model->GetIconAt(i), profile);
-    item->minor_icon = BuildMenuIcon(model->GetMinorIconAt(i), profile);
-    item->accelerator = BuildMenuAccelerator(model, i);
-
-    if (auto* submenu = model->GetSubmenuModelAt(i)) {
-      item->submenu = BuildMenuItems(submenu, profile);
-    }
-
-    items.push_back(std::move(item));
-  }
-
-  return items;
-}
